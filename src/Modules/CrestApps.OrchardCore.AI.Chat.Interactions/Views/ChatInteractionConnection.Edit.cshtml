@using CrestApps.OrchardCore.AI.Chat.Interactions.ViewModels
@using CrestApps.Core.AI
@using CrestApps.OrchardCore.AI.Core
@using CrestApps.OrchardCore.AI.Core.Orchestration
@using OrchardCore

@model EditChatInteractionConnectionViewModel

@{
    var groupedChatDeployments = Model.ChatDeployments
        .GroupBy(item => item.Group?.Name)
        .OrderBy(group => group.Key ?? string.Empty, StringComparer.OrdinalIgnoreCase);
}

@if (Model.ShowMissingDefaultChatDeploymentWarning)
{
    <div class="alert alert-warning orchestrator-dependent orchestrator-dependent-@(DefaultOrchestrator.OrchestratorName)" role="alert">
        @T["Default chat deployment is not configured in Settings > Artificial Intelligence > Default Deployments. Configure it there so the Default option resolves to the intended chat deployment."]
    </div>
}

<div class="mb-3 orchestrator-dependent orchestrator-dependent-@(DefaultOrchestrator.OrchestratorName)">
    <label asp-for="ChatDeploymentName" class="form-label">
        @T["Chat deployment"]
        <span class="text-muted" data-bs-toggle="tooltip" title="@T["Select the deployment to use for chat completions."]">
            <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
        </span>
    </label>
    <select asp-for="ChatDeploymentName" class="form-select setting-input" data-setting="deploymentName">
        <option value="" data-supports-vision="@Model.DefaultChatDeploymentSupportsVision.ToString().ToLowerInvariant()">@T["Default"]</option>
        @foreach (var group in groupedChatDeployments)
        {
            if (string.IsNullOrEmpty(group.Key))
            {
                foreach (var deployment in group)
                {
                    var supportsVision = Model.DeploymentVisionSupport.TryGetValue(deployment.Value, out var deploymentSupportsVision) &&
                        deploymentSupportsVision;
                    var isSelected = string.Equals(deployment.Value, Model.ChatDeploymentName, StringComparison.Ordinal);
                    if (isSelected)
                    {
                        <option value="@deployment.Value" selected="selected" data-supports-vision="@supportsVision.ToString().ToLowerInvariant()">@deployment.Text</option>
                    }
                    else
                    {
                        <option value="@deployment.Value" data-supports-vision="@supportsVision.ToString().ToLowerInvariant()">@deployment.Text</option>
                    }
                }
            }
            else
            {
                <optgroup label="@group.Key">
                    @foreach (var deployment in group)
                    {
                        var supportsVision = Model.DeploymentVisionSupport.TryGetValue(deployment.Value, out var deploymentSupportsVision) &&
                            deploymentSupportsVision;
                        var isSelected = string.Equals(deployment.Value, Model.ChatDeploymentName, StringComparison.Ordinal);
                        if (isSelected)
                        {
                            <option value="@deployment.Value" selected="selected" data-supports-vision="@supportsVision.ToString().ToLowerInvariant()">@deployment.Text</option>
                        }
                        else
                        {
                            <option value="@deployment.Value" data-supports-vision="@supportsVision.ToString().ToLowerInvariant()">@deployment.Text</option>
                        }
                    }
                </optgroup>
            }
        }
    </select>
    <span asp-validation-for="ChatDeploymentName" class="text-danger"></span>
</div>

@if (Model.ShowMissingDefaultUtilityDeploymentWarning)
{
    <div class="alert alert-warning orchestrator-dependent orchestrator-dependent-@(DefaultOrchestrator.OrchestratorName)" role="alert">
        @T["Default utility deployment is not configured in Settings > Artificial Intelligence > Default Deployments. Configure it there so the Default option resolves to the intended utility deployment."]
    </div>
}

<div class="mb-3 orchestrator-dependent orchestrator-dependent-@(DefaultOrchestrator.OrchestratorName)">
    <label asp-for="UtilityDeploymentName" class="form-label">
        @T["Utility deployment"]
        <span class="text-muted" data-bs-toggle="tooltip" title="@T["Select a lightweight deployment for auxiliary tasks. Falls back to the global default if not set."]">
            <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
        </span>
    </label>
    <select asp-for="UtilityDeploymentName" asp-items="Model.UtilityDeployments" class="form-select setting-input" data-setting="utilityDeploymentName">
        <option value="">@T["Default"]</option>
    </select>
    <span asp-validation-for="UtilityDeploymentName" class="text-danger"></span>
</div>
