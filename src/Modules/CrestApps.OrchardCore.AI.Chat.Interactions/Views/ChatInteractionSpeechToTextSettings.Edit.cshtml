@using CrestApps.OrchardCore.AI.Chat.Interactions.ViewModels
@using OrchardCore

@model ChatInteractionSpeechToTextSettingsViewModel

<div class="@Orchard.GetWrapperClasses() speech-to-text-model-selector-dependent">
    <div class="@Orchard.GetEndClasses(true)">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="EnableSpeechToText">
            <label class="form-check-label" asp-for="EnableSpeechToText">@T["Enable speech-to-text in chat interactions"]</label>
            <span class="hint dashed">@T["When enabled, a microphone button will be available in the chat interactions interface, allowing users to speak their prompts. Requires a default speech-to-text deployment to be configured."]</span>
        </div>
    </div>
</div>
