@using CrestApps.Core
@using CrestApps.OrchardCore.AI
@using CrestApps.Core.AI
@using CrestApps.OrchardCore.AI.Chat.Interactions.Hubs
@using CrestApps.OrchardCore.AI.Chat.Interactions.Settings
@using CrestApps.OrchardCore.AI.Chat.Interactions.ViewModels
@using CrestApps.Core.SignalR.Services
@using CrestApps.OrchardCore.AI.Core.Models
@using CrestApps.Core.AI.Models
@using OrchardCore.DisplayManagement
@using OrchardCore.DisplayManagement.ModelBinding
@using OrchardCore.Entities
@using OrchardCore.Settings
@using System.Text.Json

@model ChatInteractionCapsuleViewModel

@inject IUpdateModelAccessor UpdateModelAccessor
@inject HubRouteManager HubRouteManager
@inject ISiteService SiteService
@inject IAIDeploymentManager AIDeploymentManager
@{
    var baseId = Html.IdForModel();
    var chatAppHtmlId = $"{baseId}_ChatApp";
    var buttonHtmlId = $"{baseId}_SendButton";
    var userPromptHtmlId = $"{baseId}_UserPrompt";
    var placeholderHtmlId = $"{baseId}_SessionPlaceHolder";
    var chatContainerHtmlId = $"{baseId}_ChatContainer";
    var micBtnHtmlId = $"{baseId}_MicBtn";

    var site = await SiteService.GetSiteSettingsAsync();
    var chatModeSettings = site.GetOrCreate<ChatInteractionChatModeSettings>();
    var chatMode = chatModeSettings.ChatMode;
    var speechToTextDeployment = await AIDeploymentManager.ResolveOrDefaultAsync(AIDeploymentType.SpeechToText);
    var textToSpeechDeployment = await AIDeploymentManager.ResolveOrDefaultAsync(AIDeploymentType.TextToSpeech);
    var speechToTextEnabled = (chatMode == ChatMode.AudioInput || chatMode == ChatMode.Conversation)
        && speechToTextDeployment != null;
    var textToSpeechEnabled = (chatMode == ChatMode.Conversation || chatModeSettings.EnableTextToSpeechPlayback)
        && textToSpeechDeployment != null;
    var conversationModeEnabled = speechToTextEnabled && textToSpeechEnabled;
    var conversationBtnHtmlId = $"{baseId}_ConversationBtn";
}

<div class="d-flex flex-column h-100">
    <div class="flex-grow-1 overflow-y-auto rounded-2 border bg-theme p-3 mb-3" id="@chatContainerHtmlId">
        <div class="w-100 ai-chat-messages">
            <div id="@placeholderHtmlId" class="text-center p-3@(Model.Prompts.Count > 0 ? " d-none" : string.Empty)">
                <h1>
                    @T["What do you want to know?"]
                </h1>
            </div>

            <div id="@chatAppHtmlId"></div>
        </div>
    </div>

    <div class="flex-shrink-0">
        <div class="text-bg-light rounded border w-100">
            <textarea class="form-control bg-transparent border-0 chat-user-prompt-input px-4" id="@userPromptHtmlId" data-interaction-id="@Model.Interaction.ItemId" placeholder="@T["Message AI Chat"] ..." aria-label="@T["Message AI Chat"]" aria-describedby="@buttonHtmlId"></textarea>

            <div class="d-flex justify-content-between px-3 my-2">
                <div></div>

                <div>
                    <button class="btn btn-outline-secondary rounded stt-mic-btn" type="button" id="@micBtnHtmlId" title="@T["Voice input"]" style="display: none;">
                        <i class="fa-solid fa-microphone"></i>
                    </button>
                    @if (conversationModeEnabled)
                    {
                        <button class="btn btn-dark rounded" type="button" id="@conversationBtnHtmlId" title="@T["Start Conversation"]" data-start-title="@T["Start Conversation"]" data-end-title="@T["End Conversation"]" data-start-html="<i class='fa-solid fa-wave-square'></i>" data-end-html="<i class='fa-solid fa-stop me-1'></i> @T["End Conversation"]">
                            <i class="fa-solid fa-wave-square"></i>
                        </button>
                    }
                    <button class="btn btn-dark" type="button" id="@buttonHtmlId"disabled data-start-icon="<i class='fa-solid fa-arrow-up'></i>" data-stop-icon="<i class='fa-solid fa-stop'></i>">
                        <i class="fa-solid fa-arrow-up"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
@{
    var prompts = new List<object>();

    if (Model.Prompts != null)
    {
        foreach (var prompt in Model.Prompts)
        {
            prompts.Add(new
            {
                Id = prompt.ItemId,
                prompt.Role,
                Content = prompt.Text,
                prompt.Title,
                prompt.IsGeneratedPrompt,
                prompt.References,
            });
        }
    }
}

<style at="Head">
    .chat-user-prompt-input:focus {
        border: none;
        box-shadow: none;
    }

    .chat-parameters-content .nav-link {
        padding: 0.5rem !important;
    }
</style>

<style asp-name="AIChatApp" at="Head"></style>
<style asp-name="highlightjs" at="Head"></style>
@if (speechToTextEnabled)
{
    <style asp-name="SpeechToText" at="Head"></style>
}
<script asp-name="ChatInteractionApp" at="Foot"></script>
<script depends-on="ChatInteractionApp" at="Foot">
    document.addEventListener('DOMContentLoaded', function () {
        function setupTtsPlaybackSync(app, chatAppElement) {
            if (!app || !chatAppElement || typeof app.$watch !== 'function') {
                return;
            }

            var refreshQueued = false;

            function updateTtsPlaybackButtons() {
                var messageItems = chatAppElement.querySelectorAll('.ai-chat-message-item');
                var messageCount = Math.min(messageItems.length, app.messages.length);

                for (var index = 0; index < messageCount; index++) {
                    var message = app.messages[index];
                    if (!message || message.role !== 'assistant' || message.isStreaming || !app.textToSpeechEnabled || app.isConversationMode) {
                        continue;
                    }

                    var container = messageItems[index].querySelector('.message-buttons-container');
                    if (!container) {
                        continue;
                    }

                    var button = container.querySelector('[data-tts-message-index]') || container.querySelector('.button-message-toolbox');
                    if (!button) {
                        continue;
                    }

                    var isPlaying = index === app.ttsPlayingMessageIndex;
                    button.setAttribute('data-tts-message-index', index);
                    button.classList.toggle('tts-playing', isPlaying);
                    button.setAttribute('title', isPlaying ? 'Pause audio' : 'Read aloud');
                    button.innerHTML = isPlaying
                        ? '<span class="fa-solid fa-circle-pause"></span>'
                        : '<span class="fa-solid fa-circle-play"></span>';
                }
            }

            function queueTtsPlaybackRefresh() {
                if (refreshQueued) {
                    return;
                }

                refreshQueued = true;
                requestAnimationFrame(function () {
                    refreshQueued = false;
                    updateTtsPlaybackButtons();
                });
            }

            app.$watch('ttsPlayingMessageIndex', queueTtsPlaybackRefresh);
            app.$watch(
                function () {
                    return (app.messages || [])
                        .map(function (message) { return [message.role, !!message.isStreaming].join(':'); })
                        .join('|');
                },
                queueTtsPlaybackRefresh);
            app.$watch('isConversationMode', queueTtsPlaybackRefresh);

            new MutationObserver(queueTtsPlaybackRefresh).observe(chatAppElement, {
                childList: true,
                subtree: true
            });

            queueTtsPlaybackRefresh();
        }

        var configEl = document.getElementById('@($"{baseId}_Config")');
        if (configEl) {
            var chatInteractionApp = chatInteractionManager.initialize(JSON.parse(configEl.getAttribute('data-config')));
            setupTtsPlaybackSync(chatInteractionApp, document.getElementById('@chatAppHtmlId'));
        }

        // Provide a renderPendingCharts fallback for chart-interaction.js which
        // stores unrendered chart configs in window.__chartConfigs but does not
        // include a retry mechanism (unlike ai-chat.js).
        if (typeof window.renderPendingCharts !== 'function') {
            window.renderPendingCharts = function () {
                if (typeof Chart === 'undefined') return;
                var configs = window.__chartConfigs;
                if (!configs) return;
                requestAnimationFrame(function () {
                    Object.keys(configs).forEach(function (chartId) {
                        var canvas = document.getElementById(chartId);
                        if (!canvas || canvas.offsetParent === null) return;
                        try {
                            if (canvas._chartInstance) canvas._chartInstance.destroy();
                            var cfg = typeof configs[chartId] === 'string' ? JSON.parse(configs[chartId]) : configs[chartId];
                            cfg.options = cfg.options || {};
                            cfg.options.responsive = true;
                            cfg.options.maintainAspectRatio = true;
                            cfg.options.aspectRatio = cfg.options.aspectRatio || 4 / 3;
                            canvas._chartInstance = new Chart(canvas, cfg);
                            delete configs[chartId];
                        } catch (e) {
                            console.error('Error creating chart:', e);
                        }
                    });
                });
            };
        }

        // Observe the chat container for newly added canvas elements that may
        // need chart rendering. This catches charts that were deferred because
        // the canvas was not yet visible or was replaced during streaming.
        var chatContainer = document.getElementById('@chatContainerHtmlId');
        if (chatContainer) {
            new MutationObserver(function () {
                window.renderPendingCharts();
            }).observe(chatContainer, { childList: true, subtree: true });
        }
    });
</script>
@{
    var chatInteractionConfig = new Dictionary<string, object>
    {
        ["signalRHubUrl"] = HubRouteManager.GetUriByHub<ChatInteractionHub>(ViewContext.HttpContext),
        ["appElementSelector"] = $"#{chatAppHtmlId}",
        ["chatContainerElementSelector"] = $"#{chatContainerHtmlId}",
        ["inputElementSelector"] = $"#{userPromptHtmlId}",
        ["sendButtonElementSelector"] = $"#{buttonHtmlId}",
        ["placeholderElementSelector"] = $"#{placeholderHtmlId}",
        ["messages"] = prompts,
        ["untitledText"] = T["Untitled"].Value,
        ["clearHistoryTitle"] = T["Clear History"].Value,
        ["clearHistoryMessage"] = T["Are you sure you want to clear the chat history? This action cannot be undone. Your documents, parameters, and tools will be preserved."].Value,
        ["clearHistoryOkText"] = T["Yes"].Value,
        ["clearHistoryCancelText"] = T["Cancel"].Value,
        ["chatMode"] = chatMode.ToString(),
        ["micButtonElementSelector"] = $"#{micBtnHtmlId}",
        ["conversationButtonElementSelector"] = $"#{conversationBtnHtmlId}",
        ["saveIndicatorElementSelector"] = "#settings-save-indicator",
        ["textToSpeechEnabled"] = textToSpeechEnabled,
    };
}
<div id="@($"{baseId}_Config")" class="d-none" data-config="@JsonSerializer.Serialize(chatInteractionConfig, JOptions.CamelCase)"></div>
