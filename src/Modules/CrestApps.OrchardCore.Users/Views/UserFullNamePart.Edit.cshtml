@using CrestApps.OrchardCore.Users.Core.Models
@using CrestApps.OrchardCore.Users.Core.ViewModels
@using CrestApps.OrchardCore.Users.Models

@model UserFullNamePartViewModel

@if (Model.Settings.DisplayName != DisplayNamePropertyType.None)
{
    <div class="ocat-wrapper">
        <label asp-for="DisplayName" class="ocat-label">@T["Display Name"]</label>
        <div class="ocat-end">
            <input asp-for="DisplayName" class="form-control" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>
    </div>
}

