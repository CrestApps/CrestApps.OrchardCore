@using CrestApps.OrchardCore.Users.Models
@using OrchardCore

@model UserAvatarOptions

<div class="@Orchard.GetWrapperClasses()">
    <div class="@Orchard.GetLabelClasses()">@T["Avatar options"]</div>
    <div class="@Orchard.GetEndClasses()">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="Required">
            <label class="form-check-label" asp-for="Required">@T["Require Avatar"]</label>
            <span class="hint dashed">@T["Whether the user must provide an Avatar or not."]</span>
        </div>

        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="UseDefaultStyle">
            <label class="form-check-label" asp-for="UseDefaultStyle">@T["Use default CSS styles"]</label>
            <span class="hint dashed">@T["Set to false, if you want to defined your own CSS styles for avatar."]</span>
        </div>
    </div>
</div>
