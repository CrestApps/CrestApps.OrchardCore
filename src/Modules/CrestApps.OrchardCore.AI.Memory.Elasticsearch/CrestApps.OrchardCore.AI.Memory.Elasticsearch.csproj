<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Title>CrestApps OrchardCore AI Memory - Elasticsearch</Title>
    <Description>
      $(CrestAppsDescription)

      Elasticsearch support for AI memory embeddings and indexing.
    </Description>
    <PackageTags>$(PackageTags) OrchardCoreCMS AI Memory Elasticsearch</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="C:\Code\CrestApps\CrestApps.OrchardCore\src\README.md" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OrchardCore.Module.Targets" />
    <PackageReference Include="OrchardCore.Elasticsearch.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../Core/CrestApps.OrchardCore.AI.Core/CrestApps.OrchardCore.AI.Core.csproj" />
    <ProjectReference Include="..\CrestApps.OrchardCore.AI.Memory\CrestApps.OrchardCore.AI.Memory.csproj" PrivateAssets="none" />
  </ItemGroup>

</Project>
