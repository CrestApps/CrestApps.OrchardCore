@model PhoneNumberVerificationReportViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Phone Number Verifications Report"])</h1></zone>

<div class="row row-cols-1 row-cols-md-3 g-3 mb-4">
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Total contacts"]</h6>
                <p class="display-6 mb-0">@Model.TotalContacts</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Verified numbers"]</h6>
                <p class="display-6 mb-0 text-success">@Model.VerifiedNumbers</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Unverified numbers"]</h6>
                <p class="display-6 mb-0">@Model.UnverifiedNumbers</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Invalid numbers"]</h6>
                <p class="display-6 mb-0 text-danger">@Model.InvalidNumbers</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Verification failures"]</h6>
                <p class="display-6 mb-0 text-warning">@Model.VerificationFailures</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Success rate"]</h6>
                <p class="display-6 mb-0">@Model.VerificationSuccessRate.ToString("0.##")%</p>
            </div>
        </div>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-3 mb-4">
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Mobile numbers"]</h6>
                <p class="h3 mb-0">@Model.MobileNumbers</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Landline numbers"]</h6>
                <p class="h3 mb-0">@Model.LandlineNumbers</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["VoIP numbers"]</h6>
                <p class="h3 mb-0">@Model.VoipNumbers</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Pending verification"]</h6>
                <p class="h3 mb-0">@Model.PendingVerification</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">@T["Requiring revalidation"]</h6>
                <p class="h3 mb-0">@Model.RequiringRevalidation</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">@T["Provider usage"]</div>
    <div class="card-body">
        @if (Model.ProviderUsageCounts.Count == 0)
        {
            <p class="text-muted mb-0">@T["No providers are enabled."]</p>
        }
        else
        {
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>@T["Provider"]</th>
                        <th class="text-end">@T["Verified records"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usage in Model.ProviderUsageCounts)
                    {
                        <tr>
                            <td>@usage.Key</td>
                            <td class="text-end">@usage.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
