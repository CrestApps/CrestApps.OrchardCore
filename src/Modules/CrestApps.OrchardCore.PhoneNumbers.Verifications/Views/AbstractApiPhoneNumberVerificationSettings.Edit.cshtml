@using CrestApps.OrchardCore.PhoneNumbers.Verifications.Models
@model AbstractApiPhoneNumberVerificationSettingsViewModel

<h4 class="card-title">@T["AbstractAPI"]</h4>
<p class="hint">@T["Configure the connection to the AbstractAPI Phone Validation service."]</p>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check form-switch">
            <input type="checkbox" class="form-check-input" asp-for="IsEnabled" data-bs-toggle="collapse" data-bs-target="#AbstractApi_Provider_Settings" aria-controls="AbstractApi_Provider_Settings" aria-expanded="@(Model.IsEnabled ? "true" : "false")" />
            <label class="form-check-label" asp-for="IsEnabled">@T["Enable this provider"]</label>
        </div>
        <span class="hint">@T["When enabled, this provider becomes available for selection as the default verification provider."]</span>
    </div>
</div>

<div id="AbstractApi_Provider_Settings" class="collapse @(Model.IsEnabled ? "show" : string.Empty)">
    <div class="ocat-wrapper">
        <label asp-for="Endpoint" class="ocat-label">@T["Endpoint"]</label>
        <div class="ocat-end">
            <input type="url" class="form-control" asp-for="Endpoint" placeholder="https://phonevalidation.abstractapi.com/v1/" />
            <span asp-validation-for="Endpoint" class="text-danger"></span>
            <span class="hint">@T["The AbstractAPI Phone Validation endpoint."]</span>
        </div>
    </div>

    <div class="ocat-wrapper">
        <label asp-for="AuthenticationType" class="ocat-label">@T["Authentication type"]</label>
        <div class="ocat-end">
            <select asp-for="AuthenticationType" class="form-select">
                <option value="@PhoneNumberVerificationAuthenticationType.ApiKey">@T["API key"]</option>
                <option value="@PhoneNumberVerificationAuthenticationType.Basic">@T["Basic"]</option>
            </select>
            <span class="hint">@T["The authentication strategy used when calling the provider. AbstractAPI uses API key authentication."]</span>
        </div>
    </div>

    <div class="ocat-wrapper">
        <label asp-for="ApiKey" class="ocat-label">@T["API key"]</label>
        <div class="ocat-end">
            <input type="password" class="form-control" asp-for="ApiKey" autocomplete="off" placeholder='@T["Enter a new API key to replace the saved key"]' />
            <span asp-validation-for="ApiKey" class="text-danger"></span>
            @if (Model.HasApiKey)
            {
                <span class="hint text-success">@T["An API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key."]</span>
            }
            else
            {
                <span class="hint">@T["The API key provided by AbstractAPI for authenticating requests."]</span>
            }
        </div>
    </div>

    <div class="ocat-wrapper">
        <label asp-for="Username" class="ocat-label">@T["Username"]</label>
        <div class="ocat-end">
            <input type="text" class="form-control" asp-for="Username" autocomplete="off" />
            <span class="hint">@T["The username used when basic authentication is selected."]</span>
        </div>
    </div>

    <div class="ocat-wrapper">
        <label asp-for="Password" class="ocat-label">@T["Password"]</label>
        <div class="ocat-end">
            <input type="password" class="form-control" asp-for="Password" autocomplete="off" placeholder='@T["Enter a new password to replace the saved value"]' />
            @if (Model.HasPassword)
            {
                <span class="hint text-success">@T["A password has been securely stored. Enter a new value to replace it, or leave empty to keep the existing password."]</span>
            }
            else
            {
                <span class="hint">@T["The password used when basic authentication is selected."]</span>
            }
        </div>
    </div>
</div>
