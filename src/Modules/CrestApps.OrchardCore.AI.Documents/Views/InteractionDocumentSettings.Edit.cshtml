@using CrestApps.OrchardCore.AI.Chat.Interactions.ViewModels

@model InteractionDocumentSettingsViewModel

@if (!Model.IndexProfiles.Any())
{
    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <div class="alert alert-warning" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                <strong>@T["No index profiles configured"]</strong>
                <p class="mb-0">
                    @T["There are no index profiles configured for user uploaded documents. To enable document embedding, go to Search > Indexing, click Add index and add an 'AI Documents' index. If you do not see `AI Documents` options, you'll need to enable one of the 'AI Documents indexing' features."]
                </p>
            </div>
        </div>
    </div>
}

<div class="ocat-wrapper">
    <label asp-for="IndexProfileName" class="ocat-label">@T["Index profile"]</label>
    <div class="ocat-end">
        <select asp-for="IndexProfileName" asp-items="Model.IndexProfiles" class="form-select">
            <option value="">@T["Select a profile"]</option>
        </select>
        <span class="hint">@T["The index profile used to index documents for chat interactions. After this is configured in production, avoid changing it to prevent losing access to documents created for existing sessions."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <label asp-for="RetrievalMode" class="ocat-label">@T["Document retrieval mode"]</label>
    <div class="ocat-end">
        <select asp-for="RetrievalMode" asp-items="Model.RetrievalModes" class="form-select"></select>
        <span class="hint">@T["Choose the default retrieval behavior for uploaded document knowledge. Chunk keeps chunk-level context. Hierarchical matches on chunks, then injects the full text of the matched documents."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="AllowDocumentUploads" />
            <label class="form-check-label" asp-for="AllowDocumentUploads">@T["Allow document uploads in chat interactions"]</label>
            <span class="hint">@T["When enabled, users can upload document files in chat interactions."]</span>
        </div>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="AllowImageUploads" />
            <label class="form-check-label" asp-for="AllowImageUploads">@T["Allow image uploads in chat interactions"]</label>
            <span class="hint">@T["When enabled, users can upload image files in chat interactions. Requires a vision deployment to be configured in the global AI settings."]</span>
        </div>
    </div>
</div>
