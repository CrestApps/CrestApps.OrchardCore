@using CrestApps.OrchardCore.TimeZones.ViewModels

@model TimeZoneMapDeploymentStepViewModel

<div class="ocat-wrapper">
    <div class="ocat-label">@T["Time Zone Maps"]</div>
    <div class="ocat-end">
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IncludeAll" data-bs-toggle="collapse" role="button" data-bs-target="#time-zone-map-list" aria-expanded="false" aria-controls="time-zone-map-list" />
                @T["Include all time zone maps"]
            </label>
        </div>

        <div id="time-zone-map-list" class="collapse@(Model.IncludeAll ? string.Empty : " show")">
            <div class="hint mb-1">@T["The time zone maps to export as part of the deployment plan."]</div>

            <div class="mb-3">
                @for (var i = 0; i < Model.Maps.Length; i++)
                {
                    <div class="form-check">
                        <input type="hidden" asp-for="Maps[i].ItemId" />
                        <input asp-for="Maps[i].IsSelected" type="checkbox" class="form-check-input">
                        <label class="form-check-label" asp-for="Maps[i].IsSelected">@Model.Maps[i].Name <span class="text-muted">(@Model.Maps[i].TimeZoneId)</span></label>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
