@using CrestApps.OrchardCore.AI.Mcp.ViewModels
@using OrchardCore

@model McpResourceStepViewModel

<div class="@Orchard.GetWrapperClasses()">
    <div class="@Orchard.GetLabelClasses()">@T["MCP Resources"]</div>
    <div class="@Orchard.GetEndClasses()">
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IncludeAll" data-bs-toggle="collapse" role="button" data-bs-target="#resources-list" aria-expanded="false" aria-controls="resources-list" />
                @T["Include all MCP resources"]
            </label>
        </div>

        <div id="resources-list" class="collapse@(Model.IncludeAll ? string.Empty : " show")">
            <div class="hint mb-1">@T["The MCP resources to export as part of the plan."]</div>

            <ul class="list-group mb-3">
                @for (int i = 0; i < Model.Resources.Length; i++)
                {
                    var option = Model.Resources[i];
                    <li class="list-group-item">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="@Html.NameFor(m => m.Resources[i].Selected)"
                                       value="true"
                                @(option.Selected ? "checked" : "") />
                                <input type="hidden" name="@Html.NameFor(m => m.Resources[i].Text)" value="@option.Text" />
                                <input type="hidden" name="@Html.NameFor(m => m.Resources[i].Value)" value="@option.Value" />
                                @option.Text
                            </label>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
