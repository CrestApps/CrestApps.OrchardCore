@using CrestApps.Core.AI.Mcp.Models
@using Microsoft.AspNetCore.Mvc.Localization
@using OrchardCore.DisplayManagement.Shapes
@using System.Globalization

@model ShapeViewModel<McpResource>

@{
    var modifiedAt = Model.Value.ModifiedUtc ?? Model.Value.CreatedUtc;
}

<span class="badge ta-badge font-weight-normal" data-bs-toggle="tooltip" title="@await DisplayAsync(await New.DateTime(Utc: modifiedAt, Format: "g"))">
    <i class="fa-solid fa-calendar text-secondary" aria-hidden="true"></i>
    <time datetime="@modifiedAt.ToString(DateTimeFormatConstants.HtmlDateTimeOffset, CultureInfo.InvariantCulture)">@await DisplayAsync(await New.Timespan(Utc: modifiedAt))</time>
</span>

@if (!string.IsNullOrEmpty(Model.Value.Author))
{
    <span class="badge ta-badge font-weight-normal" data-bs-toggle="tooltip" title="@T["Author"]">
        <i class="fa-solid fa-user text-secondary me-1" aria-hidden="true"></i>@Model.Value.Author
    </span>
}

@if (!string.IsNullOrEmpty(Model.Value.Source))
{
    <span class="badge ta-badge font-weight-normal" data-bs-toggle="tooltip" title="@T["Type"]">
        <i class="fa-solid fa-tag text-secondary me-1" aria-hidden="true"></i>@Model.Value.Source
    </span>
}

@if (!string.IsNullOrEmpty(Model.Value.Resource?.MimeType))
{
    <span class="badge ta-badge font-weight-normal" data-bs-toggle="tooltip" title="@T["MIME Type"]">
        <i class="fa-solid fa-file text-secondary me-1" aria-hidden="true"></i>@Model.Value.Resource.MimeType
    </span>
}
