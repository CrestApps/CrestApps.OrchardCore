@using CrestApps.Core.AI.Claude.Models
@using CrestApps.OrchardCore.AI.Chat.Claude.Settings
@model CrestApps.OrchardCore.AI.Chat.Claude.ViewModels.ClaudeSettingsViewModel

<fieldset>
    <legend>@T["Claude authentication"]</legend>
    <p class="hint">@T["Configure how the Claude orchestrator authenticates with Anthropic."]</p>

    <div class="ocat-limited-wrapper">
        <label asp-for="AuthenticationType" class="ocat-label">@T["Authentication type"]</label>
        <div class="ocat-limited">
            <select asp-for="AuthenticationType" asp-items="Model.AuthenticationTypes" class="form-select" id="claude-auth-type">
            </select>
            <span class="hint">@T["Choose how the Claude orchestrator authenticates. \"Not configured\" keeps Claude disabled until you explicitly enable API key authentication."]</span>
        </div>
    </div>

    <div id="claude-api-key-section" class="@(Model.AuthenticationType == ClaudeAuthenticationType.ApiKey ? "" : "d-none")">
        <div class="ocat-limited-wrapper">
            <label asp-for="BaseUrl" class="ocat-label">@T["Base URL"]</label>
            <div class="ocat-limited">
                <input asp-for="BaseUrl" class="form-control" placeholder="https://api.anthropic.com" />
                <span class="hint">@T["Use the standard Anthropic API base URL unless you have a custom gateway."]</span>
            </div>
        </div>

        <div class="ocat-limited-wrapper">
            <label asp-for="ApiKey" class="ocat-label">@T["API key"]</label>
            <div class="ocat-limited">
                <input asp-for="ApiKey" type="password" class="form-control" placeholder="@T["Enter API key"]" />
                <span asp-validation-for="ApiKey" class="text-danger"></span>
                @if (Model.HasApiKey)
                {
                    <span class="hint text-success">@T["A Claude API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key."]</span>
                }
                else
                {
                    <span class="hint">@T["The Claude API key used for live model discovery and Claude-orchestrated chats."]</span>
                }
            </div>
        </div>

        @if (Model.AvailableModels.Any())
        {
            <div class="ocat-limited-wrapper">
                <label asp-for="DefaultModel" class="ocat-label">@T["Default model"]</label>
                <div class="ocat-limited">
                    <select asp-for="DefaultModel" asp-items="Model.AvailableModels" class="form-select">
                        <option value="">@T["Use per-item override"]</option>
                    </select>
                    <span class="hint">@T["Available models are loaded from the Anthropic Models API using the configured API key."]</span>
                </div>
            </div>
        }
        else
        {
            <div class="ocat-limited-wrapper">
                <label asp-for="DefaultModel" class="ocat-label">@T["Default model"]</label>
                <div class="ocat-limited">
                    <input asp-for="DefaultModel" class="form-control" placeholder="claude-sonnet-4-6" />
                    <span class="hint">@T["Optionally set the Claude model ID used when a profile, template, or interaction does not override it."]</span>
                </div>
            </div>
        }
    </div>
</fieldset>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', function () {
        const authTypeSelect = document.getElementById('claude-auth-type');
        const apiKeySection = document.getElementById('claude-api-key-section');

        function toggleSections() {
            const isApiKey = authTypeSelect.value === '@(nameof(ClaudeAuthenticationType.ApiKey))';
            apiKeySection.classList.toggle('d-none', !isApiKey);
        }

        if (authTypeSelect) {
            authTypeSelect.addEventListener('change', toggleSections);
        }

        toggleSections();
    });
</script>
