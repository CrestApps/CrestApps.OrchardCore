@using CrestApps.Core.AI.Claude.Models
@using CrestApps.Core.AI.Claude.Services
@using CrestApps.OrchardCore.AI.Chat.Claude.ViewModels

@model EditClaudeProfileViewModel

<div class="d-none orchestrator-dependent orchestrator-dependent-@(ClaudeOrchestrator.OrchestratorName)">
    <fieldset class="ocat-wrapper">
        <legend class="ocat-label">@T["Claude configuration"]</legend>
        <div class="ocat-end">
            @if (!Model.IsClaudeConfigured)
            {
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    @T["Claude is not configured and cannot be used until it has been configured in Settings → Artificial Intelligence → Claude."]
                </div>
            }
            else if (Model.AvailableModels.Any())
            {
                <div class="ocat-limited-wrapper">
                    <label asp-for="ClaudeModel" class="ocat-label">@T["Claude model"]</label>
                    <div class="ocat-limited">
                        <select asp-for="ClaudeModel" asp-items="Model.AvailableModels" class="form-select">
                            <option value="">@T["Use default model"]</option>
                        </select>
                        <span asp-validation-for="ClaudeModel" class="text-danger"></span>
                        <span class="hint">@T["Select a Claude model override for profiles created from this template, or leave it on the configured default."]</span>
                    </div>
                </div>

                <div class="ocat-limited-wrapper">
                    <label asp-for="ClaudeEffortLevel" class="ocat-label">@T["Effort level"]</label>
                    <div class="ocat-limited">
                        <select asp-for="ClaudeEffortLevel" class="form-select">
                            <option value="@ClaudeEffortLevel.None">@T["Default"]</option>
                            <option value="@ClaudeEffortLevel.Low">@T["Low"]</option>
                            <option value="@ClaudeEffortLevel.Medium">@T["Medium"]</option>
                            <option value="@ClaudeEffortLevel.High">@T["High"]</option>
                        </select>
                        <span class="hint">@T["Select the reasoning effort level. Higher effort produces more thorough responses but uses more tokens."]</span>
                    </div>
                </div>
            }
            else if (Model.IsClaudeConfigured)
            {
                <div class="ocat-limited-wrapper">
                    <label asp-for="ClaudeModel" class="ocat-label">@T["Claude model"]</label>
                    <div class="ocat-limited">
                        <input asp-for="ClaudeModel" class="form-control" placeholder="@T["Leave empty to use the default model from settings"]" />
                        <span asp-validation-for="ClaudeModel" class="text-danger"></span>
                        <span class="hint">@T["Optionally override the Claude model. Leave empty to use the default model configured in settings."]</span>
                    </div>
                </div>

                <div class="ocat-limited-wrapper">
                    <label asp-for="ClaudeEffortLevel" class="ocat-label">@T["Effort level"]</label>
                    <div class="ocat-limited">
                        <select asp-for="ClaudeEffortLevel" class="form-select">
                            <option value="@ClaudeEffortLevel.None">@T["Default"]</option>
                            <option value="@ClaudeEffortLevel.Low">@T["Low"]</option>
                            <option value="@ClaudeEffortLevel.Medium">@T["Medium"]</option>
                            <option value="@ClaudeEffortLevel.High">@T["High"]</option>
                        </select>
                        <span class="hint">@T["Select the reasoning effort level. Higher effort produces more thorough responses but uses more tokens."]</span>
                    </div>
                </div>
            }
        </div>
    </fieldset>
</div>
