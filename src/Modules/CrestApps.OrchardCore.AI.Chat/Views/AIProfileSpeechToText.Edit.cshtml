@using CrestApps.OrchardCore.AI.Chat.ViewModels
@using OrchardCore

@model AIProfileSpeechToTextViewModel

<div class="@Orchard.GetWrapperClasses("profile-type profile-type-chat")">
    <div class="@Orchard.GetEndClasses(true)">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="EnableSpeechToText">
            <label class="form-check-label" asp-for="EnableSpeechToText">@T["Enable speech-to-text"]</label>
            <span class="hint dashed">@T["When enabled, a microphone button will be available in the chat interface, allowing users to speak their prompts."]</span>
        </div>
    </div>
</div>
