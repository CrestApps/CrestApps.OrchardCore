@model CrestApps.OrchardCore.AI.Chat.ViewModels.UsageAnalyticsIndexViewModel
@using System.Globalization

@{
    ViewData["Title"] = T["AI Usage Analytics"];
    var datePattern = CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern;
    var timePattern = CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern;
}

<style asp-name="flatpickr"></style>
<script asp-name="flatpickr" at="Foot"></script>
<script asp-name="flatpickr-culture" at="Foot"></script>

<div class="mb-3">
    <h1>@T["AI Usage Analytics"]</h1>
    <p class="text-muted mb-0">@T["Review provider usage by user, model, and conversation type across chat sessions and chat interactions."]</p>
</div>

@if (!Model.IsAIUsageTrackingEnabled)
{
    <div class="alert alert-warning">
        @T["AI usage tracking is currently disabled. Enable AI usage tracking in Settings -> Artificial Intelligence to capture future provider usage data for this report."]
    </div>
}

<div class="card mb-3">
    <div class="card-header">
        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-5 no-gutters">
                <div class="col p-1">
                    <label asp-for="StartDate" class="form-label">@T["From"]</label>
                    <input type="text" asp-for="StartDate" class="form-control" placeholder="@T["From"]" />
                </div>
                <div class="col p-1">
                    <label asp-for="EndDate" class="form-label">@T["To"]</label>
                    <input type="text" asp-for="EndDate" class="form-control" placeholder="@T["To"]" />
                </div>
                <div class="col p-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark">
                        <i class="fas fa-filter"></i> @T["Show"]
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="card-body p-3">
        @if (!Model.ShowReport)
        {
            <div class="alert alert-info mb-0">@T["Use the filters above to generate the usage report."]</div>
        }
        else if (Model.Rows.Count == 0)
        {
            <div class="alert alert-warning mb-0">@T["No usage data was found for the selected filters."]</div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T["Provider calls"]</div><div class="fs-3 fw-semibold">@Model.TotalCalls</div></div></div></div>
                <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T["Chat sessions"]</div><div class="fs-3 fw-semibold">@Model.TotalSessions</div></div></div></div>
                <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T["Chat interactions"]</div><div class="fs-3 fw-semibold">@Model.TotalChatInteractions</div></div></div></div>
                <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T["Total tokens"]</div><div class="fs-3 fw-semibold">@Model.TotalTokens</div></div></div></div>
            </div>

            <div class="card">
                <div class="card-header">@T["Usage by user and model"]</div>
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@T["User"]</th>
                                <th>@T["Client"]</th>
                                <th>@T["Model"]</th>
                                <th class="text-end">@T["Calls"]</th>
                                <th class="text-end">@T["Sessions"]</th>
                                <th class="text-end">@T["Interactions"]</th>
                                <th class="text-end">@T["Input"]</th>
                                <th class="text-end">@T["Output"]</th>
                                <th class="text-end">@T["Tokens"]</th>
                                <th class="text-end">@T["Avg latency"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@row.UserLabel</div>
                                    <div class="text-muted small">@(row.IsAuthenticated ? T["Authenticated"] : T["Anonymous"])</div>
                                </td>
                                <td>@row.ClientName</td>
                                <td>@row.ModelName</td>
                                <td class="text-end">@row.TotalCalls</td>
                                <td class="text-end">@row.TotalSessions</td>
                                <td class="text-end">@row.TotalChatInteractions</td>
                                <td class="text-end">@row.TotalInputTokens</td>
                                <td class="text-end">@row.TotalOutputTokens</td>
                                <td class="text-end fw-semibold">@row.TotalTokens</td>
                                <td class="text-end">@(row.AverageResponseLatencyMs > 0 ? $"{row.AverageResponseLatencyMs} ms" : "-")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

<script at="Foot" depends-on="flatpickr,flatpickr-culture">
    flatpickr('#@Html.IdFor(m => m.StartDate)', flatpickrCulture.createLocalizedDateTimeConfig('@datePattern', '@timePattern', {
        altInputClass: 'form-control'
    }));
    flatpickr('#@Html.IdFor(m => m.EndDate)', flatpickrCulture.createLocalizedDateTimeConfig('@datePattern', '@timePattern', {
        altInputClass: 'form-control'
    }));
</script>
