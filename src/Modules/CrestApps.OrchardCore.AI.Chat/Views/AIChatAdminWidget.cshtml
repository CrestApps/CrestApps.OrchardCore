@using CrestApps.Core
@using CrestApps.Core.AI
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Models
@using CrestApps.OrchardCore.AI.Chat.Hubs
@using CrestApps.OrchardCore.AI.Core
@using CrestApps.OrchardCore.AI.Core.Models
@using CrestApps.Core.SignalR.Services
@using OrchardCore.Entities
@using OrchardCore.Environment.Shell
@using OrchardCore.Environment.Shell.Scope
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using System.Text.Json

@inject HubRouteManager HubRouteManager
@inject ShellSettings ShellSettings
@{
    var profile = (AIProfile)Model.Profile;
    IEnumerable<AIChatSessionEntry> sessions = Model.Sessions;
    var maxSessions = (int)Model.MaxSessions;
    var primaryColor = (string)Model.PrimaryColor;

    var hubLink = HubRouteManager.GetUriByHub<AIChatHub>(ViewContext.HttpContext);
    var showHistory = maxSessions > 0;

    var baseId = "AiAdminWidget";
    var chatAppHtmlId = $"{baseId}_App";
    var buttonHtmlId = $"{baseId}_Send";
    var userPromptHtmlId = $"{baseId}_Prompt";
    var chatContainerHtmlId = $"{baseId}_Body";
    var placeholderHtmlId = $"{baseId}_Placeholder";
    var widgetContainerId = $"{baseId}_Container";
    var toggleBtnId = $"{baseId}_Toggle";
    var closeBtnId = $"{baseId}_Close";
    var newChatBtnId = $"{baseId}_NewChat";
    var historyBtnId = $"{baseId}_ShowHistory";
    var historyPanelId = $"{baseId}_HistoryPanel";
    var closeHistoryBtnId = $"{baseId}_CloseHistory";
    var restoreSizeBtnId = $"{baseId}_RestoreSize";
    var documentBarHtmlId = $"{baseId}_DocumentBar";

    var storagePrefix = $"{ShellSettings.Name}-{baseId}";

    var shellFeaturesManager = ShellScope.Services.GetRequiredService<IShellFeaturesManager>();
    var enabledFeatures = await shellFeaturesManager.GetEnabledFeaturesAsync();
    var sessionDocumentsFeatureEnabled = enabledFeatures.Any(f => f.Id == AIConstants.Feature.ChatSessionDocuments);
    var sessionDocumentsEnabled = sessionDocumentsFeatureEnabled
        && profile.GetOrCreate<AIProfileSessionDocumentsMetadata>().AllowSessionDocuments;
    var allowedExtensions = string.Empty;
    var supportedExtensionsText = string.Empty;
    if (sessionDocumentsEnabled)
    {
        var chatDocOptions = ShellScope.Services.GetRequiredService<IOptions<ChatDocumentsOptions>>();
        allowedExtensions = chatDocOptions.Value.GetAllowedFileExtensionsAcceptValue();
        supportedExtensionsText = chatDocOptions.Value.GetAllowedFileExtensionsDisplayValue();
    }

    var metricsEnabled = enabledFeatures.Any(f => f.Id == AIConstants.Feature.ChatAnalytics)
        && profile.GetOrCreate<AnalyticsMetadata>().EnableSessionMetrics;
    var profileMetadata = profile.GetOrCreate<AIProfileMetadata>();
    var addInitialPrompt = !string.IsNullOrWhiteSpace(profileMetadata.InitialPrompt);
    ChatModeProfileSettings chatModeSettings = null;
    profile.TryGetSettings<ChatModeProfileSettings>(out chatModeSettings);
    var chatMode = chatModeSettings?.ChatMode ?? ChatMode.TextInput;
    var speechToTextEnabled = chatMode == ChatMode.AudioInput || chatMode == ChatMode.Conversation;
    var textToSpeechEnabled = chatMode == ChatMode.Conversation || chatModeSettings?.EnableTextToSpeechPlayback == true;
    var ttsVoiceName = chatModeSettings?.VoiceName;
    var conversationModeEnabled = chatMode == ChatMode.Conversation;
    var micBtnHtmlId = $"{baseId}_MicBtn";
    var conversationBtnHtmlId = $"{baseId}_ConversationBtn";
    var orchestratorAvailability = new OrchestratorAvailability();
    if (!string.IsNullOrWhiteSpace(profile.OrchestratorName))
    {
        var availabilityProvider = ViewContext.HttpContext.RequestServices.GetServices<IOrchestratorAvailabilityProvider>()
            .FirstOrDefault(provider => string.Equals(provider.OrchestratorName, profile.OrchestratorName, StringComparison.OrdinalIgnoreCase));

        if (availabilityProvider is not null)
        {
            orchestratorAvailability = await availabilityProvider.GetAvailabilityAsync();
        }
    }
}

<div id="@($"{baseId}_Shell")" class="ai-chat-admin-widget-shell" style="--ai-widget-primary: @primaryColor; visibility:hidden;">
    <!-- Toggle Button (green circle ring with robot icon) -->
    <button id="@toggleBtnId" class="ai-chat-widget-toggle" title="@T["Open AI Assistant"]">
        <i class="fa fa-robot"></i>
    </button>

    <!-- Widget Container -->
    <div id="@widgetContainerId" class="ai-chat-widget-container">
        <!-- Header (drag handle) -->
        <div class="ai-chat-widget-header">
            <span class="title">@(string.IsNullOrEmpty(profile.DisplayText) ? T["AI Assistant"] : profile.DisplayText)</span>
            <div class="ai-chat-widget-header-actions">
                <button class="btn btn-link d-none" id="@restoreSizeBtnId" title="@T["Restore size"]">
                    <i class="fas fa-compress"></i>
                </button>
                <button class="btn btn-link" id="@newChatBtnId" title="@T["New chat"]">
                    <i class="fas fa-plus"></i>
                </button>
                @if (showHistory)
                {
                    <button class="btn btn-link" id="@historyBtnId" title="@T["Chat history"]">
                        <i class="fas fa-clock-rotate-left"></i>
                    </button>
                }
                <button class="btn btn-link" id="@closeBtnId" title="@T["Close"]">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Chat Body -->
        <div class="ai-chat-widget-messages" id="@chatContainerHtmlId">
            @if (!orchestratorAvailability.IsAvailable)
            {
                <div class="alert alert-warning m-3 mb-0">
                    <i class="fas fa-exclamation-triangle"></i>
                    @orchestratorAvailability.Message
                </div>
            }
            <div id="@placeholderHtmlId" class="ai-chat-widget-welcome@(addInitialPrompt ? " d-none" : string.Empty)">
                <i class="fa fa-robot" style="font-size: 2rem;"></i><br>
                @(addInitialPrompt || string.IsNullOrEmpty(profile.WelcomeMessage) ? T["What do you want to know?"] : profile.WelcomeMessage)
            </div>
            <div id="@chatAppHtmlId"></div>
        </div>

        @if (sessionDocumentsEnabled)
        {
            <div id="@documentBarHtmlId" class="border-top bg-light d-none"></div>
        }

        <!-- Input Area -->
        <div class="ai-chat-widget-input">
            <textarea id="@userPromptHtmlId"
                      data-session-id=""
                      data-profile-id="@profile.ItemId"
                      placeholder="@T["Message..."]"
                      rows="1"
                      aria-label="@T["Message"]"></textarea>
            <button class="stt-mic-btn btn btn-outline-secondary btn-sm"
                    type="button"
                    id="@micBtnHtmlId"
                    title="@T["Voice input"]"
                    style="display: none;">
                <i class="fa-solid fa-microphone"></i>
            </button>
            @if (conversationModeEnabled)
            {
                <button class="btn btn-outline-dark btn-sm"
                        type="button"
                        id="@conversationBtnHtmlId"
                        title="@T["Start Conversation"]"
                        data-start-title="@T["Start Conversation"]"
                        data-end-title="@T["End Conversation"]"
                        data-start-html="<i class='fa-solid fa-wave-square'></i>"
                        data-end-html="<i class='fa-solid fa-stop me-1'></i> @T["End Conversation"]">
                    <i class="fa-solid fa-wave-square"></i>
                </button>
            }
            <button id="@buttonHtmlId"
                    disabled
                    data-start-icon="<i class='fa-solid fa-arrow-up'></i>"
                    data-stop-icon="<i class='fa-solid fa-stop'></i>">
                <i class="fa-solid fa-arrow-up"></i>
            </button>
        </div>

        @if (showHistory)
        {
            <!-- History Panel -->
            <div class="ai-chat-widget-history-panel" id="@historyPanelId">
                <div class="history-header">
                    <h5>@T["Chat History"]</h5>
                    <button class="btn btn-sm btn-link text-secondary" id="@closeHistoryBtnId">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <ul class="ai-chat-widget-history-list">
                    @foreach (var session in sessions)
                    {
                        <li>
                            <a href="#" class="chat-session-history-item"
                                   data-session-id="@session.SessionId"
                                   title="@session.Title">
                                @(string.IsNullOrEmpty(session.Title) ? T["Untitled Chat"] : session.Title)
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@{
    var chatConfig = new Dictionary<string, object>
    {
        ["signalRHubUrl"] = hubLink,
        ["appElementSelector"] = $"#{chatAppHtmlId}",
        ["chatContainerElementSelector"] = $"#{chatContainerHtmlId}",
        ["inputElementSelector"] = $"#{userPromptHtmlId}",
        ["sendButtonElementSelector"] = $"#{buttonHtmlId}",
        ["placeholderElementSelector"] = $"#{placeholderHtmlId}",
        ["autoCreateSession"] = addInitialPrompt,
        ["initialPrompt"] = addInitialPrompt ? profileMetadata.InitialPrompt : null,
        ["messages"] = Array.Empty<object>(),
        ["metricsEnabled"] = metricsEnabled,
        ["chatMode"] = chatMode.ToString(),
        ["micButtonElementSelector"] = $"#{micBtnHtmlId}",
        ["ttsVoiceName"] = string.IsNullOrWhiteSpace(ttsVoiceName) ? null : ttsVoiceName,
        ["conversationButtonElementSelector"] = $"#{conversationBtnHtmlId}",
        ["textToSpeechEnabled"] = textToSpeechEnabled,
        ["isOrchestratorAvailable"] = orchestratorAvailability.IsAvailable,
        ["orchestratorUnavailableMessage"] = orchestratorAvailability.IsAvailable ? null : orchestratorAvailability.Message,
    };

    if (sessionDocumentsEnabled)
    {
        chatConfig["sessionDocumentsEnabled"] = true;
        chatConfig["documentBarSelector"] = $"#{documentBarHtmlId}";
        chatConfig["uploadDocumentUrl"] = Url.RouteUrl(AIConstants.RouteNames.ChatSessionUploadDocument);
        chatConfig["removeDocumentUrl"] = Url.RouteUrl(AIConstants.RouteNames.ChatSessionRemoveDocument);
        chatConfig["allowedExtensions"] = allowedExtensions;
        chatConfig["supportedExtensionsText"] = supportedExtensionsText;
        chatConfig["existingDocuments"] = Array.Empty<object>();
    }
}
<div id="@($"{baseId}_Config")" class="d-none" data-config="@JsonSerializer.Serialize(chatConfig, JOptions.CamelCase)"></div>
<script>
    (function () {
        var shell = document.getElementById('@($"{baseId}_Shell")');
        var initializationAttempts = 0;
        var maxInitializationAttempts = 40;
        var isInitialized = false;

        function revealShell() {
            if (shell) {
                shell.style.visibility = '';
            }
        }

        function initializeWidget() {
            if (isInitialized) {
                return;
            }

            if (!window.openAIChatWidgetManager || !window.openAIChatManager) {
                initializationAttempts++;

                if (initializationAttempts < maxInitializationAttempts) {
                    window.requestAnimationFrame(initializeWidget);

                    return;
                }

                console.warn('AI chat widget runtime is not available.');
                revealShell();

                return;
            }

            isInitialized = true;

            var widgetStateName = '@(storagePrefix + "-ai-admin-widget")';
            window.openAIChatWidgetManager.initialize({
            configElementSelector: '#@($"{baseId}_Config")',
            messageTemplateSelector: '#@($"{baseId}_MessageTemplate")',
            indicatorTemplateSelector: '#@($"{baseId}_IndicatorTemplate")',
            shellSelector: '#@($"{baseId}_Shell")',
            widgetContainerSelector: '#@widgetContainerId',
            toggleButtonSelector: '#@toggleBtnId',
            closeButtonSelector: '#@closeBtnId',
            inputSelector: '#@userPromptHtmlId',
            widgetStateName: widgetStateName,
            widgetOpenStateKey: '@(storagePrefix + "-ai-admin-widget-state")',
            openStateValue: 'open',
            closedStateValue: 'closed',
            openIconHtml: '<i class="fas fa-times"></i>',
            closedIconHtml: '<i class="fa fa-robot"></i>',
            chatConfig: Object.assign(
                {},
                JSON.parse(document.getElementById('@($"{baseId}_Config")').getAttribute('data-config')),
                {
                    widget: {
                        chatWidgetContainer: '#@widgetContainerId',
                        chatWidgetStateName: widgetStateName,
                        chatHistorySection: '#@historyPanelId',
                        closeHistoryButton: '#@closeHistoryBtnId',
                        showHistoryButton: '#@historyBtnId',
                        newChatButton: '#@newChatBtnId',
                        toggleButtonSelector: '#@toggleBtnId',
                        resetSizeButtonSelector: '#@restoreSizeBtnId',
                        dragHandleSelector: '.ai-chat-widget-header',
                        enableDragging: true,
                        enableResizing: true,
                        persistLayout: true,
                        minWidth: 288,
                        minHeight: 320
                    }
                })
            });
        }

        initializeWidget();
    })();
</script>
<template id="@($"{baseId}_MessageTemplate")">
    <div class="ai-chat-messages">
        <div v-for="(message, index) in messages" :key="index" class="ai-chat-message-item">
            <div>
                <div v-if="message.role === 'user'" class="ai-chat-msg-role ai-chat-msg-role-user">@T["You"]</div>
                <div v-else-if="message.role !== 'indicator'" class="ai-chat-msg-role ai-chat-msg-role-assistant">
                    <span :class="message.isStreaming && index === lastAssistantIndex ? 'ai-streaming-icon' : 'ai-bot-icon'"><i class="fa fa-robot"></i></span>
                    @T["Assistant"]
                </div>
                <div class="ai-chat-message-body min-w-0">
                    <h6 v-if="message.title" class="mb-1" style="font-size: 0.8rem;">{{ message.title }}</h6>
                    <div v-html="message.htmlContent || message.content" style="font-size: 0.85rem; line-height: 1.5;"></div>
                    <span class="message-buttons-container" v-if="!isIndicator(message)">
                        <template v-if="metricsEnabled && message.role === 'assistant'">
                            <span class="ai-chat-message-assistant-feedback" :data-message-id="message.id">
                                <button class="btn btn-sm btn-link text-success p-0 me-2 rate-up-btn button-message-toolbox" @@click="rateMessage(message, true, $event)" title="@T["Thumbs up"]">
                                    <i class="fa-regular fa-thumbs-up" style="font-size: 0.9rem;"></i>
                                </button>
                                <button class="btn btn-sm btn-link text-danger p-0 me-2 rate-down-btn button-message-toolbox" @@click="rateMessage(message, false, $event)" title="@T["Thumbs down"]">
                                    <i class="fa-regular fa-thumbs-down" style="font-size: 0.9rem;"></i>
                                </button>
                            </span>
                        </template>
                        <button v-if="textToSpeechEnabled && !isConversationMode && message.role === 'assistant' && !message.isStreaming" class="btn btn-sm btn-link text-secondary p-0 me-1 button-message-toolbox" :class="{ 'tts-playing': ttsPlayingMessageIndex === index }" :data-tts-message-index="index" @@click="toggleMessageTts(message, index)" :title="ttsPlayingMessageIndex === index ? 'Pause audio' : 'Read aloud'">
                            <span :class="ttsPlayingMessageIndex === index ? 'fa-solid fa-circle-pause' : 'fa-solid fa-circle-play'" style="font-size: 0.9rem;"></span>
                        </button>
                        <button class="btn btn-sm btn-link text-secondary p-0 button-message-toolbox" @@click="copyResponse(message.content)" title="@T["Copy"]">
                            <i class="fa-solid fa-copy" style="font-size: 0.9rem;"></i>
                        </button>
                    </span>
                </div>
            </div>
        </div>
    </div>
</template>
<template id="@($"{baseId}_IndicatorTemplate")">
    <div class="ai-chat-msg-role ai-chat-msg-role-assistant">
        <span class="ai-streaming-icon"><i class="fa fa-robot" style="display: inline-block;"></i></span>
        @T["Assistant"]
    </div>
</template>
