@model CrestApps.OrchardCore.AI.Chat.ViewModels.ChatConversionGoalsIndexViewModel
@using System.Globalization

@{
    var datePattern = CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern;
    var timePattern = CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern;
}

<style asp-name="flatpickr"></style>
<script asp-name="flatpickr" at="Foot"></script>
<script asp-name="flatpickr-culture" at="Foot"></script>

<zone Name="Title"><h1>@T["AI Chat Conversion Goals"]</h1></zone>

<div class="card bg-default">
    <div class="card-header">
        <form asp-action="Index" method="post">
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-5 no-gutters">
                <div class="col p-1">
                    <label class="form-label" asp-for="ProfileId">@T["AI Profile"]</label>
                    <select asp-for="ProfileId" asp-items="Model.Profiles" class="form-select" required></select>
                    <span asp-validation-for="ProfileId" class="text-danger"></span>
                </div>
                <div class="col p-1">
                    <label class="form-label" asp-for="StartDate">@T["From"]</label>
                    <input type="text" asp-for="StartDate" class="form-control" placeholder="@T["From"]" />
                </div>
                <div class="col p-1">
                    <label class="form-label" asp-for="EndDate">@T["To"]</label>
                    <input type="text" asp-for="EndDate" class="form-control" placeholder="@T["To"]" />
                </div>
                <div class="col p-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark">
                        <i class="fas fa-filter"></i> @T["Show"]
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="card-body p-3">
        @if (!Model.ShowReport)
        {
            <p class="card-text text-center">@T["Select an AI Profile to run the report."]</p>
        }
        else if (Model.Rows.Count == 0)
        {
            <p class="card-text text-center">@T["No conversion-goal results found for the selected filters."]</p>
        }
        else
        {
            <div class="mb-3">
                <form asp-action="Export" method="post">
                    <input type="hidden" asp-for="ProfileId" />
                    <input type="hidden" asp-for="StartDate" />
                    <input type="hidden" asp-for="EndDate" />
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-file-csv me-1"></i>@T["Export as CSV"]
                    </button>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>@T["Session date"]</th>
                            <th>@T["Session ID"]</th>
                            <th>@T["Total points"]</th>
                            @foreach (var column in Model.Columns)
                            {
                                <th>@column</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@row.SessionStartedUtc.ToString("g")</td>
                                <td><code>@row.SessionId</code></td>
                                <td>@row.TotalPoints</td>
                                @foreach (var column in Model.Columns)
                                {
                                    row.Values.TryGetValue(column, out var value);
                                    <td>@value</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script at="Foot" depends-on="flatpickr,flatpickr-culture">
    flatpickr('#@Html.IdFor(m => m.StartDate)', flatpickrCulture.createLocalizedDateTimeConfig('@datePattern', '@timePattern', {
        altInputClass: 'form-control'
    }));
    flatpickr('#@Html.IdFor(m => m.EndDate)', flatpickrCulture.createLocalizedDateTimeConfig('@datePattern', '@timePattern', {
        altInputClass: 'form-control'
    }));
</script>
