@using CrestApps.Core
@using CrestApps.Core.AI
@using CrestApps.OrchardCore.AI.Core
@using CrestApps.OrchardCore.AI.Chat.Hubs
@using CrestApps.OrchardCore.AI.Chat.ViewModels
@using CrestApps.Core.SignalR.Services
@using System.Text.Json

@model TestProfileViewModel

@inject HubRouteManager HubRouteManager

@{
    var baseId = Html.IdForModel();
    var chatAppHtmlId = $"{baseId}_ChatApp";
    var buttonHtmlId = $"{baseId}_SendButton";
    var userPromptHtmlId = $"{baseId}_UserPrompt";
    var chatContainerHtmlId = $"{baseId}_ChatContainer";
    var placeholderHtmlId = $"{baseId}_Placeholder";
}

<div class="container-fluid d-flex flex-column" style="height: calc(100vh - 2rem - var(--oc-top-nav-height, 0));">
    <div class="flex-grow-1 overflow-y-auto p-3 mb-3 rounded-2 border bg-theme" id="@chatContainerHtmlId">
        <div class="w-100 ai-chat-messages">
            <div id="@placeholderHtmlId" class="text-center p-3">
                <h1 class="mb-3">@T["Invoke {0}", Model.Profile?.DisplayText ?? Model.Profile?.Name ?? "Profile"]</h1>
                <p class="text-muted">@T["Send a message to invoke this profile. Only the last response is shown."]</p>
            </div>

            <div id="@chatAppHtmlId"></div>
        </div>
    </div>

    <div class="flex-shrink-0">
        <div class="ai-chat-prompt-container bg-body text-body rounded border w-100">
            <textarea class="form-control bg-transparent border-0 chat-user-prompt-input px-4"
                      id="@userPromptHtmlId"
                      data-session-id=""
                      data-profile-id="@Model.ProfileId"
                      placeholder="@T["Enter a message"] ..."
                      aria-label="@T["Enter a message"]"
                      aria-describedby="@buttonHtmlId"></textarea>

            <div class="d-flex justify-content-end px-3 my-2">
                <button class="btn btn-dark rounded" type="button" id="@buttonHtmlId" disabled
                        data-start-icon="<i class='fa-solid fa-arrow-up'></i>"
                        data-stop-icon="<i class='fa-solid fa-stop'></i>">
                    <i class="fa-solid fa-arrow-up"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<style asp-name="AIChatApp" at="Head"></style>
<style asp-name="highlightjs" at="Head"></style>

<script asp-name="AIChatBootstrap" at="Foot"></script>

<div id="@($"{baseId}_Config")"
     class="d-none"
     data-ai-chat-config
     data-reset-session-on-send="true"
     data-signal-r-hub-url="@(HubRouteManager.GetPathByHub<AIChatHub>())"
     data-app-element-selector="#@chatAppHtmlId"
     data-chat-container-element-selector="#@chatContainerHtmlId"
     data-input-element-selector="#@userPromptHtmlId"
     data-send-button-element-selector="#@buttonHtmlId"
     data-placeholder-element-selector="#@placeholderHtmlId"
     data-auto-create-session="false"
     data-messages="@JsonSerializer.Serialize(Array.Empty<object>(), JOptions.CamelCase)"
     data-metrics-enabled="false"
     data-chat-mode="TextInput"
     data-is-orchestrator-available="true"></div>

<style at="Head">
    .ta-content {
        height: 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        padding-bottom: 0 !important;
    }
    .chat-user-prompt-input:focus {
        border: none;
        box-shadow: none;
    }
</style>
