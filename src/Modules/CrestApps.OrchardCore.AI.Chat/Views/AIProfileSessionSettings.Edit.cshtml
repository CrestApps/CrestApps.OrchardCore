@using CrestApps.OrchardCore.AI.Chat.ViewModels
@using OrchardCore

@model EditAIProfileSessionSettingsViewModel

<div class="@Orchard.GetWrapperClasses()">
    <label class="@Orchard.GetLabelClasses()" asp-for="SessionInactivityTimeoutInMinutes">@T["Session inactivity timeout (minutes)"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input type="number" class="form-control" asp-for="SessionInactivityTimeoutInMinutes" min="1" />
        <span class="hint">@T["Sessions inactive longer than this duration will be automatically closed. Must be at least 1 minute. Default is 30 minutes."]</span>
    </div>
</div>
