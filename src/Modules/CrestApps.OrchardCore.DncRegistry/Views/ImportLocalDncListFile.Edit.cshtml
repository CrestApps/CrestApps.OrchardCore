@model CrestApps.OrchardCore.DncRegistry.ViewModels.UploadLocalDncListViewModel

<div class="ocat-wrapper">
    <label asp-for="Name" class="ocat-label">@T["List name"]</label>
    <div class="ocat-end">
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
        <span class="hint">@T["A descriptive name for this list (e.g., \"June 2026 DNC Update\")."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <label asp-for="CountryCode" class="ocat-label">@T["Country"]</label>
    <div class="ocat-end">
        <select asp-for="CountryCode" asp-items="Model.CountryOptions" class="form-select">
            <option value="">@T["Select a country"]</option>
        </select>
        <span asp-validation-for="CountryCode" class="text-danger"></span>
        <span class="hint">@T["Select the country this phone number list applies to. Phone numbers will be associated with this country for filtering."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <label asp-for="File" class="ocat-label">@T["CSV file"]</label>
    <div class="ocat-end">
        <input asp-for="File" type="file" class="form-control" accept=".csv" />
        <span asp-validation-for="File" class="text-danger"></span>
        <span class="hint">@T["The import continues in the background after the file is uploaded."]</span>
    </div>
</div>
