@model CrestApps.OrchardCore.DncRegistry.ViewModels.UsaFtcDncRegistrySettingsViewModel

<h4 class="card-title">@T["USA FTC Do Not Call Registry"]</h4>
<p class="hint">@T["Configure the connection to the United States Federal Trade Commission (FTC) National Do Not Call Registry API at telemarketing.donotcall.gov."]</p>

<div class="ocat-wrapper" asp-validation-class-for="OrganizationId">
    <label class="ocat-label" asp-for="OrganizationId">@T["Organization ID"]</label>
    <div class="ocat-end">
        <input type="text" class="form-control" asp-for="OrganizationId" />
        <span asp-validation-for="OrganizationId" class="text-danger"></span>
        <span class="hint">@T["The organization ID registered with the FTC for DNC API access."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ApiKey">
    <label class="ocat-label" asp-for="ApiKey">@T["API key"]</label>
    <div class="ocat-end">
        <input type="password" class="form-control" asp-for="ApiKey" autocomplete="off" placeholder='@T["Enter a new API key to replace the saved key"]' />
        <span asp-validation-for="ApiKey" class="text-danger"></span>
        @if (Model.HasApiKey)
        {
            <span class="hint text-success">@T["An API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key."]</span>
        }
        else
        {
            <span class="hint">@T["The API key provided by the FTC for authenticating requests."]</span>
        }
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="BaseUrl">
    <label class="ocat-label" asp-for="BaseUrl">@T["Base URL"]</label>
    <div class="ocat-end">
        <input type="url" class="form-control" asp-for="BaseUrl" placeholder="https://telemarketing.donotcall.gov/api/" />
        <span asp-validation-for="BaseUrl" class="text-danger"></span>
        <span class="hint">@T["The base URL for the FTC DNC Registry API."]</span>
    </div>
</div>
