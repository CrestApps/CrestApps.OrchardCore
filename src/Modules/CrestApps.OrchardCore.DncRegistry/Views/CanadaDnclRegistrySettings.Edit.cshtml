@model CrestApps.OrchardCore.DncRegistry.ViewModels.CanadaDnclRegistrySettingsViewModel

<h4 class="card-title">@T["Canada LNNTE-DNCL Registry"]</h4>
<p class="hint">@T["Configure the connection to the Canadian National Do Not Call List (LNNTE-DNCL) API maintained by the CRTC."]</p>

<div class="ocat-wrapper" asp-validation-class-for="AccountNumber">
    <label class="ocat-label" asp-for="AccountNumber">@T["Account number"]</label>
    <div class="ocat-end">
        <input type="text" class="form-control" asp-for="AccountNumber" />
        <span asp-validation-for="AccountNumber" class="text-danger"></span>
        <span class="hint">@T["The organization account number registered with the CRTC for DNCL API access."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ApiKey">
    <label class="ocat-label" asp-for="ApiKey">@T["API key"]</label>
    <div class="ocat-end">
        <input type="password" class="form-control" asp-for="ApiKey" autocomplete="off" placeholder='@T["Enter a new API key to replace the saved key"]' />
        <span asp-validation-for="ApiKey" class="text-danger"></span>
        @if (Model.HasApiKey)
        {
            <span class="hint text-success">@T["An API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key."]</span>
        }
        else
        {
            <span class="hint">@T["The API key provided by the CRTC for authenticating requests to the LNNTE-DNCL API."]</span>
        }
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="BaseUrl">
    <label class="ocat-label" asp-for="BaseUrl">@T["Base URL"]</label>
    <div class="ocat-end">
        <input type="url" class="form-control" asp-for="BaseUrl" placeholder="https://www.lnnte-dncl.gc.ca/api/" />
        <span asp-validation-for="BaseUrl" class="text-danger"></span>
        <span class="hint">@T["The base URL for the LNNTE-DNCL API."]</span>
    </div>
</div>
