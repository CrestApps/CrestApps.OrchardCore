<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <Title>CrestApps OrchardCore Telephony Module</Title>
    <Description>
      $(CrestAppsDescription)

      Provides a provider-agnostic soft phone widget and a SignalR hub that routes call-control
      requests to a configured telephony provider.
    </Description>
    <PackageTags>$(PackageTags) OrchardCoreCMS Telephony SoftPhone</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OrchardCore.Module.Targets" />
    <PackageReference Include="OrchardCore.DisplayManagement" />
    <PackageReference Include="OrchardCore.Navigation.Core" />
    <PackageReference Include="OrchardCore.ResourceManagement" />
    <PackageReference Include="OrchardCore.Infrastructure.Abstractions" />
    <PackageReference Include="OrchardCore.Data.Abstractions" />
    <PackageReference Include="OrchardCore.Users.Abstractions" />
    <PackageReference Include="YesSql.Abstractions" />
    <PackageReference Include="CrestApps.Core.SignalR" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../Abstractions/CrestApps.OrchardCore.Abstractions/CrestApps.OrchardCore.Abstractions.csproj" />
    <ProjectReference Include="../../Abstractions/CrestApps.OrchardCore.Telephony.Abstractions/CrestApps.OrchardCore.Telephony.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Ensure this module directly depends on the SignalR module so that when someone installs it,
      they won't need to manually include the SignalR package. This guarantees the soft phone hub
      functions correctly and resolves the feature dependency.
    -->
    <ProjectReference Include="../CrestApps.OrchardCore.SignalR/CrestApps.OrchardCore.SignalR.csproj" PrivateAssets="none" />
  </ItemGroup>

</Project>
