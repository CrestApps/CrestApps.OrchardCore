@model EntryPointViewModel

<style asp-name="crestapps-bootstrap-select"></style>
<script asp-name="crestapps-bootstrap-select" depends-on="bootstrap" at="Foot"></script>

<div class="ocat-wrapper" asp-validation-class-for="Name">
    <label asp-for="Name" class="ocat-label ocat-label-required">@T["Name"]</label>
    <div class="ocat-end">
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Description">
    <label asp-for="Description" class="ocat-label">@T["Description"]</label>
    <div class="ocat-end">
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="DialedNumbersText">
    <label asp-for="DialedNumbersText" class="ocat-label">@T["Dialed numbers"]</label>
    <div class="ocat-end">
        <textarea asp-for="DialedNumbersText" class="form-control" rows="3" placeholder="+15551234567"></textarea>
        <span asp-validation-for="DialedNumbersText" class="text-danger"></span>
        <span class="hint">@T["One dialed number (DID) per line. Calls to these numbers route through this entry point."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="TargetQueueId">
    <label asp-for="TargetQueueId" class="ocat-label">@T["Target queue"]</label>
    <div class="ocat-end">
        <select asp-for="TargetQueueId" asp-items="Model.TargetQueueOptions" class="selectpicker show-tick" data-live-search="true" data-header="@T["Select a queue"]" data-width="100%" data-style="btn-outline-secondary" title="@T["No queue"]">
            <option value="">@T["No queue"]</option>
        </select>
        <span asp-validation-for="TargetQueueId" class="text-danger"></span>
    </div>
</div>

<div class="ocat-limited-wrapper" asp-validation-class-for="Priority">
    <label asp-for="Priority" class="ocat-label">@T["Priority"]</label>
    <div class="ocat-limited">
        <select asp-for="Priority" class="form-select">
            <option value="@InteractionPriority.Lowest">@T["Lowest"]</option>
            <option value="@InteractionPriority.Low">@T["Low"]</option>
            <option value="@InteractionPriority.Normal">@T["Normal"]</option>
            <option value="@InteractionPriority.High">@T["High"]</option>
            <option value="@InteractionPriority.Highest">@T["Highest"]</option>
        </select>
        <span asp-validation-for="Priority" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="BusinessHoursCalendarId">
    <label asp-for="BusinessHoursCalendarId" class="ocat-label">@T["Business hours calendar"]</label>
    <div class="ocat-end">
        <select asp-for="BusinessHoursCalendarId" asp-items="Model.BusinessHoursCalendarOptions" class="selectpicker show-tick" data-live-search="true" data-header="@T["Select a calendar"]" data-width="100%" data-style="btn-outline-secondary" title="@T["Always open"]">
            <option value="">@T["Always open"]</option>
        </select>
        <span asp-validation-for="BusinessHoursCalendarId" class="text-danger"></span>
        <span class="hint">@T["Gates when the entry point is open. Leave empty to accept calls around the clock."]</span>
    </div>
</div>

<div class="ocat-limited-wrapper" asp-validation-class-for="ClosedAction">
    <label asp-for="ClosedAction" class="ocat-label">@T["Closed action"]</label>
    <div class="ocat-limited">
        <select asp-for="ClosedAction" class="form-select">
            <option value="@EntryPointClosedAction.HoldInQueue">@T["Hold in queue"]</option>
            <option value="@EntryPointClosedAction.Voicemail">@T["Voicemail"]</option>
            <option value="@EntryPointClosedAction.Overflow">@T["Overflow"]</option>
            <option value="@EntryPointClosedAction.Reject">@T["Reject"]</option>
        </select>
        <span asp-validation-for="ClosedAction" class="text-danger"></span>
        <span class="hint">@T["What happens to a call that arrives while the entry point is closed."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="OverflowQueueId">
    <label asp-for="OverflowQueueId" class="ocat-label">@T["Overflow queue"]</label>
    <div class="ocat-end">
        <select asp-for="OverflowQueueId" asp-items="Model.OverflowQueueOptions" class="selectpicker show-tick" data-live-search="true" data-header="@T["Select a queue"]" data-width="100%" data-style="btn-outline-secondary" title="@T["No overflow"]">
            <option value="">@T["No overflow"]</option>
        </select>
        <span asp-validation-for="OverflowQueueId" class="text-danger"></span>
        <span class="hint">@T["Used when the closed action is Overflow."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="WelcomeMessage">
    <label asp-for="WelcomeMessage" class="ocat-label">@T["Welcome message"]</label>
    <div class="ocat-end">
        <textarea asp-for="WelcomeMessage" class="form-control" rows="2"></textarea>
        <span asp-validation-for="WelcomeMessage" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="ClosedMessage">
    <label asp-for="ClosedMessage" class="ocat-label">@T["Closed message"]</label>
    <div class="ocat-end">
        <textarea asp-for="ClosedMessage" class="form-control" rows="2"></textarea>
        <span asp-validation-for="ClosedMessage" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Enabled">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input asp-for="Enabled" class="form-check-input" />
            <label asp-for="Enabled" class="form-check-label">@T["Enabled"]</label>
        </div>
        <span class="hint dashed">@T["Disabled entry points do not receive inbound calls."]</span>
    </div>
</div>
