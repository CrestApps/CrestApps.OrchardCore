@model DialerProfileViewModel
<zone Name="Title"><h1>@T["Add Dialer Profile"]</h1></zone>
<form asp-action="Create" method="post">
    <div class="mb-3"><label asp-for="Name">@T["Name"]</label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-3"><label asp-for="CampaignId">@T["Campaign Id"]</label><input asp-for="CampaignId" class="form-control" /></div>
    <div class="mb-3"><label asp-for="QueueId">@T["Queue Id"]</label><input asp-for="QueueId" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Mode">@T["Mode"]</label><select asp-for="Mode" asp-items="Html.GetEnumSelectList<DialerMode>()" class="form-select"></select></div>
    <div class="mb-3"><label asp-for="ProviderName">@T["Provider"]</label><input asp-for="ProviderName" class="form-control" /></div>
    <div class="mb-3"><label asp-for="CallsPerAgent">@T["Calls per agent"]</label><input asp-for="CallsPerAgent" class="form-control" /></div>
    <div class="mb-3"><label asp-for="MaxAttempts">@T["Max attempts"]</label><input asp-for="MaxAttempts" class="form-control" /></div>
    <div class="mb-3"><label asp-for="CallerId">@T["Caller Id"]</label><input asp-for="CallerId" class="form-control" /></div>
    <div class="form-check mb-3"><input asp-for="Enabled" class="form-check-input" /><label asp-for="Enabled" class="form-check-label">@T["Enabled"]</label></div>
    <button type="submit" class="btn btn-primary">@T["Save"]</button>
    <a class="btn btn-secondary" asp-action="Index">@T["Cancel"]</a>
</form>
