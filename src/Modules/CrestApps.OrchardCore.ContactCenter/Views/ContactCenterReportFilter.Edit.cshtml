@model CrestApps.OrchardCore.ContactCenter.ViewModels.ContactCenterReportFilterViewModel

@if (Model.ShowWorkforceFilters)
{
    <div class="col p-1">
        <label class="form-label" asp-for="AgentId">@T["Agent"]</label>
        <select asp-for="AgentId" asp-items="Model.Agents" class="form-select">
            <option value="">@T["All agents"]</option>
        </select>
    </div>
}
else if (Model.ShowInteractionFilters)
{
    <div class="col p-1">
        <label class="form-label" asp-for="QueueId">@T["Queue"]</label>
        <select asp-for="QueueId" asp-items="Model.Queues" class="form-select">
            <option value="">@T["All queues"]</option>
        </select>
    </div>
    <div class="col p-1">
        <label class="form-label" asp-for="AgentId">@T["Agent"]</label>
        <select asp-for="AgentId" asp-items="Model.Agents" class="form-select">
            <option value="">@T["All agents"]</option>
        </select>
    </div>
    <div class="col p-1">
        <label class="form-label" asp-for="Direction">@T["Direction"]</label>
        <select asp-for="Direction" asp-items="Model.Directions" class="form-select">
            <option value="">@T["All directions"]</option>
        </select>
    </div>
}
else if (Model.ShowActivityFilters)
{
    <div class="col p-1">
        <label class="form-label" asp-for="CampaignId">@T["Campaign"]</label>
        <select asp-for="CampaignId" asp-items="Model.Campaigns" class="form-select">
            <option value="">@T["All campaigns"]</option>
        </select>
    </div>
    <div class="col p-1">
        <label class="form-label" asp-for="ActivitySource">@T["Source"]</label>
        <select asp-for="ActivitySource" asp-items="Model.ActivitySources" class="form-select">
            <option value="">@T["All sources"]</option>
        </select>
    </div>
    <div class="col p-1">
        <label class="form-label" asp-for="ActivityStatus">@T["Status"]</label>
        <select asp-for="ActivityStatus" asp-items="Model.ActivityStatuses" class="form-select">
            <option value="">@T["All statuses"]</option>
        </select>
    </div>
}

@if (!Model.ShowWorkforceFilters)
{
    <div class="col p-1">
        <label class="form-label" asp-for="Channel">@T["Channel"]</label>
        <select asp-for="Channel" asp-items="Model.Channels" class="form-select">
            <option value="">@T["All channels"]</option>
        </select>
    </div>
}
