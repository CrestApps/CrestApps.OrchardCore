@using System.Text.Json
@model SupervisorDashboardIndexViewModel

@{
    var config = new Dictionary<string, object>
    {
        ["hubUrl"] = Model.HubUrl,
        ["stateUrl"] = Model.StateUrl,
        ["strings"] = new Dictionary<string, string>
        {
            ["waiting"] = T["Waiting"].Value,
            ["available"] = T["Available agents"].Value,
            ["agents"] = T["Agents"].Value,
            ["queues"] = T["Queues"].Value,
            ["noQueues"] = T["No queues are configured."].Value,
            ["longestWait"] = T["Longest wait"].Value,
            ["slaBreaches"] = T["SLA breaches"].Value,
            ["noAgents"] = T["No agents are configured."].Value,
            ["activeInteractions"] = T["Active interactions"].Value,
        },
    };
}

<style asp-name="contact-center-workspace"></style>
<script asp-name="contact-center-supervisor-dashboard" at="Foot"></script>

<zone Name="Title"><h1>@RenderTitleSegments(T["Live dashboard"])</h1></zone>

<div class="cc-workspace cc-dashboard" data-cc-dashboard data-config="@JsonSerializer.Serialize(config, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase })">
    <div class="cc-dashboard__summary" data-cc-summary></div>

    <div class="cc-panel mb-3">
        <div class="cc-panel__header">@T["Queues"]</div>
        <div class="cc-panel__body">
            <div class="cc-tiles" data-cc-tiles></div>
        </div>
    </div>

    <div class="cc-panel">
        <div class="cc-panel__header">@T["Agents"]</div>
        <div class="cc-panel__body">
            <div class="cc-board" data-cc-board></div>
        </div>
    </div>
</div>
