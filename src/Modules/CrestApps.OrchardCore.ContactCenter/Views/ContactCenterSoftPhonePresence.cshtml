@using CrestApps.OrchardCore.ContactCenter.Core.Models
@using CrestApps.OrchardCore.ContactCenter.Models

@{
    var profile = Model.Profile as AgentProfile;
}

@if (profile is not null)
{
    <form asp-action="SetPresence" asp-controller="AgentWorkspace" asp-area="CrestApps.OrchardCore.ContactCenter" method="post" class="px-3 py-2 border-bottom">
        <div class="mb-2">
            <label for="contact-center-presence-status" class="form-label small mb-1">@T["Contact Center presence"]</label>
            <select id="contact-center-presence-status" name="status" class="form-select form-select-sm">
                <option value="@AgentPresenceStatus.Available" selected="@(profile.PresenceStatus == AgentPresenceStatus.Available)">@T["Available"]</option>
                <option value="@AgentPresenceStatus.Break" selected="@(profile.PresenceStatus == AgentPresenceStatus.Break)">@T["Break"]</option>
                <option value="@AgentPresenceStatus.WrapUp" selected="@(profile.PresenceStatus == AgentPresenceStatus.WrapUp)">@T["Wrap-up"]</option>
                <option value="@AgentPresenceStatus.Offline" selected="@(profile.PresenceStatus == AgentPresenceStatus.Offline)">@T["Offline"]</option>
            </select>
        </div>
        <div class="mb-2">
            <input name="presenceReason" value="@profile.PresenceReason" class="form-control form-control-sm" placeholder="@T["Reason"]" />
        </div>
        <button type="submit" class="btn btn-sm btn-outline-primary w-100">@T["Update presence"]</button>
    </form>
}
