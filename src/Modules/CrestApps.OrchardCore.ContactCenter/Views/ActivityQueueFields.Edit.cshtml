@model QueueViewModel

<style asp-name="crestapps-bootstrap-select"></style>
<script asp-name="crestapps-bootstrap-select" depends-on="bootstrap" at="Foot"></script>

<div class="ocat-wrapper" asp-validation-class-for="Name">
    <label asp-for="Name" class="ocat-label ocat-label-required">@T["Name"]</label>
    <div class="ocat-end">
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Description">
    <label asp-for="Description" class="ocat-label">@T["Description"]</label>
    <div class="ocat-end">
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
</div>

<div class="ocat-limited-wrapper" asp-validation-class-for="DefaultPriority">
    <label asp-for="DefaultPriority" class="ocat-label">@T["Default priority"]</label>
    <div class="ocat-limited">
        <select asp-for="DefaultPriority" class="form-select">
            <option value="@InteractionPriority.Lowest">@T["Lowest"]</option>
            <option value="@InteractionPriority.Low">@T["Low"]</option>
            <option value="@InteractionPriority.Normal">@T["Normal"]</option>
            <option value="@InteractionPriority.High">@T["High"]</option>
            <option value="@InteractionPriority.Highest">@T["Highest"]</option>
        </select>
        <span asp-validation-for="DefaultPriority" class="text-danger"></span>
    </div>
</div>

<div class="ocat-limited-wrapper" asp-validation-class-for="SlaThresholdSeconds">
    <label asp-for="SlaThresholdSeconds" class="ocat-label">@T["SLA threshold (seconds)"]</label>
    <div class="ocat-limited">
        <input asp-for="SlaThresholdSeconds" class="form-control" />
        <span asp-validation-for="SlaThresholdSeconds" class="text-danger"></span>
    </div>
</div>

<div class="ocat-limited-wrapper" asp-validation-class-for="ReservationTimeoutSeconds">
    <label asp-for="ReservationTimeoutSeconds" class="ocat-label">@T["Reservation timeout (seconds)"]</label>
    <div class="ocat-limited">
        <input asp-for="ReservationTimeoutSeconds" class="form-control" />
        <span asp-validation-for="ReservationTimeoutSeconds" class="text-danger"></span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="RequiredSkills">
    <label asp-for="RequiredSkills" class="ocat-label">@T["Required skills"]</label>
    <div class="ocat-end">
        <select asp-for="RequiredSkills" asp-items="Model.SkillOptions" class="selectpicker show-tick" multiple data-live-search="true" data-actions-box="true" data-header="@T["Select skills"]" data-width="100%" data-selected-text-format="count > 2" data-count-selected-text="{0} skills selected" data-style="btn-outline-secondary" title="@T["No required skills"]"></select>
        <span asp-validation-for="RequiredSkills" class="text-danger"></span>
        <span class="hint">@T["Agents must have every selected skill to receive work from this queue."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="InboundChannelEndpointId">
    <label asp-for="InboundChannelEndpointId" class="ocat-label">@T["Inbound channel endpoint"]</label>
    <div class="ocat-end">
        <select asp-for="InboundChannelEndpointId" asp-items="Model.InboundChannelEndpointOptions" class="selectpicker show-tick" data-live-search="true" data-header="@T["Select an endpoint"]" data-width="100%" data-style="btn-outline-secondary" title="@T["Default inbound queue"]">
            <option value="">@T["Default inbound queue"]</option>
        </select>
        <span asp-validation-for="InboundChannelEndpointId" class="text-danger"></span>
        <span class="hint">@T["Calls received on this Omnichannel endpoint route to this queue. Leave empty for a default inbound queue."]</span>
    </div>
</div>

<div class="ocat-wrapper" asp-validation-class-for="Enabled">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input asp-for="Enabled" class="form-check-input" />
            <label asp-for="Enabled" class="form-check-label">@T["Enabled"]</label>
        </div>
        <span class="hint dashed">@T["Disabled queues do not receive routing assignments."]</span>
    </div>
</div>
