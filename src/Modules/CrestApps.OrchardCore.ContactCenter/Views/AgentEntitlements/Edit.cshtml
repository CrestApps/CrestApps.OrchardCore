@model AgentEntitlementViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Edit agent entitlements"])</h1></zone>

<form method="post" class="no-multisubmit">
    @Html.ValidationSummary()

    <div class="mb-3">
        <label class="form-label">@T["User"]</label>
        <input class="form-control" value="@Model.UserName" readonly />
    </div>

    @await Html.PartialAsync("_EntitlementFields", Model)

    <div class="ocat-wrapper">
        <div class="ocat-end-offset">
            <button class="btn btn-primary" type="submit">@T["Save"]</button>
            <a class="btn btn-secondary cancel" role="button" asp-action="Index">@T["Cancel"]</a>
        </div>
    </div>
</form>
