@using CrestApps.OrchardCore.ContactCenter.ViewModels

@model QueueSummaryViewModel

<h5>@Model.Queue.Name</h5>

@if (!string.IsNullOrWhiteSpace(Model.Queue.Description))
{
    <div class="text-muted">@Model.Queue.Description</div>
}

<div class="mt-1">
    @if (!string.IsNullOrWhiteSpace(Model.QueueGroupName))
    {
        <span class="badge text-bg-secondary">@T["Group: {0}", Model.QueueGroupName]</span>
    }
    <span class="badge text-bg-secondary">@T["Priority: {0}", Model.Queue.DefaultPriority]</span>
    <span class="badge text-bg-secondary">@T["SLA: {0}s", Model.Queue.SlaThresholdSeconds]</span>
    @if (Model.Queue.RequiredSkills.Count > 0)
    {
        <span class="badge text-bg-secondary">@T["Skills: {0}", string.Join(", ", Model.Queue.RequiredSkills)]</span>
    }
    @if (!Model.Queue.Enabled)
    {
        <span class="badge text-bg-warning">@T["Disabled"]</span>
    }
</div>
