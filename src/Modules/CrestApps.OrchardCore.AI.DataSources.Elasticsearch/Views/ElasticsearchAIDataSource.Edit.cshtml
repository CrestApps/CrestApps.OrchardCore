@using CrestApps.Core.AI.Models
@using CrestApps.OrchardCore.AI.DataSources.Elasticsearch.ViewModels

@model EditElasticsearchAIDataSourceViewModel

<div data-ai-data-source-section="Elasticsearch" hidden>
    <fieldset class="ocat-wrapper">
        <legend class="ocat-label">@T["Elasticsearch Connection"]</legend>
        <div class="ocat-end">
            <div class="mb-3">
                <label asp-for="EnvironmentType" class="form-label">@T["Environment type"]</label>
                <select asp-for="EnvironmentType" class="form-select" id="elasticsearch-environment-type">
                    <option value="@ElasticsearchSourceMetadata.SelfManagedEnvironmentType">@T["Self-managed"]</option>
                    <option value="@ElasticsearchSourceMetadata.CloudHostedEnvironmentType">@T["Cloud-hosted"]</option>
                </select>
                <span asp-validation-for="EnvironmentType" class="text-danger"></span>
            </div>

            <div id="elasticsearch-url-settings">
                <div class="mb-3">
                    <label asp-for="Url" class="form-label">@T["Elasticsearch URL"]</label>
                    <input asp-for="Url" class="form-control" />
                    <span asp-validation-for="Url" class="text-danger"></span>
                    <span class="hint">@T["Required for self-managed clusters or endpoint-based hosted deployments."]</span>
                </div>
            </div>

            <div id="elasticsearch-cloud-id-settings" hidden>
                <div class="mb-3">
                    <label asp-for="CloudId" class="form-label">@T["Elastic Cloud ID"]</label>
                    <input asp-for="CloudId" class="form-control" />
                    <span asp-validation-for="CloudId" class="text-danger"></span>
                    <span class="hint">@T["Required for Elastic Cloud hosted deployments."]</span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="AuthenticationType" class="form-label">@T["Authentication type"]</label>
                <select asp-for="AuthenticationType" class="form-select" id="elasticsearch-authentication-type">
                    <option value="@ElasticsearchSourceMetadata.NoneAuthenticationType">@T["None"]</option>
                    <option value="@ElasticsearchSourceMetadata.BasicAuthenticationType">@T["Basic"]</option>
                    <option value="@ElasticsearchSourceMetadata.ApiKeyAuthenticationType">@T["API key"]</option>
                    <option value="@ElasticsearchSourceMetadata.Base64ApiKeyAuthenticationType">@T["Base64 API key"]</option>
                    <option value="@ElasticsearchSourceMetadata.KeyIdAndKeyAuthenticationType">@T["Key ID and key"]</option>
                </select>
                <span asp-validation-for="AuthenticationType" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IndexName" class="form-label">@T["Index name"]</label>
                <input asp-for="IndexName" class="form-control" />
                <span asp-validation-for="IndexName" class="text-danger"></span>
                <span class="hint">@T["The Elasticsearch index name on the remote server."]</span>
            </div>

            <div id="elasticsearch-basic-auth-settings" hidden>
                <div class="mb-3">
                    <label asp-for="Username" class="form-label">@T["Username"]</label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">@T["Password"]</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="@(Model.HasPassword ? T["Leave empty to keep the saved password"].Value : string.Empty)" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <div id="elasticsearch-api-key-settings" hidden>
                <div class="mb-3">
                    <label asp-for="ApiKey" class="form-label">@T["API key"]</label>
                    <input asp-for="ApiKey" class="form-control" type="password" placeholder="@(Model.HasApiKey ? T["Leave empty to keep the saved API key"].Value : string.Empty)" />
                    <span asp-validation-for="ApiKey" class="text-danger"></span>
                </div>
            </div>

            <div id="elasticsearch-base64-api-key-settings" hidden>
                <div class="mb-3">
                    <label asp-for="Base64ApiKey" class="form-label">@T["Base64 API key"]</label>
                    <input asp-for="Base64ApiKey" class="form-control" type="password" placeholder="@(Model.HasBase64ApiKey ? T["Leave empty to keep the saved base64 API key"].Value : string.Empty)" />
                    <span asp-validation-for="Base64ApiKey" class="text-danger"></span>
                </div>
            </div>

            <div id="elasticsearch-key-id-settings" hidden>
                <div class="mb-3">
                    <label asp-for="ApiKeyId" class="form-label">@T["API key ID"]</label>
                    <input asp-for="ApiKeyId" class="form-control" />
                    <span asp-validation-for="ApiKeyId" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-0">
                <label asp-for="CertificateFingerprint" class="form-label">@T["Certificate fingerprint"]</label>
                <input asp-for="CertificateFingerprint" class="form-control" />
                <span asp-validation-for="CertificateFingerprint" class="text-danger"></span>
                <span class="hint">@T["Optional TLS certificate fingerprint for trusted server validation."]</span>
            </div>
        </div>
    </fieldset>
</div>

<script asp-name="ai-data-source-elasticsearch-auth" at="Foot">
    document.addEventListener('DOMContentLoaded', function () {
        var environmentType = document.getElementById('elasticsearch-environment-type');
        var authenticationType = document.getElementById('elasticsearch-authentication-type');
        var urlSettings = document.getElementById('elasticsearch-url-settings');
        var cloudIdSettings = document.getElementById('elasticsearch-cloud-id-settings');
        var basicAuthSettings = document.getElementById('elasticsearch-basic-auth-settings');
        var apiKeySettings = document.getElementById('elasticsearch-api-key-settings');
        var base64ApiKeySettings = document.getElementById('elasticsearch-base64-api-key-settings');
        var keyIdSettings = document.getElementById('elasticsearch-key-id-settings');

        if (!environmentType || !authenticationType || !urlSettings || !cloudIdSettings || !basicAuthSettings || !apiKeySettings || !base64ApiKeySettings || !keyIdSettings) {
            return;
        }

        function updateVisibility() {
            var isCloudHosted = environmentType.value === '@ElasticsearchSourceMetadata.CloudHostedEnvironmentType';
            var isBasic = authenticationType.value === '@ElasticsearchSourceMetadata.BasicAuthenticationType';
            var isApiKey = authenticationType.value === '@ElasticsearchSourceMetadata.ApiKeyAuthenticationType';
            var isBase64ApiKey = authenticationType.value === '@ElasticsearchSourceMetadata.Base64ApiKeyAuthenticationType';
            var isKeyIdAndKey = authenticationType.value === '@ElasticsearchSourceMetadata.KeyIdAndKeyAuthenticationType';

            urlSettings.hidden = isCloudHosted;
            cloudIdSettings.hidden = !isCloudHosted;
            basicAuthSettings.hidden = !isBasic;
            apiKeySettings.hidden = !(isApiKey || isKeyIdAndKey);
            base64ApiKeySettings.hidden = !isBase64ApiKey;
            keyIdSettings.hidden = !isKeyIdAndKey;
        }

        environmentType.addEventListener('change', updateVisibility);
        authenticationType.addEventListener('change', updateVisibility);
        updateVisibility();
    });
</script>
