@using CrestApps.OrchardCore.AI.DataSources.Deployments

@model AIDataSourceDeploymentStepViewModel

<div class="ocat-wrapper">
    <div class="ocat-label">@T["AI Data Sources"]</div>
    <div class="ocat-end">
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IncludeAll" data-bs-toggle="collapse" role="button" data-bs-target="#data-source-list" aria-expanded="false" aria-controls="data-source-list" />
                @T["Include all data sources"]
            </label>
        </div>

        <div id="data-source-list" class="collapse@(Model.IncludeAll ? string.Empty : " show")">
            <div class="hint mb-1">@T["The AI data sources to export as part of the plan."]</div>

            <div class="mb-3">
                @for (var i = 0; i < Model.DataSources.Length; i++)
                {
                    <div class="form-check">
                        <input type="hidden" asp-for="DataSources[i].ItemId" />
                        <input asp-for="DataSources[i].IsSelected" type="checkbox" class="form-check-input">
                        <label class="form-check-label" asp-for="DataSources[i].IsSelected">@Model.DataSources[i].DisplayText</label>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
