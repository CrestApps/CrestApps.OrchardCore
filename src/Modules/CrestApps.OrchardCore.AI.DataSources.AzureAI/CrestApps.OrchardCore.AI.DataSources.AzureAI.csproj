<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Title>CrestApps OrchardCore AI Data Sources - Azure AI Search</Title>
    <Description>
      $(CrestAppsDescription)

      Azure AI Search support for AI data source document embeddings, vector search, and indexing.
    </Description>
    <PackageTags>$(PackageTags) OrchardCoreCMS AI DataSources AzureAISearch</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OrchardCore.Module.Targets" />
    <PackageReference Include="OrchardCore.AzureAI.Core" />
    <PackageReference Include="CrestApps.Core.Azure.AISearch" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../Core/CrestApps.OrchardCore.AI.Core/CrestApps.OrchardCore.AI.Core.csproj" />
  </ItemGroup>

</Project>
