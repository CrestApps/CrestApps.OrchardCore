@using CrestApps.Core.AI.Models
@using CrestApps.OrchardCore.AI.ViewModels

@model AIProfileTemplateProfileFieldsViewModel

<div class="ocat-wrapper">
    <label asp-for="ProfileType" class="ocat-label">@T["Profile type"]</label>
    <div class="ocat-end">
        <select asp-for="ProfileType" class="form-select">
            <option value="">@T["Select a type"]</option>
            @foreach (var item in Model.ProfileTypes)
            {
                <option value="@item.Value" selected="@(item.Value == Model.ProfileType?.ToString())">@item.Text</option>
            }
        </select>
        <span asp-validation-for="ProfileType" class="text-danger"></span>
        <span class="hint">@T["The type of AI profile this template creates."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-agent@(Model.ProfileType == AIProfileType.Agent ? string.Empty : " d-none")">
    <label asp-for="Description" class="ocat-label">@T["Description"]</label>
    <div class="ocat-end">
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
        <span class="hint">@T["A description of what this agent does. This is used by the AI model to determine when to invoke this agent."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-agent@(Model.ProfileType == AIProfileType.Agent ? string.Empty : " d-none")">
    <label asp-for="AgentAvailability" class="ocat-label">@T["Availability"]</label>
    <div class="ocat-end">
        <select asp-for="AgentAvailability" class="form-select">
            <option value="">@T["Not set"]</option>
            @foreach (var item in Model.AvailabilityTypes)
            {
                <option value="@item.Value" selected="@(item.Value == Model.AgentAvailability?.ToString())">@item.Text</option>
            }
        </select>
        <span asp-validation-for="AgentAvailability" class="text-danger"></span>
        <span class="hint">@T["Controls how this agent is included in AI requests. On demand agents are only included when matched by relevance scoring. Always available agents are automatically included in every request."]</span>
        <div id="templateAgentAvailabilityWarning" class="alert alert-warning mt-2@(Model.AgentAvailability == AgentAvailability.AlwaysAvailable ? string.Empty : " d-none")">
            <i class="fa-solid fa-triangle-exclamation me-1" aria-hidden="true"></i>
            @T["Always available agents are included in every AI request, which increases token usage and cost. Use this setting only for agents that must always be accessible to the AI model."]
        </div>
    </div>
</div>
