@using CrestApps.Core.AI.Models
@using CrestApps.OrchardCore.AI.ViewModels

@model EditProfileViewModel

<div class="ocat-wrapper profile-type profile-type-chat">
    <label asp-for="TitleType" class="ocat-label">@T["Title type"]</label>
    <div class="ocat-end">
        <select asp-for="TitleType" asp-items="Model.TitleTypes" class="form-select"></select>
        <span asp-validation-for="TitleType" class="text-danger"></span>
        <span class="hint">@T["Choose how the session title should be set when a new session is created."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-chat">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input asp-for="AddInitialPrompt" class="form-check-input" />
            <label asp-for="AddInitialPrompt" class="form-check-label">@T["Add initial prompt"]</label>
            <span class="hint">@T["When enabled, each new chat session starts with an assistant message from the initial prompt and the welcome message is ignored."]</span>
        </div>
    </div>
</div>

<div id="welcomeMessageGroup" class="ocat-wrapper profile-type profile-type-chat">
    <label asp-for="WelcomeMessage" class="ocat-label">@T["Welcome message"]</label>
    <div class="ocat-end">
        <input asp-for="WelcomeMessage" class="form-control" />
        <span asp-validation-for="WelcomeMessage" class="text-danger"></span>
        <span class="hint">@T["The welcome message to show on the user-interface when a new session is created."]</span>
    </div>
</div>

<div id="initialPromptGroup" class="ocat-wrapper profile-type profile-type-chat d-none">
    <label asp-for="InitialPrompt" class="ocat-label">@T["Initial prompt"]</label>
    <div class="ocat-end">
        <textarea asp-for="InitialPrompt" class="form-control" rows="4"></textarea>
        <span asp-validation-for="InitialPrompt" class="text-danger"></span>
        <span class="hint">@T["This assistant message is added as the first chat history entry when a new session is created."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-template-prompt@(Model.ProfileType == AIProfileType.TemplatePrompt ? string.Empty : " d-none")">
    <label asp-for="PromptSubject" class="ocat-label">@T["Prompt subject"]</label>
    <div class="ocat-end">
        <input asp-for="PromptSubject" class="form-control" />
        <span asp-validation-for="PromptSubject" class="text-danger"></span>
        <span class="hint">@T["When set, this title will be displayed as the response header for each message from the model."]</span>
    </div>
</div>
