@using CrestApps.OrchardCore.AI.ViewModels

@model AIProfileTemplateParametersViewModel

<fieldset>
    <legend>@T["Parameters"]</legend>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Temperature" class="form-label">@T["Temperature"]</label>
            <input asp-for="Temperature" class="form-control" type="number" step="0.01" min="0" max="1" />
            <span class="hint">@T["Controls randomness in the AI response. Values between 0 and 1."]</span>
        </div>
        <div class="col-md-6">
            <label asp-for="TopP" class="form-label">@T["Top P"]</label>
            <input asp-for="TopP" class="form-control" type="number" step="0.01" min="0" max="1" />
            <span class="hint">@T["Controls diversity of the AI response via nucleus sampling."]</span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="FrequencyPenalty" class="form-label">@T["Frequency Penalty"]</label>
            <input asp-for="FrequencyPenalty" class="form-control" type="number" step="0.01" min="0" max="1" />
            <span class="hint">@T["Penalizes new tokens based on existing frequency in the text."]</span>
        </div>
        <div class="col-md-6">
            <label asp-for="PresencePenalty" class="form-label">@T["Presence Penalty"]</label>
            <input asp-for="PresencePenalty" class="form-control" type="number" step="0.01" min="0" max="1" />
            <span class="hint">@T["Penalizes new tokens based on whether they appear in the text."]</span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="MaxOutputTokens" class="form-label">@T["Max Output Tokens"]</label>
            <input asp-for="MaxOutputTokens" class="form-control" type="number" min="4" />
            <span class="hint">@T["The maximum number of tokens for AI output."]</span>
        </div>
        <div class="col-md-6">
            <label asp-for="PastMessagesCount" class="form-label">@T["Past Messages Count"]</label>
            <input asp-for="PastMessagesCount" class="form-control" type="number" min="2" max="20" />
            <span class="hint">@T["The number of past messages to include in the context."]</span>
        </div>
    </div>
</fieldset>
