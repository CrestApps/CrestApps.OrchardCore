@using CrestApps.OrchardCore.AI.ViewModels
@using OrchardCore

@model EditProfileDeploymentViewModel

@if (Model.ShowMissingDefaultChatDeploymentWarning)
{
    <div class="@Orchard.GetWrapperClasses("orchestrator-dependent orchestrator-dependent-default")">
        <div class="@Orchard.GetEndClasses(true)">
            <div class="alert alert-warning mb-0" role="alert">
                @T["Default chat deployment is not configured in Settings > Artificial Intelligence > Default Deployments. Configure it there so the Default option resolves to the intended chat deployment."]
            </div>
        </div>
    </div>
}

<div class="@Orchard.GetWrapperClasses("orchestrator-dependent orchestrator-dependent-default")">
    <label asp-for="ChatDeploymentName" class="@Orchard.GetLabelClasses()">@T["Chat deployment"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select asp-for="ChatDeploymentName" asp-items="Model.ChatDeployments" class="form-select">
            <option value="">@T["Default"]</option>
        </select>
        <span asp-validation-for="ChatDeploymentName" class="text-danger"></span>
        <span class="hint">@T["Select the deployment to use for chat completions."]</span>
    </div>
</div>

@if (Model.ShowMissingDefaultUtilityDeploymentWarning)
{
    <div class="@Orchard.GetWrapperClasses("orchestrator-dependent orchestrator-dependent-default")">
        <div class="@Orchard.GetEndClasses(true)">
            <div class="alert alert-warning mb-0" role="alert">
                @T["Default utility deployment is not configured in Settings > Artificial Intelligence > Default Deployments. Configure it there so the Default option resolves to the intended utility deployment."]
            </div>
        </div>
    </div>
}

<div class="@Orchard.GetWrapperClasses("orchestrator-dependent orchestrator-dependent-default")">
    <label asp-for="UtilityDeploymentName" class="@Orchard.GetLabelClasses()">@T["Utility deployment"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select asp-for="UtilityDeploymentName" asp-items="Model.UtilityDeployments" class="form-select">
            <option value="">@T["Default"]</option>
        </select>
        <span asp-validation-for="UtilityDeploymentName" class="text-danger"></span>
        <span class="hint">@T["Select a lightweight deployment for auxiliary tasks. Falls back to the global default if not set."]</span>
    </div>
</div>
