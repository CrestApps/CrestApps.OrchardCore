@using CrestApps.OrchardCore.AI.Deployments.ViewModels
@using OrchardCore

@model AIProfileTemplateDeploymentStepViewModel

<div class="@Orchard.GetWrapperClasses()">
    <div class="@Orchard.GetLabelClasses()">@T["AI Profile Templates"]</div>
    <div class="@Orchard.GetEndClasses()">
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IncludeAll" data-bs-toggle="collapse" role="button" data-bs-target="#template-names-list" aria-expanded="false" aria-controls="template-names-list" />
                @T["Include all AI profile templates"]
            </label>
        </div>

        <div id="template-names-list" class="collapse@(Model.IncludeAll ? string.Empty : " show")">
            <div class="hint mb-1">@T["The AI profile templates to export as part of the plan."]</div>

            <ul class="list-group mb-3">
                @foreach (var templateName in Model.AllTemplateNames)
                {
                    var isChecked = Model.TemplateNames?.Contains(templateName);

                    <li class="list-group-item">
                        <div class="form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" name="@Html.NameFor(m => m.TemplateNames)" value="@templateName" checked="@isChecked">
                                @templateName
                            </label>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
