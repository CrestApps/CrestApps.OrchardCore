@using CrestApps.Core.AI.Models
@using CrestApps.OrchardCore.AI.Core
@using OrchardCore.DisplayManagement.Views

@model ShapeViewModel<AIDeployment>

<span class="badge ta-badge bg-info-subtle font-weight-normal" data-bs-toggle="tooltip" title="@T["Type"]">
    <i class="text-secondary" aria-hidden="true"></i>@Model.Value.Type
</span>

<span class="badge ta-badge bg-warning-subtle font-weight-normal" data-bs-toggle="tooltip" title="@T["Client name"]">
    <i class="text-secondary" aria-hidden="true"></i>@Model.Value.ClientName
</span>

@if (!string.IsNullOrEmpty(Model.Value.ConnectionName))
{
    <span class="badge ta-badge bg-primary-subtle font-weight-normal" data-bs-toggle="tooltip" title="@T["Connection name"]">
        <i class="text-secondary" aria-hidden="true"></i>@Model.Value.GetConnectionDisplayName()
    </span>
}
else
{
    <span class="badge ta-badge bg-secondary-subtle font-weight-normal" data-bs-toggle="tooltip" title="@T["Contained connection"]">
        <i class="text-secondary" aria-hidden="true"></i>@T["Contained connection"]
    </span>
}
