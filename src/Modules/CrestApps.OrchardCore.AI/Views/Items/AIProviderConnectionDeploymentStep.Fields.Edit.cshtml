@using CrestApps.OrchardCore.AI.Deployments.ViewModels

@model AIProviderConnectionDeploymentStepViewModel

<div class="ocat-wrapper">
    <div class="ocat-label">@T["AI Provider Connections"]</div>
    <div class="ocat-end">
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="IncludeAll" data-bs-toggle="collapse" role="button" data-bs-target="#instances-list" aria-expanded="false" aria-controls="instances-list" />
                @T["Include all connections"]
            </label>
        </div>

        <div id="instances-list" class="collapse@(Model.IncludeAll ? string.Empty : " show")">
            <div class="hint mb-1">@T["The connections to export as part of the plan."]</div>

            <div class="mb-3">
                @for (var i = 0; i < Model.Connections.Length; i++)
                {
                    <div class="form-check">
                        <input type="hidden" asp-for="Connections[i].ItemId" />
                        <input asp-for="Connections[i].IsSelected" type="checkbox" class="form-check-input">
                        <label class="form-check-label" asp-for="Connections[i].IsSelected">@Model.Connections[i].DisplayText</label>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
