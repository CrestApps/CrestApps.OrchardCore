@using CrestApps.OrchardCore.AI.Workflows.ViewModels
@using OrchardCore

@model AIChatSessionClosedEventViewModel

<div class="@Orchard.GetWrapperClasses()">
    <label class="@Orchard.GetLabelClasses()" asp-for="ProfileId">@T["Profile"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select class="form-select" asp-for="ProfileId" asp-items="Model.Profiles">
            <option value="">@T["Any profile"]</option>
        </select>
        <span class="hint">@T["Optionally filter this event to a specific AI chat profile."]</span>
    </div>
</div>
