@using CrestApps.OrchardCore.AI.ViewModels

@model AIProfileTemplateSelectionViewModel

@if (Model.Templates.Count > 0)
{
    <div class="mb-3">
        <label asp-for="TemplateId" class="form-label">@T["Apply Template"]</label>
        <div class="input-group">
            <select asp-for="TemplateId" class="form-control" id="templateSelector">
                <option value="">@T["-- Select a template --"]</option>
                @{
                    string lastCategory = null;
                }
                @foreach (var template in Model.Templates)
                {
                    if (!string.IsNullOrEmpty(template.Category) && template.Category != lastCategory)
                    {
                        if (lastCategory != null)
                        {
                            @:</optgroup>
                        }
                        lastCategory = template.Category;
                        @:<optgroup label="@template.Category">
                    }

                    <option value="@template.Id">@template.DisplayText</option>
                }
                @if (lastCategory != null)
                {
                    @:</optgroup>
                }
            </select>
            <button type="button" class="btn btn-outline-secondary" id="applyTemplateBtn">
                <i class="fa-solid fa-paste" aria-hidden="true"></i> @T["Apply"]
            </button>
        </div>
        <span class="hint">@T["Select a profile template to pre-fill the form fields."]</span>
    </div>

    <script asp-name="jQuery" at="Foot"></script>
    <script at="Foot" depends-on="jQuery">
        $(function () {
            $('#applyTemplateBtn').on('click', function () {
                var templateId = $('#templateSelector').val();
                if (templateId) {
                    var currentUrl = new URL(window.location.href);
                    currentUrl.searchParams.set('templateId', templateId);
                    window.location.href = currentUrl.toString();
                }
            });
        });
    </script>
}
