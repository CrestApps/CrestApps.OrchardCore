@using CrestApps.Core.AI.Models
@using CrestApps.OrchardCore.AI.ViewModels

@model AIProfileTemplateProfileFieldsViewModel

<div class="ocat-wrapper">
    <label asp-for="ProfileType" class="ocat-label">@T["Profile type"]</label>
    <div class="ocat-end">
        <select asp-for="ProfileType" class="form-select">
            <option value="">@T["Select a type"]</option>
            @foreach (var item in Model.ProfileTypes)
            {
                <option value="@item.Value" selected="@(item.Value == Model.ProfileType?.ToString())">@item.Text</option>
            }
        </select>
        <span asp-validation-for="ProfileType" class="text-danger"></span>
        <span class="hint">@T["The type of AI profile this template creates."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-agent@(Model.ProfileType == AIProfileType.Agent ? string.Empty : " d-none")">
    <label asp-for="Description" class="ocat-label">@T["Description"]</label>
    <div class="ocat-end">
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
        <span class="hint">@T["A description of what this agent does. This is used by the AI model to determine when to invoke this agent."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-agent@(Model.ProfileType == AIProfileType.Agent ? string.Empty : " d-none")">
    <label asp-for="AgentAvailability" class="ocat-label">@T["Availability"]</label>
    <div class="ocat-end">
        <select asp-for="AgentAvailability" class="form-select">
            <option value="">@T["Not set"]</option>
            @foreach (var item in Model.AvailabilityTypes)
            {
                <option value="@item.Value" selected="@(item.Value == Model.AgentAvailability?.ToString())">@item.Text</option>
            }
        </select>
        <span asp-validation-for="AgentAvailability" class="text-danger"></span>
        <span class="hint">@T["Controls how this agent is included in AI requests. On demand agents are only included when matched by relevance scoring. Always available agents are automatically included in every request."]</span>
        <div id="templateAgentAvailabilityWarning" class="alert alert-warning mt-2@(Model.AgentAvailability == AgentAvailability.AlwaysAvailable ? string.Empty : " d-none")">
            <i class="fa-solid fa-triangle-exclamation me-1" aria-hidden="true"></i>
            @T["Always available agents are included in every AI request, which increases token usage and cost. Use this setting only for agents that must always be accessible to the AI model."]
        </div>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-template-prompt@(Model.ProfileType == AIProfileType.TemplatePrompt ? string.Empty : " d-none")">
    <label asp-for="PromptTemplate" class="ocat-label">@T["Prompt template"]</label>
    <div class="ocat-end">
        <textarea asp-for="PromptTemplate" class="form-control content-preview-text" rows="5"></textarea>
        <span class="hint">@T["When using the session tool, the prompt is dynamically generated based on a prompt template. You can structure the prompt using Liquid syntax and incorporate the <code>{0}</code> and <code>{1}</code> variables.", "session", "profile"]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-chat">
    <label asp-for="TitleType" class="ocat-label">@T["Title type"]</label>
    <div class="ocat-end">
        <select asp-for="TitleType" class="form-select">
            <option value="">@T["Select a session title type"]</option>
            @foreach (var item in Model.TitleTypes)
            {
                <option value="@item.Value" selected="@(item.Value == Model.TitleType?.ToString())">@item.Text</option>
            }
        </select>
        <span asp-validation-for="TitleType" class="text-danger"></span>
        <span class="hint">@T["Choose how the session title should be set when a new session is created."]</span>
    </div>
</div>

<div class="ocat-wrapper profile-type profile-type-chat">
    <label asp-for="WelcomeMessage" class="ocat-label">@T["Welcome message"]</label>
    <div class="ocat-end">
        <input asp-for="WelcomeMessage" class="form-control" />
        <span asp-validation-for="WelcomeMessage" class="text-danger"></span>
        <span class="hint">@T["The welcome message to show on the user-interface when a new session is created."]</span>
    </div>
</div>

<div class="ocat-wrapper">
    <label asp-for="PromptSubject" class="ocat-label">@T["Prompt subject"]</label>
    <div class="ocat-end">
        <input asp-for="PromptSubject" class="form-control" />
        <span asp-validation-for="PromptSubject" class="text-danger"></span>
        <span class="hint">@T["When set, this title will be displayed as the response header for each message from the model."]</span>
    </div>
</div>

<style asp-name="codemirror"></style>
<script asp-name="codemirror" at="Foot"></script>
<script asp-name="codemirror-mode-javascript" at="Foot"></script>
<script asp-name="codemirror-addon-display-autorefresh" at="Foot"></script>
<script asp-name="codemirror-addon-mode-simple" at="Foot"></script>
<script asp-name="codemirror-addon-mode-multiplex" at="Foot"></script>
<script asp-name="codemirror-mode-xml" at="Foot"></script>
<script asp-src="~/OrchardCore.Liquid/codemirror/liquid.js" at="Foot"></script>
<script at="Foot">
    document.addEventListener('DOMContentLoaded', function () {
        const convertToKebabCase = (str) => {
            return str.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
        }

        const initializeLiquidEditor = (textArea) => {
            if (!textArea) {
                return;
            }

            var editor = CodeMirror.fromTextArea(textArea, {
                autoRefresh: true,
                lineNumbers: true,
                styleActiveLine: true,
                matchBrackets: true,
                mode: { name: "liquid" },
            });

            editor.on('change', function (cmEditor) {
                cmEditor.save();
                document.dispatchEvent(new Event('contentpreview:render'));
            });
        }

        const profileType = document.getElementById('@Html.IdFor(x => x.ProfileType)');
        const templateAgentAvailability = document.getElementById('@Html.IdFor(x => x.AgentAvailability)');
        const templateAgentAvailabilityWarning = document.getElementById('templateAgentAvailabilityWarning');

        profileType.addEventListener('change', function (e) {
            let value = e.target.value;
            let className = 'profile-type-' + convertToKebabCase(value);
            let elements = document.querySelectorAll('.profile-type');

            for (let i = 0; i < elements.length; i++) {
                var element = elements[i];

                if (element.classList.contains(className)) {
                    element.classList.remove('d-none');
                } else {
                    element.classList.add('d-none');
                }
            }
        });

        if (templateAgentAvailability && templateAgentAvailabilityWarning) {
            templateAgentAvailability.addEventListener('change', function () {
                templateAgentAvailabilityWarning.classList.toggle('d-none', this.value !== 'AlwaysAvailable');
            });
        }

        profileType.dispatchEvent(new Event('change'));
        initializeLiquidEditor(document.getElementById('@Html.IdFor(x => x.PromptTemplate)'));
    });
</script>
