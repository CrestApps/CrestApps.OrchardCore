@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels

@model OmnichannelActivityBatchAIProfileViewModel

<div class="card mb-3">
    <div class="card-header">
        @T["AI settings"]
    </div>
    <div class="card-body">
        <div class="ocat-wrapper">
            <label asp-for="AIProfileId" class="ocat-label">@T["AI profile"]</label>
            <div class="ocat-end">
                <select asp-for="AIProfileId" asp-items="Model.AIProfiles" class="form-select">
                    <option value="">@T["Use subject flow profile"]</option>
                </select>
                <span asp-validation-for="AIProfileId" class="text-danger"></span>
                <span class="hint">@T["Only chat profiles with Add initial prompt enabled are shown. The selected profile is stored on each loaded activity and starts automated conversations."]</span>
            </div>
        </div>
    </div>
</div>
