@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels
@using Microsoft.AspNetCore.Mvc.Localization

@model SubjectFlowsIndexViewModel

<zone Name="Title"><h1>@RenderTitleSegments(T["Subject Flows"])</h1></zone>

@if (Model.Subjects.Count == 0)
{
    <div class="alert alert-info" role="alert">
        <p class="mb-2">@T["There are no subject content types configured yet."]</p>
        <p class="mb-0">
            @T["To get started, create a content type and attach the <code>{0}</code> part.", "OmnichannelSubjectPart"]
            <a href="@Url.Action("Create", "Admin", new { area = "OrchardCore.ContentTypes" })">@T["Create a new content type"]</a>
        </p>
    </div>
}
else
{
    <form asp-action="Index" method="post" class="no-multisubmit">
        <div class="card text-bg-theme mb-3 position-sticky action-bar">
            <div class="card-body">
                <div class="row gx-1">
                    <div class="col">
                        <div class="has-search">
                            <i class="fa-solid fa-search form-control-feedback" aria-hidden="true"></i>
                            <input id="search-box" class="form-control" placeholder="@T["Search"]" type="search" autofocus autocomplete="off" />
                        </div>
                    </div>
                    <div class="col-auto">
                        <a class="btn btn-secondary create" role="button" href="@Url.Action("Create", "Admin", new { area = "OrchardCore.ContentTypes" })">@T["Add Subject"]</a>
                    </div>
                </div>
            </div>
        </div>

        <ul class="list-group" id="subject-flows-list">
            <li class="list-group-item text-bg-theme ignore-elements">
                <div class="row gx-3">
                    <div class="col">
                        <span class="text-muted">
                            @T.Plural(Model.Subjects.Count, "1 subject", "{0} subjects")
                        </span>
                    </div>
                </div>
            </li>
            @foreach (var subject in Model.Subjects)
            {
                <li class="list-group-item item" data-filter-value="@subject.DisplayName?.ToLowerInvariant() @subject.ContentTypeName?.ToLowerInvariant()">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <a asp-route-action="Configure"
                               asp-route-controller="SubjectFlows"
                               asp-route-subjectContentType="@subject.ContentTypeName"
                               class="fw-semibold text-break">@subject.DisplayName</a>
                            <span class="text-muted ms-1">(@subject.ContentTypeName)</span>
                            @if (subject.IsConfigured)
                            {
                                <span class="badge text-bg-success ms-2">@T["Configured"]</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning ms-2">@T["Not configured"]</span>
                            }
                            @if (!subject.HasActions)
                            {
                                <span class="badge text-bg-danger ms-2">@T["Missing flow"]</span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <a class="btn btn-sm btn-primary"
                               asp-route-action="Configure"
                               asp-route-controller="SubjectFlows"
                               asp-route-subjectContentType="@subject.ContentTypeName">@T["Configure"]</a>
                            <a class="btn btn-sm btn-secondary"
                               asp-route-action="ManageActions"
                               asp-route-controller="SubjectFlows"
                               asp-route-subjectContentType="@subject.ContentTypeName">@T["Manage Flow"]</a>
                        </div>
                    </div>
                </li>
            }
        </ul>

        <div id="list-alert" class="alert alert-info my-3 d-none text-center" role="alert">
            @T["Your search returned no results."]
        </div>
    </form>

    <script at="Foot">
        document.addEventListener('DOMContentLoaded', function () {
            const searchBox = document.getElementById('search-box');
            const list = document.getElementById('subject-flows-list');
            const alert = document.getElementById('list-alert');

            if (searchBox && list) {
                searchBox.addEventListener('input', function () {
                    const filter = this.value.toLowerCase();
                    const items = list.querySelectorAll('.item');
                    let visibleCount = 0;

                    items.forEach(function (item) {
                        const value = item.getAttribute('data-filter-value') || '';
                        if (value.includes(filter)) {
                            item.style.display = '';
                            visibleCount++;
                        } else {
                            item.style.display = 'none';
                        }
                    });

                    if (alert) {
                        alert.classList.toggle('d-none', visibleCount > 0 || !filter);
                    }
                });
            }
        });
    </script>
}
