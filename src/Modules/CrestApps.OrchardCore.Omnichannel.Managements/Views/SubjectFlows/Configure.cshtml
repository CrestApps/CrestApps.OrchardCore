@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels
@using OrchardCore.DisplayManagement

@model SubjectFlowConfigureViewModel

<zone Name="Title"><h1>@T["Configure Subject Flow: {0}", Model.SubjectDisplayName]</h1></zone>

<form asp-action="Configure" asp-route-subjectContentType="@Model.SubjectContentType" method="post">
    @await DisplayAsync(Model.Editor)

    <div class="mb-3 mt-3">
        <button class="btn btn-primary" type="submit">@T["Save"]</button>
        <a class="btn btn-secondary" asp-action="Index">@T["Cancel"]</a>
    </div>
</form>

