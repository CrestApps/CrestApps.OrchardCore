@using System.Text.Json
@using CrestApps.OrchardCore.Omnichannel.Core.Models
@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels
@using OrchardCore

@model OmnichannelActivityViewModel

<dl class="mb-3">
    <dt>@T["Interaction type"]</dt>
    <dd>@Model.InteractionType</dd>

    <dt>@T["Channel"]</dt>
    <dd>@Model.Channel</dd>

    <dt>@T["Campaign"]</dt>
    <dd>@Model.CampaignTitle</dd>

    <dt>@T["Urgency level"]</dt>
    <dd>
        @{
            var value = Model.UrgencyLevel switch
            {
                ActivityUrgencyLevel.VeryLow => T["Very low"],
                ActivityUrgencyLevel.Low => T["Low"],
                ActivityUrgencyLevel.Medium => T["Medium"],
                ActivityUrgencyLevel.High => T["High"],
                ActivityUrgencyLevel.VeryHigh => T["Very high"],
                _ => T["Normal"],
            };

            @value
        }
    </dd>

    <dt>@T["Assigned to"]</dt>
    <dd>@Model.AssignedToName</dd>

    <dt>@T["Scheduled at"]</dt>
    <dd>@Model.ScheduledLocal.ToString("g")</dd>

    @if (Model.CompletedLocal.HasValue)
    {
        <dt>@T["Completed by"]</dt>
        <dd>@Model.CompletedByName</dd>

        <dt>@T["Completed at"]</dt>
        <dd>@Model.CompletedLocal.Value.ToString("g")</dd>
    }

    <dt>@T["Instructions"]</dt>
    <dd>@Model.Instructions</dd>

</dl>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Notes" class="@Orchard.GetLabelClasses()">@T["Notes"]</label>
    <div class="@Orchard.GetEndClasses()">
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
</div>

<div class="activity-wrapper">
    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="DispositionId" class="@Orchard.GetLabelClasses()">@T["Disposition"]</label>
        <div class="@Orchard.GetEndClasses()">
            <select asp-for="DispositionId" class="form-select">
                <option value="">@T["Select a disposition"]</option>
                @foreach (var disposition in Model.Dispositions)
                {
                    <option value="@disposition.ItemId">@disposition.DisplayText</option>
                }
            </select>
            <span asp-validation-for="DispositionId" class="text-danger"></span>
        </div>
    </div>

    <div id="campaign-actions-preview" class="d-none mb-3">
        <h5 class="text-uppercase">@T["Workflow Results"]</h5>
        <div id="actions-list"></div>
    </div>
</div>

<style asp-name="flatpickr"></style>
<script asp-name="flatpickr" at="Foot"></script>
<script asp-name="flatpickr-culture" at="Foot"></script>

<script at="Foot" depends-on="flatpickr,flatpickr-culture">
    document.addEventListener("DOMContentLoaded", function () {
        var datePattern = '@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern';
        var timePattern = '@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern';
        var patterns = flatpickrCulture.createFlatpickrDateTimePattern(datePattern, timePattern);

        const dispositionMenu = document.getElementById("@Html.IdFor(x => x.DispositionId)");
        const previewContainer = document.getElementById("campaign-actions-preview");
        const actionsList = document.getElementById("actions-list");
        const campaignId = '@Model.CampaignId';
        const currentSubjectTitle = @Html.Raw(JsonSerializer.Serialize(Model.Subject));
        const currentSubjectContentType = @Html.Raw(JsonSerializer.Serialize(Model.SubjectContentType));
        const currentAttempts = @Model.Attempts;

        function initFlatpickr(input) {
            flatpickr(input, {
                enableTime: true,
                time_24hr: patterns.time24hr,
                dateFormat: patterns.dateTimePattern,
                allowInput: true,
            });
        }

        async function loadDispositionActions() {
            const dispositionId = dispositionMenu.value;

            if (!dispositionId) {
                previewContainer.classList.add("d-none");
                actionsList.innerHTML = "";
                return;
            }

            try {
                const response = await fetch('@Url.Content("~/api/omnichannel/disposition-actions")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        campaignId: campaignId,
                        dispositionId: dispositionId,
                        currentSubjectTitle: currentSubjectTitle,
                        currentSubjectContentType: currentSubjectContentType,
                        currentAttempts: currentAttempts
                    })
                });

                if (!response.ok) {
                    previewContainer.classList.add("d-none");
                    return;
                }

                const actions = await response.json();

                if (!actions || actions.length === 0) {
                    previewContainer.classList.add("d-none");
                    actionsList.innerHTML = "";
                    return;
                }

                actionsList.innerHTML = "";

                actions.forEach(function (action) {
                    const card = document.createElement("div");
                    card.className = "card mb-2";

                    let cardBody = '<div class="card-body"><strong>' + action.previewTitle + '</strong>';

                    if (action.requiresScheduleDate) {
                        const inputId = 'schedule-' + action.actionId;
                        const inputName = 'ActionScheduleDates[' + action.actionId + ']';
                        const defaultDate = action.defaultScheduleDate
                            ? new Date(action.defaultScheduleDate).toLocaleString()
                            : '';

                        cardBody += '<div class="mt-2">';
                        cardBody += '<label for="' + inputId + '" class="form-label">@T["Schedule date"]</label>';
                        cardBody += '<input type="text" id="' + inputId + '" name="' + inputName + '" value="' + defaultDate + '" class="form-control schedule-date-input" placeholder="@T["Schedule date"]" />';
                        cardBody += '</div>';
                    }

                    cardBody += '</div>';
                    card.innerHTML = cardBody;
                    actionsList.appendChild(card);

                    if (action.requiresScheduleDate) {
                        const dateInput = card.querySelector('.schedule-date-input');
                        if (dateInput) {
                            initFlatpickr(dateInput);
                        }
                    }
                });

                previewContainer.classList.remove("d-none");
            } catch (e) {
                previewContainer.classList.add("d-none");
            }
        }

        dispositionMenu.addEventListener("change", loadDispositionActions);

        // Load on page load if a disposition is already selected.
        loadDispositionActions();
    });
</script>
