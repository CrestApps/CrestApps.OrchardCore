@using System.Text.Json
@using CrestApps.OrchardCore.Omnichannel.Core.Models
@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels

@model BulkActivityActionsViewModel

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">@T["Bulk actions"]</h5>
    </div>
    <div class="card-body">
        <div class="row gx-3 gy-3 align-items-end">
            <div class="col-lg-5">
                <label class="form-label">@T["Action scope"]</label>
                <div class="form-check">
                    <input type="hidden" name="ApplyToAllMatching" value="false" />
                    <input type="checkbox" class="form-check-input" id="apply-to-all-matching" name="ApplyToAllMatching" value="true">
                    <label class="form-check-label" for="apply-to-all-matching">
                        @T["Apply to all {0} matching activities", Model.TotalCount]
                    </label>
                </div>
                <div class="form-text">
                    @T["Leave this unchecked to apply the action only to the activities selected below."]
                </div>
            </div>

            <div class="col-lg-4">
                <label class="form-label">@T["Choose action"]</label>
                <div class="dropdown">
                    <button class="btn btn-sm btn-warning dropdown-toggle w-100 text-start" type="button" id="bulk-action-menu-button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        <span id="bulk-action-title">@T["Select an action"]</span>
                    </button>
                    <ul class="dropdown-menu w-100" aria-labelledby="bulk-action-menu-button">
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.Assign)" data-title="@T["Assign activities"]">@T["Assign"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.Reschedule)" data-title="@T["Reschedule activities"]">@T["Reschedule"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.Purge)" data-title="@T["Purge activities"]">@T["Purge"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.SetInstructions)" data-title="@T["Set instructions"]">@T["Set Instructions"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.SetUrgencyLevel)" data-title="@T["Set urgency level"]">@T["Set Urgency Level"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.ChangeSubject)" data-title="@T["Change subject"]">@T["Change Subject"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.ClearAssignment)" data-title="@T["Clear assignment"]">@T["Clear Assignment"]</a></li>
                        <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.ChangeSource)" data-title="@T["Change activity source"]">@T["Change Source"]</a></li>
                        @if (Model.DialerProfileOptions.Count() > 1)
                        {
                            <li><a class="dropdown-item bulk-action-item" href="javascript:void(0)" data-action="@nameof(BulkActivityAction.ChangeDialerProfile)" data-title="@T["Change dialer profile"]">@T["Change Dialer Profile"]</a></li>
                        }
                    </ul>
                </div>
            </div>

        </div>

        <div id="bulk-action-params" class="mt-3 d-none">
            @* Assign Parameters *@
            <div id="params-Assign" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["Assign to user(s)"]</label>
                    <p class="text-muted small">@T["When multiple users are selected, activities will be evenly distributed among them."]</p>
                    @await Component.InvokeAsync("ItemSelector", new
                    {
                        id = "bulk-assign-user-selector",
                        inputName = "AssignToUserIds",
                        endpoint = Model.UserSearchEndpoint,
                        initialItemsJson = "[]",
                        multiple = true,
                        enableSearch = true,
                        enableSelectAll = false,
                        enableDeselectAll = true,
                        buttonText = T["Browse users"].Value,
                        searchPlaceholder = T["Search users"].Value,
                        emptyResultsText = T["No users found."].Value,
                        noSelectionText = T["No users selected."].Value,
                        loadingText = T["Loading users..."].Value,
                        loadErrorText = T["Unable to load users."].Value,
                        resultsTextFormat = T["Found {0} user(s)."].Value,
                        selectedItemsLabel = T["Selected users"].Value,
                        availableItemsLabel = T["Available users"].Value,
                        selectAllText = T["Select all"].Value,
                        deselectAllText = T["Deselect all"].Value,
                        searchButtonText = T["Search"].Value,
                    })
                </div>
            </div>

            @* Reschedule Parameters *@
            <div id="params-Reschedule" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["New scheduled date"]</label>
                    <input type="text" id="new-scheduled-date" name="NewScheduledDate" class="form-control" placeholder="@T["Select a date..."]" />
                </div>
            </div>

            @* Set Instructions Parameters *@
            <div id="params-SetInstructions" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["Instructions"]</label>
                    <textarea name="Instructions" class="form-control" rows="4" placeholder="@T["Enter instructions for the agent to read before completing the task..."]"></textarea>
                </div>
            </div>

            @* Set Urgency Level Parameters *@
            <div id="params-SetUrgencyLevel" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["Urgency level"]</label>
                    <select name="NewUrgencyLevel" class="form-select">
                        @foreach (var level in Model.UrgencyLevels)
                        {
                            <option value="@level.Value">@level.Text</option>
                        }
                    </select>
                </div>
            </div>

            @* Change Subject Parameters *@
            <div id="params-ChangeSubject" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["New subject type"]</label>
                    <select name="NewSubjectContentType" class="form-select">
                        @foreach (var subjectType in Model.SubjectContentTypes)
                        {
                            <option value="@subjectType.Value">@subjectType.Text</option>
                        }
                    </select>
                </div>
            </div>

            @* Clear Assignment Parameters *@
            <div id="params-ClearAssignment" class="bulk-action-param d-none">
                <div class="alert alert-warning mb-0">
                    @T["This removes the current assignee and any reservation state so the selected activities can be routed or dialed again."]
                </div>
            </div>

            @* Change Source Parameters *@
            <div id="params-ChangeSource" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["New source"]</label>
                    <select name="NewSource" class="form-select">
                        @foreach (var source in Model.SourceOptions)
                        {
                            <option value="@source.Value">@source.Text</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">@T["Interaction type"]</label>
                    <select name="NewInteractionType" class="form-select">
                        @foreach (var interactionType in Model.InteractionTypeOptions)
                        {
                            <option value="@interactionType.Value">@interactionType.Text</option>
                        }
                    </select>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="clear-assignment-for-source" name="ClearCurrentAssignment" value="true" checked>
                    <label class="form-check-label" for="clear-assignment-for-source">
                        @T["Clear assignment and reservation state"]
                    </label>
                </div>
            </div>

            @* Change Dialer Profile Parameters *@
            <div id="params-ChangeDialerProfile" class="bulk-action-param d-none">
                <div class="mb-3">
                    <label class="form-label">@T["Dialer profile"]</label>
                    <select name="NewDialerProfileId" class="form-select">
                        @foreach (var profile in Model.DialerProfileOptions)
                        {
                            <option value="@profile.Value">@profile.Text</option>
                        }
                    </select>
                    <div class="form-text">
                        @T["Applying a dialer profile updates the activity campaign and dialer source to match that profile."]
                    </div>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="clear-assignment-for-profile" name="ClearCurrentAssignment" value="true" checked>
                    <label class="form-check-label" for="clear-assignment-for-profile">
                        @T["Clear assignment and reservation state"]
                    </label>
                </div>
            </div>

            <div class="text-end">
                <button type="submit" name="submit.BulkAction" value="Execute" class="btn btn-warning" id="execute-bulk-action">
                    <i class="fa-solid fa-bolt"></i> @T["Execute Action"]
                </button>
            </div>
        </div>
    </div>
</div>
