@using System.Globalization
@using System.Text.Json
@using CrestApps.OrchardCore.Omnichannel.Core
@using CrestApps.OrchardCore.Omnichannel.Core.Models
@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels

@model OmnichannelActivityBatchViewModel

@{
    var contactCreatedFromId = Html.IdFor(m => m.LeadCreatedFrom);
    var contactCreatedToId = Html.IdFor(m => m.LeadCreatedTo);
    var datePattern = CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern;
    var timePattern = CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern;
    var scheduleAtValue = Model.ScheduleAt?.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
    var contactCreatedFromValue = Model.LeadCreatedFrom?.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
    var contactCreatedToValue = Model.LeadCreatedTo?.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
}

<style asp-name="flatpickr"></style>
<script asp-name="flatpickr" at="Foot"></script>
<script asp-name="flatpickr-culture" at="Foot"></script>
<script asp-name="bootstrap-select" depends-on="bootstrap" at="Foot"></script>

@if (Model.Status != OmnichannelActivityBatchStatus.New)
{
    <div class="alert alert-info" role="alert">
        @T["You cannot change the settings of an activity batch once it has started loading. If you need to change any of these settings, please create a new activity batch."]
    </div>
}

<div class="card mb-3">
    <div class="card-header">
        @T["Batch settings"]
    </div>
    <div class="card-body">
        <div class="ocat-wrapper">
            <label asp-for="DisplayText" class="ocat-label">@T["Title"]</label>
            <div class="ocat-end">
                <input asp-for="DisplayText" class="form-control" />
                <span asp-validation-for="DisplayText" class="text-danger"></span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="SubjectContentType" class="ocat-label">@T["Subject content type"]</label>
            <div class="ocat-end">
                <select asp-for="SubjectContentType" asp-items="Model.SubjectContentTypes" class="form-select">
                    <option value="">@T["Select a subject content type"]</option>
                </select>
                <span asp-validation-for="SubjectContentType" class="text-danger"></span>
                <span class="hint">@T["The selected subject flow determines the campaign, interaction type, and channel used when the batch loads activities."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="ScheduleAt" class="ocat-label">@T["Schedule at"]</label>
            <div class="ocat-end">
                <input type="text"
                       id="@Html.IdFor(m => m.ScheduleAt)"
                       name="@Html.NameFor(m => m.ScheduleAt)"
                       value="@scheduleAtValue"
                       class="form-control"
                       placeholder="@T["Schedule at"]" />
                <span asp-validation-for="ScheduleAt" class="text-danger"></span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="UserIds" class="ocat-label">@T["User(s) to assign activities to"]</label>
            <div class="ocat-end">
                @await Component.InvokeAsync("ItemSelector", new
                {
                    id = $"{Html.IdFor(m => m.UserIds)}_Selector",
                    inputName = Html.NameFor(m => m.UserIds),
                    endpoint = Url.RouteUrl("CrestApps.Users.Search", new { valueType = "userId" }),
                    initialItemsJson = JsonSerializer.Serialize(Model.SelectedUsers.Select(x => new { value = x.Value, text = x.Text, selected = true })),
                    multiple = true,
                    enableSearch = true,
                    enableSelectAll = true,
                    enableDeselectAll = true,
                    buttonText = T["Browse users"].Value,
                    searchPlaceholder = T["Search users"].Value,
                    emptyResultsText = T["No users found."].Value,
                    noSelectionText = T["No users selected."].Value,
                    loadingText = T["Loading users..."].Value,
                    loadErrorText = T["Unable to load users."].Value,
                    resultsTextFormat = T["Found {0} user(s)."].Value,
                    selectedItemsLabel = T["Selected users"].Value,
                    availableItemsLabel = T["Available users"].Value,
                    selectAllText = T["Select all"].Value,
                    deselectAllText = T["Deselect all"].Value,
                    searchButtonText = T["Search"].Value,
                })
                <span asp-validation-for="UserIds" class="text-danger"></span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="UrgencyLevel" class="ocat-label">@T["Urgency level"]</label>
            <div class="ocat-end">
                <select asp-for="UrgencyLevel" asp-items="Model.UrgencyLevels" class="form-select"></select>
                <span asp-validation-for="UrgencyLevel" class="text-danger"></span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="Instructions" class="ocat-label">@T["Instructions"]</label>
            <div class="ocat-end">
                <textarea asp-for="Instructions" class="form-control"></textarea>
                <span asp-validation-for="Instructions" class="text-danger"></span>
                <span class="hint">@T["Optionally, specify any instructions the user should know or be aware of before completing this activity."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <div class="ocat-end-offset">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" asp-for="PreventDuplicates">
                    <label class="form-check-label" asp-for="PreventDuplicates">@T["Prevent duplicate activity with the same subject"]</label>
                    <span class="hint dashed">@T["When enabled, if a contact already has an outstanding activity with the same subject, a new one will not be created."]</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        @T["Contact filters"]
    </div>
    <div class="card-body">
        <div class="ocat-wrapper">
            <label asp-for="ContactContentType" class="ocat-label">@T["Contact content type"]</label>
            <div class="ocat-end">
                <select asp-for="ContactContentType" asp-items="Model.ContactContentTypes" class="form-select">
                    <option value="">@T["Select a contact content type"]</option>
                </select>
                <span asp-validation-for="ContactContentType" class="text-danger"></span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="LeadCreatedFrom" class="ocat-label">@T["Contact created from"]</label>
            <div class="ocat-end">
                <input type="text"
                       id="@contactCreatedFromId"
                       name="@Html.NameFor(m => m.LeadCreatedFrom)"
                       value="@contactCreatedFromValue"
                       class="form-control"
                       placeholder="@T["Contact created from"]" />
                <span asp-validation-for="LeadCreatedFrom" class="text-danger"></span>
                <span class="hint">@T["Optionally, only include contacts created on or after this date."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="LeadCreatedTo" class="ocat-label">@T["Contact created to"]</label>
            <div class="ocat-end">
                <input type="text"
                       id="@contactCreatedToId"
                       name="@Html.NameFor(m => m.LeadCreatedTo)"
                       value="@contactCreatedToValue"
                       class="form-control"
                       placeholder="@T["Contact created to"]" />
                <span asp-validation-for="LeadCreatedTo" class="text-danger"></span>
                <span class="hint">@T["Optionally, only include contacts created on or before this date."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <div class="ocat-end-offset">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" asp-for="OnlyPublishedLeads">
                    <label class="form-check-label" asp-for="OnlyPublishedLeads">@T["Only published contacts"]</label>
                    <span class="hint dashed">@T["When enabled, only published contacts will be included. When disabled, the latest version of contacts will be included regardless of their publish status."]</span>
                </div>
            </div>
        </div>

        <div class="ocat-wrapper">
            <div class="ocat-end-offset">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" asp-for="IncludeDoNoCalls">
                    <label class="form-check-label" asp-for="IncludeDoNoCalls">@T["Include do not call contacts"]</label>
                    <span class="hint dashed">@T["When enabled, we'll include any contact that is flagged as do not call."]</span>
                </div>
            </div>
        </div>

        <div class="ocat-wrapper">
            <div class="ocat-end-offset">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" asp-for="IncludeDoNoEmail">
                    <label class="form-check-label" asp-for="IncludeDoNoEmail">@T["Include do not email contacts"]</label>
                    <span class="hint dashed">@T["When enabled, we'll include any contact that is flagged as do not email."]</span>
                </div>
            </div>
        </div>

        <div class="ocat-wrapper">
            <div class="ocat-end-offset">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" asp-for="IncludeDoNoSms">
                    <label class="form-check-label" asp-for="IncludeDoNoSms">@T["Include do not SMS contacts"]</label>
                    <span class="hint dashed">@T["When enabled, we'll include any contact that is flagged as do not SMS."]</span>
                </div>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="PhoneNumberMatchType" class="ocat-label">@T["Phone number filter"]</label>
            <div class="ocat-end">
                <div class="input-group">
                    <select asp-for="PhoneNumberMatchType" asp-items="Model.PhoneNumberMatchTypes" class="form-select" style="max-width: 160px;"></select>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="@T["Phone number (E.164)"]" />
                </div>
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                <span class="hint">@T["E.164 format required (e.g., +1702 for US/Canada). Searches both cell and home phone numbers."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="TimeZoneIds" class="ocat-label">@T["Time zones"]</label>
            <div class="ocat-end">
                <select asp-for="TimeZoneIds" asp-items="Model.TimeZones" class="selectpicker show-tick" multiple data-live-search="true" data-actions-box="true" data-header="@T["Select time zones"]" data-width="100%" data-selected-text-format="count > 2" data-count-selected-text="{0} time zones selected" data-style="btn-outline-secondary" title="@T["Any time zone"]">
                </select>
                <span class="hint">@T["Optionally, only include contacts in the selected time zones."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="Limit" class="ocat-label">@T["Limit"]</label>
            <div class="ocat-end">
                <input type="number" asp-for="Limit" class="form-control" placeholder="@T["Max contacts"]" min="1" />
                <span class="hint">@T["Optionally, limit the number of contacts loaded into this batch."]</span>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        @T["Last activity filters"]
    </div>
    <div class="card-body">
        <p class="text-muted mb-3">@T["Filter contacts based on their last completed activity. For example, find contacts whose last activity had a specific subject and disposition."]</p>

        <div class="ocat-wrapper">
            <label asp-for="LastActivitySubjectContentType" class="ocat-label">@T["Last activity subject"]</label>
            <div class="ocat-end">
                <select asp-for="LastActivitySubjectContentType" asp-items="Model.SubjectContentTypes" class="form-select">
                    <option value="">@T["Any subject"]</option>
                </select>
                <span class="hint">@T["Filter contacts whose last completed activity had this subject type."]</span>
            </div>
        </div>

        <div class="ocat-wrapper">
            <label asp-for="LastActivityDispositionId" class="ocat-label">@T["Last activity disposition"]</label>
            <div class="ocat-end">
                <select asp-for="LastActivityDispositionId" asp-items="Model.Dispositions" class="form-select">
                </select>
                <span class="hint">@T["Filter contacts whose last completed activity had this disposition."]</span>
            </div>
        </div>
    </div>
</div>

<script at="Foot" depends-on="flatpickr,flatpickr-culture">
    document.addEventListener('DOMContentLoaded', function () {
        var fromField = document.getElementById('@contactCreatedFromId');
        var toField = document.getElementById('@contactCreatedToId');

        var fromPicker = flatpickr(fromField, Object.assign(
            flatpickrCulture.createLocalizedDateTimeConfig("@datePattern", "@timePattern", {
                altInputClass: fromField.className,
            }),
            {
            onChange: function (selectedDates) {
                if (selectedDates && selectedDates.length > 0) {
                    toPicker.set('minDate', selectedDates[0]);
                } else {
                    toPicker.set('minDate', null);
                }
            }
            }));

        var toPicker = flatpickr(toField, Object.assign(
            flatpickrCulture.createLocalizedDateTimeConfig("@datePattern", "@timePattern", {
                altInputClass: toField.className,
            }),
            {
            onChange: function (selectedDates) {
                if (selectedDates && selectedDates.length > 0) {
                    fromPicker.set('maxDate', selectedDates[0]);
                } else {
                    fromPicker.set('maxDate', null);
                }
            }
            }));

        if (fromField.value) {
            toPicker.set('minDate', fromField.value);
        }

        if (toField.value) {
            fromPicker.set('maxDate', toField.value);
        }

        var scheduleAtField = document.getElementById('@Html.IdFor(m => m.ScheduleAt)');
        if (scheduleAtField) {
            flatpickr(scheduleAtField, flatpickrCulture.createLocalizedDateTimeConfig("@datePattern", "@timePattern", {
                altInputClass: scheduleAtField.className,
            }));
        }
    });
</script>
