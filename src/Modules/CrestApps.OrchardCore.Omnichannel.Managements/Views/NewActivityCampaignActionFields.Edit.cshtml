@using CrestApps.OrchardCore.Omnichannel.Core.Models
@using CrestApps.OrchardCore.Omnichannel.Managements.ViewModels
@using OrchardCore

@model NewActivityCampaignActionViewModel

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="CampaignId" class="@Orchard.GetLabelClasses()">@T["Target campaign"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select asp-for="CampaignId" asp-items="Model.Campaigns" class="form-select">
            <option value="">@T["Use the same campaign"]</option>
        </select>
        <span class="hint">@T["The campaign for the new activity. Leave empty to use the current campaign."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="SubjectContentType" class="@Orchard.GetLabelClasses()">@T["Subject content type"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select asp-for="SubjectContentType" asp-items="Model.SubjectContentTypes" class="form-select">
            <option value="">@T["Use the same subject type"]</option>
        </select>
        <span class="hint">@T["The content type for the new activity's subject. Leave empty to use the original activity's subject type."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="UrgencyLevel" class="@Orchard.GetLabelClasses()">@T["Urgency level"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select asp-for="UrgencyLevel" class="form-select">
            <option value="">@T["Use original activity's urgency level"]</option>
            <option value="@nameof(ActivityUrgencyLevel.VeryLow)">@T["Very low"]</option>
            <option value="@nameof(ActivityUrgencyLevel.Low)">@T["Low"]</option>
            <option value="@nameof(ActivityUrgencyLevel.Normal)">@T["Normal"]</option>
            <option value="@nameof(ActivityUrgencyLevel.Medium)">@T["Medium"]</option>
            <option value="@nameof(ActivityUrgencyLevel.High)">@T["High"]</option>
            <option value="@nameof(ActivityUrgencyLevel.VeryHigh)">@T["Very high"]</option>
        </select>
        <span class="hint">@T["Override the urgency level for the new activity."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="NormalizedUserName" class="@Orchard.GetLabelClasses()">@T["Assign to user"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="NormalizedUserName" class="form-control" />
        <span class="hint">@T["The normalized username to assign the new activity to. Leave empty to assign to the user who completed the activity."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="DefaultScheduleHours" class="@Orchard.GetLabelClasses()">@T["Default schedule hours"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="DefaultScheduleHours" class="form-control" type="number" min="1" />
        <span class="hint">@T["Default hours ahead to schedule the new activity. Used when no schedule date is provided during completion. Defaults to 24 hours."]</span>
    </div>
</div>
