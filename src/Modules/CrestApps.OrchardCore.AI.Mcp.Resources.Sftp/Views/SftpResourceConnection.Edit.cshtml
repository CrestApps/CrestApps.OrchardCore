@using CrestApps.OrchardCore.AI.Mcp.Resources.Sftp.ViewModels
@using OrchardCore

@model SftpConnectionViewModel

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Host" class="@Orchard.GetLabelClasses()">@T["Host"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="Host" class="form-control" />
        <span asp-validation-for="Host" class="text-danger"></span>
        <span class="hint">@T["The SFTP server hostname (e.g., sftp.example.com)."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Port" class="@Orchard.GetLabelClasses()">@T["Port"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="Port" type="number" class="form-control" placeholder="22" />
        <span asp-validation-for="Port" class="text-danger"></span>
        <span class="hint">@T["The SFTP server port. Default is 22."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Username" class="@Orchard.GetLabelClasses()">@T["Username"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
        <span class="hint">@T["The username for SFTP authentication."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Password" class="@Orchard.GetLabelClasses()">@T["Password"]</label>
    <div class="@Orchard.GetEndClasses()">
        @if (Model.HasPassword)
        {
            <input asp-for="Password" type="password" class="form-control" placeholder="@T["Keep current password"]" />
            <span class="hint">@T["Leave empty to keep the current password."]</span>
        }
        else
        {
            <input asp-for="Password" type="password" class="form-control" />
        }
        <span asp-validation-for="Password" class="text-danger"></span>
        <span class="hint">@T["The password for password-based authentication. Optional if using private key."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="PrivateKey" class="@Orchard.GetLabelClasses()">@T["Private Key"]</label>
    <div class="@Orchard.GetEndClasses()">
        @if (Model.HasPrivateKey)
        {
            <textarea asp-for="PrivateKey" class="form-control" rows="5" placeholder="@T["Keep current private key"]"></textarea>
            <span class="hint">@T["Leave empty to keep the current private key."]</span>
        }
        else
        {
            <textarea asp-for="PrivateKey" class="form-control" rows="5" placeholder="-----BEGIN RSA PRIVATE KEY-----"></textarea>
        }
        <span asp-validation-for="PrivateKey" class="text-danger"></span>
        <span class="hint">@T["The private key for key-based authentication. Optional if using password."]</span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="Passphrase" class="@Orchard.GetLabelClasses()">@T["Passphrase"]</label>
    <div class="@Orchard.GetEndClasses()">
        @if (Model.HasPassphrase)
        {
            <input asp-for="Passphrase" type="password" class="form-control" placeholder="@T["Keep current passphrase"]" />
            <span class="hint">@T["Leave empty to keep the current passphrase."]</span>
        }
        else
        {
            <input asp-for="Passphrase" type="password" class="form-control" />
        }
        <span asp-validation-for="Passphrase" class="text-danger"></span>
        <span class="hint">@T["The passphrase for the private key. Only required if the private key is encrypted."]</span>
    </div>
</div>

<fieldset class="mb-3">
    <legend class="h6">@T["Proxy Settings"]</legend>

    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="ProxyType" class="@Orchard.GetLabelClasses()">@T["Proxy Type"]</label>
        <div class="@Orchard.GetEndClasses()">
            <select asp-for="ProxyType" class="form-select">
                <option value="">@T["None"]</option>
                <option value="Http">@T["HTTP"]</option>
                <option value="Socks4">@T["SOCKS4"]</option>
                <option value="Socks5">@T["SOCKS5"]</option>
            </select>
            <span asp-validation-for="ProxyType" class="text-danger"></span>
            <span class="hint">@T["The type of proxy to use for the SFTP connection."]</span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="ProxyHost" class="@Orchard.GetLabelClasses()">@T["Proxy Host"]</label>
        <div class="@Orchard.GetEndClasses()">
            <input asp-for="ProxyHost" class="form-control" />
            <span asp-validation-for="ProxyHost" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="ProxyPort" class="@Orchard.GetLabelClasses()">@T["Proxy Port"]</label>
        <div class="@Orchard.GetEndClasses()">
            <input asp-for="ProxyPort" type="number" class="form-control" placeholder="1080" />
            <span asp-validation-for="ProxyPort" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="ProxyUsername" class="@Orchard.GetLabelClasses()">@T["Proxy Username"]</label>
        <div class="@Orchard.GetEndClasses()">
            <input asp-for="ProxyUsername" class="form-control" />
            <span asp-validation-for="ProxyUsername" class="text-danger"></span>
        </div>
    </div>

    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="ProxyPassword" class="@Orchard.GetLabelClasses()">@T["Proxy Password"]</label>
        <div class="@Orchard.GetEndClasses()">
            @if (Model.HasProxyPassword)
            {
                <input asp-for="ProxyPassword" type="password" class="form-control" placeholder="@T["Keep current password"]" />
                <span class="hint">@T["Leave empty to keep the current proxy password."]</span>
            }
            else
            {
                <input asp-for="ProxyPassword" type="password" class="form-control" />
            }
            <span asp-validation-for="ProxyPassword" class="text-danger"></span>
        </div>
    </div>
</fieldset>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="ConnectionTimeout" class="@Orchard.GetLabelClasses()">@T["Connection Timeout (seconds)"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="ConnectionTimeout" type="number" class="form-control" placeholder="@T["Default"]" />
        <span asp-validation-for="ConnectionTimeout" class="text-danger"></span>
    </div>
</div>

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="KeepAliveInterval" class="@Orchard.GetLabelClasses()">@T["Keep-Alive Interval (seconds)"]</label>
    <div class="@Orchard.GetEndClasses()">
        <input asp-for="KeepAliveInterval" type="number" class="form-control" placeholder="@T["Disabled"]" />
        <span asp-validation-for="KeepAliveInterval" class="text-danger"></span>
        <span class="hint">@T["Sends periodic keep-alive messages to prevent the connection from being dropped by firewalls or NAT devices."]</span>
    </div>
</div>
