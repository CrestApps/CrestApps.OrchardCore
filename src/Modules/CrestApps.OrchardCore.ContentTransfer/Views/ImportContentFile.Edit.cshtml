@model ContentImportViewModel

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <label class="form-label" asp-for="File" id="FilenameLabel" data-placeholder="@T["Click browser to select file"]">@T["Click browser to select file"]</label>
        <input type="file" class="form-control" asp-for="File" required accept="@Model.AcceptedFileTypes">
        <span asp-validation-for="File"></span>
    </div>
</div>

<div class="ocat-wrapper">
    <div class="ocat-end-offset">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" asp-for="PublishImportedContent" />
            <label class="form-check-label" asp-for="PublishImportedContent">@T["Publish imported content"]</label>
            <span class="hint dashed">@T["When enabled, imported content items are published after they are created or updated. When disabled, the import only saves the latest draft version."]</span>
        </div>
    </div>
</div>

<script at="Foot">
    document.addEventListener('DOMContentLoaded', function () {

        var file = document.getElementById('@Html.IdFor(x => x.File)');
        var placeholder = document.getElementById('FilenameLabel');
        if (!file || !placeholder) {
            return;
        }
        file.addEventListener('change', function (e) {
            if (e.target && e.target.files && e.target.files.length) {
                placeholder.innerHTML = e.target.files[0].name;
            } else {
                placeholder.innerHTML = placeholder.getAttribute('data-placeholder');
            }
        });
        file.dispatchEvent(new Event('change'));
    });
</script>
