@using Microsoft.AspNetCore.Authorization
@using CrestApps.OrchardCore.ContentTransfer
@using OrchardCore.Entities
@using OrchardCore.Modules

@inject IAuthorizationService AuthorizationService
@inject IClock Clock

@model OrchardCore.DisplayManagement.Views.ShapeViewModel<ContentTransferEntryViewModel>

@{
    var entry = Model.Value.ContentTransferEntry;
    var hasErrorRecords = entry.TryGet<ImportFileProcessStatsPart>(out var statsPart)
        && statsPart.Errors?.Count > 0;
    var canDelete = await AuthorizationService.AuthorizeAsync(User, ContentTransferPermissions.DeleteContentTransferEntries);
    var canProcessImport = await AuthorizationService.AuthorizeAsync(User, ContentTransferPermissions.ImportContentFromFile, (object)entry.ContentType);
    var isStalled = entry.Status == ContentTransferEntryStatus.Processing
        && entry.ProcessSaveUtc.HasValue
        && (Clock.UtcNow - entry.ProcessSaveUtc.Value).TotalMinutes > 10;
    var canResumeImport = entry.Status.CanResumeImport() || isStalled;
    var canPauseImport = entry.Status == ContentTransferEntryStatus.Processing && !isStalled;
}

@if (entry.Direction == ContentTransferDirection.Import && hasErrorRecords)
{
    <a asp-action="DownloadErrors" asp-controller="Admin" asp-route-area="@ContentTransferConstants.Feature.ModuleId" asp-route-entryId="@entry.EntryId" class="dropdown-item btn-sm">
        <i class="fa-solid fa-file-excel text-danger" aria-hidden="true"></i> @T["Download errors ({0})", statsPart.Errors.Count]
    </a>
}

@if (entry.Direction == ContentTransferDirection.Import
    && canProcessImport
    && canResumeImport)
{
    <a asp-action="ResumeImport" asp-controller="Admin" asp-route-area="@ContentTransferConstants.Feature.ModuleId" asp-route-entryId="@entry.EntryId" asp-route-returnUrl="@FullRequestPath" class="dropdown-item btn-sm">
        <i class="fa-solid fa-play text-primary" aria-hidden="true"></i> @T["Resume import"]
    </a>
}

@if (entry.Direction == ContentTransferDirection.Import
    && canProcessImport
    && canPauseImport)
{
    <a asp-action="PauseImport" asp-controller="Admin" asp-route-area="@ContentTransferConstants.Feature.ModuleId" asp-route-entryId="@entry.EntryId" asp-route-returnUrl="@FullRequestPath" data-url-af="UnsafeUrl RemoveUrl" data-title=@T["Pause import"] data-message=@T["Are you sure you want to pause this import?"] data-ok-text="@T["Yes"]" data-cancel-text="@T["No"]" data-ok-class="btn-warning" class="dropdown-item btn-sm">
        <i class="fa-solid fa-pause text-warning" aria-hidden="true"></i> @T["Pause import"]
    </a>
}

@if (canDelete && entry.Status != ContentTransferEntryStatus.Deleting)
{
    <a asp-action="Delete" asp-controller="Admin" asp-route-area="@ContentTransferConstants.Feature.ModuleId" asp-route-entryId="@entry.EntryId" asp-route-returnUrl="@FullRequestPath" data-url-af="UnsafeUrl RemoveUrl" data-title=@T["Delete entry"] data-message=@T["Are you sure you want to delete this entry?"] data-ok-text="@T["Yes"]" data-cancel-text="@T["No"]" data-ok-class="btn-primary" class="dropdown-item btn-sm">@T["Delete"]</a>
}
