@using Microsoft.Extensions.Options
@using System.Text.Json
@using CrestApps.OrchardCore.ContentTransfer
@using CrestApps.OrchardCore.ContentTransfer.Models

@model ContentImporterViewModel

@inject IOptions<ContentImportOptions> ContentImportOptions

@functions {
    private static string FormatBytes(long bytes)
    {
        string[] units = ["bytes", "KB", "MB", "GB", "TB"];
        double size = bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:0.##} {units[unitIndex]}";
    }
}

@{
    var supportedFormats = Model.FileFormats?.Select(format => format.Value).ToList() ?? [];
    var maxUploadChunkSize = ContentImportOptions.Value.MaxUploadChunkSize;
    var maxUploadFileSize = ContentImportOptions.Value.MaxUploadFileSize;
    var maxUploadFileSizeDisplay = FormatBytes(maxUploadFileSize);
    var importConfig = new
    {
        maxChunkSize = maxUploadChunkSize,
        maxFileSize = maxUploadFileSize,
        maxFileSizeDisplay = maxUploadFileSizeDisplay,
        redirectUrl = Url.Action("List", "Admin", new { area = ContentTransferConstants.Feature.ModuleId }),
        messages = new
        {
            selectFile = T["Please select a file to upload."].Value,
            fileTooLargeClient = T["The selected file is larger than the maximum allowed size of {0}."].Value,
            uploadGeneric = T["An error occurred while uploading the file."].Value,
            fileTooLargeServer = T["The file is too large to upload. Maximum allowed size is {0}."].Value,
            uploadInterrupted = T["The upload was interrupted. Please check your connection and try again."].Value,
            uploading = T["Uploading..."].Value,
        },
    };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="List" asp-controller="Admin">@T["Bulk Import"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@RenderTitleSegments(T["Import {0} contents", Model.ContentTypeDefinition.DisplayName])</li>
    </ol>
</nav>

@if (!ViewContext.ModelState.IsValid)
{
    @Html.ValidationSummary(false, string.Empty, new { @class = "text-danger" })
}

<div class="card text-bg-theme mb-3">
    <div class="card-header fw-bold">@T["Import {0} contents", Model.ContentTypeDefinition.DisplayName]</div>
    <div class="card-body">
        <form id="import-form" asp-route-contentTypeId="@(Model.ContentTypeDefinition.Name)" enctype="multipart/form-data" method="post" data-content-transfer-import data-config="@JsonSerializer.Serialize(importConfig, JOptions.CamelCase)">

            @await DisplayAsync(Model.Content)
            <div id="upload-progress" class="mb-3 mt-2" style="display:none;">
                <div class="progress">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
                </div>
                <small class="text-muted mt-1 d-block" id="upload-status">@T["Uploading..."]</small>
            </div>
            <div id="upload-error" class="alert alert-danger mt-2" style="display:none;"></div>
            <div class="mb-3 mt-2" id="upload-actions">

                <button type="submit" class="btn btn-primary">@T["Upload"]</button>
            </div>
        </form>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header fw-bold">@T["File Requirements"]</div>

    <div class="card-body">
        @if (supportedFormats.Count == 0)
        {
            <div class="alert alert-warning mb-0">
                @T["No file formats are currently enabled for bulk import."]
            </div>
        }
        else
        {
            <ul>
                <li>@T["The uploaded file must use one of the enabled formats: {0}.", string.Join(", ", supportedFormats)]</li>
                <li>@T["The very first row of the uploaded file must be the column names. The column names and their requirements are defined below."]</li>
                <li>@T["The order of the columns in the file is not important as long as they exist. Any column not defined below will be ignored."]</li>
                <li>
                    @T["Download a template for one of the enabled formats:"]

                    @for (var i = 0; i < Model.FileFormats.Count; i++)
                    {
                        var format = Model.FileFormats[i];
                        if (i > 0)
                        {
                            @: |
                        }

                        <a asp-action="DownloadTemplate"
                           asp-controller="Admin"
                           asp-route-contentTypeId="@Model.ContentTypeDefinition.Name"
                           asp-route-format="@format.Value"
                           asp-area="@(ContentTransferConstants.Feature.ModuleId)"
                           download="Bulk-@(Model.ContentTypeDefinition.Name)-Import-Template@(format.Value)">
                            @T["Download template ({0})", format.Text]
                        </a>
                    }
                </li>
            </ul>
        }

        <table class="table">
            <thead class="table-dark">
                <tr>
                    <th colspan="3" class="text-center">@T["Columns Requirements"]</th>
                </tr>
            </thead>
            <tbody>
                <tr class="table-secondary">
                    <th>@T["Column Name as it must appear on the first row on the file"]</th>
                    <th>@T["Required?"]</th>
                    <th>@T["Description"]</th>
                </tr>

                @foreach (var column in Model.Columns)
                {
                    <tr>
                        <th>@column.Name</th>
                        <td>@(column.IsRequired ? T["Yes"] : T["No"])</td>
                        <td>
                            <p>@column.Description</p>
                            @if (column.ValidValues != null && column.ValidValues.Length > 0)
                            {
                                <p>
                                    <span>@T["Valid values"] </span>

                                    @foreach (var validValue in column.ValidValues)
                                    {
                                        @Html.Raw("<code>\"" + validValue + "\"</code> ")
                                    }
                                </p>
                            }
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
</div>

<script asp-name="ContentTransferImport" at="Foot"></script>
