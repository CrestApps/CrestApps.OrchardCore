<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <RootNamespace>CrestApps.OrchardCore.ContentTransfer</RootNamespace>
    <Title>CrestApps OrchardCore Content Transfer</Title>
    <Description>
      $(CrestAppsDescription)

      Import and export Orchard Core content with the CrestApps Content Transfer module.
    </Description>
    <PackageTags>$(PackageTags) ContentTransfer</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OrchardCore.ContentManagement" />
    <PackageReference Include="OrchardCore.ContentTypes.Abstractions" />
    <PackageReference Include="OrchardCore.DisplayManagement" />
    <PackageReference Include="OrchardCore.FileStorage.FileSystem" />
    <PackageReference Include="OrchardCore.Module.Targets" />
    <PackageReference Include="OrchardCore.Mvc.Core" />
    <PackageReference Include="OrchardCore.Navigation.Core" />
    <PackageReference Include="OrchardCore.Notifications.Abstractions" />
    <PackageReference Include="OrchardCore.Notifications.Core" />
    <PackageReference Include="OrchardCore.Users.Abstractions" />
    <ProjectReference Include="..\..\Abstractions\CrestApps.OrchardCore.Abstractions\CrestApps.OrchardCore.Abstractions.csproj" />
    <ProjectReference Include="..\..\Core\CrestApps.OrchardCore.ContentTransfer.Core\CrestApps.OrchardCore.ContentTransfer.Core.csproj" />
  </ItemGroup>

</Project>
