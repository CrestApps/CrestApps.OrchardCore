<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CrestApps.AI.AzureAIInference</RootNamespace>
    <Title>CrestApps AI Azure AI Inference Core</Title>
    <Description>
      $(CrestAppsDescription)

      Azure AI Inference (GitHub Models) provider implementation for CrestApps AI services.
    </Description>
    <PackageTags>$(PackageTags) AI Azure AzureAIInference</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" />
    <PackageReference Include="Microsoft.Extensions.AI.AzureAIInference" />
    <PackageReference Include="Azure.Identity" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
    <ProjectReference Include="../CrestApps.Azure/CrestApps.Azure.csproj" />
  </ItemGroup>

</Project>
