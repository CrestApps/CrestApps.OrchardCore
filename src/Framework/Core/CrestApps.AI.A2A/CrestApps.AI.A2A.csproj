<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CrestApps.AI.A2A</RootNamespace>
    <Title>CrestApps AI A2A Core</Title>
    <Description>
      $(CrestAppsDescription)

      Framework-independent Agent-to-Agent (A2A) client support for CrestApps AI services.
    </Description>
    <PackageTags>$(PackageTags) AI A2A AgentToAgent</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="A2A" />
    <PackageReference Include="A2A.AspNetCore" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../Abstractions/CrestApps.Abstractions/CrestApps.Abstractions.csproj" />
    <ProjectReference Include="../../Abstractions/CrestApps.AI.Abstractions/CrestApps.AI.Abstractions.csproj" />
    <ProjectReference Include="../CrestApps.Core/CrestApps.Core.csproj" />
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
  </ItemGroup>

</Project>
