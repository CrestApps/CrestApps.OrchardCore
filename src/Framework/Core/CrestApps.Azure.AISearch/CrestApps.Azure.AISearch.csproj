<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CrestApps.Azure.AISearch</RootNamespace>
    <Title>CrestApps Azure AI Search</Title>
    <Description>
      $(CrestAppsDescription)

      Azure AI Search integration services for search index management, document indexing, vector search, and data source access.
    </Description>
    <PackageTags>$(PackageTags) AzureAI AzureAISearch Search</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Azure.Search.Documents" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
    <ProjectReference Include="../../Abstractions/CrestApps.Infrastructure.Abstractions/CrestApps.Infrastructure.Abstractions.csproj" />
    <ProjectReference Include="../CrestApps.Infrastructure/CrestApps.Infrastructure.csproj" />
  </ItemGroup>

</Project>
