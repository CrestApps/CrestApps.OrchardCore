<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Title>CrestApps AI - Azure AI Search</Title>
    <Description>
      $(CrestAppsDescription)

      Azure AI Search integration services for search index management, document indexing, vector search, and data source access.
    </Description>
    <PackageTags>$(PackageTags) AI AzureAI AzureAISearch</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Azure.Search.Documents" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
  </ItemGroup>

</Project>
