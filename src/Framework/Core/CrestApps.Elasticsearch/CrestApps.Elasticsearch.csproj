<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CrestApps.Elasticsearch</RootNamespace>
    <Title>CrestApps Elasticsearch</Title>
    <Description>
      $(CrestAppsDescription)

      Elasticsearch integration services for search index management, document indexing, vector search, and data source access.
    </Description>
    <PackageTags>$(PackageTags) Elasticsearch Search</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Elastic.Clients.Elasticsearch" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
    <ProjectReference Include="../../Abstractions/CrestApps.Infrastructure.Abstractions/CrestApps.Infrastructure.Abstractions.csproj" />
    <ProjectReference Include="../CrestApps.Infrastructure/CrestApps.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Utilities\CrestApps.Support\CrestApps.Support.csproj" />
  </ItemGroup>

</Project>
