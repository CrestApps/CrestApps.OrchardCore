<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Title>CrestApps AI Data Sources - Elasticsearch</Title>
    <Description>
      $(CrestAppsDescription)

      Elasticsearch support for AI data source document embeddings, vector search, and indexing.
    </Description>
    <PackageTags>$(PackageTags) AI DataSources Elasticsearch</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Elastic.Clients.Elasticsearch" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
  </ItemGroup>

</Project>
