<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>CrestApps.AI.Chat</RootNamespace>
    <Title>CrestApps AI Chat Core</Title>
    <Description>
			$(CrestAppsDescription)

			Chat services, SignalR hub contracts, and document processing tools for CrestApps AI.
			Framework-independent, usable in any ASP.NET Core application.
		</Description>
    <PackageTags>$(PackageTags) AI Chat SignalR</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Templates\Prompts\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DocumentFormat.OpenXml" />
    <PackageReference Include="PdfPig" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
  </ItemGroup>

</Project>
