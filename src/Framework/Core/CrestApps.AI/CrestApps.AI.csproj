<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>CrestApps.AI</RootNamespace>
		<Title>CrestApps AI Core</Title>
		<Description>
			$(CrestAppsDescription)

			Core AI service implementations including orchestration, tool registry, and completion services.
			Framework-independent, usable in any ASP.NET Core application.
		</Description>
		<PackageTags>$(PackageTags) AI Core</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<EmbeddedResource Include="AITemplates\Prompts\**\*" />
	</ItemGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Lucene.Net.Analysis.Common" />
		<PackageReference Include="Markdig" />
		<PackageReference Include="Microsoft.Extensions.AI" />
		<PackageReference Include="Microsoft.Extensions.DataIngestion" />
		<PackageReference Include="Microsoft.Extensions.DataIngestion.Markdig" />
		<PackageReference Include="Microsoft.ML.Tokenizers.Data.O200kBase" />
		<PackageReference Include="ZString" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="../../Abstractions/CrestApps.AI.Abstractions/CrestApps.AI.Abstractions.csproj" />
		<ProjectReference Include="../CrestApps.Core/CrestApps.Core.csproj" />
		<ProjectReference Include="../../Utilities/CrestApps.AI.Prompting/CrestApps.AI.Prompting.csproj" />
	</ItemGroup>

</Project>
