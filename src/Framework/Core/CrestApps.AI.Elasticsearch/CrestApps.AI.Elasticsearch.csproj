<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Title>CrestApps AI - Elasticsearch</Title>
    <Description>
      $(CrestAppsDescription)

      Elasticsearch integration services for search index management, document indexing, vector search, and data source access.
    </Description>
    <PackageTags>$(PackageTags) AI Elasticsearch</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Elastic.Clients.Elasticsearch" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
  </ItemGroup>

</Project>
