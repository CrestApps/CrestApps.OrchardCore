<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>$(MSBuildProjectName)</RootNamespace>
    <Title>CrestApps AI Data Sources - Azure AI Search</Title>
    <Description>
      $(CrestAppsDescription)

      Azure AI Search support for AI data source document embeddings, vector search, and indexing.
    </Description>
    <PackageTags>$(PackageTags) AI DataSources AzureAISearch</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Azure.Search.Documents" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CrestApps.AI/CrestApps.AI.csproj" />
  </ItemGroup>

</Project>
