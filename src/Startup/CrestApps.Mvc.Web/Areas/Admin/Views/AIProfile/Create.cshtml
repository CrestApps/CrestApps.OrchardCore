@model CrestApps.Mvc.Web.Areas.Admin.ViewModels.AIProfileViewModel
@{
    ViewData["Title"] = "Create AI Profile";
}

<h2><i class="bi bi-plus-lg"></i> Create AI Profile</h2>
<hr />

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @if (Model.AvailableProfileTemplates.Count > 1)
    {
        <div class="card mb-3 border-info">
            <div class="card-body py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-file-earmark-text text-info"></i>
                    <label class="form-label mb-0 fw-semibold">Apply template</label>
                    <select id="applyTemplateSelect" class="form-select form-select-sm" style="max-width: 300px;">
                        @foreach (var tpl in Model.AvailableProfileTemplates)
                        {
                            <option value="@tpl.Value">@tpl.Text</option>
                        }
                    </select>
                    <button type="button" class="btn btn-sm btn-info text-white" id="applyTemplateBtn" disabled>
                        <i class="bi bi-check-lg"></i> Apply
                    </button>
                    <span class="form-text mb-0 ms-2">Pre-fill this profile from a profile-source template.</span>
                </div>
            </div>
        </div>
    }
    <div class="row">
        <div class="col-md-8">
            <ul class="nav nav-tabs" id="profileTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="basic-tab" data-bs-toggle="tab" data-bs-target="#basic" type="button" role="tab">Basic Info</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="params-tab" data-bs-toggle="tab" data-bs-target="#params" type="button" role="tab">AI Parameters</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="capabilities-tab" data-bs-toggle="tab" data-bs-target="#capabilities" type="button" role="tab">Capabilities</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button" role="tab">Documents</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="extraction-tab" data-bs-toggle="tab" data-bs-target="#extraction" type="button" role="tab">Data Extraction</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics" type="button" role="tab">Analytics</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">Settings</button>
                </li>
            </ul>

            <div class="tab-content p-3 border border-top-0 rounded-bottom" id="profileTabContent">
                <!-- Basic Info Tab -->
                <div class="tab-pane fade show active" id="basic" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required placeholder="e.g., my-chat-assistant" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DisplayText" class="form-label">Display text</label>
                        <input asp-for="DisplayText" class="form-control" placeholder="e.g., My Chat Assistant" />
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="Type" class="form-label">Profile type</label>
                                <select asp-for="Type" class="form-select" id="profileTypeSelect">
                                    @foreach (var profileType in Enum.GetValues<CrestApps.AI.Models.AIProfileType>())
                                    {
                                        if (Model.Type == profileType)
                                        {
                                            @:<option value="@profileType" selected>@profileType</option>
                                        }
                                        else
                                        {
                                            @:<option value="@profileType">@profileType</option>
                                        }
                                    }
                                </select>
                                <div class="form-text">Choose the type of the profile.</div>
                            </div>
                        </div>
                        <div class="col-md-4 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")">
                            <div class="mb-3">
                                <label asp-for="TitleType" class="form-label">Title type</label>
                                <select asp-for="TitleType" class="form-select" asp-items="Html.GetEnumSelectList<CrestApps.AI.Models.AISessionTitleType>()">
                                    <option value="">— Default —</option>
                                </select>
                                <div class="form-text">How the chat session title is determined.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Agent-only: Description -->
                    <div class="mb-3 profile-type profile-type-agent@(Model.Type != CrestApps.AI.Models.AIProfileType.Agent ? " d-none" : "")">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe what this agent does so the orchestrator can decide when to invoke it."></textarea>
                        <div class="form-text">A description of what this agent does. Used by the orchestrator to determine when to route requests to this agent.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                    <label asp-for="ChatDeploymentName" class="form-label">Chat deployment</label>
                                    <select asp-for="ChatDeploymentName" class="form-select" asp-items="Model.ChatDeployments"></select>
                                <div class="form-text">The chat model deployment to use.</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                    <label asp-for="UtilityDeploymentName" class="form-label">Utility deployment</label>
                                    <select asp-for="UtilityDeploymentName" class="form-select" asp-items="Model.UtilityDeployments"></select>
                                <div class="form-text">Optional deployment for utility tasks (planning, summarization).</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="OrchestratorName" class="form-label">Orchestrator</label>
                                <select asp-for="OrchestratorName" class="form-select" asp-items="Model.Orchestrators"></select>
                                <div class="form-text">The orchestrator that manages AI interactions.</div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableUserMemory" class="form-check-input" type="checkbox" />
                            <label asp-for="EnableUserMemory" class="form-check-label">Enable user memory</label>
                        </div>
                        <div class="form-text">Store and recall user conversation history for personalized responses.</div>
                    </div>

                    <!-- Chat-only: Prompt Subject -->
                    <div class="mb-3 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")">
                        <label asp-for="PromptSubject" class="form-label">Prompt subject</label>
                        <input asp-for="PromptSubject" class="form-control" placeholder="Optional subject context for the prompt" />
                        <div class="form-text">Provides context to the AI about the primary subject of the conversation.</div>
                    </div>

                    <!-- Chat-only: Add Initial Prompt toggle -->
                    <div class="mb-3 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")">
                        <div class="form-check form-switch">
                            <input asp-for="AddInitialPrompt" class="form-check-input" type="checkbox" id="addInitialPromptCheck" />
                            <label asp-for="AddInitialPrompt" class="form-check-label">Add initial prompt</label>
                        </div>
                        <div class="form-text">When enabled, each new chat session starts with an assistant message from the initial prompt and the welcome message is ignored.</div>
                    </div>

                    <!-- Chat-only: Welcome Message (shown when AddInitialPrompt is unchecked) -->
                    <div class="mb-3 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")" id="welcomeMessageGroup">
                        <label asp-for="WelcomeMessage" class="form-label">Welcome message</label>
                        <textarea asp-for="WelcomeMessage" class="form-control" rows="3" placeholder="Message shown when a chat starts"></textarea>
                        <div class="form-text">The welcome message to show on the user-interface when a new session is created.</div>
                    </div>

                    <!-- Chat-only: Initial Prompt (shown when AddInitialPrompt is checked) -->
                    <div class="mb-3 profile-type profile-type-chat d-none" id="initialPromptGroup">
                        <label asp-for="InitialPrompt" class="form-label">Initial prompt</label>
                        <textarea asp-for="InitialPrompt" class="form-control" rows="4" placeholder="The assistant message added as the first chat history entry"></textarea>
                        <div class="form-text">This assistant message is added as the first chat history entry when a new session is created.</div>
                    </div>

                    <!-- TemplatePrompt-only: Prompt Template -->
                    <div class="mb-3 profile-type profile-type-template-prompt@(Model.Type != CrestApps.AI.Models.AIProfileType.TemplatePrompt ? " d-none" : "")">
                        <label asp-for="PromptTemplate" class="form-label">Prompt template</label>
                        <textarea asp-for="PromptTemplate" class="form-control" rows="5" placeholder="Template for generating prompts"></textarea>
                        <div class="form-text">
                            Liquid syntax is supported. Available variables: <code>{{ User.UserName }}</code>, <code>{{ User.Email }}</code>,
                            <code>{{ Session.Id }}</code>, <code>{{ Profile.Name }}</code>, and any custom parameters.
                        </div>
                    </div>
                </div>

                <!-- AI Parameters Tab -->
                <div class="tab-pane fade" id="params" role="tabpanel">
                    @if (Model.AvailablePromptTemplates.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                Prompt templates
                                <span class="text-muted" data-bs-toggle="tooltip" title="Add one or more reusable prompt templates that will be rendered in order before the custom system instructions.">
                                    <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
                                </span>
                            </label>
                            <div class="dropdown mb-3">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" id="addPromptTemplateBtn" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-plus"></i> Add prompt template
                                </button>
                                <div class="dropdown-menu p-2" id="promptTemplateDropdown" style="max-height:24rem;min-width:22rem;overflow-y:auto;">
                                    <div class="mb-2">
                                        <input type="search" class="form-control form-control-sm" id="promptTemplateSearch" placeholder="Search prompt templates..." />
                                    </div>
                                    <div class="prompt-template-menu-items">
                                        @foreach (var group in Model.AvailablePromptTemplates.GroupBy(t => t.Category).OrderBy(g => g.Key))
                                        {
                                            <div class="dropdown-header px-2">@group.Key</div>
                                            @foreach (var option in group)
                                            {
                                                <button type="button"
                                                        class="dropdown-item prompt-template-add-btn text-wrap"
                                                        data-template-id="@option.TemplateId"
                                                        data-template-title="@option.Title"
                                                        data-template-description="@option.Description">
                                                    <span class="d-block fw-semibold">@option.Title</span>
                                                    @if (!string.IsNullOrWhiteSpace(option.Description))
                                                    {
                                                        <small class="text-muted">@option.Description</small>
                                                    }
                                                </button>
                                            }
                                        }
                                    </div>
                                    <div class="text-muted small d-none px-2 py-1" id="promptTemplateNoResults">No prompt templates match your search.</div>
                                </div>
                            </div>

                            <div id="promptTemplatesContainer">
                                @for (var i = 0; i < Model.PromptTemplates.Count; i++)
                                {
                                    var selection = Model.PromptTemplates[i];
                                    var option = Model.AvailablePromptTemplates.FirstOrDefault(t => string.Equals(t.TemplateId, selection.TemplateId, StringComparison.OrdinalIgnoreCase));
                                    var title = option?.Title ?? selection.TemplateId ?? "Prompt template";
                                    var category = option?.Category ?? "Unavailable";
                                    var description = option?.Description;
                                    var parameters = option?.Parameters ?? [];

                                    <div class="card mb-1 prompt-template-card" data-template-id="@selection.TemplateId">
                                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                                            <a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0"
                                               data-bs-toggle="collapse" href="#promptCollapse_@i" role="button" aria-expanded="false">
                                                <i class="fa-solid fa-chevron-right me-1"></i>
                                                <span class="prompt-template-title fw-semibold">@title</span>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger remove-prompt-template-btn" title="Remove">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                        <div id="promptCollapse_@i" class="collapse">
                                            <div class="card-body">
                                                <input type="hidden" name="PromptTemplates[@i].TemplateId" value="@selection.TemplateId" class="prompt-template-id-input" />
                                                <div class="d-flex flex-wrap gap-2 mb-2">
                                                    <span class="badge text-bg-secondary">@category</span>
                                                    @if (option == null)
                                                    {
                                                        <span class="badge text-bg-warning">Unavailable</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(description))
                                                {
                                                    <div class="text-muted small mb-3">@description</div>
                                                }
                                                @if (parameters.Count > 0)
                                                {
                                                    <div class="mb-3">
                                                        <small class="text-muted d-block mb-1">Expected parameters:</small>
                                                        <ul class="mb-0 small text-muted">
                                                            @foreach (var p in parameters)
                                                            {
                                                                <li><strong>@p.Name</strong>@(string.IsNullOrWhiteSpace(p.Description) ? "" : $": {p.Description}")</li>
                                                            }
                                                        </ul>
                                                    </div>
                                                }
                                                <div class="mb-1">
                                                    <label class="form-label">Template parameters</label>
                                                    <textarea name="PromptTemplates[@i].PromptParameters"
                                                              class="form-control prompt-template-parameters-input" rows="3"
                                                              placeholder='e.g., {"key1": "value1", "key2": "value2"}'>@selection.PromptParameters</textarea>
                                                    <span class="form-text">Optional JSON key-value pairs to pass as template arguments.</span>
                                                    <div class="text-danger small d-none prompt-template-parameters-error"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="text-muted small @(Model.PromptTemplates.Count == 0 ? "" : "d-none")" id="promptTemplateEmptyState">
                                No prompt templates selected.
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="SystemMessage" class="form-label">System message</label>
                        <textarea asp-for="SystemMessage" class="form-control" rows="5" placeholder="You are a helpful AI assistant..."></textarea>
                        <div class="form-text">Instructions that guide the AI's behavior throughout the conversation.</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Temperature" class="form-label">Temperature</label>
                                <input asp-for="Temperature" type="number" class="form-control" step="0.01" min="0" max="2" placeholder="0.0 - 2.0" />
                                <div class="form-text">Controls randomness. Lower = more focused, higher = more creative.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="TopP" class="form-label">Top P</label>
                                <input asp-for="TopP" type="number" class="form-control" step="0.01" min="0" max="1" placeholder="0.0 - 1.0" />
                                <div class="form-text">Nucleus sampling. Controls diversity of responses.</div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="FrequencyPenalty" class="form-label">Frequency penalty</label>
                                <input asp-for="FrequencyPenalty" type="number" class="form-control" step="0.01" min="-2" max="2" placeholder="-2.0 - 2.0" />
                                <div class="form-text">Penalizes repeated tokens. Higher = less repetition.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PresencePenalty" class="form-label">Presence penalty</label>
                                <input asp-for="PresencePenalty" type="number" class="form-control" step="0.01" min="-2" max="2" placeholder="-2.0 - 2.0" />
                                <div class="form-text">Penalizes tokens already present. Higher = more topic variety.</div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="MaxTokens" class="form-label">Max output tokens</label>
                                <input asp-for="MaxTokens" type="number" class="form-control" min="1" placeholder="Leave blank for model default" />
                                <div class="form-text">Maximum number of tokens in the response.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PastMessagesCount" class="form-label">Past messages count</label>
                                <input asp-for="PastMessagesCount" type="number" class="form-control" min="0" placeholder="Leave blank for all" />
                                <div class="form-text">Number of previous messages to include in context.</div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="UseCaching" class="form-check-input" type="checkbox" />
                            <label asp-for="UseCaching" class="form-check-label">Enable response caching</label>
                        </div>
                        <div class="form-text">Cache responses to improve performance for repeated queries.</div>
                    </div>
                </div>

                <!-- Capabilities Tab (A2A, MCP, Tools) -->
                <div class="tab-pane fade" id="capabilities" role="tabpanel">
                    <!-- A2A Connections Section -->
                    <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h6>
                    @if (Model.AvailableA2AConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No A2A host connections are configured. Add them under <strong>Agent to Agent Hosts</strong> first.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the remote A2A hosts this profile can use for agent orchestration.</p>
                        @foreach (var connection in Model.AvailableA2AConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedA2AConnectionIds" value="@connection.ItemId" id="a2a_@connection.ItemId"
                                       @(connection.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="a2a_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong><br />
                                    <small class="text-muted">@connection.Endpoint</small>
                                </label>
                            </div>
                        }
                    }

                    <!-- MCP Connections Section -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-plug"></i> MCP Connections</h6>
                    @if (Model.AvailableMcpConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No MCP connections are configured. Add them under <strong>MCP Connections</strong> first.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the MCP server connections this profile can use for external tools and resources.</p>
                        @foreach (var connection in Model.AvailableMcpConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedMcpConnectionIds" value="@connection.ItemId" id="mcp_@connection.ItemId"
                                       @(connection.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="mcp_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(connection.Source))
                                    {
                                        <br /><small class="text-muted">@connection.Source</small>
                                    }
                                </label>
                            </div>
                        }
                    }

                    <!-- AI Tools Section -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-tools"></i> AI Tools</h6>
                    @if (Model.AvailableTools.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> No selectable AI tools are registered.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <p class="text-muted mb-0 small">Select the tools this profile can use during conversations.</p>
                            <div class="btn-group btn-group-sm ms-3" role="group">
                                <button type="button" class="btn btn-outline-primary" id="select-all-tools"><i class="bi bi-check-all"></i> Select All</button>
                                <button type="button" class="btn btn-outline-secondary" id="deselect-all-tools"><i class="bi bi-x-lg"></i> Deselect All</button>
                            </div>
                        </div>
                        @foreach (var group in Model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                        {
                            <h6 class="text-secondary mt-3 mb-2"><i class="bi bi-folder"></i> @group.Key</h6>
                            @foreach (var tool in group)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="SelectedToolNames" value="@tool.Name" id="tool_@tool.Name"
                                           @(tool.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="tool_@tool.Name">
                                        <strong>@tool.Title</strong>
                                        @if (!string.IsNullOrEmpty(tool.Description))
                                        {
                                            <br /><small class="text-muted">@tool.Description</small>
                                        }
                                    </label>
                                </div>
                            }
                        }
                    }
                </div>

                <!-- Documents Tab -->
                <div class="tab-pane fade" id="docs" role="tabpanel">
                    @if (Model.HasDocumentIndexConfiguration)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Documents uploaded here are indexed into the <strong>@Model.DocumentIndexProfileName</strong> AI Documents index and can be used as background knowledge during chat.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> Document knowledge-base search is not configured yet. Create an <strong>AI Documents</strong> index profile and select it under <strong>Settings → AI Settings → Documents</strong> before expecting uploaded documents to influence answers.
                        </div>
                    }
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="AllowSessionDocuments" class="form-check-input" type="checkbox" />
                            <label asp-for="AllowSessionDocuments" class="form-check-label">Allow session document uploads</label>
                        </div>
                        <div class="form-text">Allow users to upload documents during chat sessions with this profile.</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DocumentTopN" class="form-label">Document Top N</label>
                                <input asp-for="DocumentTopN" type="number" class="form-control" min="1" max="20" placeholder="Default: 3" />
                                <div class="form-text">Number of top matching document chunks to include as AI context.</div>
                            </div>
                        </div>
                    </div>

                    <h6 class="mt-3 mb-2"><i class="bi bi-paperclip"></i> Attach Documents</h6>
                    <div id="pending-docs-list" class="mb-3"></div>
                    <div class="input-group">
                        <input type="file" class="form-control" id="doc-add-input" multiple
                               accept=".txt,.md,.csv,.json,.xml,.html,.pdf,.docx,.xlsx,.pptx" />
                        <button type="button" class="btn btn-outline-primary" id="doc-add-btn">
                            <i class="bi bi-plus-lg"></i> Add
                        </button>
                    </div>
                    <div class="form-text">Supported formats: Plain text, Markdown, JSON, XML, HTML, PDF, and Office documents (when matching readers are configured).</div>
                </div>

                <!-- Data Extraction Tab -->
                <div class="tab-pane fade" id="extraction" role="tabpanel">
                    <p class="text-muted mb-3">Configure automatic data extraction from conversations.</p>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableDataExtraction" class="form-check-input" type="checkbox" id="enableDataExtractionCheck" />
                            <label asp-for="EnableDataExtraction" class="form-check-label">Enable data extraction</label>
                        </div>
                        <div class="form-text">Run AI-powered extraction on conversation messages to populate structured fields.</div>
                    </div>
                    <div id="dataExtractionSettings" class="@(Model.EnableDataExtraction ? "" : "d-none")">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ExtractionCheckInterval" class="form-label">Extraction check interval</label>
                                    <input asp-for="ExtractionCheckInterval" type="number" class="form-control" min="1" max="20" />
                                    <div class="form-text">How often extraction runs (1 = every message, 2 = every other message, etc.).</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SessionInactivityTimeoutInMinutes" class="form-label">Session inactivity timeout (minutes)</label>
                                    <input asp-for="SessionInactivityTimeoutInMinutes" type="number" class="form-control" min="1" />
                                    <div class="form-text">Sessions inactive longer than this will be automatically closed.</div>
                                </div>
                            </div>
                        </div>

                        <h6 class="mb-2 mt-2 border-bottom pb-2"><i class="bi bi-list-check"></i> Extraction Entries</h6>
                        <div id="extractionEntriesContainer">
                            @for (var i = 0; i < Model.DataExtractionEntries.Count; i++)
                            {
                                var entry = Model.DataExtractionEntries[i];
                                <div class="card mb-2 extraction-entry-card">
                                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                                        <a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0"
                                           data-bs-toggle="collapse" href="#entryCollapse_@i" role="button" aria-expanded="true">
                                            <i class="fa-solid fa-chevron-down me-1"></i>
                                            <span class="entry-name-display fw-semibold">@(string.IsNullOrWhiteSpace(entry.Name) ? "New Entry" : entry.Name)</span>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger remove-entry-btn" title="Remove">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                    <div id="entryCollapse_@i" class="collapse show">
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="form-label">Name</label>
                                                <input type="text" class="form-control entry-name-input"
                                                       name="DataExtractionEntries[@i].Name" value="@entry.Name"
                                                       pattern="^[a-zA-Z0-9_]+$" required placeholder="e.g., customer_name" />
                                                <span class="form-text">A unique identifier. Only alphanumeric characters and underscores.</span>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Description</label>
                                                <textarea class="form-control" name="DataExtractionEntries[@i].Description"
                                                          rows="3" placeholder="What to extract">@entry.Description</textarea>
                                                <span class="form-text">Describes what data to extract. The AI uses this to understand what to look for.</span>
                                            </div>
                                            <div class="form-check mb-2">
                                                <input type="checkbox" class="form-check-input"
                                                       name="DataExtractionEntries[@i].AllowMultipleValues" value="true"
                                                       @(entry.AllowMultipleValues ? "checked" : "") />
                                                <label class="form-check-label">Allow multiple values</label>
                                                <span class="form-text d-block">When enabled, the field accumulates multiple values across messages.</span>
                                            </div>
                                            <div class="form-check mb-2">
                                                <input type="checkbox" class="form-check-input"
                                                       name="DataExtractionEntries[@i].IsUpdatable" value="true"
                                                       @(entry.IsUpdatable ? "checked" : "") />
                                                <label class="form-check-label">Updatable</label>
                                                <span class="form-text d-block">When enabled, the value can be replaced if updated information is provided.</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-success" id="addExtractionEntry">
                            <i class="fa-solid fa-plus"></i> Add Entry
                        </button>
                    </div>
                </div>

                <!-- Analytics Tab -->
                <div class="tab-pane fade" id="analytics" role="tabpanel">
                    <p class="text-muted mb-3">Configure session metrics and post-session processing for conversations using this profile.</p>

                    <h6 class="mb-2"><i class="bi bi-graph-up"></i> Session Metrics</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableSessionMetrics" class="form-check-input" type="checkbox" />
                            <label asp-for="EnableSessionMetrics" class="form-check-label">Enable session metrics</label>
                        </div>
                        <div class="form-text">Capture usage, latency, and feedback metrics for analytics.</div>
                    </div>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="EnableAIResolutionDetection" class="form-check-input" type="checkbox" />
                            <label asp-for="EnableAIResolutionDetection" class="form-check-label">Enable AI resolution detection</label>
                        </div>
                        <div class="form-text">When enabled, the AI will determine whether the user's issue was resolved during the session.</div>
                    </div>

                    <h6 class="mb-2"><i class="bi bi-bullseye"></i> Conversion Goals</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableConversionMetrics" class="form-check-input" type="checkbox" id="enableConversionMetricsCheck" />
                            <label asp-for="EnableConversionMetrics" class="form-check-label">Enable conversion metrics</label>
                        </div>
                        <div class="form-text">Evaluate each session against defined goals and assign scores to measure session success.</div>
                    </div>
                    <div id="conversionGoalsSection" class="@(Model.EnableConversionMetrics ? "" : "d-none")">
                        <div id="conversionGoalsContainer">
                            @for (var i = 0; i < Model.ConversionGoals.Count; i++)
                            {
                                var goal = Model.ConversionGoals[i];
                                <div class="card mb-2 conversion-goal-card">
                                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                                        <a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0"
                                           data-bs-toggle="collapse" href="#goalCollapse_@i" role="button" aria-expanded="true">
                                            <i class="fa-solid fa-chevron-down me-1"></i>
                                            <span class="goal-name-display fw-semibold">@(string.IsNullOrWhiteSpace(goal.Name) ? "New Goal" : goal.Name)</span>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger remove-goal-btn" title="Remove">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                    <div id="goalCollapse_@i" class="collapse show">
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="form-label">Name</label>
                                                <input type="text" class="form-control goal-name-input"
                                                       name="ConversionGoals[@i].Name" value="@goal.Name"
                                                       pattern="^[a-zA-Z0-9_]+$" required placeholder="e.g., booking_completed" />
                                                <span class="form-text">A unique identifier. Only alphanumeric characters and underscores.</span>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Description</label>
                                                <textarea class="form-control" name="ConversionGoals[@i].Description"
                                                          rows="3" placeholder="Describe what constitutes success for this goal">@goal.Description</textarea>
                                                <span class="form-text">Provided to the AI model as evaluation criteria.</span>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="mb-3">
                                                        <label class="form-label">Min score</label>
                                                        <input type="number" class="form-control" name="ConversionGoals[@i].MinScore"
                                                               value="@goal.MinScore" min="0" />
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="mb-3">
                                                        <label class="form-label">Max score</label>
                                                        <input type="number" class="form-control" name="ConversionGoals[@i].MaxScore"
                                                               value="@goal.MaxScore" min="1" />
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-success" id="addConversionGoal">
                            <i class="fa-solid fa-plus"></i> Add Goal
                        </button>
                    </div>

                    <hr class="my-4" />

                    <h6 class="mb-2"><i class="bi bi-clipboard-check"></i> Post-session Processing</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnablePostSessionProcessing" class="form-check-input" type="checkbox" id="enablePostSessionCheck" />
                            <label asp-for="EnablePostSessionProcessing" class="form-check-label">Enable post-session processing</label>
                        </div>
                        <div class="form-text">Run AI-powered analysis on the complete conversation after a session closes.</div>
                    </div>

                    <div id="postSessionTasksSection" class="@(Model.EnablePostSessionProcessing ? "" : "d-none")">
                        <div id="post-session-tasks"></div>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="add-task-btn">
                            <i class="bi bi-plus-circle"></i> Add Task
                        </button>
                    </div>
                </div>

                <!-- Settings Tab -->
                <div class="tab-pane fade" id="settings" role="tabpanel">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsListable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsListable" class="form-check-label">Listable</label>
                        </div>
                        <div class="form-text">Show this profile in the chat UI for users to select.</div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsRemovable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsRemovable" class="form-check-label">Removable</label>
                        </div>
                        <div class="form-text">Allow this profile to be deleted.</div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="LockSystemMessage" class="form-check-input" type="checkbox" />
                            <label asp-for="LockSystemMessage" class="form-check-label">Lock system message</label>
                        </div>
                        <div class="form-text">Prevent modification of the system message after creation.</div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // --- Profile Type conditional visibility ---
            const profileTypeSelect = document.getElementById('profileTypeSelect');
            const addInitialPromptCheck = document.getElementById('addInitialPromptCheck');
            const welcomeMessageGroup = document.getElementById('welcomeMessageGroup');
            const initialPromptGroup = document.getElementById('initialPromptGroup');

            function convertToKebabCase(str) {
                return str.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
            }

            function toggleProfileTypeFields() {
                if (!profileTypeSelect) return;
                const value = profileTypeSelect.value;
                const className = 'profile-type-' + convertToKebabCase(value);
                const elements = document.querySelectorAll('.profile-type');
                elements.forEach(function (el) {
                    if (el.classList.contains(className)) {
                        el.classList.remove('d-none');
                    } else {
                        el.classList.add('d-none');
                    }
                });
                toggleInitialPromptFields();
            }

            function toggleInitialPromptFields() {
                if (!profileTypeSelect || !addInitialPromptCheck || !welcomeMessageGroup || !initialPromptGroup) return;
                const isChatType = profileTypeSelect.value === 'Chat';
                const showInitialPrompt = addInitialPromptCheck.checked;
                welcomeMessageGroup.classList.toggle('d-none', !isChatType || showInitialPrompt);
                initialPromptGroup.classList.toggle('d-none', !isChatType || !showInitialPrompt);
            }

            if (profileTypeSelect) {
                profileTypeSelect.addEventListener('change', toggleProfileTypeFields);
                toggleProfileTypeFields();
            }

            if (addInitialPromptCheck) {
                addInitialPromptCheck.addEventListener('change', toggleInitialPromptFields);
            }

            // --- Data Extraction conditional visibility ---
            const enableDataExtractionCheck = document.getElementById('enableDataExtractionCheck');
            const dataExtractionSettings = document.getElementById('dataExtractionSettings');
            if (enableDataExtractionCheck && dataExtractionSettings) {
                enableDataExtractionCheck.addEventListener('change', function () {
                    dataExtractionSettings.classList.toggle('d-none', !this.checked);
                });
            }

            // --- Data Extraction Entries ---
            (function () {
                var entriesContainer = document.getElementById('extractionEntriesContainer');
                var addEntryBtn = document.getElementById('addExtractionEntry');
                if (!entriesContainer || !addEntryBtn) return;

                addEntryBtn.addEventListener('click', function () {
                    var index = entriesContainer.querySelectorAll('.extraction-entry-card').length;
                    var card = document.createElement('div');
                    card.className = 'card mb-2 extraction-entry-card';
                    card.innerHTML =
                        '<div class="card-header d-flex justify-content-between align-items-center py-2">' +
                            '<a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0" data-bs-toggle="collapse" href="#entryCollapse_' + index + '" role="button" aria-expanded="true">' +
                                '<i class="fa-solid fa-chevron-down me-1"></i>' +
                                '<span class="entry-name-display fw-semibold">New Entry</span>' +
                            '</a>' +
                            '<button type="button" class="btn btn-sm btn-danger remove-entry-btn" title="Remove"><i class="fa-solid fa-trash"></i></button>' +
                        '</div>' +
                        '<div id="entryCollapse_' + index + '" class="collapse show">' +
                            '<div class="card-body">' +
                                '<div class="mb-3"><label class="form-label">Name</label>' +
                                    '<input type="text" class="form-control entry-name-input" name="DataExtractionEntries[' + index + '].Name" pattern="^[a-zA-Z0-9_]+$" required placeholder="e.g., customer_name" />' +
                                    '<span class="form-text">A unique identifier. Only alphanumeric characters and underscores.</span></div>' +
                                '<div class="mb-3"><label class="form-label">Description</label>' +
                                    '<textarea class="form-control" name="DataExtractionEntries[' + index + '].Description" rows="3" placeholder="What to extract"></textarea>' +
                                    '<span class="form-text">Describes what data to extract. The AI uses this to understand what to look for.</span></div>' +
                                '<div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="DataExtractionEntries[' + index + '].AllowMultipleValues" value="true" />' +
                                    '<label class="form-check-label">Allow multiple values</label>' +
                                    '<span class="form-text d-block">When enabled, the field accumulates multiple values across messages.</span></div>' +
                                '<div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="DataExtractionEntries[' + index + '].IsUpdatable" value="true" />' +
                                    '<label class="form-check-label">Updatable</label>' +
                                    '<span class="form-text d-block">When enabled, the value can be replaced if updated information is provided.</span></div>' +
                            '</div>' +
                        '</div>';
                    entriesContainer.appendChild(card);
                });

                document.addEventListener('click', function (e) {
                    if (e.target.closest('.remove-entry-btn')) {
                        var card = e.target.closest('.extraction-entry-card');
                        if (card) card.remove();
                    }
                });

                document.addEventListener('input', function (e) {
                    if (e.target.classList.contains('entry-name-input')) {
                        var card = e.target.closest('.extraction-entry-card');
                        if (card) {
                            var display = card.querySelector('.entry-name-display');
                            if (display) display.textContent = e.target.value || 'New Entry';
                        }
                    }
                });
            })();

            // --- Prompt Template Management ---
            (function () {
                var container = document.getElementById('promptTemplatesContainer');
                var dropdown = document.getElementById('promptTemplateDropdown');
                var searchInput = document.getElementById('promptTemplateSearch');
                var noResults = document.getElementById('promptTemplateNoResults');
                var emptyState = document.getElementById('promptTemplateEmptyState');
                var addButton = document.getElementById('addPromptTemplateBtn');
                if (!container) return;

                var promptOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.AvailablePromptTemplates.Select(t => new {
                        t.TemplateId, t.Title, t.Description, t.Category,
                        Parameters = t.Parameters.Select(p => new { p.Name, p.Description })
                    })));

                function escapeH(v) {
                    return (v || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
                }

                function getOption(id) {
                    return promptOptions.find(function (o) { return o.TemplateId === id; }) || null;
                }

                function buildParamsMarkup(option) {
                    if (!option || !option.Parameters || option.Parameters.length === 0) return '';
                    return option.Parameters.map(function (p) {
                        var desc = p.Description ? ': ' + escapeH(p.Description) : '';
                        return '<li><strong>' + escapeH(p.Name) + '</strong>' + desc + '</li>';
                    }).join('');
                }

                function createCard(templateId, promptParameters) {
                    var option = getOption(templateId);
                    var card = document.createElement('div');
                    var title = option && option.Title ? option.Title : templateId;
                    var description = option && option.Description ? option.Description : '';
                    var category = option ? option.Category : 'Unavailable';
                    var paramsMarkup = buildParamsMarkup(option);
                    var unavailableBadge = option ? '' : '<span class="badge text-bg-warning">Unavailable</span>';

                    card.className = 'card mb-1 prompt-template-card';
                    card.dataset.templateId = templateId;
                    card.innerHTML =
                        '<div class="card-header d-flex justify-content-between align-items-center py-2">' +
                            '<a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0" data-bs-toggle="collapse" href="#" role="button" aria-expanded="true">' +
                                '<i class="fa-solid fa-chevron-down me-1"></i>' +
                                '<span class="prompt-template-title fw-semibold">' + escapeH(title) + '</span>' +
                            '</a>' +
                            '<button type="button" class="btn btn-sm btn-danger remove-prompt-template-btn" title="Remove"><i class="fa-solid fa-trash"></i></button>' +
                        '</div>' +
                        '<div class="collapse show">' +
                            '<div class="card-body">' +
                                '<input type="hidden" class="prompt-template-id-input" value="' + escapeH(templateId) + '" />' +
                                '<div class="d-flex flex-wrap gap-2 mb-2">' +
                                    '<span class="badge text-bg-secondary">' + escapeH(category) + '</span>' +
                                    unavailableBadge +
                                '</div>' +
                                (description ? '<div class="text-muted small mb-3">' + escapeH(description) + '</div>' : '') +
                                '<div class="mb-3' + (paramsMarkup ? '' : ' d-none') + '">' +
                                    '<small class="text-muted d-block mb-1">Expected parameters:</small>' +
                                    '<ul class="mb-0 small text-muted">' + paramsMarkup + '</ul>' +
                                '</div>' +
                                '<div class="mb-1">' +
                                    '<label class="form-label">Template parameters</label>' +
                                    '<textarea class="form-control prompt-template-parameters-input" rows="3" placeholder=\'e.g., {"key1": "value1", "key2": "value2"}\'></textarea>' +
                                    '<span class="form-text">Optional JSON key-value pairs to pass as template arguments.</span>' +
                                    '<div class="text-danger small d-none prompt-template-parameters-error"></div>' +
                                '</div>' +
                            '</div>' +
                        '</div>';
                    card.querySelector('.prompt-template-parameters-input').value = promptParameters || '';
                    return card;
                }

                function updateEmptyState() {
                    if (emptyState) emptyState.classList.toggle('d-none', container.querySelectorAll('.prompt-template-card').length > 0);
                }

                function reindexCards() {
                    container.querySelectorAll('.prompt-template-card').forEach(function (card, index) {
                        var idInput = card.querySelector('.prompt-template-id-input');
                        var paramsInput = card.querySelector('.prompt-template-parameters-input');
                        if (idInput) idInput.name = 'PromptTemplates[' + index + '].TemplateId';
                        if (paramsInput) paramsInput.name = 'PromptTemplates[' + index + '].PromptParameters';
                    });
                }

                function validateParams(textarea) {
                    if (!textarea) return;
                    var errorEl = textarea.closest('.mb-1')?.querySelector('.prompt-template-parameters-error');
                    if (!errorEl) return;
                    var val = textarea.value.trim();
                    if (!val) { errorEl.classList.add('d-none'); return; }
                    try {
                        var parsed = JSON.parse(val);
                        if (typeof parsed !== 'object' || Array.isArray(parsed) || parsed === null) throw new Error();
                        for (var k in parsed) { if (typeof parsed[k] !== 'string') throw new Error(); }
                        errorEl.classList.add('d-none');
                    } catch { errorEl.textContent = 'Must be valid JSON with string key-value pairs.'; errorEl.classList.remove('d-none'); }
                }

                if (dropdown) {
                    dropdown.addEventListener('click', function (e) {
                        var btn = e.target.closest('.prompt-template-add-btn');
                        if (!btn) return;
                        container.appendChild(createCard(btn.dataset.templateId, ''));
                        reindexCards();
                        updateEmptyState();
                        var dd = bootstrap.Dropdown.getOrCreateInstance(addButton);
                        dd.hide();
                        container.querySelector('.prompt-template-card:last-child .prompt-template-parameters-input')?.focus();
                    });
                }

                document.addEventListener('click', function (e) {
                    var removeBtn = e.target.closest('.remove-prompt-template-btn');
                    if (!removeBtn) return;
                    var card = removeBtn.closest('.prompt-template-card');
                    if (card) { card.remove(); reindexCards(); updateEmptyState(); }
                });

                document.addEventListener('input', function (e) {
                    if (e.target.classList.contains('prompt-template-parameters-input')) validateParams(e.target);
                });

                if (searchInput && dropdown) {
                    searchInput.addEventListener('input', function () {
                        var query = (this.value || '').trim().toLowerCase();
                        var anyVisible = false;
                        var currentHeader = null, currentHeaderHasVisible = false;
                        dropdown.querySelectorAll('.dropdown-header, .prompt-template-add-btn').forEach(function (el) {
                            if (el.classList.contains('dropdown-header')) {
                                if (currentHeader && !currentHeaderHasVisible) currentHeader.classList.add('d-none');
                                currentHeader = el; currentHeaderHasVisible = false; currentHeader.classList.remove('d-none');
                                return;
                            }
                            var text = (el.dataset.templateTitle || '') + ' ' + (el.dataset.templateDescription || '');
                            var matches = !query || text.toLowerCase().includes(query);
                            el.classList.toggle('d-none', !matches);
                            if (matches) { anyVisible = true; currentHeaderHasVisible = true; }
                        });
                        if (currentHeader && !currentHeaderHasVisible) currentHeader.classList.add('d-none');
                        if (noResults) noResults.classList.toggle('d-none', anyVisible);
                    });
                }

                container.querySelectorAll('.prompt-template-parameters-input').forEach(validateParams);
                reindexCards();
                updateEmptyState();
            })();

            // --- Post Session Processing conditional visibility ---
            const enablePostSessionCheck = document.getElementById('enablePostSessionCheck');
            const postSessionTasksSection = document.getElementById('postSessionTasksSection');
            if (enablePostSessionCheck && postSessionTasksSection) {
                enablePostSessionCheck.addEventListener('change', function () {
                    postSessionTasksSection.classList.toggle('d-none', !this.checked);
                });
            }

            // --- Post Session Tasks ---
            const tasksContainer = document.getElementById('post-session-tasks');
            const addTaskBtn = document.getElementById('add-task-btn');
            let taskIndex = 0;

            if (addTaskBtn) {
                addTaskBtn.addEventListener('click', function () {
                    const idx = taskIndex++;
                    const card = document.createElement('div');
                    card.className = 'card mb-3 post-session-task-card';
                    card.innerHTML = `
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="card-title mb-2">Task ${idx + 1}</h6>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-task-btn"><i class="bi bi-trash"></i></button>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <label class="form-label">Name <span class="text-danger">*</span></label>
                                        <input name="PostSessionTasks[${idx}].Name" class="form-control" placeholder="e.g., sentiment_analysis" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <label class="form-label">Type</label>
                                        <select name="PostSessionTasks[${idx}].Type" class="form-select">
                                            <option value="Semantic">Semantic (free text)</option>
                                            <option value="PredefinedOptions">Predefined Options</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Instructions</label>
                                <textarea name="PostSessionTasks[${idx}].Instructions" class="form-control" rows="2" placeholder="Instructions for the AI model..."></textarea>
                            </div>
                            <div class="mb-2">
                                <div class="form-check">
                                    <input name="PostSessionTasks[${idx}].AllowMultipleValues" type="checkbox" class="form-check-input" value="true" />
                                    <label class="form-check-label">Allow multiple values</label>
                                </div>
                            </div>
                            <div class="mb-0">
                                <label class="form-label">Options (one per line, for Predefined Options type)</label>
                                <textarea name="PostSessionTasks[${idx}].Options" class="form-control" rows="3" placeholder="Option 1\nOption 2\nOption 3"></textarea>
                            </div>
                        </div>`;
                    tasksContainer.appendChild(card);
                });
            }

            document.addEventListener('click', function (e) {
                if (e.target.closest('.remove-task-btn')) {
                    e.target.closest('.post-session-task-card')?.remove();
                }
            });

            // --- Select All / Deselect All tools ---
            var selectAllBtn = document.getElementById('select-all-tools');
            var deselectAllBtn = document.getElementById('deselect-all-tools');

            if (selectAllBtn) {
                selectAllBtn.addEventListener('click', function () {
                    document.querySelectorAll('input[name="SelectedToolNames"]').forEach(function (cb) { cb.checked = true; });
                });
            }

            if (deselectAllBtn) {
                deselectAllBtn.addEventListener('click', function () {
                    document.querySelectorAll('input[name="SelectedToolNames"]').forEach(function (cb) { cb.checked = false; });
                });
            }

            // --- Document file management ---
            var docAddBtn = document.getElementById('doc-add-btn');
            var docAddInput = document.getElementById('doc-add-input');
            var pendingDocsList = document.getElementById('pending-docs-list');
            var pendingFiles = [];
            var fileContainer = document.createElement('div');
            fileContainer.style.display = 'none';
            document.querySelector('form').appendChild(fileContainer);

            if (docAddBtn) {
                docAddBtn.addEventListener('click', function () {
                    var files = docAddInput.files;
                    if (!files || files.length === 0) return;

                    for (var i = 0; i < files.length; i++) {
                        var file = files[i];
                        var idx = pendingFiles.length;
                        pendingFiles.push(file);

                        var row = document.createElement('div');
                        row.className = 'd-flex align-items-center mb-2 pending-doc-row';
                        row.dataset.index = idx;
                        row.innerHTML = '<i class="bi bi-file-earmark me-2"></i>' +
                            '<span class="flex-grow-1">' + escapeHtml(file.name) + ' <small class="text-muted">(' + formatSize(file.size) + ')</small></span>' +
                            '<button type="button" class="btn btn-sm btn-outline-danger ms-2 remove-pending-doc"><i class="bi bi-x"></i></button>';
                        pendingDocsList.appendChild(row);

                        var dt = new DataTransfer();
                        dt.items.add(file);
                        var hiddenInput = document.createElement('input');
                        hiddenInput.type = 'file';
                        hiddenInput.name = 'Documents';
                        hiddenInput.style.display = 'none';
                        hiddenInput.files = dt.files;
                        hiddenInput.dataset.docIndex = idx;
                        fileContainer.appendChild(hiddenInput);
                    }

                    docAddInput.value = '';
                });
            }

            document.addEventListener('click', function (e) {
                var removeBtn = e.target.closest('.remove-pending-doc');
                if (removeBtn) {
                    var row = removeBtn.closest('.pending-doc-row');
                    var idx = row.dataset.index;
                    row.remove();
                    var input = fileContainer.querySelector('input[data-doc-index="' + idx + '"]');
                    if (input) input.remove();
                }
            });

            // --- Conversion Goals conditional visibility ---
            const enableConversionMetricsCheck = document.getElementById('enableConversionMetricsCheck');
            const conversionGoalsSection = document.getElementById('conversionGoalsSection');
            if (enableConversionMetricsCheck && conversionGoalsSection) {
                enableConversionMetricsCheck.addEventListener('change', function () {
                    conversionGoalsSection.classList.toggle('d-none', !this.checked);
                });
            }

            // --- Conversion Goals Entries ---
            (function () {
                var goalsContainer = document.getElementById('conversionGoalsContainer');
                var addGoalBtn = document.getElementById('addConversionGoal');
                if (!goalsContainer || !addGoalBtn) return;

                addGoalBtn.addEventListener('click', function () {
                    var index = goalsContainer.querySelectorAll('.conversion-goal-card').length;
                    var card = document.createElement('div');
                    card.className = 'card mb-2 conversion-goal-card';
                    card.innerHTML =
                        '<div class="card-header d-flex justify-content-between align-items-center py-2">' +
                            '<a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0" data-bs-toggle="collapse" href="#goalCollapse_' + index + '" role="button" aria-expanded="true">' +
                                '<i class="fa-solid fa-chevron-down me-1"></i>' +
                                '<span class="goal-name-display fw-semibold">New Goal</span>' +
                            '</a>' +
                            '<button type="button" class="btn btn-sm btn-danger remove-goal-btn" title="Remove"><i class="fa-solid fa-trash"></i></button>' +
                        '</div>' +
                        '<div id="goalCollapse_' + index + '" class="collapse show">' +
                            '<div class="card-body">' +
                                '<div class="mb-3"><label class="form-label">Name</label>' +
                                    '<input type="text" class="form-control goal-name-input" name="ConversionGoals[' + index + '].Name" pattern="^[a-zA-Z0-9_]+$" required placeholder="e.g., booking_completed" />' +
                                    '<span class="form-text">A unique identifier. Only alphanumeric characters and underscores.</span></div>' +
                                '<div class="mb-3"><label class="form-label">Description</label>' +
                                    '<textarea class="form-control" name="ConversionGoals[' + index + '].Description" rows="3" placeholder="Describe what constitutes success for this goal"></textarea>' +
                                    '<span class="form-text">Provided to the AI model as evaluation criteria.</span></div>' +
                                '<div class="row">' +
                                    '<div class="col-md-6"><div class="mb-3"><label class="form-label">Min score</label>' +
                                        '<input type="number" class="form-control" name="ConversionGoals[' + index + '].MinScore" value="0" min="0" /></div></div>' +
                                    '<div class="col-md-6"><div class="mb-3"><label class="form-label">Max score</label>' +
                                        '<input type="number" class="form-control" name="ConversionGoals[' + index + '].MaxScore" value="10" min="1" /></div></div>' +
                                '</div>' +
                            '</div>' +
                        '</div>';
                    goalsContainer.appendChild(card);
                });

                document.addEventListener('click', function (e) {
                    if (e.target.closest('.remove-goal-btn')) {
                        var card = e.target.closest('.conversion-goal-card');
                        if (card) card.remove();
                    }
                });

                document.addEventListener('input', function (e) {
                    if (e.target.classList.contains('goal-name-input')) {
                        var card = e.target.closest('.conversion-goal-card');
                        if (card) {
                            var display = card.querySelector('.goal-name-display');
                            if (display) display.textContent = e.target.value || 'New Goal';
                        }
                    }
                });
            })();

            // --- Apply Template ---
            var applyTemplateSelect = document.getElementById('applyTemplateSelect');
            var applyTemplateBtn = document.getElementById('applyTemplateBtn');
            if (applyTemplateSelect && applyTemplateBtn) {
                applyTemplateSelect.addEventListener('change', function () {
                    applyTemplateBtn.disabled = !this.value;
                });

                applyTemplateBtn.addEventListener('click', function () {
                    var templateId = applyTemplateSelect.value;
                    if (!templateId) return;
                    window.location.href = '@Url.Action("Create", "AIProfile", new { area = "Admin" })' + '?templateId=' + encodeURIComponent(templateId);
                });
            }

            function escapeHtml(text) {
                var div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            function formatSize(bytes) {
                if (bytes < 1024) return bytes + ' B';
                if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
                return (bytes / 1048576).toFixed(1) + ' MB';
            }
        });
    </script>
}
