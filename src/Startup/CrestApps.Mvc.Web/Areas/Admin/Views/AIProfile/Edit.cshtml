@model CrestApps.Mvc.Web.Areas.Admin.ViewModels.AIProfileViewModel
@{
    ViewData["Title"] = "Edit AI Profile";
}

<h2><i class="bi bi-pencil"></i> Edit AI Profile</h2>
<hr />

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ItemId" />
    <div class="row">
        <div class="col-md-8">
            <ul class="nav nav-tabs" id="profileTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="basic-tab" data-bs-toggle="tab" data-bs-target="#basic" type="button" role="tab">Basic Info</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="params-tab" data-bs-toggle="tab" data-bs-target="#params" type="button" role="tab">AI Parameters</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="capabilities-tab" data-bs-toggle="tab" data-bs-target="#capabilities" type="button" role="tab">Capabilities</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button" role="tab">Documents</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="extraction-tab" data-bs-toggle="tab" data-bs-target="#extraction" type="button" role="tab">Data Extraction</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics" type="button" role="tab">Analytics</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">Settings</button>
                </li>
            </ul>

            <div class="tab-content p-3 border border-top-0 rounded-bottom" id="profileTabContent">
                <!-- Basic Info Tab -->
                <div class="tab-pane fade show active" id="basic" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required placeholder="e.g., my-chat-assistant" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DisplayText" class="form-label">Display text</label>
                        <input asp-for="DisplayText" class="form-control" placeholder="e.g., My Chat Assistant" />
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="Type" class="form-label">Profile type</label>
                                <select asp-for="Type" class="form-select" id="profileTypeSelect" asp-items="Html.GetEnumSelectList<CrestApps.AI.Models.AIProfileType>()"></select>
                                <div class="form-text">Choose the type of the profile.</div>
                            </div>
                        </div>
                        <div class="col-md-4 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")">
                            <div class="mb-3">
                                <label asp-for="TitleType" class="form-label">Title type</label>
                                <select asp-for="TitleType" class="form-select" asp-items="Html.GetEnumSelectList<CrestApps.AI.Models.AISessionTitleType>()">
                                    <option value="">— Default —</option>
                                </select>
                                <div class="form-text">How the chat session title is determined.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Agent-only: Description -->
                    <div class="mb-3 profile-type profile-type-agent@(Model.Type != CrestApps.AI.Models.AIProfileType.Agent ? " d-none" : "")">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe what this agent does so the orchestrator can decide when to invoke it."></textarea>
                        <div class="form-text">A description of what this agent does. Used by the orchestrator to determine when to route requests to this agent.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="ChatDeploymentId" class="form-label">Chat deployment</label>
                                <select asp-for="ChatDeploymentId" class="form-select" asp-items="Model.ChatDeployments"></select>
                                <div class="form-text">The chat model deployment to use.</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="UtilityDeploymentId" class="form-label">Utility deployment</label>
                                <select asp-for="UtilityDeploymentId" class="form-select" asp-items="Model.UtilityDeployments"></select>
                                <div class="form-text">Optional deployment for utility tasks (planning, summarization).</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="OrchestratorName" class="form-label">Orchestrator</label>
                                <select asp-for="OrchestratorName" class="form-select" asp-items="Model.Orchestrators"></select>
                                <div class="form-text">The orchestrator that manages AI interactions.</div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="SelectedTemplateId" class="form-label">AI template</label>
                                <select asp-for="SelectedTemplateId" class="form-select" asp-items="Model.Templates"></select>
                                <div class="form-text">Optionally apply a template to pre-fill the system message and parameters.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3 pt-4">
                                <div class="form-check form-switch">
                                    <input asp-for="EnableUserMemory" class="form-check-input" type="checkbox" />
                                    <label asp-for="EnableUserMemory" class="form-check-label">Enable user memory</label>
                                </div>
                                <div class="form-text">Store and recall user conversation history for personalized responses.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Chat-only: Prompt Subject -->
                    <div class="mb-3 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")">
                        <label asp-for="PromptSubject" class="form-label">Prompt subject</label>
                        <input asp-for="PromptSubject" class="form-control" placeholder="Optional subject context for the prompt" />
                        <div class="form-text">Provides context to the AI about the primary subject of the conversation.</div>
                    </div>

                    <!-- Chat-only: Add Initial Prompt toggle -->
                    <div class="mb-3 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")">
                        <div class="form-check form-switch">
                            <input asp-for="AddInitialPrompt" class="form-check-input" type="checkbox" id="addInitialPromptCheck" />
                            <label asp-for="AddInitialPrompt" class="form-check-label">Add initial prompt</label>
                        </div>
                        <div class="form-text">When enabled, each new chat session starts with an assistant message from the initial prompt and the welcome message is ignored.</div>
                    </div>

                    <!-- Chat-only: Welcome Message -->
                    <div class="mb-3 profile-type profile-type-chat@(Model.Type != CrestApps.AI.Models.AIProfileType.Chat ? " d-none" : "")" id="welcomeMessageGroup">
                        <label asp-for="WelcomeMessage" class="form-label">Welcome message</label>
                        <textarea asp-for="WelcomeMessage" class="form-control" rows="3" placeholder="Message shown when a chat starts"></textarea>
                        <div class="form-text">The welcome message to show on the user-interface when a new session is created.</div>
                    </div>

                    <!-- Chat-only: Initial Prompt -->
                    <div class="mb-3 profile-type profile-type-chat d-none" id="initialPromptGroup">
                        <label asp-for="InitialPrompt" class="form-label">Initial prompt</label>
                        <textarea asp-for="InitialPrompt" class="form-control" rows="4" placeholder="The assistant message added as the first chat history entry"></textarea>
                        <div class="form-text">This assistant message is added as the first chat history entry when a new session is created.</div>
                    </div>

                    <!-- TemplatePrompt-only: Prompt Template -->
                    <div class="mb-3 profile-type profile-type-template-prompt@(Model.Type != CrestApps.AI.Models.AIProfileType.TemplatePrompt ? " d-none" : "")">
                        <label asp-for="PromptTemplate" class="form-label">Prompt template</label>
                        <textarea asp-for="PromptTemplate" class="form-control" rows="5" placeholder="Template for generating prompts"></textarea>
                        <div class="form-text">
                            Liquid syntax is supported. Available variables: <code>{{ User.UserName }}</code>, <code>{{ User.Email }}</code>,
                            <code>{{ Session.Id }}</code>, <code>{{ Profile.Name }}</code>, and any custom parameters.
                        </div>
                    </div>
                </div>

                <!-- AI Parameters Tab -->
                <div class="tab-pane fade" id="params" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="SystemMessage" class="form-label">System message</label>
                        <textarea asp-for="SystemMessage" class="form-control" rows="5" placeholder="You are a helpful AI assistant..."></textarea>
                        <div class="form-text">Instructions that guide the AI's behavior throughout the conversation.</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Temperature" class="form-label">Temperature</label>
                                <input asp-for="Temperature" type="number" class="form-control" step="0.01" min="0" max="2" placeholder="0.0 - 2.0" />
                                <div class="form-text">Controls randomness. Lower = more focused, higher = more creative.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="TopP" class="form-label">Top P</label>
                                <input asp-for="TopP" type="number" class="form-control" step="0.01" min="0" max="1" placeholder="0.0 - 1.0" />
                                <div class="form-text">Nucleus sampling. Controls diversity of responses.</div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="FrequencyPenalty" class="form-label">Frequency penalty</label>
                                <input asp-for="FrequencyPenalty" type="number" class="form-control" step="0.01" min="-2" max="2" placeholder="-2.0 - 2.0" />
                                <div class="form-text">Penalizes repeated tokens. Higher = less repetition.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PresencePenalty" class="form-label">Presence penalty</label>
                                <input asp-for="PresencePenalty" type="number" class="form-control" step="0.01" min="-2" max="2" placeholder="-2.0 - 2.0" />
                                <div class="form-text">Penalizes tokens already present. Higher = more topic variety.</div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="MaxTokens" class="form-label">Max output tokens</label>
                                <input asp-for="MaxTokens" type="number" class="form-control" min="1" placeholder="Leave blank for model default" />
                                <div class="form-text">Maximum number of tokens in the response.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PastMessagesCount" class="form-label">Past messages count</label>
                                <input asp-for="PastMessagesCount" type="number" class="form-control" min="0" placeholder="Leave blank for all" />
                                <div class="form-text">Number of previous messages to include in context.</div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="UseCaching" class="form-check-input" type="checkbox" />
                            <label asp-for="UseCaching" class="form-check-label">Enable response caching</label>
                        </div>
                        <div class="form-text">Cache responses to improve performance for repeated queries.</div>
                    </div>
                </div>

                <!-- Capabilities Tab -->
                <div class="tab-pane fade" id="capabilities" role="tabpanel">
                    <!-- AI Tools -->
                    <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-tools"></i> AI Tools</h6>
                    @if (Model.AvailableTools.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No selectable AI tools are registered.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <p class="text-muted mb-0 small">Select the tools this profile can use during conversations.</p>
                            <div class="btn-group btn-group-sm ms-3" role="group">
                                <button type="button" class="btn btn-outline-primary" id="select-all-tools"><i class="bi bi-check-all"></i> Select All</button>
                                <button type="button" class="btn btn-outline-secondary" id="deselect-all-tools"><i class="bi bi-x-lg"></i> Deselect All</button>
                            </div>
                        </div>
                        @foreach (var group in Model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                        {
                            <h6 class="text-secondary mt-3 mb-2"><i class="bi bi-folder"></i> @group.Key</h6>
                            @foreach (var tool in group)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="SelectedToolNames" value="@tool.Name" id="tool_@tool.Name"
                                           @(tool.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="tool_@tool.Name">
                                        <strong>@tool.Title</strong>
                                        @if (!string.IsNullOrEmpty(tool.Description))
                                        {
                                            <br /><small class="text-muted">@tool.Description</small>
                                        }
                                    </label>
                                </div>
                            }
                        }
                    }

                    <!-- A2A -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h6>
                    @if (Model.AvailableA2AConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No A2A host connections are configured.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the remote A2A hosts this profile can use.</p>
                        @foreach (var connection in Model.AvailableA2AConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedA2AConnectionIds" value="@connection.ItemId" id="a2a_@connection.ItemId"
                                       @(connection.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="a2a_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong><br />
                                    <small class="text-muted">@connection.Endpoint</small>
                                </label>
                            </div>
                        }
                    }

                    <!-- MCP -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-plug"></i> MCP Connections</h6>
                    @if (Model.AvailableMcpConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> No MCP connections are configured.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the MCP server connections this profile can use.</p>
                        @foreach (var connection in Model.AvailableMcpConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedMcpConnectionIds" value="@connection.ItemId" id="mcp_@connection.ItemId"
                                       @(connection.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="mcp_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(connection.Source))
                                    {
                                        <br /><small class="text-muted">@connection.Source</small>
                                    }
                                </label>
                            </div>
                        }
                    }
                </div>

                <!-- Documents Tab -->
                <div class="tab-pane fade" id="docs" role="tabpanel">
                    @if (Model.HasDocumentIndexConfiguration)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Documents are indexed into the <strong>@Model.DocumentIndexProfileName</strong> AI Documents index.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> Document knowledge-base search is not configured. Create an <strong>AI Documents</strong> index profile and select it in <strong>Settings</strong>.
                        </div>
                    }
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="AllowSessionDocuments" class="form-check-input" type="checkbox" />
                            <label asp-for="AllowSessionDocuments" class="form-check-label">Allow session document uploads</label>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DocumentTopN" class="form-label">Document Top N</label>
                                <input asp-for="DocumentTopN" type="number" class="form-control" min="1" max="20" placeholder="Default: 3" />
                            </div>
                        </div>
                    </div>
                    @if (Model.AttachedDocuments.Count > 0)
                    {
                        <h6 class="mt-3 mb-2"><i class="bi bi-file-earmark-text"></i> Attached Documents</h6>
                        @foreach (var doc in Model.AttachedDocuments)
                        {
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-file-earmark me-2"></i>
                                <span class="flex-grow-1">@doc.FileName <small class="text-muted">(@(doc.FileSize < 1024 ? doc.FileSize + " B" : doc.FileSize < 1048576 ? (doc.FileSize / 1024.0).ToString("F1") + " KB" : (doc.FileSize / 1048576.0).ToString("F1") + " MB"))</small></span>
                            </div>
                        }
                    }
                </div>

                <!-- Data Extraction Tab -->
                <div class="tab-pane fade" id="extraction" role="tabpanel">
                    <p class="text-muted mb-3">Configure automatic data extraction from conversations.</p>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableDataExtraction" class="form-check-input" type="checkbox" id="enableDataExtractionCheck" />
                            <label asp-for="EnableDataExtraction" class="form-check-label">Enable data extraction</label>
                        </div>
                    </div>
                    <div id="dataExtractionSettings" class="@(Model.EnableDataExtraction ? "" : "d-none")">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ExtractionCheckInterval" class="form-label">Extraction check interval</label>
                                    <input asp-for="ExtractionCheckInterval" type="number" class="form-control" min="1" max="20" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="SessionInactivityTimeoutInMinutes" class="form-label">Session inactivity timeout (minutes)</label>
                                    <input asp-for="SessionInactivityTimeoutInMinutes" type="number" class="form-control" min="1" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Analytics Tab -->
                <div class="tab-pane fade" id="analytics" role="tabpanel">
                    <h6 class="mb-2"><i class="bi bi-graph-up"></i> Session Metrics</h6>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="EnableSessionMetrics" class="form-check-input" type="checkbox" />
                            <label asp-for="EnableSessionMetrics" class="form-check-label">Enable session metrics</label>
                        </div>
                    </div>

                    <h6 class="mb-2"><i class="bi bi-clipboard-check"></i> Post-session Processing</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnablePostSessionProcessing" class="form-check-input" type="checkbox" id="enablePostSessionCheck" />
                            <label asp-for="EnablePostSessionProcessing" class="form-check-label">Enable post-session processing</label>
                        </div>
                    </div>

                    <div id="postSessionTasksSection" class="@(Model.EnablePostSessionProcessing ? "" : "d-none")">
                        <div id="post-session-tasks">
                            @for (var i = 0; i < Model.PostSessionTasks.Count; i++)
                            {
                                var task = Model.PostSessionTasks[i];
                                <div class="card mb-3 post-session-task-card">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h6 class="card-title mb-2">Task @(i + 1)</h6>
                                            <button type="button" class="btn btn-sm btn-outline-danger remove-task-btn"><i class="bi bi-trash"></i></button>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-2">
                                                    <label class="form-label">Name <span class="text-danger">*</span></label>
                                                    <input name="PostSessionTasks[@i].Name" class="form-control" value="@task.Name" required />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-2">
                                                    <label class="form-label">Type</label>
                                                    <select name="PostSessionTasks[@i].Type" class="form-select">
                                                        @if (task.Type == CrestApps.AI.Models.PostSessionTaskType.Semantic)
                                                        {
                                                            <option value="Semantic" selected>Semantic</option>
                                                            <option value="PredefinedOptions">Predefined Options</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="Semantic">Semantic</option>
                                                            <option value="PredefinedOptions" selected>Predefined Options</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label">Instructions</label>
                                            <textarea name="PostSessionTasks[@i].Instructions" class="form-control" rows="2">@task.Instructions</textarea>
                                        </div>
                                        <div class="mb-2">
                                            <div class="form-check">
                                                <input name="PostSessionTasks[@i].AllowMultipleValues" type="checkbox" class="form-check-input" value="true" @(task.AllowMultipleValues ? "checked" : "") />
                                                <label class="form-check-label">Allow multiple values</label>
                                            </div>
                                        </div>
                                        <div class="mb-0">
                                            <label class="form-label">Options (one per line)</label>
                                            <textarea name="PostSessionTasks[@i].Options" class="form-control" rows="3">@task.Options</textarea>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="add-task-btn">
                            <i class="bi bi-plus-circle"></i> Add Task
                        </button>
                    </div>
                </div>

                <!-- Settings Tab -->
                <div class="tab-pane fade" id="settings" role="tabpanel">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsListable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsListable" class="form-check-label">Listable</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsRemovable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsRemovable" class="form-check-label">Removable</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="LockSystemMessage" class="form-check-input" type="checkbox" />
                            <label asp-for="LockSystemMessage" class="form-check-label">Lock system message</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Save
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var profileTypeSelect = document.getElementById('profileTypeSelect');
            var addInitialPromptCheck = document.getElementById('addInitialPromptCheck');
            var welcomeMessageGroup = document.getElementById('welcomeMessageGroup');
            var initialPromptGroup = document.getElementById('initialPromptGroup');

            function convertToKebabCase(str) {
                return str.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
            }

            function toggleProfileTypeFields() {
                if (!profileTypeSelect) return;
                var value = profileTypeSelect.value;
                var className = 'profile-type-' + convertToKebabCase(value);
                document.querySelectorAll('.profile-type').forEach(function (el) {
                    el.classList.toggle('d-none', !el.classList.contains(className));
                });
                toggleInitialPromptFields();
            }

            function toggleInitialPromptFields() {
                if (!profileTypeSelect || !addInitialPromptCheck || !welcomeMessageGroup || !initialPromptGroup) return;
                var isChatType = profileTypeSelect.value === 'Chat';
                var showInitialPrompt = addInitialPromptCheck.checked;
                welcomeMessageGroup.classList.toggle('d-none', !isChatType || showInitialPrompt);
                initialPromptGroup.classList.toggle('d-none', !isChatType || !showInitialPrompt);
            }

            if (profileTypeSelect) {
                profileTypeSelect.addEventListener('change', toggleProfileTypeFields);
                toggleProfileTypeFields();
            }
            if (addInitialPromptCheck) {
                addInitialPromptCheck.addEventListener('change', toggleInitialPromptFields);
            }

            var enableDataExtractionCheck = document.getElementById('enableDataExtractionCheck');
            var dataExtractionSettings = document.getElementById('dataExtractionSettings');
            if (enableDataExtractionCheck && dataExtractionSettings) {
                enableDataExtractionCheck.addEventListener('change', function () {
                    dataExtractionSettings.classList.toggle('d-none', !this.checked);
                });
            }

            var enablePostSessionCheck = document.getElementById('enablePostSessionCheck');
            var postSessionTasksSection = document.getElementById('postSessionTasksSection');
            if (enablePostSessionCheck && postSessionTasksSection) {
                enablePostSessionCheck.addEventListener('change', function () {
                    postSessionTasksSection.classList.toggle('d-none', !this.checked);
                });
            }

            var tasksContainer = document.getElementById('post-session-tasks');
            var addTaskBtn = document.getElementById('add-task-btn');
            var taskIndex = @Model.PostSessionTasks.Count;

            if (addTaskBtn) {
                addTaskBtn.addEventListener('click', function () {
                    var idx = taskIndex++;
                    var card = document.createElement('div');
                    card.className = 'card mb-3 post-session-task-card';
                    card.innerHTML = '<div class="card-body"><div class="d-flex justify-content-between align-items-start"><h6 class="card-title mb-2">Task ' + (idx + 1) + '</h6><button type="button" class="btn btn-sm btn-outline-danger remove-task-btn"><i class="bi bi-trash"></i></button></div><div class="row"><div class="col-md-6"><div class="mb-2"><label class="form-label">Name <span class="text-danger">*</span></label><input name="PostSessionTasks[' + idx + '].Name" class="form-control" required /></div></div><div class="col-md-6"><div class="mb-2"><label class="form-label">Type</label><select name="PostSessionTasks[' + idx + '].Type" class="form-select"><option value="Semantic">Semantic</option><option value="PredefinedOptions">Predefined Options</option></select></div></div></div><div class="mb-2"><label class="form-label">Instructions</label><textarea name="PostSessionTasks[' + idx + '].Instructions" class="form-control" rows="2"></textarea></div><div class="mb-2"><div class="form-check"><input name="PostSessionTasks[' + idx + '].AllowMultipleValues" type="checkbox" class="form-check-input" value="true" /><label class="form-check-label">Allow multiple values</label></div></div><div class="mb-0"><label class="form-label">Options (one per line)</label><textarea name="PostSessionTasks[' + idx + '].Options" class="form-control" rows="3"></textarea></div></div>';
                    tasksContainer.appendChild(card);
                });
            }

            document.addEventListener('click', function (e) {
                if (e.target.closest('.remove-task-btn')) {
                    e.target.closest('.post-session-task-card')?.remove();
                }
            });

            var selectAllBtn = document.getElementById('select-all-tools');
            var deselectAllBtn = document.getElementById('deselect-all-tools');
            if (selectAllBtn) {
                selectAllBtn.addEventListener('click', function () {
                    document.querySelectorAll('input[name="SelectedToolNames"]').forEach(function (cb) { cb.checked = true; });
                });
            }
            if (deselectAllBtn) {
                deselectAllBtn.addEventListener('click', function () {
                    document.querySelectorAll('input[name="SelectedToolNames"]').forEach(function (cb) { cb.checked = false; });
                });
            }
        });
    </script>
}