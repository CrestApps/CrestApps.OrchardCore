@model CrestApps.Mvc.Web.Areas.Admin.ViewModels.ChatInteractionChatViewModel
@{
    ViewData["Title"] = "Chat - " + (Model.Title ?? "Untitled Chat");
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/default.min.css" />

<style>
    .chat-page-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 180px);
    }
    .ai-chat-messages { padding: 1rem; }
    .ai-chat-messages .ai-chat-message-item { position: relative; padding: 0.25rem 0; }
    .ai-chat-messages .ai-chat-message-item + .ai-chat-message-item::before {
        content: '';
        display: block;
        width: 100%;
        margin-bottom: 0.25rem;
        border-top: 1px solid var(--bs-border-color, #dee2e6);
    }
    .ai-chat-messages .ai-chat-message-item p:last-child { margin-bottom: 0; }
    .ai-chat-msg-role { font-size: 0.75rem; font-weight: 600; margin-bottom: 2px; }
    .ai-chat-msg-role-user { color: #0d6efd; }
    .ai-chat-msg-role-assistant { color: #6f42c1; }
    .ai-chat-msg-role-assistant i.ai-streaming-icon { animation: pulse 1.5s infinite; }
    .ai-chat-msg-role-assistant i.ai-bot-icon { color: #6f42c1; }
    .ai-chat-messages .message-buttons-container {
        position: absolute;
        bottom: 0.25rem;
        right: 0.25rem;
        display: none;
    }
    .ai-chat-messages .ai-chat-message-item:hover .message-buttons-container {
        display: inline-block;
    }
    @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* Settings sidebar */
    .chat-settings-sidebar {
        height: calc(100vh - 180px);
        overflow-y: auto;
        border-right: 1px solid var(--bs-border-color, #dee2e6);
    }
    .chat-settings-sidebar .nav-pills .nav-link {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
    }
    .chat-settings-sidebar .nav-pills .nav-link.active {
        background-color: var(--bs-primary);
    }
    .settings-section label.form-label {
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    .settings-save-indicator {
        font-size: 0.85rem;
        min-height: 1.25rem;
        transition: opacity 0.3s ease;
    }
    .capability-section + .capability-section {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--bs-border-color, #dee2e6);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-chat-left-dots"></i> @(Model.Title ?? "Untitled Chat")</h5>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div class="row g-0 border rounded" style="height: calc(100vh - 180px);">
    <!-- Left: Settings Sidebar -->
    <div class="col-md-4 col-lg-3 chat-settings-sidebar bg-light">
        <div class="p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong class="small text-uppercase text-muted">Settings</strong>
                <span id="settings-save-indicator" class="settings-save-indicator text-muted"></span>
            </div>

            <!-- Settings Tabs -->
            <ul class="nav nav-pills nav-fill mb-3" id="settingsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-settings" data-bs-toggle="pill" data-bs-target="#pane-settings" type="button" role="tab">
                        <i class="bi bi-gear"></i> General
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-capabilities" data-bs-toggle="pill" data-bs-target="#pane-capabilities" type="button" role="tab">
                        <i class="bi bi-lightning"></i> Capabilities
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-knowledge" data-bs-toggle="pill" data-bs-target="#pane-knowledge" type="button" role="tab">
                        <i class="bi bi-database"></i> Knowledge
                    </button>
                </li>
            </ul>

            <div class="tab-content settings-section" id="settingsTabContent">
                <!-- Tab 1: General Settings -->
                <div class="tab-pane fade show active" id="pane-settings" role="tabpanel">
                    <div class="mb-2">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control setting-input" id="setting-title"
                               value="@Model.Title" placeholder="e.g., Code Helper" data-setting="title" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Deployment</label>
                        <select class="form-select setting-input" id="setting-deployment" data-setting="deploymentName">
                            <option value="">— Select deployment —</option>
                            @foreach (var d in Model.Deployments)
                            {
                                <option value="@d.Value" selected="@(d.Value == Model.ChatDeploymentName)">@d.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Orchestrator</label>
                        <select class="form-select setting-input" id="setting-orchestratorName" data-setting="orchestratorName">
                            @foreach (var o in Model.Orchestrators)
                            {
                                <option value="@o.Value" selected="@(o.Value == Model.OrchestratorName)">@o.Text</option>
                            }
                        </select>
                    </div>

                    @* Copilot panel (shown/hidden by orchestrator-dependent JS in the partial) *@
                    @await Html.PartialAsync("_CopilotConfig", null, new ViewDataDictionary(ViewData) {
                        { "CopilotPrefix", "ci" },
                        { "CopilotAuthType", Model.CopilotAuthenticationType },
                        { "CopilotIsConfigured", Model.CopilotIsConfigured },
                        { "CopilotIsAuth", Model.CopilotIsAuthenticated },
                        { "CopilotUsername", Model.CopilotGitHubUsername },
                        { "CopilotModel", Model.CopilotModel },
                        { "CopilotIsAllowAll", Model.CopilotIsAllowAll },
                        { "CopilotModels", Model.CopilotAvailableModels },
                    })

                    <!-- Prompt Templates -->
                    @if (Model.AvailablePromptTemplates.Count > 0)
                    {
                        <div class="mb-2">
                            <label class="form-label">Prompt templates</label>
                            <div class="dropdown mb-2">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle w-100" type="button"
                                        id="chatPromptTemplateBtn" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-plus-lg"></i> Add template
                                </button>
                                <div class="dropdown-menu p-2" style="max-height:20rem;min-width:18rem;overflow-y:auto;">
                                    <input type="search" class="form-control mb-2" id="chatPromptTemplateSearch" placeholder="Search..." />
                                    <div class="chat-prompt-template-menu">
                                        @foreach (var group in Model.AvailablePromptTemplates.GroupBy(t => t.Category).OrderBy(g => g.Key))
                                        {
                                            <div class="dropdown-header px-2 small">@group.Key</div>
                                            @foreach (var option in group)
                                            {
                                                <button type="button"
                                                        class="dropdown-item chat-prompt-add-btn text-wrap small"
                                                        data-template-id="@option.TemplateId"
                                                        data-template-title="@option.Title"
                                                        data-template-description="@(option.Description ?? "")"
                                                        data-template-params="@(System.Text.Json.JsonSerializer.Serialize(option.Parameters.Select(p => new { p.Name, p.Description })))">
                                                    @option.Title
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                            <div id="chatPromptTemplatesContainer"></div>
                        </div>
                    }

                    <div class="mb-2">
                        <label class="form-label">System message</label>
                        <textarea class="form-control setting-input" id="setting-systemMessage"
                                  rows="3" placeholder="You are a helpful assistant..." data-setting="systemMessage">@Model.SystemMessage</textarea>
                    </div>

                    <div class="row g-2">
                        <div class="col-4">
                            <div class="mb-2">
                                <label class="form-label">Temperature</label>
                                <input type="number" class="form-control setting-input" id="setting-temperature"
                                       step="0.1" min="0" max="2" value="@Model.Temperature" placeholder="0.7" data-setting="temperature" />
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="mb-2">
                                <label class="form-label">Top P</label>
                                <input type="number" class="form-control setting-input" id="setting-topP"
                                       step="0.1" min="0" max="1" value="@Model.TopP" placeholder="1.0" data-setting="topP" />
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="mb-2">
                                <label class="form-label">Max tokens</label>
                                <input type="number" class="form-control setting-input" id="setting-maxTokens"
                                       min="1" value="@Model.MaxTokens" placeholder="4096" data-setting="maxTokens" />
                            </div>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-4">
                            <div class="mb-2">
                                <label class="form-label">Freq. penalty</label>
                                <input type="number" class="form-control setting-input" id="setting-frequencyPenalty"
                                       step="0.1" min="-2" max="2" value="@Model.FrequencyPenalty" placeholder="0" data-setting="frequencyPenalty" />
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="mb-2">
                                <label class="form-label">Pres. penalty</label>
                                <input type="number" class="form-control setting-input" id="setting-presencePenalty"
                                       step="0.1" min="-2" max="2" value="@Model.PresencePenalty" placeholder="0" data-setting="presencePenalty" />
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="mb-2">
                                <label class="form-label">Past msgs</label>
                                <input type="number" class="form-control setting-input" id="setting-pastMessagesCount"
                                       min="0" value="@Model.PastMessagesCount" placeholder="10" data-setting="pastMessagesCount" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab 2: Capabilities -->
                <div class="tab-pane fade" id="pane-capabilities" role="tabpanel">
                    <!-- AI Agents -->
                    @if (Model.AvailableAgents.Count > 0)
                    {
                        <div class="capability-section">
                            <h6 class="small fw-bold mb-2"><i class="bi bi-robot"></i> AI Agents</h6>
                            @foreach (var agent in Model.AvailableAgents)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input capability-checkbox" type="checkbox"
                                           value="@agent.Name" id="chat_agent_@agent.Name" data-group="agentNames"
                                           @(agent.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="chat_agent_@agent.Name">
                                        @agent.DisplayText
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    <!-- AI Tools -->
                    @if (Model.AvailableTools.Count > 0)
                    {
                        <div class="capability-section">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="small fw-bold mb-0"><i class="bi bi-tools"></i> AI Tools</h6>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary btn-sm py-0 px-1" id="chat-select-all-tools" style="font-size:0.7rem;">All</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1" id="chat-deselect-all-tools" style="font-size:0.7rem;">None</button>
                                </div>
                            </div>
                            @foreach (var group in Model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                            {
                                <div class="text-muted small fw-semibold mt-2 mb-1">@group.Key</div>
                                @foreach (var tool in group)
                                {
                                    <div class="form-check mb-1">
                                        <input class="form-check-input capability-checkbox chat-tool-checkbox" type="checkbox"
                                               value="@tool.Name" id="chat_tool_@tool.Name" data-group="toolNames"
                                               @(tool.IsSelected ? "checked" : "") />
                                        <label class="form-check-label" for="chat_tool_@tool.Name">
                                            @tool.Title
                                            @if (!string.IsNullOrEmpty(tool.Description))
                                            {
                                                <br /><span class="text-muted" style="font-size:0.7rem;">@tool.Description</span>
                                            }
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    }

                    <!-- A2A Connections -->
                    @if (Model.AvailableA2AConnections.Count > 0)
                    {
                        <div class="capability-section">
                            <h6 class="small fw-bold mb-2"><i class="bi bi-diagram-3"></i> A2A Hosts</h6>
                            @foreach (var connection in Model.AvailableA2AConnections)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input capability-checkbox" type="checkbox"
                                           value="@connection.ItemId" id="chat_a2a_@connection.ItemId" data-group="a2aConnectionIds"
                                           @(connection.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="chat_a2a_@connection.ItemId">
                                        @connection.DisplayText
                                        <br /><span class="text-muted" style="font-size:0.7rem;">@connection.Endpoint</span>
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    <!-- MCP Hosts -->
                    @if (Model.AvailableMcpConnections.Count > 0)
                    {
                        <div class="capability-section">
                            <h6 class="small fw-bold mb-2"><i class="bi bi-plug"></i> MCP Hosts</h6>
                            @foreach (var connection in Model.AvailableMcpConnections)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input capability-checkbox" type="checkbox"
                                           value="@connection.ItemId" id="chat_mcp_@connection.ItemId" data-group="mcpConnectionIds"
                                           @(connection.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="chat_mcp_@connection.ItemId">
                                        @connection.DisplayText
                                        @if (!string.IsNullOrEmpty(connection.Source))
                                        {
                                            <br /><span class="text-muted" style="font-size:0.7rem;">@connection.Source</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    @if (Model.AvailableAgents.Count == 0 && Model.AvailableTools.Count == 0
                        && Model.AvailableA2AConnections.Count == 0 && Model.AvailableMcpConnections.Count == 0)
                    {
                        <div class="text-muted small text-center py-3">
                            <i class="bi bi-info-circle"></i> No capabilities are available to configure.
                        </div>
                    }
                </div>

                <!-- Tab 3: Knowledge Base -->
                <div class="tab-pane fade" id="pane-knowledge" role="tabpanel">
                    <div class="mb-2">
                        <label class="form-label">Data source</label>
                        <select class="form-select setting-input" id="setting-dataSourceId" data-setting="dataSourceId">
                            <option value="">— None —</option>
                            @foreach (var ds in Model.DataSources)
                            {
                                <option value="@ds.Value" selected="@(ds.Value == Model.DataSourceId)">@ds.Text</option>
                            }
                        </select>
                        <div class="form-text">External data source for AI context.</div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Document Top N</label>
                        <input type="number" class="form-control setting-input" id="setting-documentTopN"
                               min="1" max="20" value="@Model.DocumentTopN" placeholder="Default: 3" data-setting="documentTopN" />
                        <div class="form-text">Number of top matching document chunks to include as context.</div>
                    </div>

                    @if (Model.HasDocumentIndexConfiguration)
                    {
                        <div class="alert alert-info small py-2 mb-2">
                            <i class="bi bi-info-circle"></i> Documents are indexed into <strong>@Model.DocumentIndexProfileName</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning small py-2 mb-2">
                            <i class="bi bi-exclamation-triangle"></i> Document indexing is not configured.
                        </div>
                    }

                    <div class="mb-2">
                        <label class="form-label"><i class="bi bi-paperclip"></i> Upload documents</label>
                        <input type="file" class="form-control" id="chat-doc-upload" multiple
                               accept=".txt,.md,.csv,.json,.xml,.html,.pdf,.docx,.xlsx,.pptx" />
                        <div class="form-text">Supported: Text, Markdown, JSON, XML, HTML, PDF, Office docs.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Chat Area -->
    <div class="col-md-8 col-lg-9 d-flex flex-column" style="height: 100%;">
        <!-- Chat header with Clear History -->
        <div class="d-flex justify-content-between align-items-center border-bottom px-3 py-2 bg-white">
            <span class="text-muted small" id="chat-title-display">
                <i class="bi bi-chat-left-dots"></i> <span id="chat-title-text">@(Model.Title ?? "Untitled Chat")</span>
            </span>
            <button type="button" id="clear-history-btn" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash3"></i> Clear history
            </button>
        </div>

        <!-- Messages container -->
        <div id="chat-container" class="flex-grow-1 overflow-auto">
            <div id="chat-placeholder">
                <div class="p-3 text-muted">
                    <i class="bi bi-robot"></i> Start chatting! Your messages are sent directly to the AI with the parameters you configured.
                </div>
            </div>
            <div id="chat-app"></div>
        </div>

        <!-- Input area -->
        <div class="border-top p-3 bg-white">
            <div class="d-flex gap-2">
                <textarea id="chat-input"
                          class="form-control"
                          rows="1"
                          placeholder="Type a message..."
                          data-item-id="@Model.ItemId"></textarea>
                <button type="button" id="send-btn" class="btn btn-primary">
                    <i class="bi bi-send"></i> Send
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var itemId = '@Model.ItemId';
            var hubUrl = '/hubs/chat-interaction';
            var existingMessages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExistingMessages));

            // --- Markdown rendering ---
            var renderer = new marked.Renderer();
            renderer.link = function (data) {
                return '<a href="' + DOMPurify.sanitize(data.href) + '" target="_blank" rel="noopener noreferrer">' + data.text + '</a>';
            };
            marked.setOptions({
                renderer: renderer,
                highlight: function (code, lang) {
                    if (lang && hljs.getLanguage(lang)) {
                        return hljs.highlight(code, { language: lang }).value;
                    }
                    return hljs.highlightAuto(code).value;
                }
            });

            function renderMarkdown(text) {
                return DOMPurify.sanitize(marked.parse(text || ''));
            }

            // --- Vue app for messages ---
            var app = Vue.createApp({
                data: function () {
                    return {
                        messages: existingMessages.map(function (m) {
                            return {
                                role: m.role,
                                content: m.content,
                                htmlContent: renderMarkdown(m.content),
                                isStreaming: false,
                                isSystem: false
                            };
                        })
                    };
                },
                methods: {
                    addMessage: function (role, content, isStreaming, isSystem) {
                        this.messages.push({
                            role: role,
                            content: content,
                            htmlContent: renderMarkdown(content),
                            isStreaming: isStreaming || false,
                            isSystem: isSystem || false
                        });
                        var self = this;
                        this.$nextTick(function () { self.scrollToBottom(); });
                    },
                    appendToLast: function (token) {
                        var last = this.messages[this.messages.length - 1];
                        if (last && last.role === 'assistant') {
                            last.content += token;
                            last.htmlContent = renderMarkdown(last.content);
                        }
                    },
                    finishStreaming: function () {
                        var last = this.messages[this.messages.length - 1];
                        if (last) {
                            last.isStreaming = false;
                            last.htmlContent = renderMarkdown(last.content);
                        }
                        var self = this;
                        this.$nextTick(function () { self.scrollToBottom(); });
                    },
                    clearAll: function () {
                        this.messages = [];
                    },
                    scrollToBottom: function () {
                        var container = document.getElementById('chat-container');
                        if (container) container.scrollTop = container.scrollHeight;
                    },
                    copyResponse: function (content) {
                        navigator.clipboard.writeText(content);
                    }
                },
                template:
                    '<div class="ai-chat-messages">' +
                        '<div v-for="(message, index) in messages" :key="index" class="ai-chat-message-item">' +
                            '<div v-if="message.isSystem" class="text-center py-2">' +
                                '<span class="badge text-bg-secondary"><i class="bi bi-info-circle"></i> {{ message.content }}</span>' +
                            '</div>' +
                            '<template v-else>' +
                                '<div v-if="message.role === \'user\'" class="ai-chat-msg-role ai-chat-msg-role-user">You</div>' +
                                '<div v-else class="ai-chat-msg-role ai-chat-msg-role-assistant">' +
                                    '<i :class="\'bi bi-robot\' + (message.isStreaming ? \' ai-streaming-icon\' : \' ai-bot-icon\')"></i> ' +
                                    'Assistant' +
                                '</div>' +
                                '<div class="lh-base">' +
                                    '<div v-html="message.htmlContent"></div>' +
                                    '<span class="message-buttons-container" v-if="message.role === \'assistant\' && !message.isStreaming">' +
                                        '<button class="btn btn-sm btn-link text-secondary p-0" v-on:click="copyResponse(message.content)" title="Copy response">' +
                                            '<i class="bi bi-clipboard"></i>' +
                                        '</button>' +
                                    '</span>' +
                                '</div>' +
                            '</template>' +
                        '</div>' +
                    '</div>'
            });

            var vm = app.mount('#chat-app');

            // --- SignalR connection ---
            var connection = new signalR.HubConnectionBuilder()
                .withUrl(hubUrl)
                .withAutomaticReconnect()
                .build();

            var isSending = false;

            connection.start().then(function () {
                console.log('Connected to ChatInteraction hub.');
            }).catch(function (err) {
                console.error('SignalR connection error:', err);
            });

            connection.on('ReceiveError', function (error) {
                vm.addMessage('assistant', '\u26a0\ufe0f ' + error);
            });

            connection.on('SettingsSaved', function (savedItemId, title) {
                showSaveIndicator('Saved \u2713', 'text-success');
                if (title) {
                    var titleEl = document.getElementById('chat-title-text');
                    if (titleEl) titleEl.textContent = title;
                }
            });

            connection.on('HistoryCleared', function () {
                vm.clearAll();
                vm.addMessage('system', 'Chat history cleared.', false, true);
                var placeholder = document.getElementById('chat-placeholder');
                if (placeholder) placeholder.style.display = 'none';
            });

            // --- Send message ---
            var inputEl = document.getElementById('chat-input');
            var sendBtn = document.getElementById('send-btn');
            var placeholder = document.getElementById('chat-placeholder');

            function sendMessage() {
                var prompt = inputEl.value.trim();
                if (!prompt || isSending) return;

                isSending = true;
                sendBtn.disabled = true;
                inputEl.value = '';

                if (placeholder) placeholder.style.display = 'none';

                vm.addMessage('user', prompt);
                vm.addMessage('assistant', '', true);

                try {
                    var stream = connection.stream('SendMessage', itemId, prompt);
                    stream.subscribe({
                        next: function (chunk) {
                            if (chunk && chunk.content) {
                                vm.appendToLast(chunk.content);
                            }
                        },
                        complete: function () {
                            vm.finishStreaming();
                            isSending = false;
                            sendBtn.disabled = false;
                            inputEl.focus();
                        },
                        error: function (err) {
                            console.error('Stream error:', err);
                            vm.finishStreaming();
                            vm.addMessage('assistant', '\u26a0\ufe0f An error occurred while streaming the response.');
                            isSending = false;
                            sendBtn.disabled = false;
                        }
                    });
                } catch (err) {
                    console.error('SendMessage error:', err);
                    vm.finishStreaming();
                    vm.addMessage('assistant', '\u26a0\ufe0f Failed to send message.');
                    isSending = false;
                    sendBtn.disabled = false;
                }
            }

            sendBtn.addEventListener('click', sendMessage);
            inputEl.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            // Auto-resize textarea
            inputEl.addEventListener('input', function () {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 120) + 'px';
            });

            // --- Clear History ---
            document.getElementById('clear-history-btn').addEventListener('click', function () {
                if (!confirm('Clear all messages?')) return;
                connection.invoke('ClearHistory', itemId).catch(function (err) {
                    console.error('Failed to clear history:', err);
                });
            });

            // --- Settings Auto-Save via SignalR ---
            var saveIndicator = document.getElementById('settings-save-indicator');
            var saveTimeout = null;

            function showSaveIndicator(text, cssClass) {
                saveIndicator.textContent = text;
                saveIndicator.className = 'settings-save-indicator ' + (cssClass || 'text-muted');
                clearTimeout(saveTimeout);
                saveTimeout = setTimeout(function () {
                    saveIndicator.textContent = '';
                }, 3000);
            }

            function collectSettings() {
                var settings = {};

                // Scalar settings from inputs
                document.querySelectorAll('.setting-input').forEach(function (el) {
                    var key = el.dataset.setting;
                    if (!key) return;
                    var val = el.value.trim();
                    if (el.type === 'number') {
                        settings[key] = val === '' ? null : parseFloat(val);
                    } else {
                        settings[key] = val || null;
                    }
                });

                // Capability checkboxes grouped by data-group
                var groups = {};
                document.querySelectorAll('.capability-checkbox').forEach(function (cb) {
                    var group = cb.dataset.group;
                    if (!groups[group]) groups[group] = [];
                    if (cb.checked) groups[group].push(cb.value);
                });
                for (var g in groups) {
                    settings[g] = groups[g];
                }

                // Prompt templates with parameters
                var promptTemplates = [];
                document.querySelectorAll('#chatPromptTemplatesContainer .chat-prompt-card').forEach(function (card) {
                    var tid = card.dataset.templateId;
                    if (!tid) return;
                    var paramsInput = card.querySelector('.chat-prompt-params-input');
                    var paramsValue = paramsInput ? paramsInput.value.trim() : '';
                    promptTemplates.push({ templateId: tid, promptParameters: paramsValue });
                });
                settings.promptTemplateIds = promptTemplates.map(function (t) { return t.templateId; });
                settings.promptTemplates = promptTemplates;

                return settings;
            }

            var debounceTimer = null;

            function debounceSave() {
                clearTimeout(debounceTimer);
                showSaveIndicator('Saving...', 'text-warning');
                debounceTimer = setTimeout(function () {
                    var settings = collectSettings();
                    connection.invoke('SaveSettings', itemId, settings).catch(function (err) {
                        console.error('Failed to save settings:', err);
                        showSaveIndicator('Save failed', 'text-danger');
                    });
                }, 500);
            }

            // Bind setting-input changes
            document.querySelectorAll('.setting-input').forEach(function (el) {
                el.addEventListener('input', debounceSave);
                el.addEventListener('change', debounceSave);
            });

            // Bind capability checkbox changes
            document.querySelectorAll('.capability-checkbox').forEach(function (cb) {
                cb.addEventListener('change', debounceSave);
            });

            // Tool Select All / Deselect All
            var selectAllToolsBtn = document.getElementById('chat-select-all-tools');
            var deselectAllToolsBtn = document.getElementById('chat-deselect-all-tools');
            if (selectAllToolsBtn) {
                selectAllToolsBtn.addEventListener('click', function () {
                    document.querySelectorAll('.chat-tool-checkbox').forEach(function (cb) { cb.checked = true; });
                    debounceSave();
                });
            }
            if (deselectAllToolsBtn) {
                deselectAllToolsBtn.addEventListener('click', function () {
                    document.querySelectorAll('.chat-tool-checkbox').forEach(function (cb) { cb.checked = false; });
                    debounceSave();
                });
            }

            // --- Prompt Template Management ---
            (function () {
                var container = document.getElementById('chatPromptTemplatesContainer');
                var searchInput = document.getElementById('chatPromptTemplateSearch');
                if (!container) return;

                function createTemplateCard(templateId, title, description, params) {
                    var card = document.createElement('div');
                    card.className = 'card mb-2 chat-prompt-card';
                    card.dataset.templateId = templateId;

                    var headerHtml = '<div class="card-body p-2">' +
                        '<div class="d-flex justify-content-between align-items-center">' +
                        '<span class="fw-bold small">' + (title || templateId) + '</span>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger border-0 p-0 ms-2" aria-label="Remove">' +
                        '<i class="bi bi-trash"></i></button></div>';

                    if (description) {
                        headerHtml += '<div class="text-muted small">' + description + '</div>';
                    }

                    var paramsHtml = '';
                    if (params && params.length > 0) {
                        paramsHtml += '<div class="mt-1"><small class="text-muted d-block mb-1">Expected parameters:</small><ul class="mb-0 small text-muted">';
                        params.forEach(function (p) {
                            paramsHtml += '<li><strong>' + p.Name + '</strong>' + (p.Description ? ': ' + p.Description : '') + '</li>';
                        });
                        paramsHtml += '</ul></div>';
                    }

                    paramsHtml += '<div class="mt-1">' +
                        '<label class="form-label small">Template parameters</label>' +
                        '<textarea class="form-control form-control-sm chat-prompt-params-input" rows="2" ' +
                        'placeholder=\'e.g., {"key1": "value1", "key2": "value2"}\'></textarea>' +
                        '<span class="form-text small">Optional JSON key-value pairs to pass as template arguments.</span>' +
                        '</div>';

                    card.innerHTML = headerHtml + paramsHtml + '</div>';
                    card.querySelector('.btn-outline-danger').addEventListener('click', function () {
                        card.remove();
                        debounceSave();
                    });
                    card.querySelector('.chat-prompt-params-input').addEventListener('change', function () {
                        debounceSave();
                    });
                    return card;
                }

                document.addEventListener('click', function (e) {
                    var btn = e.target.closest('.chat-prompt-add-btn');
                    if (!btn) return;
                    e.preventDefault();
                    var params = [];
                    try { params = JSON.parse(btn.dataset.templateParams || '[]'); } catch (ex) { }
                    var card = createTemplateCard(btn.dataset.templateId, btn.dataset.templateTitle, btn.dataset.templateDescription, params);
                    container.appendChild(card);
                    debounceSave();
                });

                if (searchInput) {
                    searchInput.addEventListener('input', function () {
                        var query = this.value.toLowerCase();
                        document.querySelectorAll('.chat-prompt-add-btn').forEach(function (item) {
                            var text = (item.textContent || '').toLowerCase();
                            item.style.display = !query || text.indexOf(query) >= 0 ? '' : 'none';
                        });
                        document.querySelectorAll('.chat-prompt-template-menu .dropdown-header').forEach(function (h) {
                            h.style.display = query ? 'none' : '';
                        });
                    });
                }
            })();

            // Hide placeholder if we already have messages
            if (existingMessages.length > 0 && placeholder) {
                placeholder.style.display = 'none';
            }
        });
    </script>
}
