@model IReadOnlyCollection<CrestApps.AI.Models.AIProviderConnection>
@{
    ViewData["Title"] = "AI Connections";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-plug"></i> AI Connections</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Connection
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI connections found. Create a connection to link AI providers.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Display Text</th>
                    <th>Provider</th>
                    <th>Chat Deployment</th>
                    <th>Default</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var connection in Model)
                {
                    <tr>
                        <td><strong>@connection.Name</strong></td>
                        <td>@connection.DisplayText</td>
                        <td>
                            <span class="badge bg-info">@(connection.Source ?? "—")</span>
                        </td>
                        <td>@(connection.ChatDeploymentName ?? "—")</td>
                        <td>
                            @if (connection.IsDefault)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i> Yes</span>
                            }
                            else
                            {
                                <span class="text-muted">No</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@connection.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@connection.ItemId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this connection?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
