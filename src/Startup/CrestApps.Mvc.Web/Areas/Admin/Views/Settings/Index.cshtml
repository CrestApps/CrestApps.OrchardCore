@model CrestApps.Mvc.Web.Areas.Admin.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "AI Settings";
}

<h2><i class="bi bi-gear"></i> AI Settings</h2>
<hr />

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Save" method="post">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Default Deployments</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        Select the default deployment for each capability. These are used as a
                        fallback when a specific deployment is not configured at the profile or
                        connection level.
                    </p>

                    <div class="mb-3">
                        <label asp-for="DefaultChatDeploymentName" class="form-label">Default chat deployment</label>
                        <select asp-for="DefaultChatDeploymentName" asp-items="Model.ChatDeployments" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <div class="form-text">The default deployment used for chat sessions and chat interactions when no specific chat deployment is configured.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultUtilityDeploymentName" class="form-label">Default utility deployment</label>
                        <select asp-for="DefaultUtilityDeploymentName" asp-items="Model.UtilityDeployments" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <div class="form-text">The default deployment used for auxiliary tasks such as planning, intent detection, query rewriting, and chart generation.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultEmbeddingDeploymentName" class="form-label">Default embedding deployment</label>
                        <select asp-for="DefaultEmbeddingDeploymentName" asp-items="Model.EmbeddingDeployments" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <div class="form-text">The default deployment used for embedding generation in document indexing, data sources, and vector search.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultImageDeploymentName" class="form-label">Default image deployment</label>
                        <select asp-for="DefaultImageDeploymentName" asp-items="Model.ImageDeployments" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <div class="form-text">The default deployment used for image generation.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultSpeechToTextDeploymentName" class="form-label">Default speech-to-text deployment</label>
                        <select asp-for="DefaultSpeechToTextDeploymentName" asp-items="Model.SpeechToTextDeployments" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <div class="form-text">The default deployment used for speech-to-text transcription.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultTextToSpeechDeploymentName" class="form-label">Default text-to-speech deployment</label>
                        <select asp-for="DefaultTextToSpeechDeploymentName" asp-items="Model.TextToSpeechDeployments" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <div class="form-text">The default deployment used for text-to-speech synthesis.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultTextToSpeechVoiceId" class="form-label">Default text-to-speech voice</label>
                        <input asp-for="DefaultTextToSpeechVoiceId" class="form-control" placeholder="e.g. alloy" />
                        <div class="form-text">The default voice used for text-to-speech when a profile does not specify one.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Memory</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnablePreemptiveMemoryRetrieval" class="form-check-input" type="checkbox" />
                            <label asp-for="EnablePreemptiveMemoryRetrieval" class="form-check-label">Enable preemptive memory retrieval</label>
                        </div>
                        <div class="form-text">When enabled, the system automatically retrieves relevant memories before processing user requests (RAG).</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Documents</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        Configure the default AI Documents index used to store embedded chunks for profile and session documents.
                        Uploading files alone is not enough for knowledge-base search; the app also needs an <strong>AI Documents</strong> index profile.
                    </p>

                    <div class="mb-3">
                        <label asp-for="DocumentIndexProfileName" class="form-label">Default AI Documents index</label>
                        <select asp-for="DocumentIndexProfileName" asp-items="Model.DocumentIndexProfiles" class="form-select"></select>
                        <div class="form-text">Choose the AI Documents index profile that stores embedded document chunks for retrieval during chat.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DocumentTopN" class="form-label">Default document Top N</label>
                        <input asp-for="DocumentTopN" class="form-control" type="number" min="1" max="20" style="max-width: 200px;" />
                        <span asp-validation-for="DocumentTopN" class="text-danger"></span>
                        <div class="form-text">The default number of matching document chunks to include when a profile does not override it.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Data sources</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DataSourceDefaultStrictness" class="form-label">Default strictness</label>
                                <input asp-for="DataSourceDefaultStrictness" class="form-control" type="number" min="1" max="5" />
                                <span asp-validation-for="DataSourceDefaultStrictness" class="text-danger"></span>
                                <div class="form-text">The default strictness threshold applied when a profile does not specify its own data source strictness.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DataSourceDefaultTopNDocuments" class="form-label">Default retrieved documents</label>
                                <input asp-for="DataSourceDefaultTopNDocuments" class="form-control" type="number" min="3" max="20" />
                                <span asp-validation-for="DataSourceDefaultTopNDocuments" class="text-danger"></span>
                                <div class="form-text">The default number of data source documents retrieved when a profile does not override it.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Orchestration</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="MaximumIterationsPerRequest" class="form-label">Maximum iterations per request</label>
                        <input asp-for="MaximumIterationsPerRequest" class="form-control" type="number" min="1" max="100" style="max-width: 200px;" />
                        <span asp-validation-for="MaximumIterationsPerRequest" class="text-danger"></span>
                        <div class="form-text">The maximum number of orchestrator iterations allowed per request. Default is 10.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Caching</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableDistributedCaching" class="form-check-input" type="checkbox" />
                            <label asp-for="EnableDistributedCaching" class="form-check-label">Enable distributed caching</label>
                        </div>
                        <div class="form-text">Cache AI responses across nodes for improved performance.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Diagnostics</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="EnableOpenTelemetry" class="form-check-input" type="checkbox" />
                            <label asp-for="EnableOpenTelemetry" class="form-check-label">Enable OpenTelemetry</label>
                        </div>
                        <div class="form-text">Enable distributed tracing and diagnostics for AI operations.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Model Context Protocol (MCP) server</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        Configure how external MCP clients access the MVC application's MCP endpoint at <code>/mcp</code>.
                    </p>
                    <div class="mb-3">
                        <label asp-for="McpServerAuthenticationType" class="form-label">Authentication type</label>
                        <select asp-for="McpServerAuthenticationType" class="form-select" id="mcpServerAuthenticationType">
                            @foreach (var authenticationType in Enum.GetValues<CrestApps.AI.Mcp.Models.McpServerAuthenticationType>())
                            {
                                <option value="@((int)authenticationType)">@authenticationType</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3" id="mcpServerApiKeyFields">
                        <label asp-for="McpServerApiKey" class="form-label">API key</label>
                        <input asp-for="McpServerApiKey" class="form-control" />
                        <span asp-validation-for="McpServerApiKey" class="text-danger"></span>
                        <div class="form-text">Clients may send this as <code>Bearer key</code>, <code>ApiKey key</code>, or the raw value in the <code>Authorization</code> header.</div>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="McpServerRequireAccessPermission" class="form-check-input" type="checkbox" />
                        <label asp-for="McpServerRequireAccessPermission" class="form-check-label">Require administrator access for OpenId mode</label>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Save Settings
                </button>
            </div>
        </div>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const authenticationType = document.getElementById('mcpServerAuthenticationType');
        const apiKeyFields = document.getElementById('mcpServerApiKeyFields');

        function updateVisibility() {
            apiKeyFields.style.display = authenticationType.value === '@((int)CrestApps.AI.Mcp.Models.McpServerAuthenticationType.ApiKey)' ? '' : 'none';
        }

        authenticationType.addEventListener('change', updateVisibility);
        updateVisibility();
    });
</script>
