@model CrestApps.Mvc.Web.Areas.Admin.ViewModels.McpPromptViewModel

<form asp-action="@(string.IsNullOrEmpty(Model.ItemId) ? "Create" : "Edit")" method="post">
    @if (!string.IsNullOrEmpty(Model.ItemId))
    {
        <input asp-for="ItemId" type="hidden" />
    }

    <div class="col-md-8">
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Arguments" class="form-label">Arguments (JSON array)</label>
            <textarea asp-for="Arguments" class="form-control" rows="8"></textarea>
            <span asp-validation-for="Arguments" class="text-danger"></span>
            <div class="form-text">Example: <code>[{ "name": "topic", "description": "Topic to expand", "required": true }]</code></div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @(string.IsNullOrEmpty(Model.ItemId) ? "Create" : "Save")</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>
