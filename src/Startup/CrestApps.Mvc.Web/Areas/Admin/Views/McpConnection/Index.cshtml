@model IReadOnlyCollection<CrestApps.AI.Mcp.Models.McpConnection>
@{
    ViewData["Title"] = "MCP Connections";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-hdd-network"></i> MCP Connections</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Add Connection</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No MCP connections are configured yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Display text</th>
                    <th>Transport</th>
                    <th>Details</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var connection in Model)
            {
                <tr>
                    <td><strong>@connection.DisplayText</strong></td>
                    <td><span class="badge bg-info text-dark">@connection.Source</span></td>
                    <td>
                        @if (connection.Source == CrestApps.AI.Mcp.McpConstants.TransportTypes.Sse)
                        {
                            var metadata = connection.As<CrestApps.AI.Mcp.Models.SseMcpConnectionMetadata>();
                            <code>@metadata.Endpoint</code>
                        }
                        else
                        {
                            var metadata = connection.As<CrestApps.AI.Mcp.Models.StdioMcpConnectionMetadata>();
                            <code>@metadata.Command</code>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@connection.ItemId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                        <form asp-action="Delete" asp-route-id="@connection.ItemId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this MCP connection?')"><i class="bi bi-trash"></i> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
