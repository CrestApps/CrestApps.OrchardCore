@using CrestApps.AI.Models
@model IReadOnlyCollection<CrestApps.AI.Models.AIDeployment>
@{
    ViewData["Title"] = "AI Deployments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-box-seam"></i> AI Deployments</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Deployment
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No deployments found. Create a deployment to map models to connections.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Technical name</th>
                    <th>Model name</th>
                    <th>Type</th>
                    <th>Provider</th>
                    <th>Connection</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var deployment in Model)
                {
                    <tr>
                        <td><strong>@deployment.Name</strong></td>
                        <td>@(string.IsNullOrWhiteSpace(deployment.ModelName) ? "—" : deployment.ModelName)</td>
                        <td>
                            @foreach (var type in deployment.Type.GetSupportedTypes())
                            {
                                <span class="badge bg-secondary me-1">@type</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-info">@(deployment.ClientName ?? "—")</span>
                        </td>
                        <td>@(string.IsNullOrEmpty(deployment.ConnectionName) ? "Standalone" : deployment.ConnectionName)</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@deployment.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@deployment.ItemId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this deployment?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
