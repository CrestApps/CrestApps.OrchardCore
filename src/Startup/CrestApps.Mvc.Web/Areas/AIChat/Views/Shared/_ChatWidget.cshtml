@using CrestApps.AI
@using CrestApps.AI.Models
@using CrestApps.AI.Profiles
@using Microsoft.Extensions.Options
@inject IAIProfileManager ProfileManager
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions

@{
    var supportedExtensionsAccept = ChatDocumentOptions.Value.GetAllowedFileExtensionsAcceptValue();
    var supportedExtensionsDisplay = ChatDocumentOptions.Value.GetAllowedFileExtensionsDisplayValue();
    var profiles = (await ProfileManager.GetAsync(AIProfileType.Chat))
        .Where(p => p.GetSettings<AIProfileSettings>().IsListable)
        .Select(p => new
        {
            id = p.ItemId,
            name = p.Name,
            displayText = p.DisplayText ?? p.Name,
            welcomeMessage = p.WelcomeMessage,
            allowSessionDocuments = p.As<AIProfileSessionDocumentsMetadata>()?.AllowSessionDocuments ?? false,
        })
        .ToArray();
}


@if (profiles.Length > 0)

{

    <link rel="stylesheet" href="~/css/chat-widget.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/default.min.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />



    <style>

        .ai-chat-messages {
            padding: 0.5rem;
        }

        .ai-chat-message-item {
            margin-bottom: 0.75rem;
        }

        .ai-chat-msg-role {
            font-size: 0.7rem;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .ai-chat-msg-role-user {
            color: #0d6efd;
        }

        .ai-chat-msg-role-assistant {
            color: #6f42c1;
        }

            .ai-chat-msg-role-assistant i.ai-streaming-icon {
                animation: pulse 1.5s infinite;
            }

            .ai-chat-msg-role-assistant i.ai-bot-icon {
                color: #6f42c1;
            }

        .message-buttons-container {
            display: inline-flex;
            gap: 4px;
            margin-top: 4px;
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }
        }
    </style>



    <!-- Floating toggle button -->

    <button id="widget-toggle" class="ai-chat-widget-toggle" title="Open AI Chat">

        <i class="bi bi-chat-dots-fill"></i>

    </button>



    <!-- Widget container -->

    <div id="widget-panel" class="ai-chat-widget-container">

        <div class="ai-chat-widget-header">

            <span class="title">AI Chat</span>

            <div>

                <button id="widget-new-chat" title="New Chat"><i class="bi bi-plus-lg"></i></button>

                <button id="widget-close" title="Close"><i class="bi bi-x-lg"></i></button>

            </div>

        </div>


        <div id="widget-chat-container" class="ai-chat-widget-messages">
            <div id="widget-placeholder">
                <div class="ai-chat-widget-welcome">
                    <i class="bi bi-robot" style="font-size: 2rem;"></i><br>
                    @(string.IsNullOrWhiteSpace(profiles[0].welcomeMessage) ? "What do you want to know?" : profiles[0].welcomeMessage)

                </div>

            </div>
            <div id="widget-chat-app"></div>
        </div>

        <div id="widget-chat-document-bar" class="border-top bg-light d-none"></div>

        <div class="ai-chat-widget-input">
            <textarea id="widget-chat-input"
                      placeholder="Type a message..."
                      rows="1"
                      data-session-id=""
                      data-profile-id="@profiles[0].id"></textarea>

            <button type="button" id="widget-send-btn">

                <i class="bi bi-send"></i>

            </button>

        </div>

    </div>



    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>

    <script src="~/js/ai-chat.js"></script>

    <script>

        document.addEventListener('DOMContentLoaded', function () {
            var profiles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(profiles));
            var selectedProfile = profiles[0];
            var panel = document.getElementById('widget-panel');
            var toggle = document.getElementById('widget-toggle');
            var closeBtn = document.getElementById('widget-close');
            var newChatBtn = document.getElementById('widget-new-chat');
            var chatInput = document.getElementById('widget-chat-input');
            var placeholder = document.getElementById('widget-placeholder');
            var widgetStateName = 'mvc-admin-chat-widget';
            var widgetOpenStateKey = widgetStateName + 'Open';

            function setPlaceholder(profile) {
                if (!placeholder) {
                    return;
                }

                var welcome = profile && profile.welcomeMessage ? profile.welcomeMessage : 'What do you want to know?';
                placeholder.innerHTML = '<div class="ai-chat-widget-welcome"><i class="bi bi-robot" style="font-size: 2rem;"></i><br>' + welcome + '</div>';
            }

            function setPanelOpen(isOpen) {
                panel.classList.toggle('open', isOpen);
                toggle.innerHTML = isOpen
                    ? '<i class="bi bi-x-lg"></i>'
                    : '<i class="bi bi-chat-dots-fill"></i>';
                localStorage.setItem(widgetOpenStateKey, isOpen ? 'true' : 'false');
            }

            setPlaceholder(selectedProfile);
            chatInput.setAttribute('data-profile-id', selectedProfile.id);

            var widgetApp = window.openAIChatManager.initialize({
                signalRHubUrl: '/hubs/ai-chat',
                appElementSelector: '#widget-chat-app',
                chatContainerElementSelector: '#widget-chat-container',
                inputElementSelector: '#widget-chat-input',
                sendButtonElementSelector: '#widget-send-btn',
                placeholderElementSelector: '#widget-placeholder',
                messages: [],
                metricsEnabled: false,
                sessionDocumentsEnabled: selectedProfile.allowSessionDocuments,
                existingDocuments: [],
                documentBarSelector: '#widget-chat-document-bar',
                uploadDocumentUrl: '@Url.Content("~/ai/chat-sessions/upload-document")',
                removeDocumentUrl: '@Url.Content("~/ai/chat-sessions/remove-document")',
                allowedExtensions: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(supportedExtensionsAccept)),
                supportedExtensionsText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(supportedExtensionsDisplay)),
                widget: {
                    chatWidgetContainer: '#widget-panel',
                    chatWidgetStateName: widgetStateName
                }
            });

            setPanelOpen(localStorage.getItem(widgetOpenStateKey) === 'true');

            toggle.addEventListener('click', function () {
                setPanelOpen(!panel.classList.contains('open'));
            });

            closeBtn.addEventListener('click', function () {
                setPanelOpen(false);
            });

            newChatBtn.addEventListener('click', function () {
                setPlaceholder(selectedProfile);
                widgetApp.resetSession();
            });
        });
    </script>

}
