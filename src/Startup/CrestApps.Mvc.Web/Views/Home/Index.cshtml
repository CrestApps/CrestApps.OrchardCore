@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card h-100 border-success">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-plug fs-2 text-success me-3"></i>
                    <h5 class="card-title mb-0">AI Connections</h5>
                </div>
                <p class="card-text">Configure connections to AI providers (OpenAI, Azure OpenAI, Ollama, Azure AI Inference).</p>
                <a asp-area="Admin" asp-controller="AIConnection" asp-action="Index" class="btn btn-success">
                    <i class="bi bi-arrow-right"></i> Manage Connections
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-primary">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-person-gear fs-2 text-primary me-3"></i>
                    <h5 class="card-title mb-0">AI Profiles</h5>
                </div>
                <p class="card-text">Create and manage AI profiles with system prompts, parameters, and provider configurations.</p>
                <a asp-area="Admin" asp-controller="AIProfile" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-arrow-right"></i> Manage Profiles
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-info">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-chat-dots fs-2 text-info me-3"></i>
                    <h5 class="card-title mb-0">AI Chat</h5>
                </div>
                <p class="card-text">Start real-time conversations with AI assistants using SignalR streaming.</p>
                <a asp-area="Admin" asp-controller="AIChat" asp-action="Index" class="btn btn-info text-white">
                    <i class="bi bi-arrow-right"></i> Start Chat
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-box-seam fs-2 text-warning me-3"></i>
                    <h5 class="card-title mb-0">AI Deployments</h5>
                </div>
                <p class="card-text">Map model deployments to connections for fine-grained control over which models are used.</p>
                <a asp-area="Admin" asp-controller="AIDeployment" asp-action="Index" class="btn btn-warning">
                    <i class="bi bi-arrow-right"></i> Manage Deployments
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-md-3">
        <div class="card h-100 border-secondary">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-file-earmark-text fs-2 text-secondary me-3"></i>
                    <h5 class="card-title mb-0">AI Templates</h5>
                </div>
                <p class="card-text">Create reusable system prompt and profile templates for consistent AI behavior.</p>
                <a asp-area="Admin" asp-controller="AITemplate" asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-right"></i> Manage Templates
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-dark">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-database-gear fs-2 text-dark me-3"></i>
                    <h5 class="card-title mb-0">Index Profiles</h5>
                </div>
                <p class="card-text">Define search index profiles for Elasticsearch or Azure AI Search vector stores.</p>
                <a asp-area="Admin" asp-controller="IndexProfile" asp-action="Index" class="btn btn-dark">
                    <i class="bi bi-arrow-right"></i> Manage Index Profiles
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100" style="border-color: #6f42c1;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-collection fs-2 me-3" style="color: #6f42c1;"></i>
                    <h5 class="card-title mb-0">Data Sources</h5>
                </div>
                <p class="card-text">Map existing search indexes to a knowledge base for AI-powered retrieval.</p>
                <a asp-area="Admin" asp-controller="AIDataSource" asp-action="Index" class="btn text-white" style="background-color: #6f42c1;">
                    <i class="bi bi-arrow-right"></i> Manage Data Sources
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100" style="border-color: #20c997;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-gear fs-2 me-3" style="color: #20c997;"></i>
                    <h5 class="card-title mb-0">Settings</h5>
                </div>
                <p class="card-text">Configure memory, orchestration, caching, and diagnostics settings.</p>
                <a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="btn text-white" style="background-color: #20c997;">
                    <i class="bi bi-arrow-right"></i> Manage Settings
                </a>
            </div>
        </div>
    </div>
</div>

@if (!User.Identity.IsAuthenticated)
{
    <div class="alert alert-warning mt-4">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>Getting Started:</strong> <a asp-controller="Account" asp-action="Login">Sign in</a> to access the admin features and start using AI chat.
    </div>
}
