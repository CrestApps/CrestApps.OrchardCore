@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    var dashboardClass = string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
    var simulatorClass = string.Equals(currentPage, "/Simulator", StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CrestApps Asterisk Web</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">CrestApps Asterisk Web</a>
            <div class="navbar-nav">
                <a class="@dashboardClass" asp-page="/Index">Asterisk Dashboard</a>
                <a class="@simulatorClass" asp-page="/Simulator">Inbound Simulator</a>
            </div>
        </div>
    </nav>
    <div class="container pb-4">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/signalr.min.js"></script>
    <script src="~/js/dashboard.js"></script>
</body>
</html>
