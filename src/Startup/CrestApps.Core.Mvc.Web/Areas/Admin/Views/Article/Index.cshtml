@model CrestApps.Core.Mvc.Web.Areas.Admin.ViewModels.ArticleIndexViewModel
@{
    ViewData["Title"] = "Articles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-journal-text"></i> Articles</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Article
    </a>
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Articles.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No articles found.
        Create one to add knowledge base content that can be indexed into Elasticsearch or Azure AI Search.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Created</th>
                    <th style="min-width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var article in Model.Articles)
                {
                    <tr>
                        <td><strong>@(article.Title ?? "Untitled")</strong></td>
                        <td>
                            <small class="text-muted">@article.CreatedUtc.ToString("g")</small>
                        </td>
                        <td>
                            <a asp-area=""
                               asp-controller="Articles"
                               asp-action="Display"
                               asp-route-id="@article.ItemId"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i> Display
                            </a>
                            <a asp-action="Edit" asp-route-id="@article.ItemId"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@article.ItemId"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this article?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("_Pager", new CrestApps.Core.Mvc.Web.Areas.Admin.ViewModels.PagerViewModel
    {
        Page = Model.Page,
        TotalPages = Model.TotalPages,
        TotalCount = Model.TotalCount,
        Action = "Index",
        Controller = "Article",
        Area = "Admin",
    })
}
