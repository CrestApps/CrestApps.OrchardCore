@model IEnumerable<CrestApps.Core.AI.Models.AIProfile>
@{
    ViewData["Title"] = "AI Chat";
    var sessions = ViewData["Sessions"] as CrestApps.Core.AI.Models.AIChatSessionResult;
}

<h2><i class="bi bi-chat-dots"></i> AI Chat</h2>
<hr />

<div class="row">
    <div class="col-md-7">
        <h4>Chat Profiles</h4>
        <p class="text-muted">Select a profile to start a new chat session.</p>

        @if (!Model.Any())
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i> No chat profiles available.
                <a asp-area="AI" asp-controller="AIProfile" asp-action="Create">Create one first.</a>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var profile in Model)
                {
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@(profile.DisplayText ?? profile.Name)</h5>
                                @if (!string.IsNullOrEmpty(profile.WelcomeMessage))
                                {
                                    <p class="card-text text-muted small">@profile.WelcomeMessage</p>
                                }
                                <div class="d-flex gap-1 mb-2">
                                    @if (!string.IsNullOrEmpty(profile.Source))
                                    {
                                        <span class="badge bg-info">@profile.Source</span>
                                    }
                                    <span class="badge bg-secondary">@profile.Type</span>
                                </div>
                            </div>
                            <div class="card-footer">
                                <form asp-action="CreateSession" method="post">
                                    <input type="hidden" name="profileId" value="@profile.ItemId" />
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="bi bi-chat-left-text"></i> Start Chat
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-md-5">
        <h4>Recent Sessions</h4>
        @if (sessions != null && sessions.Sessions.Any())
        {
            <div class="list-group">
                @foreach (var session in sessions.Sessions)
                {
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <a asp-action="Chat" asp-route-sessionId="@session.SessionId" class="text-decoration-none flex-grow-1">
                            <strong>@(session.Title ?? "Untitled")</strong>
                            <br />
                            <small class="text-muted">@session.CreatedUtc.ToString("g")</small>
                        </a>
                        <form asp-action="DeleteSession" method="post" class="ms-2">
                            <input type="hidden" name="sessionId" value="@session.SessionId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this session?')" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">No chat sessions yet. Start a new chat from a profile.</p>
        }
    </div>
</div>
