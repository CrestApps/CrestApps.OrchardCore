@model IEnumerable<CrestApps.Core.AI.Models.AIProfile>
@{
    ViewData["Title"] = "AI Profiles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-gear"></i> AI Profiles</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Profile
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI profiles found. Create your first profile to get started.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Type</th>
                    <th style="width: 260px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var profile in Model)
                {
                    <tr>
                        <td><strong>@(profile.DisplayText ?? profile.Name)</strong></td>
                        <td>@profile.Name</td>
                        <td>
                            <span class="badge @(profile.Type == CrestApps.Core.AI.Models.AIProfileType.Chat ? "bg-primary" : "bg-secondary")">
                                @profile.Type
                            </span>
                        </td>
                        <td>
                            @if (profile.Type == CrestApps.Core.AI.Models.AIProfileType.Chat)
                            {
                                <form asp-area="AIChat" asp-controller="AIChat" asp-action="CreateSession" method="post" class="d-inline">
                                    <input type="hidden" name="profileId" value="@profile.ItemId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Start a new chat session">
                                        <i class="bi bi-chat-dots"></i> Chat
                                    </button>
                                </form>
                            }
                            <a asp-action="Edit" asp-route-id="@profile.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@profile.ItemId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this profile?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
