@using CrestApps.Core.AI.Models
@using CrestApps.Core.Mvc.Web.Areas.AI.ViewModels
@model IReadOnlyCollection<AIDeploymentViewModel>
@{
    ViewData["Title"] = "AI Deployments";
    var userDefinedDeployments = Model.Where(static deployment => !deployment.IsReadOnly).ToList();
    var configuredDeployments = Model.Where(static deployment => deployment.IsReadOnly).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-box-seam"></i> AI Deployments</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Deployment
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No deployments found. Create a deployment to map models to connections.
    </div>
}
else
{
    @if (userDefinedDeployments.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">User-defined deployments</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Technical name</th>
                                <th>Model name</th>
                                <th>Type</th>
                                <th>Provider</th>
                                <th>Connection</th>
                                <th style="width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deployment in userDefinedDeployments)
                            {
                                <tr>
                                    <td><strong>@deployment.TechnicalName</strong></td>
                                    <td>@(string.IsNullOrWhiteSpace(deployment.ModelName) ? "—" : deployment.ModelName)</td>
                                    <td>
                                        @foreach (var type in deployment.GetDeploymentType().GetSupportedTypes())
                                        {
                                            <span class="badge bg-secondary me-1">@type</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@(deployment.ClientName ?? "—")</span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(deployment.ConnectionName) ? "Standalone" : deployment.ConnectionName)</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@deployment.ItemId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@deployment.ItemId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this deployment?')">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (configuredDeployments.Count > 0)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">System configuration deployments</h5>
                <span class="badge bg-secondary">Read-only</span>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">These deployments come from system configuration and cannot be edited or deleted from the UI.</p>
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Technical name</th>
                                <th>Model name</th>
                                <th>Type</th>
                                <th>Provider</th>
                                <th>Connection</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deployment in configuredDeployments)
                            {
                                <tr>
                                    <td><strong>@deployment.TechnicalName</strong></td>
                                    <td>@(string.IsNullOrWhiteSpace(deployment.ModelName) ? "—" : deployment.ModelName)</td>
                                    <td>
                                        @foreach (var type in deployment.GetDeploymentType().GetSupportedTypes())
                                        {
                                            <span class="badge bg-secondary me-1">@type</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@(deployment.ClientName ?? "—")</span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(deployment.ConnectionName) ? "Standalone" : deployment.ConnectionName)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
