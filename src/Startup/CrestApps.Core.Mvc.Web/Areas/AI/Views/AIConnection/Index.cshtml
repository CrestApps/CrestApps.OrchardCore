@using CrestApps.Core.Mvc.Web.Areas.AI.ViewModels
@model IReadOnlyCollection<AIConnectionViewModel>
@{
    ViewData["Title"] = "AI Connections";
    var userDefinedConnections = Model.Where(static connection => !connection.IsReadOnly).ToList();
    var configuredConnections = Model.Where(static connection => connection.IsReadOnly).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-plug"></i> AI Connections</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Connection
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI connections found. Create a connection to link AI providers.
    </div>
}
else
{
    @if (userDefinedConnections.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">User-defined connections</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Technical Name</th>
                                <th>Provider</th>
                                <th style="width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in userDefinedConnections)
                            {
                                <tr>
                                    <td><strong>@(connection.DisplayText ?? connection.Name)</strong></td>
                                    <td><code>@connection.Name</code></td>
                                    <td>
                                        <span class="badge bg-info">@(connection.Source ?? "—")</span>
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@connection.ItemId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@connection.ItemId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this connection?')">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (configuredConnections.Count > 0)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">System configuration connections</h5>
                <span class="badge bg-secondary">Read-only</span>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">These connections come from system configuration and cannot be edited or deleted from the UI.</p>
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Technical Name</th>
                                <th>Provider</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in configuredConnections)
                            {
                                <tr>
                                    <td><strong>@(connection.DisplayText ?? connection.Name)</strong></td>
                                    <td><code>@connection.Name</code></td>
                                    <td>
                                        <span class="badge bg-info">@(connection.Source ?? "—")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
