@model IEnumerable<CrestApps.Core.AI.Models.AIProfileTemplate>
@{
    ViewData["Title"] = "Templates";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-text"></i> Templates</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Template
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No templates configured yet.
        <a asp-action="Create">Create your first template</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Source</th>
                    <th>Category</th>
                    <th>Listable</th>
                    <th style="min-width: 190px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var template in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Edit" asp-route-id="@template.ItemId" class="text-decoration-none fw-semibold">
                                @(template.DisplayText ?? template.Name)
                            </a>
                        </td>
                        <td><code>@template.Name</code></td>
                        <td>
                            <span class="badge @(template.Source == "SystemPrompt" ? "bg-info" : "bg-success")">
                                @template.Source
                            </span>
                        </td>
                        <td>@(template.Category ?? "—")</td>
                        <td>
                            @if (template.IsListable)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <div class="d-inline-flex flex-nowrap gap-2">
                                <a asp-action="Edit" asp-route-id="@template.ItemId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@template.ItemId" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this template?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
