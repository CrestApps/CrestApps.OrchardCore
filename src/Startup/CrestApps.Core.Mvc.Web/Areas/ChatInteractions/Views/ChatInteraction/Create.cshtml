@using CrestApps.Core.Mvc.Web.Areas.ChatInteractions.ViewModels
@using CrestApps.Core.AI.Models
@using Microsoft.Extensions.Options
@model ChatInteractionViewModel
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions
@{
    ViewData["Title"] = "New Chat Interaction";
    const string maxTokensHelp = "The maximum number of tokens (roughly words or word fragments) the AI can generate in a single response. Lower values produce shorter responses and reduce costs. Higher values allow for more detailed answers.";
    const string temperatureHelp = "Controls the randomness of AI responses. Lower values (closer to 0) make responses more focused and deterministic. Higher values (up to 2) make responses more creative and varied.";
    const string topPHelp = "Also called nucleus sampling. Controls diversity by limiting the AI to consider only the most probable tokens that sum to this value. Lower values are more focused, while higher values are more diverse.";
    const string frequencyPenaltyHelp = "Penalizes tokens based on how frequently they appear in the response so far. Higher values reduce repetition of the same words and phrases.";
    const string presencePenaltyHelp = "Penalizes tokens based on whether they have appeared at all. Higher values encourage the AI to introduce new topics and ideas rather than staying on the same subjects.";
    const string pastMessagesHelp = "The number of previous messages from the conversation to include as context. More messages provide better context but increase token usage and costs.";
    var supportedExtensionsAccept = ChatDocumentOptions.Value.GetAllowedFileExtensionsAcceptValue();
    var supportedExtensionsDisplay = ChatDocumentOptions.Value.GetAllowedFileExtensionsDisplayValue();
}

<h2><i class="bi bi-plus-lg"></i> New Chat Interaction</h2>
<hr />
<p class="text-muted">Configure AI parameters and start chatting. Unlike AI Profile chat, you can fully customize the behavior here.</p>

<style>
    .parameter-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }

    @@media (min-width: 1200px) {
        .parameter-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    .parameter-label {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }

    .parameter-help-icon {
        color: var(--bs-secondary-color, #6c757d);
        cursor: help;
    }
</style>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-8">
            <ul class="nav nav-tabs" id="interactionTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">Settings</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="kb-tab" data-bs-toggle="tab" data-bs-target="#kb" type="button" role="tab">Knowledge</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="capabilities-tab" data-bs-toggle="tab" data-bs-target="#capabilities" type="button" role="tab">Capabilities</button>
                </li>
            </ul>

            <div class="tab-content p-3 border border-top-0 rounded-bottom" id="interactionTabContent">
                <!-- Settings Tab -->
                <div class="tab-pane fade show active" id="settings" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g., Code Helper, Creative Writer" />
                        <div class="form-text">An optional title for this chat interaction.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ChatDeploymentName" class="form-label">Deployment</label>
                        <select asp-for="ChatDeploymentName" class="form-select" asp-items="Model.Deployments">
                            <option value="">Select deployment</option>
                        </select>
                        <div class="form-text">The AI model deployment to use for this chat.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OrchestratorName" class="form-label">Orchestrator</label>
                        <select asp-for="OrchestratorName" class="form-select" asp-items="Model.Orchestrators">
                            <option value="">Use default orchestrator</option>
                        </select>
                        <div class="form-text">The orchestrator that manages AI interactions.</div>
                    </div>

                    @await Html.PartialAsync("_CopilotConfig", null, new ViewDataDictionary(ViewData) {
                        { "CopilotPrefix", "ci" },
                        { "CopilotAuthType", Model.CopilotAuthenticationType },
                        { "CopilotIsConfigured", Model.CopilotIsConfigured },
                        { "CopilotIsAuth", Model.CopilotIsAuthenticated },
                        { "CopilotUsername", Model.CopilotGitHubUsername },
                        { "CopilotModel", Model.CopilotModel },
                        { "CopilotIsAllowAll", Model.CopilotIsAllowAll },
                        { "CopilotModels", Model.CopilotAvailableModels },
                    })

                    <!-- Prompt Templates (moved from separate tab) -->
                    @if (Model.AvailablePromptTemplates.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                Prompt templates
                                <span class="text-muted" data-bs-toggle="tooltip" title="Add one or more reusable prompt templates that will be rendered in order before the custom system instructions.">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <div class="dropdown mb-3">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" id="addPromptTemplateBtn" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-plus-lg"></i> Add prompt template
                                </button>
                                <div class="dropdown-menu p-2" id="promptTemplateDropdown" style="max-height:24rem;min-width:22rem;overflow-y:auto;">
                                    <div class="mb-2">
                                        <input type="search" class="form-control form-control-sm" id="promptTemplateSearch" placeholder="Search prompt templates..." />
                                    </div>
                                    <div class="prompt-template-menu-items">
                                        @foreach (var group in Model.AvailablePromptTemplates.GroupBy(t => t.Category).OrderBy(g => g.Key))
                                        {
                                            <div class="dropdown-header px-2">@group.Key</div>
                                            @foreach (var option in group)
                                            {
                                                <button type="button"
                                                        class="dropdown-item prompt-template-add-btn text-wrap"
                                                        data-template-id="@option.TemplateId"
                                                        data-template-title="@option.Title"
                                                        data-template-description="@option.Description">
                                                    <span class="d-block fw-semibold">@option.Title</span>
                                                    @if (!string.IsNullOrWhiteSpace(option.Description))
                                                    {
                                                        <small class="text-muted">@option.Description</small>
                                                    }
                                                </button>
                                            }
                                        }
                                    </div>
                                    <div class="text-muted small d-none px-2 py-1" id="promptTemplateNoResults">No prompt templates match your search.</div>
                                </div>
                            </div>

                            <div id="promptTemplatesContainer">
                                @for (var i = 0; i < Model.PromptTemplates.Count; i++)
                                {
                                    var selection = Model.PromptTemplates[i];
                                    var option = Model.AvailablePromptTemplates.FirstOrDefault(t => string.Equals(t.TemplateId, selection.TemplateId, StringComparison.OrdinalIgnoreCase));
                                    var title = option?.Title ?? selection.TemplateId ?? "Prompt template";
                                    var category = option?.Category ?? "Unavailable";
                                    var description = option?.Description;
                                    var parameters = option?.Parameters ?? [];

                                    <div class="card mb-1 prompt-template-card" data-template-id="@selection.TemplateId">
                                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                                            <a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0"
                                                   data-bs-toggle="collapse" href="#promptCollapse_@i" role="button" aria-expanded="false">
                                                <i class="bi bi-chevron-right me-1"></i>
                                                <span class="prompt-template-title fw-semibold">@title</span>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger remove-prompt-template-btn" title="Remove">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        <div id="promptCollapse_@i" class="collapse">
                                            <div class="card-body">
                                                <input type="hidden" name="PromptTemplates[@i].TemplateId" value="@selection.TemplateId" class="prompt-template-id-input" />
                                                <div class="d-flex flex-wrap gap-2 mb-2">
                                                    <span class="badge text-bg-secondary">@category</span>
                                                    @if (option == null)
                                                    {
                                                        <span class="badge text-bg-warning">Unavailable</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(description))
                                                {
                                                    <div class="text-muted small mb-3">@description</div>
                                                }
                                                @if (parameters.Count > 0)
                                                {
                                                    <div class="mb-3">
                                                        <small class="text-muted d-block mb-1">Expected parameters:</small>
                                                        <ul class="mb-0 small text-muted">
                                                            @foreach (var p in parameters)
                                                            {
                                                                <li><strong>@p.Name</strong>@(string.IsNullOrWhiteSpace(p.Description) ? "" : $": {p.Description}")</li>
                                                            }
                                                        </ul>
                                                    </div>
                                                }
                                                <div class="mb-1">
                                                    <label class="form-label">Template parameters</label>
                                                    <textarea name="PromptTemplates[@i].PromptParameters"
                                                              class="form-control prompt-template-parameters-input" rows="3"
                                                              placeholder='e.g., {"key1": "value1", "key2": "value2"}'>@selection.PromptParameters</textarea>
                                                    <span class="form-text">Optional JSON key-value pairs to pass as template arguments.</span>
                                                    <div class="text-danger small d-none prompt-template-parameters-error"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="text-muted small @(Model.PromptTemplates.Count == 0 ? "" : "d-none")" id="promptTemplateEmptyState">
                                No prompt templates selected.
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="SystemMessage" class="form-label">System message</label>
                        <textarea asp-for="SystemMessage" class="form-control" rows="4" placeholder="You are a helpful assistant..."></textarea>
                        <div class="form-text">Instructions for the AI on how to behave.</div>
                    </div>

                    <div class="parameter-grid">
                        <div class="mb-3">
                            <label asp-for="MaxTokens" class="form-label parameter-label">
                                <span>Max tokens</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@maxTokensHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input asp-for="MaxTokens" type="number" class="form-control" min="1" placeholder="4096" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Temperature" class="form-label parameter-label">
                                <span>Temperature</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@temperatureHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input asp-for="Temperature" type="number" class="form-control" step="0.1" min="0" max="2" placeholder="0.7" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="TopP" class="form-label parameter-label">
                                <span>Top P</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@topPHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input asp-for="TopP" type="number" class="form-control" step="0.1" min="0" max="1" placeholder="1.0" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="FrequencyPenalty" class="form-label parameter-label">
                                <span>Frequency penalty</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@frequencyPenaltyHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input asp-for="FrequencyPenalty" type="number" class="form-control" step="0.1" min="-2" max="2" placeholder="0" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="PresencePenalty" class="form-label parameter-label">
                                <span>Presence penalty</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@presencePenaltyHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input asp-for="PresencePenalty" type="number" class="form-control" step="0.1" min="-2" max="2" placeholder="0" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="PastMessagesCount" class="form-label parameter-label">
                                <span>Past messages</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@pastMessagesHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input asp-for="PastMessagesCount" type="number" class="form-control" min="0" placeholder="10" />
                        </div>
                    </div>
                </div>

                <!-- Capabilities Tab -->
                <div class="tab-pane fade" id="capabilities" role="tabpanel">
                    <!-- AI Agents Section -->
                    <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-robot"></i> AI Agents</h6>
                    @if (Model.AvailableAgents.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No AI agent profiles are available. Create agent-type AI profiles first.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the AI agents this interaction can delegate tasks to.</p>
                        @foreach (var agent in Model.AvailableAgents)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedAgentNames" value="@agent.Name" id="interaction_agent_@agent.Name"
                                @(agent.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="interaction_agent_@agent.Name">
                                    <strong>@agent.DisplayText</strong>
                                </label>
                            </div>
                        }
                    }

                    <!-- AI Tools Section -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-tools"></i> AI Tools</h6>
                    @if (Model.AvailableTools.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No selectable AI tools are registered.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <p class="text-muted mb-0 small">Select the tools this interaction can use during conversations.</p>
                            <div class="btn-group btn-group-sm ms-3" role="group">
                                <button type="button" class="btn btn-outline-primary" id="select-all-tools"><i class="bi bi-check-all"></i> Select all</button>
                                <button type="button" class="btn btn-outline-secondary" id="deselect-all-tools"><i class="bi bi-x-lg"></i> Deselect all</button>
                            </div>
                        </div>
                        @foreach (var group in Model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                        {
                            <h6 class="text-secondary mt-3 mb-2"><i class="bi bi-folder"></i> @group.Key</h6>
                            @foreach (var tool in group)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input tool-checkbox" type="checkbox" name="SelectedToolNames" value="@tool.Name" id="interaction_tool_@tool.Name"
                                    @(tool.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="interaction_tool_@tool.Name">
                                        <strong>@tool.Title</strong>
                                        @if (!string.IsNullOrEmpty(tool.Description))
                                        {
                                            <br />

                                            <small class="text-muted">@tool.Description</small>
                                        }
                                    </label>
                                </div>
                            }
                        }
                    }

                    <!-- A2A Connections Section -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h6>
                    @if (Model.AvailableA2AConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No A2A host connections are configured. Add them under <strong>Agent to Agent Hosts</strong> first.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the remote A2A hosts this interaction can use for agent orchestration.</p>
                        @foreach (var connection in Model.AvailableA2AConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedA2AConnectionIds" value="@connection.ItemId" id="interaction_a2a_@connection.ItemId"
                                @(connection.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="interaction_a2a_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong><br />
                                    <small class="text-muted">@connection.Endpoint</small>
                                </label>
                            </div>
                        }
                    }

                    <!-- MCP Hosts Section -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-plug"></i> MCP Hosts</h6>
                    @if (Model.AvailableMcpConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> No MCP host connections are configured. Add them under <strong>MCP Hosts</strong> first.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the MCP hosts this interaction can use for external tools and resources.</p>
                        @foreach (var connection in Model.AvailableMcpConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedMcpConnectionIds" value="@connection.ItemId" id="interaction_mcp_@connection.ItemId"
                                @(connection.IsSelected ? "checked" : "") />
                                <label class="form-check-label" for="interaction_mcp_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(connection.Source))
                                    {
                                        <br />

                                        <small class="text-muted">@connection.Source</small>
                                    }
                                </label>
                            </div>
                        }
                    }
                </div>

                <!-- Knowledge Base Tab -->
                <div class="tab-pane fade" id="kb" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="DataSourceId" class="form-label">
                            Data source
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="The data source used to retrieve background knowledge for this interaction.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                        <select asp-for="DataSourceId" class="form-select" asp-items="Model.DataSources">
                            <option value="">None</option>
                        </select>
                        <div class="form-text">Select a RAG data source to provide background knowledge for this interaction.</div>
                    </div>
                    <div class="mb-3 rag-data-source-filter-dependent">
                        <label asp-for="DataSourceFilter" class="form-label">
                            Filter
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="Optional provider-specific filter expression that limits which records can be retrieved from the selected data source.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                        <input asp-for="DataSourceFilter" class="form-control" placeholder="Optional provider-specific filter" />
                        <div class="form-text">Optional filter expression passed to the configured data source provider.</div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="DataSourceIsInScope" class="form-check-input" type="checkbox" />
                            <label asp-for="DataSourceIsInScope" class="form-check-label">
                                Restrict answers to retrieved data only
                                <span class="text-muted ms-1" data-bs-toggle="tooltip" title="When enabled, responses stay grounded in the retrieved knowledge instead of supplementing with general model knowledge.">
                                    <i class="bi bi-question-circle"></i>
                                </span>
                            </label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DataSourceStrictness" class="form-label">
                                    Strictness
                                    <span class="text-muted ms-1" data-bs-toggle="tooltip" title="Controls how strictly retrieved data source matches must align with the user request.">
                                        <i class="bi bi-question-circle"></i>
                                    </span>
                                </label>
                                <input asp-for="DataSourceStrictness" type="number" class="form-control" min="1" max="5" placeholder="Default provider setting" />
                                <div class="form-text">Controls how strictly the AI should follow retrieved data-source matches.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DataSourceTopNDocuments" class="form-label">
                                    Retrieved documents
                                    <span class="text-muted ms-1" data-bs-toggle="tooltip" title="Controls how many data source documents are retrieved for retrieval-augmented generation.">
                                        <i class="bi bi-question-circle"></i>
                                    </span>
                                </label>
                                <input asp-for="DataSourceTopNDocuments" type="number" class="form-control" min="1" max="20" placeholder="Default provider setting" />
                                <div class="form-text">How many data-source documents to retrieve for RAG.</div>
                            </div>
                        </div>
                    </div>

                    @if (Model.HasDocumentIndexConfiguration)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Documents uploaded here are indexed into the <strong>@Model.DocumentIndexProfileName</strong> AI Documents index and can be used as background knowledge during chat.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> Document knowledge-base search is not configured yet. Create an <strong>AI Documents</strong> index profile and select it under <strong>Settings → AI Settings → Documents</strong> before expecting uploaded documents to influence answers.
                        </div>
                    }

                    <h6 class="mt-3 mb-2"><i class="bi bi-paperclip"></i> Attach Documents</h6>
                    <div id="pending-docs-list" class="mb-3"></div>
                    <div class="input-group">
                        <input type="file" class="form-control" id="doc-add-input" name="Documents" multiple
                               accept="@supportedExtensionsAccept" />
                    </div>
                    <div class="form-text">Supported formats: @supportedExtensionsDisplay</div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-chat-left-text"></i> Create &amp; Start Chat
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.bootstrap && window.bootstrap.Tooltip) {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                    window.bootstrap.Tooltip.getOrCreateInstance(element);
                });
            }

            var dataSourceSelect = document.getElementById('@Html.IdFor(x => x.DataSourceId)');

            function toggleDataSourceDependentFields() {
                var hasDataSource = !!(dataSourceSelect && dataSourceSelect.value && dataSourceSelect.value.trim() !== '');
                document.querySelectorAll('.rag-data-source-filter-dependent').forEach(function (element) {
                    element.classList.toggle('d-none', !hasDataSource);
                });
            }

            if (dataSourceSelect) {
                dataSourceSelect.addEventListener('change', toggleDataSourceDependentFields);
            }

            toggleDataSourceDependentFields();

            // --- Tool Select All / Deselect All ---
            var selectAllBtn = document.getElementById('select-all-tools');
            var deselectAllBtn = document.getElementById('deselect-all-tools');
            if (selectAllBtn) {
                selectAllBtn.addEventListener('click', function () {
                    document.querySelectorAll('.tool-checkbox').forEach(function (cb) { cb.checked = true; });
                });
            }
            if (deselectAllBtn) {
                deselectAllBtn.addEventListener('click', function () {
                    document.querySelectorAll('.tool-checkbox').forEach(function (cb) { cb.checked = false; });
                });
            }

            // --- Prompt Template Management ---
            (function () {
                var container = document.getElementById('promptTemplatesContainer');
                var searchInput = document.getElementById('promptTemplateSearch');
                var noResults = document.getElementById('promptTemplateNoResults');
                var emptyState = document.getElementById('promptTemplateEmptyState');
                if (!container) return;

                var promptOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                    Model.AvailablePromptTemplates.Select(t => new
                                    {
                                            t.TemplateId,
                                            t.Title,
                                            t.Description,
                                            t.Category,
                                            Parameters = t.Parameters.Select(p => new { p.Name, p.Description })
                                    })));

                function escapeH(v) {
                    return (v || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
                }

                function getOption(id) {
                    return promptOptions.find(function (o) { return o.TemplateId === id; }) || null;
                }

                function buildParamsMarkup(option) {
                    if (!option || !option.Parameters || option.Parameters.length === 0) return '';
                    return option.Parameters.map(function (p) {
                        var desc = p.Description ? ': ' + escapeH(p.Description) : '';
                        return '<li><strong>' + escapeH(p.Name) + '</strong>' + desc + '</li>';
                    }).join('');
                }

                function createCard(templateId, promptParameters) {
                    var option = getOption(templateId);
                    var card = document.createElement('div');
                    var title = option && option.Title ? option.Title : templateId;
                    var description = option && option.Description ? option.Description : '';
                    var category = option ? option.Category : 'Unavailable';
                    var paramsMarkup = buildParamsMarkup(option);
                    var unavailableBadge = option ? '' : '<span class="badge text-bg-warning">Unavailable</span>';

                    card.className = 'card mb-1 prompt-template-card';
                    card.dataset.templateId = templateId;
                    card.innerHTML =
                        '<div class="card-header d-flex justify-content-between align-items-center py-2">' +
                            '<a class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0" data-bs-toggle="collapse" href="#" role="button" aria-expanded="true">' +
                                '<i class="bi bi-chevron-down me-1"></i>' +
                                '<span class="prompt-template-title fw-semibold">' + escapeH(title) + '</span>' +
                            '</a>' +
                            '<button type="button" class="btn btn-sm btn-danger remove-prompt-template-btn" title="Remove"><i class="bi bi-trash"></i></button>' +
                        '</div>' +
                        '<div class="collapse show">' +
                            '<div class="card-body">' +
                                '<input type="hidden" class="prompt-template-id-input" value="' + escapeH(templateId) + '" />' +
                                '<div class="d-flex flex-wrap gap-2 mb-2">' +
                                    '<span class="badge text-bg-secondary">' + escapeH(category) + '</span>' +
                                    unavailableBadge +
                                '</div>' +
                                (description ? '<div class="text-muted small mb-3">' + escapeH(description) + '</div>' : '') +
                                '<div class="mb-3' + (paramsMarkup ? '' : ' d-none') + '">' +
                                    '<small class="text-muted d-block mb-1">Expected parameters:</small>' +
                                    '<ul class="mb-0 small text-muted">' + paramsMarkup + '</ul>' +
                                '</div>' +
                                '<div class="mb-1">' +
                                    '<label class="form-label">Template parameters</label>' +
                                    '<textarea class="form-control prompt-template-parameters-input" rows="3" placeholder=\'e.g., {"key1": "value1", "key2": "value2"}\'></textarea>' +
                                    '<span class="form-text">Optional JSON key-value pairs to pass as template arguments.</span>' +
                                    '<div class="text-danger small d-none prompt-template-parameters-error"></div>' +
                                '</div>' +
                            '</div>' +
                        '</div>';
                    card.querySelector('.prompt-template-parameters-input').value = promptParameters || '';
                    return card;
                }

                function updateEmptyState() {
                    if (emptyState) emptyState.classList.toggle('d-none', container.querySelectorAll('.prompt-template-card').length > 0);
                }

                function reindexCards() {
                    container.querySelectorAll('.prompt-template-card').forEach(function (card, index) {
                        var idInput = card.querySelector('.prompt-template-id-input');
                        var paramsInput = card.querySelector('.prompt-template-parameters-input');
                        if (idInput) idInput.name = 'PromptTemplates[' + index + '].TemplateId';
                        if (paramsInput) paramsInput.name = 'PromptTemplates[' + index + '].PromptParameters';
                    });
                }

                // Add template from dropdown
                document.addEventListener('click', function (e) {
                    var btn = e.target.closest('.prompt-template-add-btn');
                    if (!btn) return;
                    e.preventDefault();
                    var templateId = btn.dataset.templateId;
                    var card = createCard(templateId, '');
                    container.appendChild(card);
                    reindexCards();
                    updateEmptyState();
                });

                // Remove template
                document.addEventListener('click', function (e) {
                    if (e.target.closest('.remove-prompt-template-btn')) {
                        var card = e.target.closest('.prompt-template-card');
                        if (card) {
                            card.remove();
                            reindexCards();
                            updateEmptyState();
                        }
                    }
                });

                // Search filter
                if (searchInput) {
                    searchInput.addEventListener('input', function () {
                        var query = this.value.toLowerCase();
                        var items = document.querySelectorAll('.prompt-template-add-btn');
                        var headers = document.querySelectorAll('.prompt-template-menu-items .dropdown-header');
                        var visibleCount = 0;
                        items.forEach(function (item) {
                            var text = (item.textContent || '').toLowerCase();
                            var visible = !query || text.indexOf(query) >= 0;
                            item.style.display = visible ? '' : 'none';
                            if (visible) visibleCount++;
                        });
                        headers.forEach(function (h) { h.style.display = query ? 'none' : ''; });
                        if (noResults) noResults.classList.toggle('d-none', visibleCount > 0);
                    });
                }
            })();
        });
    </script>
}
