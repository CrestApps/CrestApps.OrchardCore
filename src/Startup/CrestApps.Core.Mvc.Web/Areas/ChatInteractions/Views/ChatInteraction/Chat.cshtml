@using CrestApps.Core.Mvc.Web.Areas.ChatInteractions.ViewModels
@using CrestApps.Core.AI.Models
@using Microsoft.Extensions.Options
@model ChatInteractionChatViewModel
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions
@{
    ViewData["Title"] = "Chat - " + (Model.Title ?? "Untitled Chat");
    const string maxTokensHelp = "The maximum number of tokens (roughly words or word fragments) the AI can generate in a single response. Lower values produce shorter responses and reduce costs. Higher values allow for more detailed answers.";
    const string temperatureHelp = "Controls the randomness of AI responses. Lower values (closer to 0) make responses more focused and deterministic. Higher values (up to 2) make responses more creative and varied.";
    const string topPHelp = "Also called nucleus sampling. Controls diversity by limiting the AI to consider only the most probable tokens that sum to this value. Lower values are more focused, while higher values are more diverse.";
    const string frequencyPenaltyHelp = "Penalizes tokens based on how frequently they appear in the response so far. Higher values reduce repetition of the same words and phrases.";
    const string presencePenaltyHelp = "Penalizes tokens based on whether they have appeared at all. Higher values encourage the AI to introduce new topics and ideas rather than staying on the same subjects.";
    const string pastMessagesHelp = "The number of previous messages from the conversation to include as context. More messages provide better context but increase token usage and costs.";
    var supportedExtensionsAccept = ChatDocumentOptions.Value.GetAllowedFileExtensionsAcceptValue();
    var supportedExtensionsDisplay = ChatDocumentOptions.Value.GetAllowedFileExtensionsDisplayValue();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/default.min.css" />
<link rel="stylesheet" href="~/css/document-drop-zone.css" />

<style>
    .chat-page-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 180px);
    }
    .ai-chat-messages { padding: 1rem; }
    .ai-chat-messages .ai-chat-message-item { position: relative; padding: 0.25rem 0; }
    .ai-chat-messages .ai-chat-message-item + .ai-chat-message-item::before {
        content: '';
        display: block;
        width: 100%;
        margin-bottom: 0.25rem;
        border-top: 1px solid var(--bs-border-color, #dee2e6);
    }
    .ai-chat-messages .ai-chat-message-item p:last-child { margin-bottom: 0; }
    .ai-chat-msg-role { font-size: 0.75rem; font-weight: 600; margin-bottom: 2px; }
    .ai-chat-msg-role-user { color: #0d6efd; }
    .ai-chat-msg-role-assistant { color: #6f42c1; }
    .ai-chat-msg-role-assistant i.ai-streaming-icon { animation: pulse 1.5s infinite; }
    .ai-chat-msg-role-assistant i.ai-bot-icon { color: #6f42c1; }
    .ai-chat-messages .message-buttons-container {
        position: absolute;
        bottom: 0.25rem;
        right: 0.25rem;
        display: none;
    }
    .ai-chat-messages .ai-chat-message-item:hover .message-buttons-container {
        display: inline-block;
    }
    @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* Settings sidebar */
    .chat-settings-sidebar {
        height: calc(100vh - 180px);
        overflow-y: auto;
        border-right: 1px solid var(--bs-border-color, #dee2e6);
    }
    .chat-settings-sidebar .nav-pills .nav-link {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
    }
    .chat-settings-sidebar .nav-pills .nav-link.active {
        background-color: var(--bs-primary);
    }
    .settings-section label.form-label {
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    .settings-save-indicator {
        font-size: 0.85rem;
        min-height: 1.25rem;
        transition: opacity 0.3s ease;
    }
    .capability-section + .capability-section {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--bs-border-color, #dee2e6);
    }
    .parameter-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }
    @@media (min-width: 1200px) {
        .parameter-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    .parameter-label {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }
    .parameter-help-icon {
        color: var(--bs-secondary-color, #6c757d);
        cursor: help;
    }
    #conversation-btn.active {
        background-color: var(--bs-primary);
        border-color: var(--bs-primary);
        color: #fff;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-chat-left-dots"></i> @(Model.Title ?? "Untitled Chat")</h5>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div class="row g-0 border rounded" style="height: calc(100vh - 180px);">
    <!-- Left: Settings Sidebar -->
    <div class="col-md-4 col-lg-3 chat-settings-sidebar bg-light">
        <div class="p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong class="small text-uppercase text-muted">Settings</strong>
                <span id="settings-save-indicator" class="settings-save-indicator text-muted"></span>
            </div>

            <!-- Settings Tabs -->
            <ul class="nav nav-pills nav-fill mb-3" id="settingsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-settings" data-bs-toggle="pill" data-bs-target="#pane-settings" type="button" role="tab">
                        <i class="bi bi-gear"></i> General
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-knowledge" data-bs-toggle="pill" data-bs-target="#pane-knowledge" type="button" role="tab">
                        <i class="bi bi-database"></i> Knowledge
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-capabilities" data-bs-toggle="pill" data-bs-target="#pane-capabilities" type="button" role="tab">
                        <i class="bi bi-lightning"></i> Capabilities
                    </button>
                </li>
            </ul>

            <div class="tab-content settings-section" id="settingsTabContent">
                <!-- Tab 1: General Settings -->
                <div class="tab-pane fade show active" id="pane-settings" role="tabpanel">
                    <div class="mb-2 rag-data-source-dependent">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control setting-input" id="setting-title"
                               value="@Model.Title" placeholder="e.g., Code Helper" data-setting="title" />
                    </div>

                    <div class="mb-2 rag-data-source-dependent">
                        <label class="form-label">Deployment</label>
                        <select class="form-select setting-input" id="setting-deployment" data-setting="deploymentName">
                            <option value="">Select deployment</option>
                            @foreach (var d in Model.Deployments)
                            {
                                <option value="@d.Value" selected="@(d.Value == Model.ChatDeploymentName ? "selected" : null)">@d.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Orchestrator</label>
                        <select class="form-select setting-input" id="setting-orchestratorName" name="OrchestratorName" data-setting="orchestratorName">
                            <option value="">Use default orchestrator</option>
                            @foreach (var o in Model.Orchestrators)
                            {
                                <option value="@o.Value" selected="@(o.Value == Model.OrchestratorName ? "selected" : null)">@o.Text</option>
                            }
                        </select>
                    </div>

                    @* Copilot panel (shown/hidden by orchestrator-dependent JS in the partial) *@
                    @await Html.PartialAsync("_CopilotConfig", null, new ViewDataDictionary(ViewData) {
                        { "CopilotPrefix", "ci" },
                        { "CopilotAuthType", Model.CopilotAuthenticationType },
                        { "CopilotIsConfigured", Model.CopilotIsConfigured },
                        { "CopilotIsAuth", Model.CopilotIsAuthenticated },
                        { "CopilotUsername", Model.CopilotGitHubUsername },
                        { "CopilotModel", Model.CopilotModel },
                        { "CopilotIsAllowAll", Model.CopilotIsAllowAll },
                        { "CopilotModels", Model.CopilotAvailableModels },
                    })

                    <!-- Prompt Templates -->
                    @if (Model.AvailablePromptTemplates.Any())
                    {
                        <div class="mb-2">
                            <label class="form-label">Prompt templates</label>
                            <div class="dropdown mb-2">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle w-100" type="button"
                                        id="chatPromptTemplateBtn" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-plus-lg"></i> Add template
                                </button>
                                <div class="dropdown-menu p-2" style="max-height:20rem;min-width:18rem;overflow-y:auto;">
                                    <input type="search" class="form-control mb-2" id="chatPromptTemplateSearch" placeholder="Search..." />
                                    <div class="chat-prompt-template-menu">
                                        @foreach (var group in Model.AvailablePromptTemplates.GroupBy(t => t.Category).OrderBy(g => g.Key))
                                        {
                                            <div class="dropdown-header px-2 small">@group.Key</div>
                                            @foreach (var option in group)
                                            {
                                                <button type="button"
                                                        class="dropdown-item chat-prompt-add-btn text-wrap small"
                                                        data-template-id="@option.TemplateId"
                                                        data-template-title="@option.Title"
                                                        data-template-description="@(option.Description ?? "")"
                                                        data-template-params="@(System.Text.Json.JsonSerializer.Serialize(option.Parameters.Select(p => new { p.Name, p.Description })))">
                                                    @option.Title
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                            <div id="chatPromptTemplatesContainer"></div>
                        </div>
                    }

                    <div class="mb-2">
                        <label class="form-label">System message</label>
                        <textarea class="form-control setting-input" id="setting-systemMessage"
                                  rows="3" placeholder="You are a helpful assistant..." data-setting="systemMessage">@Model.SystemMessage</textarea>
                    </div>

                    <div class="parameter-grid">
                        <div class="mb-2">
                            <label class="form-label parameter-label" for="setting-maxTokens">
                                <span>Max tokens</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@maxTokensHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input type="number" class="form-control setting-input" id="setting-maxTokens"
                                   min="1" value="@Model.MaxTokens" placeholder="4096" data-setting="maxTokens" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label parameter-label" for="setting-temperature">
                                <span>Temperature</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@temperatureHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input type="number" class="form-control setting-input" id="setting-temperature"
                                   step="0.1" min="0" max="2" value="@Model.Temperature" placeholder="0.7" data-setting="temperature" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label parameter-label" for="setting-topP">
                                <span>Top P</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@topPHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input type="number" class="form-control setting-input" id="setting-topP"
                                   step="0.1" min="0" max="1" value="@Model.TopP" placeholder="1.0" data-setting="topP" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label parameter-label" for="setting-frequencyPenalty">
                                <span>Frequency penalty</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@frequencyPenaltyHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input type="number" class="form-control setting-input" id="setting-frequencyPenalty"
                                   step="0.1" min="-2" max="2" value="@Model.FrequencyPenalty" placeholder="0" data-setting="frequencyPenalty" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label parameter-label" for="setting-presencePenalty">
                                <span>Presence penalty</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@presencePenaltyHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input type="number" class="form-control setting-input" id="setting-presencePenalty"
                                   step="0.1" min="-2" max="2" value="@Model.PresencePenalty" placeholder="0" data-setting="presencePenalty" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label parameter-label" for="setting-pastMessagesCount">
                                <span>Past messages</span>
                                <span class="parameter-help-icon" data-bs-toggle="tooltip" title="@pastMessagesHelp">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <input type="number" class="form-control setting-input" id="setting-pastMessagesCount"
                                   min="0" value="@Model.PastMessagesCount" placeholder="10" data-setting="pastMessagesCount" />
                        </div>
                    </div>
                </div>

                <!-- Tab 2: Capabilities -->
                <div class="tab-pane fade" id="pane-capabilities" role="tabpanel">
                    <!-- AI Agents -->
                    @if (Model.AvailableAgents.Count > 0)
                    {
                        <div class="capability-section">
                            <h6 class="small fw-bold mb-2"><i class="bi bi-robot"></i> AI Agents</h6>
                            @foreach (var agent in Model.AvailableAgents)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input capability-checkbox" type="checkbox"
                                           value="@agent.Name" id="chat_agent_@agent.Name" data-group="agentNames"
                                           @(agent.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="chat_agent_@agent.Name">
                                        @agent.DisplayText
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    <!-- AI Tools -->
                    @if (Model.AvailableTools.Count > 0)
                    {
                        <div class="capability-section">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="small fw-bold mb-0"><i class="bi bi-tools"></i> AI Tools</h6>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary btn-sm py-0 px-1" id="chat-select-all-tools" style="font-size:0.7rem;">All</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1" id="chat-deselect-all-tools" style="font-size:0.7rem;">None</button>
                                </div>
                            </div>
                            @foreach (var group in Model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                            {
                                <div class="text-muted small fw-semibold mt-2 mb-1">@group.Key</div>
                                @foreach (var tool in group)
                                {
                                    <div class="form-check mb-1">
                                        <input class="form-check-input capability-checkbox chat-tool-checkbox" type="checkbox"
                                               value="@tool.Name" id="chat_tool_@tool.Name" data-group="toolNames"
                                               @(tool.IsSelected ? "checked" : "") />
                                        <label class="form-check-label" for="chat_tool_@tool.Name">
                                            @tool.Title
                                            @if (!string.IsNullOrEmpty(tool.Description))
                                            {
                                                <br /><span class="text-muted" style="font-size:0.7rem;">@tool.Description</span>
                                            }
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    }

                    <!-- A2A Connections -->
                    @if (Model.AvailableA2AConnections.Any())
                    {
                        <div class="capability-section">
                            <h6 class="small fw-bold mb-2"><i class="bi bi-diagram-3"></i> A2A Hosts</h6>
                            @foreach (var connection in Model.AvailableA2AConnections)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input capability-checkbox" type="checkbox"
                                           value="@connection.ItemId" id="chat_a2a_@connection.ItemId" data-group="a2aConnectionIds"
                                           @(connection.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="chat_a2a_@connection.ItemId">
                                        @connection.DisplayText
                                        <br /><span class="text-muted" style="font-size:0.7rem;">@connection.Endpoint</span>
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    <!-- MCP Hosts -->
                    @if (Model.AvailableMcpConnections.Any())
                    {
                        <div class="capability-section">
                            <h6 class="small fw-bold mb-2"><i class="bi bi-plug"></i> MCP Hosts</h6>
                            @foreach (var connection in Model.AvailableMcpConnections)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input capability-checkbox" type="checkbox"
                                           value="@connection.ItemId" id="chat_mcp_@connection.ItemId" data-group="mcpConnectionIds"
                                           @(connection.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="chat_mcp_@connection.ItemId">
                                        @connection.DisplayText
                                        @if (!string.IsNullOrEmpty(connection.Source))
                                        {
                                            <br /><span class="text-muted" style="font-size:0.7rem;">@connection.Source</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    }

                    @if (Model.AvailableAgents.Count == 0 && Model.AvailableTools.Count == 0
                        && !Model.AvailableA2AConnections.Any() && !Model.AvailableMcpConnections.Any())
                    {
                        <div class="text-muted small text-center py-3">
                            <i class="bi bi-info-circle"></i> No capabilities are available to configure.
                        </div>
                    }
                </div>

                <!-- Tab 3: Knowledge Base -->
                <div class="tab-pane fade" id="pane-knowledge" role="tabpanel">
                    <div class="mb-2">
                        <label class="form-label">
                            Data source
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="The data source used to retrieve background knowledge for this interaction.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                        <select asp-for="DataSourceId" asp-items="Model.DataSources" class="form-select setting-input" id="setting-dataSourceId" data-setting="dataSourceId">
                            <option value="">None</option>
                        </select>
                        <div class="form-text">External data source for AI context.</div>
                    </div>

                    <div class="mb-2 rag-data-source-filter-dependent">
                        <label class="form-label">
                            Filter
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="Optional provider-specific filter expression that limits which records can be retrieved from the selected data source.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                        <input type="text" class="form-control setting-input" id="setting-filter"
                               value="@Model.DataSourceFilter" placeholder="Optional provider-specific filter" data-setting="filter" />
                        <div class="form-text">Optional filter expression passed to the configured data source provider.</div>
                    </div>

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input setting-input" type="checkbox" id="setting-isInScope"
                               data-setting="isInScope" @(Model.DataSourceIsInScope ? "checked" : "") />
                        <label class="form-check-label" for="setting-isInScope">
                            Restrict answers to retrieved data only
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="When enabled, responses stay grounded in the retrieved knowledge instead of supplementing with general model knowledge.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">
                            Strictness
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="Controls how strictly retrieved data source matches must align with the user request.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                        <input type="number" class="form-control setting-input" id="setting-strictness"
                               min="1" max="5" value="@Model.DataSourceStrictness" placeholder="Default provider setting" data-setting="strictness" />
                        <div class="form-text">Controls how strictly the AI should follow retrieved data-source matches.</div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">
                            Retrieved documents
                            <span class="text-muted ms-1" data-bs-toggle="tooltip" title="Controls how many data source documents are retrieved for retrieval-augmented generation.">
                                <i class="bi bi-question-circle"></i>
                            </span>
                        </label>
                        <input type="number" class="form-control setting-input" id="setting-topNDocuments"
                               min="1" max="20" value="@Model.DataSourceTopNDocuments" placeholder="Default provider setting" data-setting="topNDocuments" />
                        <div class="form-text">How many data-source documents to retrieve for RAG.</div>
                    </div>

                    @if (!Model.HasDocumentIndexConfiguration)
                    {
                        <div class="alert alert-warning small py-2 mb-2">
                            <i class="bi bi-exclamation-triangle"></i> Document indexing is not configured.
                        </div>
                    }

                    <div class="mb-2">
                        <label class="form-label"><i class="bi bi-paperclip"></i> Upload documents</label>
                        <div class="document-drop-zone" id="chat-doc-drop-zone">
                            <input type="file" class="d-none" id="chat-doc-upload" multiple
                                   accept="@supportedExtensionsAccept" />
                            <div class="document-drop-zone__body">
                                <span class="document-drop-zone__icon"><i class="bi bi-cloud-arrow-up"></i></span>
                                <div>
                                    <div class="document-drop-zone__title">Drag and drop files here</div>
                                    <div class="text-muted small">or browse for documents to upload into this chat interaction</div>
                                </div>
                                <div class="document-drop-zone__actions">
                                    <button type="button" class="btn btn-outline-primary" id="chat-doc-browse" data-drop-zone-browse>
                                        <i class="bi bi-folder2-open"></i> Browse files
                                    </button>
                                </div>
                                <div class="form-text mb-0">Supported formats: @supportedExtensionsDisplay</div>
                            </div>
                        </div>
                        <div id="chat-doc-upload-status" class="small mt-2 d-none"></div>
                        <div id="chat-doc-upload-progress" class="progress mt-2 d-none" role="progressbar" aria-label="Document upload progress" aria-valuemin="0" aria-valuemax="100">
                            <div id="chat-doc-upload-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%">0%</div>
                        </div>
                        <div id="chat-doc-upload-queue" class="d-flex flex-column gap-2 mt-2"></div>
                    </div>
                    <div id="chat-documents-list" class="d-flex flex-column gap-2"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Chat Area -->
    <div class="col-md-8 col-lg-9 d-flex flex-column" style="height: 100%;">
        <!-- Chat header with Clear History -->
        <div class="d-flex justify-content-between align-items-center border-bottom px-3 py-2 bg-white">
            <span class="text-muted small" id="chat-title-display">
                <i class="bi bi-chat-left-dots"></i> <span id="chat-title-text">@(Model.Title ?? "Untitled Chat")</span>
            </span>
            <button type="button" id="clear-history-btn" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-trash3"></i> Clear history
            </button>
        </div>

        <!-- Messages container -->
        <div id="chat-container" class="flex-grow-1 overflow-auto">
            <div id="chat-placeholder">
                <div class="p-3 text-muted">
                    <i class="bi bi-robot"></i> Start chatting! Your messages are sent directly to the AI with the parameters you configured.
                </div>
            </div>
            <div id="chat-app"></div>
        </div>

        <!-- Input area -->
        <div class="border-top p-3 bg-white">
            <div class="d-flex gap-2">
                <textarea id="chat-input"
                          class="form-control"
                          rows="1"
                          placeholder="Type a message..."
                          data-item-id="@Model.ItemId"></textarea>
                @if (Model.SpeechToTextEnabled)
                {
                    <button type="button" id="mic-btn" class="btn btn-outline-secondary" title="Record audio">
                        <i class="bi bi-mic"></i>
                    </button>
                }
                @if (Model.ConversationModeEnabled)
                {
                    <button type="button"
                            id="conversation-btn"
                            class="btn btn-outline-dark"
                            title="Start Conversation"
                            data-start-title="Start Conversation"
                            data-end-title="End Conversation"
                            data-start-html="<i class='bi bi-soundwave'></i>"
                            data-end-html="<i class='bi bi-stop-fill me-1'></i> End Conversation">
                        <i class="bi bi-soundwave"></i>
                    </button>
                }
                <button type="button" id="send-btn" class="btn btn-primary">
                    <i class="bi bi-send"></i> Send
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/document-drop-zone.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.bootstrap && window.bootstrap.Tooltip) {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                    window.bootstrap.Tooltip.getOrCreateInstance(element);
                });
            }

            var itemId = '@Model.ItemId';
            var dataSourceSelect = document.getElementById('setting-dataSourceId');
            var hubUrl = '/hubs/chat-interaction';
            var existingMessages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExistingMessages));
            var interactionDocuments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Documents));
            var uploadDocumentUrl = '@Url.Content("~/ai/chat-interactions/upload-document")';
            var removeDocumentUrl = '@Url.Content("~/ai/chat-interactions/remove-document")';
            var audioChunkIntervalMs = 250;
            var speechToTextEnabled = @Model.SpeechToTextEnabled.ToString().ToLowerInvariant();
            var conversationModeEnabled = @Model.ConversationModeEnabled.ToString().ToLowerInvariant();
            var textToSpeechEnabled = @Model.TextToSpeechEnabled.ToString().ToLowerInvariant();
            var ttsVoiceName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TextToSpeechVoiceName));

            // --- Markdown rendering ---
            var renderer = new marked.Renderer();
            renderer.link = function (data) {
                return '<a href="' + DOMPurify.sanitize(data.href) + '" target="_blank" rel="noopener noreferrer">' + data.text + '</a>';
            };
            marked.setOptions({
                renderer: renderer,
                highlight: function (code, lang) {
                    if (lang && hljs.getLanguage(lang)) {
                        return hljs.highlight(code, { language: lang }).value;
                    }
                    return hljs.highlightAuto(code).value;
                }
            });

            function renderMarkdown(text) {
                return DOMPurify.sanitize(marked.parse(text || ''), { ADD_ATTR: ['target'] });
            }

            function normalizeReference(reference) {
                if (!reference || typeof reference !== 'object') {
                    return null;
                }

                var normalized = Object.assign({}, reference);
                normalized.index = normalized.index ?? normalized.Index ?? 0;
                normalized.text = normalized.text ?? normalized.Text ?? null;
                normalized.link = normalized.link ?? normalized.Link ?? null;

                return normalized;
            }

            function normalizeReferences(references) {
                if (!references || typeof references !== 'object') {
                    return {};
                }

                var normalized = {};

                Object.entries(references).forEach(function (entry) {
                    normalized[entry[0]] = normalizeReference(entry[1]) || {};
                });

                return normalized;
            }

            function mergeReferences(target, source) {
                if (!source || typeof source !== 'object') {
                    return target;
                }

                return Object.assign(target || {}, source);
            }

            function formatMessageContent(content, references) {
                var processedContent = (content || '').trim();
                var messageReferences = normalizeReferences(references);

                if (!processedContent || !Object.keys(messageReferences).length) {
                    return processedContent;
                }

                var citedRefs = Object.entries(messageReferences).filter(function (entry) {
                    return processedContent.includes(entry[0]);
                });

                if (!citedRefs.length) {
                    return processedContent;
                }

                citedRefs.sort(function (a, b) {
                    return (a[1].index || 0) - (b[1].index || 0);
                });

                var displayIndex = 1;
                citedRefs.forEach(function (entry) {
                    var key = entry[0];
                    var value = entry[1];
                    var placeholder = '__CITE_' + (value.index || displayIndex) + '__';
                    processedContent = processedContent.replaceAll(key, placeholder);
                    value._displayIndex = displayIndex++;
                    value._placeholder = placeholder;
                });

                citedRefs.forEach(function (entry) {
                    var value = entry[1];
                    processedContent = processedContent.replaceAll(value._placeholder, '<sup><strong>' + value._displayIndex + '</strong></sup>');
                });

                processedContent = processedContent.replaceAll('</strong></sup><sup>', '</strong></sup><sup>,</sup><sup>');
                processedContent += '<br><br>';

                citedRefs.forEach(function (entry) {
                    var key = entry[0];
                    var value = entry[1];
                    var label = value.text || key;

                    processedContent += value.link
                        ? '**' + value._displayIndex + '**. [' + label + '](' + value.link + ')<br>'
                        : '**' + value._displayIndex + '**. ' + label + '<br>';
                });

                return processedContent;
            }

            function createChatMessage(role, content, isStreaming, isSystem, references) {
                var rawContent = content || '';
                var messageReferences = normalizeReferences(references);

                return {
                    role: role,
                    rawContent: rawContent,
                    content: rawContent,
                    references: messageReferences,
                    htmlContent: renderMarkdown(formatMessageContent(rawContent, messageReferences)),
                    isStreaming: isStreaming || false,
                    isSystem: isSystem || false
                };
            }

            function formatFileSize(bytes) {
                if (!bytes && bytes !== 0) {
                    return '';
                }

                if (bytes < 1024) {
                    return bytes + ' B';
                }

                if (bytes < 1024 * 1024) {
                    return (bytes / 1024).toFixed(1) + ' KB';
                }

                return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
            }

            function normalizeDocumentInfo(doc) {
                if (!doc) {
                    return null;
                }

                return {
                    documentId: doc.documentId || doc.DocumentId || null,
                    fileName: doc.fileName || doc.FileName || 'Document',
                    fileSize: doc.fileSize ?? doc.FileSize ?? 0,
                    contentType: doc.contentType || doc.ContentType || null
                };
            }

            function getDocumentKey(fileName, fileSize) {
                return ((fileName || '').trim().toLowerCase()) + '::' + (fileSize || 0);
            }

            function isDuplicateFile(file, knownKeys) {
                return knownKeys.has(getDocumentKey(file.name, file.size));
            }

            interactionDocuments = (Array.isArray(interactionDocuments) ? interactionDocuments : [])
                .map(normalizeDocumentInfo)
                .filter(function (doc) { return !!doc && !!doc.documentId; });

            function renderDocuments() {
                var container = document.getElementById('chat-documents-list');
                if (!container) {
                    return;
                }

                container.innerHTML = '';

                if (interactionDocuments.length === 0) {
                    container.innerHTML = '<div class="text-muted small">No documents uploaded yet.</div>';
                    return;
                }

                interactionDocuments.forEach(function (doc) {
                    var row = document.createElement('div');
                    row.className = 'd-flex justify-content-between align-items-start border rounded px-2 py-2 bg-white';
                    row.innerHTML =
                        '<div class="me-2">' +
                            '<div class="fw-semibold small"><i class="bi bi-file-earmark-text me-1"></i>' + DOMPurify.sanitize(doc.fileName || 'Document') + '</div>' +
                            '<div class="text-muted small">' + DOMPurify.sanitize(formatFileSize(doc.fileSize)) + '</div>' +
                        '</div>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger remove-chat-document-btn" data-document-id="' + DOMPurify.sanitize(doc.documentId) + '">' +
                            '<i class="bi bi-trash"></i> Remove' +
                        '</button>';

                    container.appendChild(row);
                });

                container.querySelectorAll('.remove-chat-document-btn').forEach(function (button) {
                    button.addEventListener('click', function () {
                        removeDocument(button.dataset.documentId);
                    });
                });
            }

            var uploadItems = [];
            var isUploadingDocuments = false;

            function showUploadStatus(message, cssClass) {
                var status = document.getElementById('chat-doc-upload-status');
                if (!status) {
                    return;
                }

                if (!message) {
                    status.textContent = '';
                    status.className = 'small mt-2 d-none';
                    return;
                }

                status.textContent = message;
                status.className = 'small mt-2 ' + (cssClass || 'text-muted');
            }

            function getUploadStatePresentation(state) {
                switch (state) {
                    case 'uploaded':
                        return { label: 'Uploaded', badgeClass: 'text-bg-success', progressClass: 'bg-success' };
                    case 'failed':
                        return { label: 'Failed', badgeClass: 'text-bg-danger', progressClass: 'bg-danger' };
                    case 'uploading':
                        return { label: 'Uploading', badgeClass: 'text-bg-warning', progressClass: 'bg-warning progress-bar-striped progress-bar-animated' };
                    default:
                        return { label: 'Queued', badgeClass: 'text-bg-secondary', progressClass: 'bg-secondary progress-bar-striped progress-bar-animated' };
                }
            }

            function formatUploadMessage(item) {
                if (item.status === 'failed' && item.error) {
                    return item.error;
                }

                if (item.status === 'uploaded') {
                    return 'Upload completed successfully.';
                }

                if (item.status === 'uploading') {
                    return item.progress + '% uploaded';
                }

                return 'Waiting to upload...';
            }

            function renderUploadQueue() {
                var container = document.getElementById('chat-doc-upload-queue');
                if (!container) {
                    return;
                }

                container.innerHTML = '';

                if (uploadItems.length === 0) {
                    return;
                }

                uploadItems.forEach(function (item) {
                    var presentation = getUploadStatePresentation(item.status);
                    var card = document.createElement('div');
                    card.className = 'border rounded px-2 py-2 bg-white';

                    var header = document.createElement('div');
                    header.className = 'd-flex justify-content-between align-items-start gap-2';

                    var fileDetails = document.createElement('div');
                    fileDetails.className = 'flex-grow-1';

                    var fileName = document.createElement('div');
                    fileName.className = 'fw-semibold small';
                    fileName.textContent = item.fileName;

                    var fileSize = document.createElement('div');
                    fileSize.className = 'text-muted small';
                    fileSize.textContent = formatFileSize(item.fileSize);

                    fileDetails.appendChild(fileName);
                    fileDetails.appendChild(fileSize);

                    var badge = document.createElement('span');
                    badge.className = 'badge ' + presentation.badgeClass;
                    badge.textContent = presentation.label;

                    header.appendChild(fileDetails);
                    header.appendChild(badge);

                    var progress = document.createElement('div');
                    progress.className = 'progress mt-2';
                    progress.setAttribute('role', 'progressbar');
                    progress.setAttribute('aria-valuemin', '0');
                    progress.setAttribute('aria-valuemax', '100');
                    progress.setAttribute('aria-valuenow', item.progress.toString());

                    var progressBar = document.createElement('div');
                    progressBar.className = 'progress-bar ' + presentation.progressClass;
                    progressBar.style.width = item.progress + '%';
                    progressBar.textContent = item.progress + '%';
                    progress.appendChild(progressBar);

                    var message = document.createElement('div');
                    message.className = item.status === 'failed' ? 'small text-danger mt-2' : 'small text-muted mt-2';
                    message.textContent = formatUploadMessage(item);

                    card.appendChild(header);
                    card.appendChild(progress);
                    card.appendChild(message);
                    container.appendChild(card);
                });
            }

            function updateUploadItem(itemId, updates) {
                uploadItems = uploadItems.map(function (item) {
                    if (item.id !== itemId) {
                        return item;
                    }

                    return Object.assign({}, item, updates);
                });

                renderUploadQueue();
            }

            function removeUploadItems(predicate) {
                uploadItems = uploadItems.filter(function (item) {
                    return !predicate(item);
                });

                renderUploadQueue();
            }

            function showUploadProgress(progress, message, cssClass) {
                var progressContainer = document.getElementById('chat-doc-upload-progress');
                var progressBar = document.getElementById('chat-doc-upload-progress-bar');
                if (!progressContainer || !progressBar) {
                    return;
                }

                if (progress === null || progress === undefined) {
                    progressContainer.className = 'progress mt-2 d-none';
                    progressContainer.setAttribute('aria-valuenow', '0');
                    progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated';
                    progressBar.style.width = '0%';
                    progressBar.textContent = '0%';
                    return;
                }

                var roundedProgress = Math.max(0, Math.min(100, Math.round(progress)));
                progressContainer.className = 'progress mt-2';
                progressContainer.setAttribute('aria-valuenow', roundedProgress.toString());
                progressBar.className = 'progress-bar ' + (cssClass || 'progress-bar-striped progress-bar-animated');
                progressBar.style.width = roundedProgress + '%';
                progressBar.textContent = message || (roundedProgress + '%');
            }

            function createUploadItem(file, index) {
                return {
                    id: file.name + '::' + file.size + '::' + file.lastModified + '::' + index + '::' + Date.now(),
                    fileName: file.name,
                    fileSize: file.size,
                    status: 'queued',
                    progress: 0,
                    error: null
                };
            }

            function uploadSingleDocument(file, itemIdToUpdate, fileIndex, totalFiles) {
                return new Promise(function (resolve, reject) {
                    var formData = new FormData();
                    formData.append('chatInteractionId', itemId);
                    formData.append('files', file);

                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', uploadDocumentUrl, true);

                    xhr.upload.addEventListener('progress', function (event) {
                        if (!event.lengthComputable) {
                            return;
                        }

                        var fileProgress = Math.round((event.loaded / event.total) * 100);
                        updateUploadItem(itemIdToUpdate, {
                            status: 'uploading',
                            progress: fileProgress
                        });

                        var overallProgress = ((fileIndex + (event.loaded / event.total)) / totalFiles) * 100;
                        showUploadProgress(overallProgress, 'Uploading ' + (fileIndex + 1) + ' of ' + totalFiles, 'progress-bar-striped progress-bar-animated');
                    });

                    xhr.addEventListener('load', function () {
                        if (xhr.status >= 200 && xhr.status < 300) {
                            try {
                                resolve(JSON.parse(xhr.responseText));
                            }
                            catch (error) {
                                reject(new Error('Upload failed: invalid server response.'));
                            }

                            return;
                        }

                        reject(new Error((xhr.responseText || 'Upload failed.').trim()));
                    });

                    xhr.addEventListener('error', function () {
                        reject(new Error('Upload failed. Please check your connection and try again.'));
                    });

                    xhr.send(formData);
                });
            }

            async function uploadDocuments(files) {
                if (!files || files.length === 0) {
                    return;
                }

                if (isUploadingDocuments) {
                    showUploadStatus('A document upload is already in progress.', 'text-warning');
                    return;
                }

                isUploadingDocuments = true;

                var filesToUpload = [];
                var duplicateItems = [];
                var knownDocumentKeys = new Set(
                    interactionDocuments.map(function (doc) {
                        return getDocumentKey(doc.fileName, doc.fileSize);
                    }));

                Array.from(files).forEach(function (file) {
                    if (isDuplicateFile(file, knownDocumentKeys)) {
                        duplicateItems.push(file);
                        return;
                    }

                    knownDocumentKeys.add(getDocumentKey(file.name, file.size));
                    filesToUpload.push(file);
                });

                if (duplicateItems.length > 0) {
                    uploadItems = uploadItems.concat(duplicateItems.map(function (file, index) {
                        return Object.assign(createUploadItem(file, index), {
                            status: 'failed',
                            progress: 100,
                            error: 'This document is already attached.',
                        });
                    }));
                    renderUploadQueue();
                }

                if (filesToUpload.length === 0) {
                    isUploadingDocuments = false;
                    showUploadStatus(duplicateItems.map(function (file) {
                        return file.name + ': This document is already attached.';
                    }).join(' | '), 'text-warning');
                    showUploadProgress(null);
                    return;
                }

                var pendingItems = filesToUpload.map(createUploadItem);
                uploadItems = uploadItems.concat(pendingItems);
                renderUploadQueue();
                showUploadProgress(0, 'Preparing upload...', 'progress-bar-striped progress-bar-animated');

                if (documentUploadInput) {
                    documentUploadInput.disabled = true;
                }

                try {
                    var uploadedCount = 0;
                    var failedUploads = duplicateItems.map(function (file) {
                        return file.name + ': This document is already attached.';
                    });

                    for (var i = 0; i < filesToUpload.length; i++) {
                        var file = filesToUpload[i];
                        var pendingItem = pendingItems[i];

                        updateUploadItem(pendingItem.id, {
                            status: 'uploading',
                            progress: 0,
                            error: null
                        });

                        showUploadStatus('Uploading ' + (i + 1) + ' of ' + filesToUpload.length + ' document(s)...', 'text-warning');

                        try {
                            var result = await uploadSingleDocument(file, pendingItem.id, i, filesToUpload.length);
                            var uploaded = (Array.isArray(result.uploaded) ? result.uploaded : [])
                                .map(normalizeDocumentInfo)
                                .filter(function (doc) { return !!doc && !!doc.documentId; });
                            var failed = Array.isArray(result.failed) ? result.failed : [];

                            if (uploaded.length > 0) {
                                uploadedCount += uploaded.length;
                                interactionDocuments = interactionDocuments.concat(uploaded);
                                updateUploadItem(pendingItem.id, {
                                    status: 'uploaded',
                                    progress: 100,
                                    error: null
                                });
                            }
                            else {
                                var missingUploadMessage = failed.length > 0
                                    ? failed.map(function (entry) { return entry.fileName + ': ' + entry.error; }).join(' | ')
                                    : 'The server did not confirm that the file was uploaded.';
                                if (failed.length === 0) {
                                    failedUploads.push(missingUploadMessage);
                                }
                                updateUploadItem(pendingItem.id, {
                                    status: 'failed',
                                    progress: 100,
                                    error: missingUploadMessage
                                });
                            }

                            if (failed.length > 0) {
                                var failedMessage = failed.map(function (entry) { return entry.fileName + ': ' + entry.error; }).join(' | ');
                                failedUploads.push(failedMessage);
                                updateUploadItem(pendingItem.id, {
                                    status: 'failed',
                                    progress: 100,
                                    error: failedMessage
                                });
                            }
                        }
                        catch (error) {
                            console.error('Upload failed:', error);
                            var errorMessage = error && error.message
                                ? error.message
                                : 'Upload failed. Please try again.';
                            failedUploads.push(file.name + ': ' + errorMessage);
                            updateUploadItem(pendingItem.id, {
                                status: 'failed',
                                progress: pendingItem.progress || 0,
                                error: errorMessage
                            });
                        }
                    }

                    renderDocuments();

                    if (failedUploads.length > 0) {
                        removeUploadItems(function (item) { return item.status === 'uploaded'; });
                        showUploadStatus(
                            (uploadedCount > 0 ? ('Uploaded ' + uploadedCount + ' document(s). ') : '') +
                            failedUploads.join(' | '),
                            uploadedCount > 0 ? 'text-warning' : 'text-danger');
                        showUploadProgress(null);
                        return;
                    }

                    removeUploadItems(function () { return true; });
                    showUploadStatus('Uploaded ' + uploadedCount + ' document(s).', 'text-success');
                    showUploadProgress(null);
                }
                catch (error) {
                    console.error('Upload failed:', error);
                    showUploadStatus('Upload failed. Please try again.', 'text-danger');
                    showUploadProgress(null);
                }
                finally {
                    isUploadingDocuments = false;

                    if (documentUploadInput) {
                        documentUploadInput.disabled = false;
                    }
                }
            }

            async function removeDocument(documentId) {
                if (!documentId || !confirm('Remove this document?')) {
                    return;
                }

                try {
                    var response = await fetch(removeDocumentUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            itemId: itemId,
                            documentId: documentId
                        })
                    });

                    if (!response.ok) {
                        console.error('Failed to remove document:', await response.text());
                        return;
                    }

                    interactionDocuments = interactionDocuments.filter(function (doc) {
                        return doc.documentId !== documentId;
                    });

                    renderDocuments();
                }
                catch (error) {
                    console.error('Remove failed:', error);
                }
            }

            // --- Vue app for messages ---
            var app = Vue.createApp({
                methods: {
                    addMessage: function (role, content, isStreaming, isSystem, references) {
                        this.messages.push(createChatMessage(role, content, isStreaming, isSystem, references));
                        var self = this;
                        this.$nextTick(function () { self.scrollToBottom(); });
                    },
                    appendToLast: function (token, references) {
                        var last = this.messages[this.messages.length - 1];
                        if (last && last.role === 'assistant') {
                            last.rawContent = (last.rawContent || '') + (token || '');
                            last.content = last.rawContent;
                            last.references = mergeReferences(last.references, references);
                            last.htmlContent = renderMarkdown(formatMessageContent(last.rawContent, last.references));
                        }
                    },
                    finishStreaming: function () {
                        var last = this.messages[this.messages.length - 1];
                        if (last) {
                            last.isStreaming = false;
                            last.htmlContent = renderMarkdown(formatMessageContent(last.rawContent, last.references));
                        }
                        var self = this;
                        this.$nextTick(function () { self.scrollToBottom(); });
                    },
                    clearAll: function () {
                        this.messages = [];
                    },
                    scrollToBottom: function () {
                        var container = document.getElementById('chat-container');
                        if (container) container.scrollTop = container.scrollHeight;
                    },
                    copyResponse: function (content) {
                        navigator.clipboard.writeText(content);
                    }
                },
                data: function () {
                    return {
                        messages: existingMessages.map(function (m) {
                            return createChatMessage(m.role, m.content, false, false, m.references || m.References);
                        })
                    };
                },
                template:
                    '<div class="ai-chat-messages">' +
                        '<div v-for="(message, index) in messages" :key="index" class="ai-chat-message-item">' +
                            '<div v-if="message.isSystem" class="text-center py-2">' +
                                '<span class="badge text-bg-secondary"><i class="bi bi-info-circle"></i> {{ message.content }}</span>' +
                            '</div>' +
                            '<template v-else>' +
                                '<div v-if="message.role === \'user\'" class="ai-chat-msg-role ai-chat-msg-role-user">You</div>' +
                                '<div v-else class="ai-chat-msg-role ai-chat-msg-role-assistant">' +
                                    '<i :class="\'bi bi-robot\' + (message.isStreaming ? \' ai-streaming-icon\' : \' ai-bot-icon\')"></i> ' +
                                    'Assistant' +
                                '</div>' +
                                '<div class="lh-base">' +
                                    '<div v-html="message.htmlContent"></div>' +
                                    '<span class="message-buttons-container" v-if="message.role === \'assistant\' && !message.isStreaming">' +
                                        '<button class="btn btn-sm btn-link text-secondary p-0" v-on:click="copyResponse(message.content)" title="Copy response">' +
                                            '<i class="bi bi-clipboard"></i>' +
                                        '</button>' +
                                    '</span>' +
                                '</div>' +
                            '</template>' +
                        '</div>' +
                    '</div>'
            });

            var vm = app.mount('#chat-app');

            // --- SignalR connection ---
            var connection = new signalR.HubConnectionBuilder()
                .withUrl(hubUrl)
                .withAutomaticReconnect()
                .build();

            var isSending = false;
            var connectionStartPromise = null;
            var mediaRecorder = null;
            var isRecording = false;
            var isConversationMode = false;
            var preRecordingPrompt = '';
            var audioInputSent = false;
            var conversationSubject = null;
            var conversationStream = null;
            var conversationAudioContext = null;
            var conversationAnalyser = null;
            var conversationPartialMessage = null;
            var conversationAssistantMessage = null;
            var audioChunks = [];
            var audioPlayQueue = [];
            var isPlayingAudio = false;
            var currentAudioElement = null;

            function toggleDataSourceDependentFields() {
                var hasDataSource = !!(dataSourceSelect && dataSourceSelect.value && dataSourceSelect.value.trim() !== '');
                document.querySelectorAll('.rag-data-source-filter-dependent').forEach(function (element) {
                    element.classList.toggle('d-none', !hasDataSource);
                });
            }

            if (dataSourceSelect) {
                dataSourceSelect.addEventListener('change', toggleDataSourceDependentFields);
            }

            toggleDataSourceDependentFields();

            function ensureConnectionStarted() {
                if (connection.state === signalR.HubConnectionState.Connected) {
                    return Promise.resolve();
                }

                if (!connectionStartPromise) {
                    connectionStartPromise = connection.start()
                        .then(function () {
                            console.log('Connected to ChatInteraction hub.');
                        })
                        .catch(function (err) {
                            console.error('SignalR connection error:', err);
                            throw err;
                        })
                        .finally(function () {
                            connectionStartPromise = null;
                        });
                }

                return connectionStartPromise;
            }

            ensureConnectionStarted().catch(function () {
                showSaveIndicator('Connection failed', 'text-danger');
            });

            function updateMicButton() {
                var micBtn = document.getElementById('mic-btn');
                if (!micBtn) {
                    return;
                }

                micBtn.classList.toggle('btn-danger', isRecording);
                micBtn.classList.toggle('btn-outline-secondary', !isRecording);
                micBtn.title = isRecording ? 'Stop recording' : 'Record audio';
                micBtn.innerHTML = isRecording
                    ? '<i class="bi bi-stop-circle"></i>'
                    : '<i class="bi bi-mic"></i>';
            }

            function updateConversationButton() {
                var conversationBtn = document.getElementById('conversation-btn');
                if (!conversationBtn) {
                    return;
                }

                conversationBtn.classList.toggle('active', isConversationMode);
                conversationBtn.classList.toggle('btn-primary', isConversationMode);
                conversationBtn.classList.toggle('btn-outline-dark', !isConversationMode);
                conversationBtn.title = isConversationMode
                    ? (conversationBtn.getAttribute('data-end-title') || 'End Conversation')
                    : (conversationBtn.getAttribute('data-start-title') || 'Start Conversation');
                var buttonHtml = isConversationMode
                    ? (conversationBtn.getAttribute('data-end-html') || '<i class="bi bi-stop-fill me-1"></i> End Conversation')
                    : (conversationBtn.getAttribute('data-start-html') || '<i class="bi bi-soundwave"></i>');
                conversationBtn.replaceChildren(DOMPurify.sanitize(buttonHtml, { RETURN_DOM_FRAGMENT: true }));

                if (!isConversationMode) {
                    conversationBtn.blur();
                }
            }

            function updateConversationInputButtons() {
                var micBtn = document.getElementById('mic-btn');
                if (micBtn) {
                    micBtn.hidden = isConversationMode;
                }

                if (sendBtn) {
                    sendBtn.hidden = isConversationMode;
                }
            }

            function stopAudio() {
                if (currentAudioElement) {
                    currentAudioElement.pause();
                    currentAudioElement.currentTime = 0;
                    currentAudioElement = null;
                }

                audioChunks = [];
                audioPlayQueue = [];
                isPlayingAudio = false;
            }

            function playAudioBlob(blob) {
                var url = URL.createObjectURL(blob);
                var audio = new Audio(url);

                currentAudioElement = audio;
                isPlayingAudio = true;

                function onEnded() {
                    URL.revokeObjectURL(url);
                    currentAudioElement = null;

                    if (audioPlayQueue.length > 0) {
                        playAudioBlob(audioPlayQueue.shift());
                        return;
                    }

                    isPlayingAudio = false;
                }

                audio.addEventListener('ended', onEnded);
                audio.addEventListener('error', onEnded);
                audio.play().catch(function () {
                    onEnded();
                });
            }

            function playCollectedAudio() {
                if (!audioChunks.length) {
                    if (!currentAudioElement) {
                        isPlayingAudio = false;
                    }

                    return;
                }

                var totalLength = audioChunks.reduce(function (sum, chunk) { return sum + chunk.length; }, 0);
                var combined = new Uint8Array(totalLength);
                var offset = 0;

                audioChunks.forEach(function (chunk) {
                    combined.set(chunk, offset);
                    offset += chunk.length;
                });

                audioChunks = [];

                var blob = new Blob([combined], { type: 'audio/mp3' });

                if (currentAudioElement) {
                    audioPlayQueue.push(blob);
                    return;
                }

                playAudioBlob(blob);
            }

            connection.on('ReceiveError', function (error) {
                vm.addMessage('assistant', '\u26a0\ufe0f ' + error);
            });

            connection.on('ReceiveTranscript', function (identifier, text, isFinal) {
                if (identifier !== itemId) {
                    return;
                }

                if (isConversationMode) {
                    if (!text || isFinal) {
                        return;
                    }

                    if (!conversationPartialMessage) {
                        conversationPartialMessage = createChatMessage('user', text, false, false);
                        conversationPartialMessage.htmlContent = '<p class="ai-partial-transcript">' + DOMPurify.sanitize(text) + '</p>';
                        conversationPartialMessage.isPartial = true;
                        vm.messages.push(conversationPartialMessage);
                    } else {
                        conversationPartialMessage.rawContent = text;
                        conversationPartialMessage.content = text;
                        conversationPartialMessage.htmlContent = '<p class="ai-partial-transcript">' + DOMPurify.sanitize(text) + '</p>';
                    }

                    vm.scrollToBottom();
                    return;
                }

                if (!text || audioInputSent) {
                    return;
                }

                inputEl.value = preRecordingPrompt + text;
                inputEl.dispatchEvent(new Event('input'));
            });

            connection.on('ReceiveConversationUserMessage', function (identifier, text) {
                if (identifier !== itemId || !text) {
                    return;
                }

                stopAudio();

                if (conversationAssistantMessage) {
                    conversationAssistantMessage.isStreaming = false;
                    conversationAssistantMessage = null;
                }

                if (conversationPartialMessage) {
                    conversationPartialMessage.rawContent = text;
                    conversationPartialMessage.content = text;
                    conversationPartialMessage.htmlContent = renderMarkdown(text);
                    conversationPartialMessage.isPartial = false;
                    conversationPartialMessage = null;
                } else {
                    vm.addMessage('user', text);
                }
            });

            connection.on('ReceiveConversationAssistantToken', function (identifier, messageId, token) {
                if (identifier !== itemId || !token) {
                    return;
                }

                if (!conversationAssistantMessage) {
                    vm.addMessage('assistant', '', true);
                    conversationAssistantMessage = vm.messages[vm.messages.length - 1];
                    conversationAssistantMessage.id = messageId;
                }

                conversationAssistantMessage.rawContent = (conversationAssistantMessage.rawContent || '') + token;
                conversationAssistantMessage.content = conversationAssistantMessage.rawContent;
                conversationAssistantMessage.htmlContent = renderMarkdown(formatMessageContent(conversationAssistantMessage.rawContent, conversationAssistantMessage.references));
                vm.scrollToBottom();
            });

            connection.on('ReceiveConversationAssistantComplete', function (identifier) {
                if (identifier !== itemId || !conversationAssistantMessage) {
                    return;
                }

                conversationAssistantMessage.isStreaming = false;
                conversationAssistantMessage.htmlContent = renderMarkdown(formatMessageContent(conversationAssistantMessage.rawContent, conversationAssistantMessage.references));
                conversationAssistantMessage = null;
                vm.scrollToBottom();
            });

            connection.on('ReceiveAudioChunk', function (identifier, base64Audio) {
                if (identifier !== itemId || !base64Audio) {
                    return;
                }

                var binary = atob(base64Audio);
                var buffer = new Uint8Array(binary.length);

                for (var i = 0; i < binary.length; i++) {
                    buffer[i] = binary.charCodeAt(i);
                }

                audioChunks.push(buffer);
            });

            connection.on('ReceiveAudioComplete', function (identifier) {
                if (identifier !== itemId) {
                    return;
                }

                playCollectedAudio();
            });

            connection.on('SettingsSaved', function (savedItemId, title) {
                showSaveIndicator('Saved \u2713', 'text-success');
                if (title) {
                    var titleEl = document.getElementById('chat-title-text');
                    if (titleEl) titleEl.textContent = title;
                }
            });

            connection.on('HistoryCleared', function () {
                vm.clearAll();
                vm.addMessage('system', 'Chat history cleared.', false, true);
                var placeholder = document.getElementById('chat-placeholder');
                if (placeholder) placeholder.style.display = 'none';
            });

            // --- Send message ---
            var inputEl = document.getElementById('chat-input');
            var sendBtn = document.getElementById('send-btn');
            var documentUploadInput = document.getElementById('chat-doc-upload');
            var placeholder = document.getElementById('chat-placeholder');

            initDocumentDropZone({
                dropZone: '#chat-doc-drop-zone',
                fileInput: '#chat-doc-upload',
                browseButton: '#chat-doc-browse'
            });

            function sendMessage() {
                if (isConversationMode) {
                    return;
                }

                var prompt = inputEl.value.trim();
                if (!prompt || isSending) return;

                audioInputSent = true;
                isSending = true;
                sendBtn.disabled = true;
                inputEl.value = '';

                if (placeholder) placeholder.style.display = 'none';

                vm.addMessage('user', prompt);
                vm.addMessage('assistant', '', true);

                try {
                    var stream = connection.stream('SendMessage', itemId, prompt);
                    stream.subscribe({
                        next: function (chunk) {
                            if (chunk && (chunk.content || (chunk.references && Object.keys(chunk.references).length))) {
                                vm.appendToLast(chunk.content || '', chunk.references);
                            }
                        },
                        complete: function () {
                            vm.finishStreaming();
                            isSending = false;
                            sendBtn.disabled = false;
                            inputEl.focus();
                        },
                        error: function (err) {
                            console.error('Stream error:', err);
                            vm.finishStreaming();
                            vm.addMessage('assistant', '\u26a0\ufe0f An error occurred while streaming the response.');
                            isSending = false;
                            sendBtn.disabled = false;
                        }
                    });
                } catch (err) {
                    console.error('SendMessage error:', err);
                    vm.finishStreaming();
                    vm.addMessage('assistant', '\u26a0\ufe0f Failed to send message.');
                    isSending = false;
                    sendBtn.disabled = false;
                }
            }

            function stopRecording() {
                if (!isRecording || !mediaRecorder) {
                    return;
                }

                mediaRecorder.stop();
                isRecording = false;
                updateMicButton();
            }

            function startRecording() {
                if (isRecording || !speechToTextEnabled) {
                    return;
                }

                navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: true, noiseSuppression: true, autoGainControl: true } })
                    .then(function (stream) {
                        var mimeType = MediaRecorder.isTypeSupported('audio/ogg;codecs=opus')
                            ? 'audio/ogg;codecs=opus'
                            : (MediaRecorder.isTypeSupported('audio/webm;codecs=opus') ? 'audio/webm;codecs=opus' : 'audio/webm');

                        mediaRecorder = new MediaRecorder(stream, {
                            mimeType: mimeType,
                            audioBitsPerSecond: 128000
                        });

                        preRecordingPrompt = inputEl.value;
                        audioInputSent = false;

                        var subject = new signalR.Subject();
                        var pendingChunk = Promise.resolve();

                        mediaRecorder.addEventListener('dataavailable', function (e) {
                            if (!e.data || e.data.size <= 0) {
                                return;
                            }

                            pendingChunk = pendingChunk.then(function () {
                                return e.data.arrayBuffer().then(function (data) {
                                    var uint8Array = new Uint8Array(data);
                                    var binaryString = uint8Array.reduce(function (str, byte) {
                                        return str + String.fromCharCode(byte);
                                    }, '');
                                    subject.next(btoa(binaryString));
                                });
                            });
                        });

                        mediaRecorder.addEventListener('stop', function () {
                            stream.getTracks().forEach(function (track) { track.stop(); });
                            pendingChunk.then(function () { subject.complete(); });
                        });

                        ensureConnectionStarted()
                            .then(function () {
                                connection.send('SendAudioStream', itemId, subject, mimeType, navigator.language || document.documentElement.lang || 'en-US');
                                mediaRecorder.start(audioChunkIntervalMs);
                                isRecording = true;
                                updateMicButton();
                            })
                            .catch(function (err) {
                                console.error('Failed to start audio input:', err);
                            });
                    })
                    .catch(function (err) {
                        console.error('Microphone access denied:', err);
                    });
            }

            function toggleRecording() {
                if (isRecording) {
                    stopRecording();
                    return;
                }

                startRecording();
            }

            function stopConversationMode() {
                if (!isConversationMode) {
                    return;
                }

                isConversationMode = false;
                updateConversationButton();
                updateConversationInputButtons();

                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke('StopConversation').catch(function () { });
                }

                if (isRecording && mediaRecorder) {
                    mediaRecorder.stop();
                    isRecording = false;
                }

                updateMicButton();

                stopAudio();
                conversationPartialMessage = null;

                if (conversationAudioContext) {
                    conversationAudioContext.close().catch(function () { });
                    conversationAudioContext = null;
                    conversationAnalyser = null;
                }
            }

            function startConversationMode() {
                if (!conversationModeEnabled || isConversationMode) {
                    return;
                }

                if (isRecording) {
                    stopRecording();
                }

                navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: true, noiseSuppression: true, autoGainControl: true } })
                    .then(function (stream) {
                        var mimeType = MediaRecorder.isTypeSupported('audio/ogg;codecs=opus')
                            ? 'audio/ogg;codecs=opus'
                            : (MediaRecorder.isTypeSupported('audio/webm;codecs=opus') ? 'audio/webm;codecs=opus' : 'audio/webm');

                        mediaRecorder = new MediaRecorder(stream, {
                            mimeType: mimeType,
                            audioBitsPerSecond: 128000
                        });

                        isConversationMode = true;
                        updateConversationButton();
                        updateConversationInputButtons();
                        conversationPartialMessage = null;
                        conversationAssistantMessage = null;
                        conversationSubject = new signalR.Subject();
                        conversationStream = stream;

                        var AudioContextCtor = window.AudioContext || window.webkitAudioContext;
                        if (AudioContextCtor) {
                            conversationAudioContext = new AudioContextCtor();
                            conversationAnalyser = conversationAudioContext.createAnalyser();
                            conversationAnalyser.fftSize = 256;
                            var micSource = conversationAudioContext.createMediaStreamSource(stream);
                            micSource.connect(conversationAnalyser);
                        }

                        var pendingChunk = Promise.resolve();

                        mediaRecorder.addEventListener('dataavailable', function (e) {
                            if (!e.data || e.data.size <= 0) {
                                return;
                            }

                            if (isPlayingAudio && conversationAnalyser) {
                                var freqData = new Uint8Array(conversationAnalyser.frequencyBinCount);
                                conversationAnalyser.getByteFrequencyData(freqData);
                                var sum = 0;

                                for (var j = 0; j < freqData.length; j++) {
                                    sum += freqData[j];
                                }

                                if ((sum / freqData.length) >= 30) {
                                    stopAudio();
                                }
                            }

                            pendingChunk = pendingChunk.then(function () {
                                return e.data.arrayBuffer().then(function (data) {
                                    var uint8Array = new Uint8Array(data);
                                    var binaryString = uint8Array.reduce(function (str, byte) {
                                        return str + String.fromCharCode(byte);
                                    }, '');
                                    conversationSubject.next(btoa(binaryString));
                                });
                            });
                        });

                        mediaRecorder.addEventListener('stop', function () {
                            stream.getTracks().forEach(function (track) { track.stop(); });
                            pendingChunk.then(function () { conversationSubject.complete(); });
                        });

                        ensureConnectionStarted()
                            .then(function () {
                                connection.send('StartConversation', itemId, conversationSubject, mimeType, navigator.language || document.documentElement.lang || 'en-US');
                                mediaRecorder.start(audioChunkIntervalMs);
                                isRecording = true;
                                updateMicButton();
                            })
                            .catch(function (err) {
                                console.error('Failed to start conversation mode:', err);
                                stopConversationMode();
                            });
                    })
                    .catch(function (err) {
                        console.error('Microphone access denied:', err);
                    });
            }

            function toggleConversationMode() {
                if (isConversationMode) {
                    stopConversationMode();
                    return;
                }

                startConversationMode();
            }

            sendBtn.addEventListener('click', sendMessage);
            var micBtn = document.getElementById('mic-btn');
            if (micBtn) {
                micBtn.addEventListener('click', toggleRecording);
                updateMicButton();
            }

            var conversationBtn = document.getElementById('conversation-btn');
            if (conversationBtn) {
                conversationBtn.addEventListener('click', toggleConversationMode);
                updateConversationButton();
            }
            updateConversationInputButtons();
            if (documentUploadInput) {
                documentUploadInput.addEventListener('change', function () {
                    uploadDocuments(documentUploadInput.files).finally(function () {
                        documentUploadInput.value = '';
                    });
                });
            }
            inputEl.addEventListener('keydown', function (e) {
                if (isConversationMode) {
                    e.preventDefault();
                    return;
                }

                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            // Auto-resize textarea
            inputEl.addEventListener('input', function () {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 120) + 'px';
            });

            // --- Clear History ---
            document.getElementById('clear-history-btn').addEventListener('click', function () {
                if (!confirm('Clear all messages?')) return;
                connection.invoke('ClearHistory', itemId).catch(function (err) {
                    console.error('Failed to clear history:', err);
                });
            });

            // --- Settings Auto-Save via SignalR ---
            var saveIndicator = document.getElementById('settings-save-indicator');
            var saveTimeout = null;

            function showSaveIndicator(text, cssClass) {
                saveIndicator.textContent = text;
                saveIndicator.className = 'settings-save-indicator ' + (cssClass || 'text-muted');
                clearTimeout(saveTimeout);
                saveTimeout = setTimeout(function () {
                    saveIndicator.textContent = '';
                }, 3000);
            }

            function getValidationMessage(input) {
                if (!input || input.type !== 'number') {
                    return null;
                }

                var value = input.value.trim();
                if (value === '') {
                    return null;
                }

                var numericValue = Number(value);
                if (Number.isNaN(numericValue)) {
                    return 'Enter a valid number.';
                }

                var min = input.getAttribute('min');
                if (min !== null && numericValue < Number(min)) {
                    return 'Value must be at least ' + min + '.';
                }

                var max = input.getAttribute('max');
                if (max !== null && numericValue > Number(max)) {
                    return 'Value must be no more than ' + max + '.';
                }

                return null;
            }

            function getOrCreateValidationMessage(input) {
                var message = input.parentElement.querySelector('.invalid-feedback[data-setting-validation]');
                if (!message) {
                    message = document.createElement('div');
                    message.className = 'invalid-feedback';
                    message.dataset.settingValidation = 'true';
                    input.parentElement.appendChild(message);
                }

                return message;
            }

            function validateSettingInput(input) {
                var message = getValidationMessage(input);
                var validation = getOrCreateValidationMessage(input);
                var isValid = !message;

                input.classList.toggle('is-invalid', !isValid);
                validation.textContent = message || '';
                validation.style.display = isValid ? 'none' : 'block';

                return isValid;
            }

            function hasInvalidSettings() {
                var isValid = true;

                document.querySelectorAll('.setting-input[type="number"]').forEach(function (input) {
                    if (!validateSettingInput(input)) {
                        isValid = false;
                    }
                });

                return !isValid;
            }

            function collectSettings() {
                var settings = {};

                // Scalar settings from inputs
                document.querySelectorAll('.setting-input').forEach(function (el) {
                    var key = el.dataset.setting;
                    if (!key) return;
                    if (el.type === 'checkbox') {
                        settings[key] = el.checked;
                        return;
                    }

                    var val = el.value.trim();
                    if (el.type === 'number') {
                        settings[key] = val === '' ? null : parseFloat(val);
                    } else {
                        settings[key] = val || null;
                    }
                });

                // Capability checkboxes grouped by data-group
                var groups = {};
                document.querySelectorAll('.capability-checkbox').forEach(function (cb) {
                    var group = cb.dataset.group;
                    if (!groups[group]) groups[group] = [];
                    if (cb.checked) groups[group].push(cb.value);
                });
                for (var g in groups) {
                    settings[g] = groups[g];
                }

                // Prompt templates with parameters
                var promptTemplates = [];
                document.querySelectorAll('#chatPromptTemplatesContainer .chat-prompt-card').forEach(function (card) {
                    var tid = card.dataset.templateId;
                    if (!tid) return;
                    var paramsInput = card.querySelector('.chat-prompt-params-input');
                    var paramsValue = paramsInput ? paramsInput.value.trim() : '';
                    promptTemplates.push({ templateId: tid, promptParameters: paramsValue });
                });
                settings.promptTemplateIds = promptTemplates.map(function (t) { return t.templateId; });
                settings.promptTemplates = promptTemplates;

                return settings;
            }

            var debounceTimer = null;

            function debounceSave() {
                clearTimeout(debounceTimer);
                if (hasInvalidSettings()) {
                    showSaveIndicator('Fix errors', 'text-danger');
                    return;
                }

                showSaveIndicator('Saving...', 'text-warning');
                debounceTimer = setTimeout(function () {
                    var settings = collectSettings();
                    ensureConnectionStarted()
                        .then(function () {
                            return connection.invoke('SaveSettings', itemId, settings);
                        })
                        .catch(function (err) {
                            console.error('Failed to save settings:', err);
                            showSaveIndicator('Save failed', 'text-danger');
                        });
                }, 500);
            }

            // Bind setting-input changes
            document.querySelectorAll('.setting-input').forEach(function (el) {
                if (el.type === 'number') {
                    validateSettingInput(el);
                }
                el.addEventListener('input', debounceSave);
                el.addEventListener('change', debounceSave);
            });

            // Bind capability checkbox changes
            document.querySelectorAll('.capability-checkbox').forEach(function (cb) {
                cb.addEventListener('change', debounceSave);
            });

            // Tool Select All / Deselect All
            var selectAllToolsBtn = document.getElementById('chat-select-all-tools');
            var deselectAllToolsBtn = document.getElementById('chat-deselect-all-tools');
            if (selectAllToolsBtn) {
                selectAllToolsBtn.addEventListener('click', function () {
                    document.querySelectorAll('.chat-tool-checkbox').forEach(function (cb) { cb.checked = true; });
                    debounceSave();
                });
            }
            if (deselectAllToolsBtn) {
                deselectAllToolsBtn.addEventListener('click', function () {
                    document.querySelectorAll('.chat-tool-checkbox').forEach(function (cb) { cb.checked = false; });
                    debounceSave();
                });
            }

            // --- Prompt Template Management ---
            (function () {
                var container = document.getElementById('chatPromptTemplatesContainer');
                var searchInput = document.getElementById('chatPromptTemplateSearch');
                if (!container) return;

                function createTemplateCard(templateId, title, description, params) {
                    var card = document.createElement('div');
                    card.className = 'card mb-2 chat-prompt-card';
                    card.dataset.templateId = templateId;

                    var headerHtml = '<div class="card-body p-2">' +
                        '<div class="d-flex justify-content-between align-items-center">' +
                        '<span class="fw-bold small">' + (title || templateId) + '</span>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger border-0 p-0 ms-2" aria-label="Remove">' +
                        '<i class="bi bi-trash"></i></button></div>';

                    if (description) {
                        headerHtml += '<div class="text-muted small">' + description + '</div>';
                    }

                    var paramsHtml = '';
                    if (params && params.length > 0) {
                        paramsHtml += '<div class="mt-1"><small class="text-muted d-block mb-1">Expected parameters:</small><ul class="mb-0 small text-muted">';
                        params.forEach(function (p) {
                            paramsHtml += '<li><strong>' + p.Name + '</strong>' + (p.Description ? ': ' + p.Description : '') + '</li>';
                        });
                        paramsHtml += '</ul></div>';
                    }

                    paramsHtml += '<div class="mt-1">' +
                        '<label class="form-label small">Template parameters</label>' +
                        '<textarea class="form-control form-control-sm chat-prompt-params-input" rows="2" ' +
                        'placeholder=\'e.g., {"key1": "value1", "key2": "value2"}\'></textarea>' +
                        '<span class="form-text small">Optional JSON key-value pairs to pass as template arguments.</span>' +
                        '</div>';

                    card.innerHTML = headerHtml + paramsHtml + '</div>';
                    card.querySelector('.btn-outline-danger').addEventListener('click', function () {
                        card.remove();
                        debounceSave();
                    });
                    card.querySelector('.chat-prompt-params-input').addEventListener('change', function () {
                        debounceSave();
                    });
                    return card;
                }

                document.addEventListener('click', function (e) {
                    var btn = e.target.closest('.chat-prompt-add-btn');
                    if (!btn) return;
                    e.preventDefault();
                    var params = [];
                    try { params = JSON.parse(btn.dataset.templateParams || '[]'); } catch (ex) { }
                    var card = createTemplateCard(btn.dataset.templateId, btn.dataset.templateTitle, btn.dataset.templateDescription, params);
                    container.appendChild(card);
                    debounceSave();
                });

                if (searchInput) {
                    searchInput.addEventListener('input', function () {
                        var query = this.value.toLowerCase();
                        document.querySelectorAll('.chat-prompt-add-btn').forEach(function (item) {
                            var text = (item.textContent || '').toLowerCase();
                            item.style.display = !query || text.indexOf(query) >= 0 ? '' : 'none';
                        });
                        document.querySelectorAll('.chat-prompt-template-menu .dropdown-header').forEach(function (h) {
                            h.style.display = query ? 'none' : '';
                        });
                    });
                }
            })();

            // Hide placeholder if we already have messages
            if (existingMessages.length > 0 && placeholder) {
                placeholder.style.display = 'none';
            }

            renderDocuments();
        });
    </script>
}
