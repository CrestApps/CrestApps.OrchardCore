@using CrestApps.Core.Mvc.Web.Areas.A2A.ViewModels
@model A2AConnectionViewModel

<form asp-action="@(string.IsNullOrEmpty(Model.ItemId) ? "Create" : "Edit")" method="post">
    @if (!string.IsNullOrEmpty(Model.ItemId))
    {
        <input asp-for="ItemId" type="hidden" />
    }
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="DisplayText" class="form-label">Title <span class="text-danger">*</span></label>
                <input asp-for="DisplayText" class="form-control" placeholder="e.g., Production Agent Hub" />
                <span asp-validation-for="DisplayText" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Endpoint" class="form-label">Endpoint <span class="text-danger">*</span></label>
                <input asp-for="Endpoint" class="form-control" placeholder="https://agents.example.com" />
                <div class="form-text">The base host URL. The agent card is resolved from <code>/.well-known/agent-card.json</code>.</div>
                <span asp-validation-for="Endpoint" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AuthenticationType" class="form-label">Authentication</label>
                <select asp-for="AuthenticationType" class="form-select" id="authType">
                    @foreach (var authType in Enum.GetValues<CrestApps.Core.AI.A2A.Models.A2AClientAuthenticationType>())
                    {
                        if (Model.AuthenticationType == authType)
                        {
                            <option value="@((int)authType)" data-auth-type="@authType" selected>@authType</option>
                        }
                        else
                        {
                            <option value="@((int)authType)" data-auth-type="@authType">@authType</option>
                        }
                    }
                </select>
            </div>

            <div id="apiKeyFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="ApiKeyHeaderName" class="form-label">API key header name</label>
                    <input asp-for="ApiKeyHeaderName" class="form-control" placeholder="Authorization" />
                </div>
                <div class="mb-3">
                    <label asp-for="ApiKeyPrefix" class="form-label">API key prefix</label>
                    <input asp-for="ApiKeyPrefix" class="form-control" placeholder="Bearer" />
                </div>
                <div class="mb-3">
                    <label asp-for="ApiKey" class="form-label">API key</label>
                    <input asp-for="ApiKey" class="form-control" type="password" autocomplete="new-password" />
                    @if (Model.HasApiKey)
                    {
                        <div class="form-text">Leave blank to keep the existing API key.</div>
                    }
                </div>
            </div>

            <div id="basicFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="BasicUsername" class="form-label">Username</label>
                    <input asp-for="BasicUsername" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="BasicPassword" class="form-label">Password</label>
                    <input asp-for="BasicPassword" class="form-control" type="password" autocomplete="new-password" />
                    @if (Model.HasBasicPassword)
                    {
                        <div class="form-text">Leave blank to keep the existing password.</div>
                    }
                </div>
            </div>

            <div id="oauthFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="OAuth2TokenEndpoint" class="form-label">Token endpoint</label>
                    <input asp-for="OAuth2TokenEndpoint" class="form-control" placeholder="https://identity.example.com/connect/token" />
                </div>
                <div class="mb-3">
                    <label asp-for="OAuth2ClientId" class="form-label">Client ID</label>
                    <input asp-for="OAuth2ClientId" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="OAuth2Scopes" class="form-label">Scopes</label>
                    <input asp-for="OAuth2Scopes" class="form-control" placeholder="agents.read agents.invoke" />
                </div>
            </div>

            <div id="oauthClientCredentialsFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="OAuth2ClientSecret" class="form-label">Client secret</label>
                    <input asp-for="OAuth2ClientSecret" class="form-control" type="password" autocomplete="new-password" />
                    @if (Model.HasOAuth2ClientSecret)
                    {
                        <div class="form-text">Leave blank to keep the existing client secret.</div>
                    }
                </div>
            </div>

            <div id="oauthPrivateKeyFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="OAuth2KeyId" class="form-label">Key ID</label>
                    <input asp-for="OAuth2KeyId" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="OAuth2PrivateKey" class="form-label">Private key (PEM)</label>
                    <textarea asp-for="OAuth2PrivateKey" class="form-control" rows="6"></textarea>
                    @if (Model.HasOAuth2PrivateKey)
                    {
                        <div class="form-text">Leave blank to keep the existing private key.</div>
                    }
                </div>
            </div>

            <div id="oauthMtlsFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="OAuth2ClientCertificate" class="form-label">Client certificate (Base64 PFX/PKCS#12)</label>
                    <textarea asp-for="OAuth2ClientCertificate" class="form-control" rows="6"></textarea>
                    @if (Model.HasOAuth2ClientCertificate)
                    {
                        <div class="form-text">Leave blank to keep the existing certificate.</div>
                    }
                </div>
                <div class="mb-3">
                    <label asp-for="OAuth2ClientCertificatePassword" class="form-label">Certificate password</label>
                    <input asp-for="OAuth2ClientCertificatePassword" class="form-control" type="password" autocomplete="new-password" />
                    @if (Model.HasOAuth2ClientCertificatePassword)
                    {
                        <div class="form-text">Leave blank to keep the existing certificate password.</div>
                    }
                </div>
            </div>

            <div id="customHeadersFields" class="auth-fields">
                <div class="mb-3">
                    <label asp-for="AdditionalHeaders" class="form-label">Additional headers (JSON)</label>
                    <textarea asp-for="AdditionalHeaders" class="form-control" rows="6" placeholder="{&#10;  &quot;X-Api-Key&quot;: &quot;value&quot;&#10;}"></textarea>
                    <span asp-validation-for="AdditionalHeaders" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> @(string.IsNullOrEmpty(Model.ItemId) ? "Create" : "Save")
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const authType = document.getElementById('authType');

        if (!authType) {
            return;
        }

        const groups = {
            ApiKey: ['apiKeyFields'],
            Basic: ['basicFields'],
            OAuth2ClientCredentials: ['oauthFields', 'oauthClientCredentialsFields'],
            OAuth2PrivateKeyJwt: ['oauthFields', 'oauthPrivateKeyFields'],
            OAuth2Mtls: ['oauthFields', 'oauthMtlsFields'],
            CustomHeaders: ['customHeadersFields']
        };

        function getSelectedAuthType() {
            return authType.selectedOptions.length > 0
                ? authType.selectedOptions[0].dataset.authType
                : null;
        }

        function updateVisibility() {
            document.querySelectorAll('.auth-fields').forEach(group => group.style.display = 'none');

            const selectedAuthType = getSelectedAuthType();
            (groups[selectedAuthType] || []).forEach(id => {
                const element = document.getElementById(id);
                if (element) {
                    element.style.display = '';
                }
            });
        }

        authType.addEventListener('change', updateVisibility);
        updateVisibility();
    });
</script>

