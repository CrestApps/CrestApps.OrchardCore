@using CrestApps.Core
@using CrestApps.Core.AI.A2A.Models

@model IReadOnlyCollection<A2AConnection>
@{
    ViewData["Title"] = "Agent to Agent Hosts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Add Connection
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No A2A hosts are configured yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Endpoint</th>
                    <th>Authentication</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var connection in Model)
                {
                    var metadata = connection.As<A2AConnectionMetadata>();
                    <tr>
                        <td><strong>@connection.DisplayText</strong></td>
                        <td><code>@connection.Endpoint</code></td>
                        <td><span class="badge bg-info text-dark">@metadata.AuthenticationType</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@connection.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@connection.ItemId" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this A2A connection?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
