@model IReadOnlyCollection<CrestApps.Core.AI.Mcp.Models.McpPrompt>
@{
    ViewData["Title"] = "MCP Prompts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-chat-square-text"></i> MCP Prompts</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Add Prompt</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No MCP prompts are configured yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Description</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var prompt in Model)
            {
                <tr>
                    <td><strong>@(prompt.Prompt?.Title ?? prompt.Name)</strong></td>
                    <td><code>@prompt.Name</code></td>
                    <td>@prompt.Prompt?.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@prompt.ItemId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                        <form asp-action="Delete" asp-route-id="@prompt.ItemId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this MCP prompt?')"><i class="bi bi-trash"></i> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
