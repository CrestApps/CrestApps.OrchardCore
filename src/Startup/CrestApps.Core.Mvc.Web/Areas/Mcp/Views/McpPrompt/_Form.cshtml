@using CrestApps.Core.Mvc.Web.Areas.Mcp.ViewModels
@model McpPromptViewModel

<form asp-action="@(string.IsNullOrEmpty(Model.ItemId) ? "Create" : "Edit")" method="post">
    @if (!string.IsNullOrEmpty(Model.ItemId))
    {
        <input asp-for="ItemId" type="hidden" />
    }

    <div class="col-md-8">
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" id="promptTitle" />
        </div>
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Technical name</label>
            @{
                var isEdit = !string.IsNullOrEmpty(Model.ItemId);
            }
            @if (isEdit)
            {
                <input asp-for="Name" class="form-control" id="promptName" disabled />
                <input type="hidden" asp-for="Name" />
            }
            else
            {
                <input asp-for="Name" class="form-control" id="promptName" />
            }
            <span asp-validation-for="Name" class="text-danger"></span>
            @if (string.IsNullOrEmpty(Model.ItemId))
            {
                <div class="form-text">Auto-generated from the title. You may override it before saving.</div>
            }
            else
            {
                <div class="form-text">The technical name cannot be changed after creation.</div>
            }
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Arguments" class="form-label">Arguments (JSON array)</label>
            <textarea asp-for="Arguments" class="form-control" rows="8"></textarea>
            <span asp-validation-for="Arguments" class="text-danger"></span>
            <div class="form-text">Example: <code>[{ "name": "topic", "description": "Topic to expand", "required": true }]</code></div>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @(string.IsNullOrEmpty(Model.ItemId) ? "Create" : "Save")</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>

@if (string.IsNullOrEmpty(Model.ItemId))
{
    <script>
        initAutoGenerateTechnicalName('promptTitle', 'promptName');
    </script>
}
