<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CrestApps AI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-robot"></i> CrestApps AI
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Home
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="nav-link btn btn-link text-light">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="d-flex app-layout">
        @if (User.IsInRole("Administrator"))
        {
            <nav id="sidebar" class="bg-light border-end p-3" style="min-width: 220px;">
                <h6 class="text-muted text-uppercase mb-3">Admin</h6>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AI" asp-controller="AIConnection" asp-action="Index">
                            <i class="bi bi-plug"></i> AI Connections
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AI" asp-controller="AIDeployment" asp-action="Index">
                            <i class="bi bi-box-seam"></i> AI Deployments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AI" asp-controller="AIProfile" asp-action="Index">
                            <i class="bi bi-person-gear"></i> AI Profiles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AIChat" asp-controller="AIChat" asp-action="Index">
                            <i class="bi bi-chat-dots"></i> AI Chat
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="ChatInteractions" asp-controller="ChatInteraction" asp-action="Index">
                            <i class="bi bi-chat-left-dots"></i> Chat Interactions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Indexing" asp-controller="IndexProfile" asp-action="Index">
                            <i class="bi bi-database-gear"></i> Index Profiles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="DataSources" asp-controller="AIDataSource" asp-action="Index">
                            <i class="bi bi-collection"></i> Data Sources
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AI" asp-controller="AITemplate" asp-action="Index">
                            <i class="bi bi-file-earmark-text"></i> Templates
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Article" asp-action="Index">
                            <i class="bi bi-journal-text"></i> Articles
                        </a>
                    </li>
                    <li class="nav-item">
                        <span class="nav-link text-uppercase small text-muted disabled ps-2">Reports</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AIChat" asp-controller="ChatAnalytics" asp-action="Index">
                            <i class="bi bi-bar-chart-line"></i> Chat Analytics
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AIChat" asp-controller="UsageAnalytics" asp-action="Index">
                            <i class="bi bi-activity"></i> AI Usage Analytics
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="AIChat" asp-controller="ChatExtractedData" asp-action="Index">
                            <i class="bi bi-table"></i> Chat Extracted Data
                        </a>
                    </li>

                    <hr class="my-2" />

                    <li class="nav-item">
                        <a class="nav-link" asp-area="A2A" asp-controller="A2AConnection" asp-action="Index">
                            <i class="bi bi-diagram-3"></i> Agent to Agent Hosts
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Mcp" asp-controller="McpConnection" asp-action="Index">
                            <i class="bi bi-hdd-network"></i> MCP Hosts
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Mcp" asp-controller="McpPrompt" asp-action="Index">
                            <i class="bi bi-chat-square-text"></i> MCP Prompts
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Mcp" asp-controller="McpResource" asp-action="Index">
                            <i class="bi bi-folder2-open"></i> MCP Resources
                        </a>
                    </li>

                    <hr class="my-2" />

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear"></i> Settings
                        </a>
                    </li>
                </ul>
            </nav>
        }

        <main class="flex-grow-1 p-4 app-content">
            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @Html.ValidationSummary(excludePropertyErrors: false, message: "Please correct the following errors:", htmlAttributes: new { @class = "mb-0" })
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/technical-name-generator.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity.IsAuthenticated && !string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "AIChat", StringComparison.OrdinalIgnoreCase))
    {
        @await Html.PartialAsync("~/Areas/AIChat/Views/Shared/_ChatWidget.cshtml")
    }
</body>
</html>
