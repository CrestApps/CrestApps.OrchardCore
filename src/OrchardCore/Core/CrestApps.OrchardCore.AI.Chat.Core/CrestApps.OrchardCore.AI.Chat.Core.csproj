<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Title>CrestApps OrchardCore AI Chat Core</Title>
    <Description>
      $(CrestAppsDescription)

      Core services project for the AI Chat module. Contains hub implementations and shared types
      that can be referenced without depending on the full module.
    </Description>
    <PackageTags>$(PackageTags) AI Chat</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Fluid.Core" />
    <PackageReference Include="Microsoft.Extensions.AI" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Framework\Abstractions\CrestApps.AI.Abstractions\CrestApps.AI.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\Framework\Primitives\CrestApps.AI.Chat\CrestApps.AI.Chat.csproj" />
    <ProjectReference Include="..\..\..\Framework\Primitives\CrestApps.SignalR\CrestApps.SignalR.csproj" />
    <ProjectReference Include="..\CrestApps.OrchardCore.AI.Core\CrestApps.OrchardCore.AI.Core.csproj" />
  </ItemGroup>

</Project>
