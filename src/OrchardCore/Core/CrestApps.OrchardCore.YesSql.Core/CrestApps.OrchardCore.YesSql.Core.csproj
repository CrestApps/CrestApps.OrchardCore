      $(CrestAppsDescription)

      OrchardCore-specific YesSql stores that extend the framework-independent CrestApps.Data.YesSql.
    </Description>
    <PackageTags>$(PackageTags) AI</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
