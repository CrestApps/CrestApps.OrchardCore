<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Title>CrestApps OrchardCore OpenAI Core</Title>
    <Description>
      $(CrestAppsDescription)

      OrchardCore-specific OpenAI services that extend the framework-independent CrestApps.Core.AI.OpenAI.Core.
    </Description>
    <PackageTags>$(PackageTags) OpenAI</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="YesSql.Abstractions" />
    <PackageReference Include="OrchardCore.ContentManagement.Abstractions" />
    <PackageReference Include="OrchardCore.Liquid.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../Framework/Primitives/CrestApps.Core.Azure/CrestApps.Core.Azure.csproj" />
    <ProjectReference Include="../CrestApps.OrchardCore.AI.Core/CrestApps.OrchardCore.AI.Core.csproj" />
    <ProjectReference Include="../../../Framework/Primitives/CrestApps.Core.AI.OpenAI/CrestApps.Core.AI.OpenAI.csproj" />
  </ItemGroup>

</Project>
