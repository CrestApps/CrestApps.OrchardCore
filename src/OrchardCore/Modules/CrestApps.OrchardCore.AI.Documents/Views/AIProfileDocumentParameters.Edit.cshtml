@using CrestApps.OrchardCore.AI.Documents.ViewModels

@model EditAIProfileDocumentsViewModel

<div class="mb-3">
    <label class="form-label">
        @T["Document Top N"]
        <span class="text-muted" data-bs-toggle="tooltip" title="@T["The number of top matching document chunks to include as context for the AI model. Higher values provide more context but may increase costs and response time."]" aria-label="@T["Help: Document Top N explanation"]">
            <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
        </span>
    </label>
    <input type="number" class="form-control" name="@Html.NameFor(m => m.TopN)" value="@Model.TopN" min="1" max="20" />
    <div class="form-text">@T["Default: 3. Recommended range: 1-10."]</div>
</div>
