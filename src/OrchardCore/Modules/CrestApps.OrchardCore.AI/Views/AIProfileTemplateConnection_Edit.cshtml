@using CrestApps.OrchardCore.AI.ViewModels
@using OrchardCore

@model AIProfileTemplateConnectionViewModel

@if (Model.Orchestrators?.Count > 1)
{
    <div class="@Orchard.GetWrapperClasses()">
        <label asp-for="OrchestratorName" class="@Orchard.GetLabelClasses()">@T["Orchestrator"]</label>
        <div class="@Orchard.GetEndClasses()">
            <select asp-for="OrchestratorName" class="form-select">
                <option value="">@T["Default"]</option>
                @foreach (var orchestrator in Model.Orchestrators)
                {
                    <option value="@orchestrator.Value" selected="@(orchestrator.Value == Model.OrchestratorName)">@orchestrator.Text</option>
                }
            </select>
            <span asp-validation-for="OrchestratorName" class="text-danger"></span>
            <span class="hint">@T["The orchestrator to use for profiles created from this template."]</span>
        </div>
    </div>
}
else
{
    <input type="hidden" asp-for="OrchestratorName" />
}
