@model CrestApps.OrchardCore.AI.DataSources.ViewModels.EditDataSourceIndexProfileViewModel

<div class="mb-3">
    <label asp-for="EmbeddingDeploymentId" class="form-label">@T["Embedding deployment"]</label>

    @if (Model.IsLocked)
    {
        <input type="text" class="form-control" value="@Model.EmbeddingDeploymentText" readonly />
        <input type="hidden" asp-for="EmbeddingDeploymentId" />
        <span class="hint">@T["The embedding deployment cannot be changed after the index is created."]</span>
    }
    else if (Model.EmbeddingDeployments.Count == 0)
    {
        <div class="alert alert-warning">
            <i class="fa-solid fa-exclamation-triangle" aria-hidden="true"></i>
            @T["No embedding deployments are available. Please configure at least one embedding deployment before creating this index."]
        </div>
    }
    else
    {
        <select asp-for="EmbeddingDeploymentId" asp-items="Model.EmbeddingDeployments" class="form-select">
            <option value="">@T["Select an embedding deployment"]</option>
        </select>

        <span class="hint">@T["Select the embedding deployment to use for generating document embeddings. This determines the vector dimensions for the index and cannot be changed after creation."]</span>
    }
</div>
