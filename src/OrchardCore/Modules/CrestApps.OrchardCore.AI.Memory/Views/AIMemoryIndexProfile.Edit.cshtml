@using CrestApps.OrchardCore.AI.Memory.ViewModels
@using OrchardCore

@model AIMemoryIndexProfileViewModel

<div class="@Orchard.GetWrapperClasses()">
    <label asp-for="EmbeddingConnection" class="@Orchard.GetLabelClasses()">@T["Embedding connection"]</label>
    <div class="@Orchard.GetEndClasses()">
        <select asp-for="EmbeddingConnection" asp-items="Model.EmbeddingConnections" class="form-select">
            <option value="">@T["Select an embedding connection"]</option>
        </select>
        <span class="hint">@T["Choose the embedding deployment that will be used to index and search user memories."]</span>
    </div>
</div>
