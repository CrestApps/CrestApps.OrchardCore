{
  "version": "1.0",
  "releaseStatus": "blocked-until-r0-r8-pass",
  "capacityTier": {
    "id": "tier-1",
    "maxTenantsPerDeployment": 5,
    "maxConcurrentSignedInAgentsPerTenant": 100,
    "maxConcurrentVoiceInteractionsPerTenant": 50,
    "maxNewInteractionsPerSecondPerTenant": 10,
