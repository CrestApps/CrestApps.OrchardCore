{
  "version": "1.0",
  "description": "Machine-readable R0a ledger for the Contact Center feature-dependency architecture contract. `acceptedExternalDependencies` lists direct manifest dependencies from a Contact Center feature onto a feature outside the Contact Center family that are intentional and are not a P0 finding. `knownViolations` lists every currently known P0 architecture-graph finding the R0a contract tests must detect and no others; each entry owns a control-matrix gate id from pr-test-control-matrix.v1.json. `acceptedLeafDependencies` lists external feature ids reachable from the Contact Center family through the SignalR, Telephony, Telephony Soft Phone, and Omnichannel Management manifests that are treated as opaque, out-of-scope leaves. `featureDependencyClosures` pins the exact transitive closure computed today from the current manifest declarations for every Contact Center feature; any deliberate change to the manifest graph in R2 must update this file in the same change.",
  "acceptedExternalDependencies": [
    {
      "feature": "CrestApps.OrchardCore.ContactCenter",
      "dependsOn": "OrchardCore.Users",
      "reason": "The base feature attributes interactions and agent profiles to signed-in Orchard users."
    },
    {
      "feature": "CrestApps.OrchardCore.ContactCenter.RealTime",
      "dependsOn": "CrestApps.OrchardCore.SignalR",
      "reason": "Real-Time intentionally hosts the SignalR hub used by the agent desktop and supervisor dashboard."
    },
    {
      "feature": "CrestApps.OrchardCore.ContactCenter.Analytics",
      "dependsOn": "CrestApps.OrchardCore.Reports",
      "reason": "Analytics intentionally contributes reports to the shared Reports framework."
    }
  ],
  "knownViolations": [
    {
      "id": "FDV001",
      "gateId": "F001",
      "kind": "declared-manifest-coupling",
      "feature": "CrestApps.OrchardCore.ContactCenter",
      "dependsOn": "CrestApps.OrchardCore.Omnichannel.Managements",
      "description": "The headless base Contact Center feature declares a hard manifest dependency on the Omnichannel Managements admin-integration feature, so it cannot boot standalone in a headless tenant.",
      "sourceLocation": "src/Modules/CrestApps.OrchardCore.ContactCenter/Manifest.cs"
    },
    {
      "id": "FDV002",
      "gateId": "F002",
      "kind": "declared-manifest-coupling",
      "feature": "CrestApps.OrchardCore.ContactCenter.Voice",
      "dependsOn": "CrestApps.OrchardCore.Telephony.SoftPhone",
      "description": "Voice declares a hard manifest dependency on the concrete Telephony Soft Phone feature instead of a stable, provider-agnostic voice abstraction.",
      "sourceLocation": "src/Modules/CrestApps.OrchardCore.ContactCenter/Manifest.cs"
    },
    {
      "id": "FDV003",
      "gateId": "F002",
      "kind": "undeclared-required-service",
      "feature": "CrestApps.OrchardCore.ContactCenter.Queues",
      "requiredService": "HubRouteManager",
      "requiredFromFeature": "CrestApps.OrchardCore.SignalR",
      "viaType": "ContactCenterSoftPhoneWidgetDisplayDriver",
      "description": "QueuesStartup unconditionally registers ContactCenterSoftPhoneWidgetDisplayDriver, whose constructor requires HubRouteManager. HubRouteManager is only registered when the SignalR feature is enabled, but Queues declares no dependency on SignalR or RealTime.",
      "sourceLocation": "src/Modules/CrestApps.OrchardCore.ContactCenter/Startup.cs"
    }
  ],
